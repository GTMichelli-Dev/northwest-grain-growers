<%@ Page Title="" Language="C#" MasterPageFile="~/Site.master" AutoEventWireup="true" CodeFile="SelectGrower.aspx.cs" Inherits="SelectGrower" %>

<asp:Content ID="Content1" ContentPlaceHolderID="MainContent" Runat="Server">

        <script src="/Scripts/jquery.signalR-2.4.1.js"></script>
        <!--Reference the autogenerated SignalR hub script. -->

        <script src="/signalr/hubs"></script>
        <!--Add script to update the page and send messages.-->


    <script>
        var seedHub = $.connection.seedHub;

            $(function () {
                $("#btnHistory").hide();
                $("#btnOk").hide();

                $.connection.hub.disconnected(function () {
                    setTimeout(function () {
                        $.connection.hub.start();
                    }, 5000); // Restart connection after 5 seconds.
                });


                $.connection.hub.disconnected(function () {
                    if ($.connection.hub.lastError) { alert("Disconnected. Reason: " + $.connection.hub.lastError.message); }
                });


                $.connection.hub.start().done(function () {
                    seedHub.server.getCustomers();
                });

                $("#txtgrower").autocomplete({
                    autoFocus: true,
                    select: checkSelectedCustomer,
                    //focus: showResult,
                    change: checkSelectedCustomer

                });
             
            });
        
            

            seedHub.client.setProducers = function(data)
            {
                $('#txtgrower').autocomplete({
                    source: data
                });
            }

            seedHub.client.customerOK = function () {
                console.log("customerOK");
                $("#btnHistory").hide();

                $("#btnOk").show();
            }


            seedHub.client.customerHasHistory = function(link)
            {
                console.log("customerHasHistory");
                $("#btnHistory").attr("href", link)
                $("#btnHistory").show();
                $("#btnOk").show();
            }



            seedHub.client.customerNotFound = function () {
                
                $("#btnHistory").hide();
                $("#btnOk").hide();
                seedHub.server.getCustomers();
            }
            


           


            function checkSelectedCustomer(event, ui)
            {
                seedHub.server.getCustomerHistory(ui.item.label);
               
               // alert(ui.item.label);
            }


            function checkCustomer(ctl)
            {
               
                seedHub.server.getCustomerHistory($(ctl).val());
            }



    </script>





           <asp:UpdatePanel runat="server" ID="UP1" >
               <ContentTemplate>

            <div class="row">
                <div class="col-sm-12 col-md-8 col-lg-6">
                    <div class="input-group input-group-lg">
                        <h3 class="pr-4">Grower</h3>
                    </div>
                </div>
            </div>

            <div class="row pt-2">
                <div class="col-12 col-md-2">
                    <asp:LinkButton runat="server" ID="btnNotFound" CssClass="btn btn-secondary" OnClick="btnNotFound_Click" Text="Not Found"></asp:LinkButton>
                </div>
            </div>

            <div class="row pt-2">

                <div class="col-sm-12 col-md-8 col-lg-6">
                    <div class="input-group input-group-lg">
                       
                                <asp:TextBox CssClass="form-control " ID="txtgrower"  placeholder="Grower Name or Number" ClientIDMode="Static" AutoPostBack="false"   onchange="checkCustomer(this)"   Font-Size="Larger" runat="server" ></asp:TextBox>
                  

                        
 
                    </div>
                </div>
            </div>


            <div class="row pt-2">
                <div class="col">
                    <a id="btnHistory" class =" btn btn-outline-dark" href="#">Copy Values From Past Loads</a>
            </div>
            </div>

            
      



            <div class="row pt-5">
                <div class="col-6 col-md-2">
                    <asp:LinkButton runat="server" ID="btnCancel" CssClass="btn btn-danger " OnClick="btnCancel_Click" Width="100%" Text="Cancel"  />
                </div>
                <div class="col-6 col-md-2">
                    <asp:Button runat="server" ID="btnOk" CssClass="btn btn-success " ClientIDMode="Static"  Width="100%" UseSubmitBehavior="false"  Text="OK" OnClick="btnOk_Click" />
                </div>


            </div>
                   </ContentTemplate>
               </asp:UpdatePanel>

</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="MainContentFull" Runat="Server">
</asp:Content>

