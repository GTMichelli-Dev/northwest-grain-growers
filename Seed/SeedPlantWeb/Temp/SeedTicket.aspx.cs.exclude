    protected void ddWeightype_TextChanged(object sender, EventArgs e)
    {
        if (this.IsPostBack)
        {

            GlobalVars.SeedTicketWeighType = (GlobalVars.enumSeedTicketWeighType)Enum.Parse(typeof(GlobalVars.enumSeedTicketWeighType), ddWeightype.Text);
            SeedTicketInfo.CurrentSeedTicketRow.Ticket_Type = GlobalVars.SeedTicketWeighType.ToString();
        }
        GetWeighType();
    }


    public void GetWeighType()
    {
        pnlBags.Visible = false;
        pnlToteWeights.Visible = false;
        pnlTruckWeights.Visible = false;

        switch (GlobalVars.SeedTicketWeighType)
        {
            case GlobalVars.enumSeedTicketWeighType.Truck:
                lblTruckWeightHeader.Text = "Truck Weights";
                pnlTruckWeights.Visible = true;
                break;
            case GlobalVars.enumSeedTicketWeighType.Tote:
                pnlToteWeights.Visible = true;
                break;
            case GlobalVars.enumSeedTicketWeighType.Bag:
                lblBagWeightHeader.Text = "Bags Weights";
                pnlBags.Visible = true;
                break;
            case GlobalVars.enumSeedTicketWeighType.Return:
                lblTruckWeightHeader.Text = "Return";
                pnlTruckWeights.Visible = true;
                break;
            case GlobalVars.enumSeedTicketWeighType.ReturnBag:
                lblBagWeightHeader.Text = "Returned Bags";
                pnlBags.Visible = true;
                break;
            default:
                pnlTruckWeights.Visible = true;
                lblTruckWeightHeader.Text = "Truck Weights";
                break;
        }
    }

    protected void btnConfirm_Click(object sender, EventArgs e)
    {
        enumConfirmType ConfirmType = (enumConfirmType)Enum.Parse(typeof(enumConfirmType), hfenumConfirmType.Value);
        if (ConfirmType == enumConfirmType.WeighMaster)
        {
            string Name = txtName.Text;
            using (ListDataSet.WeighMastersDataTable weighMastersDataTable = new ListDataSet.WeighMastersDataTable())
            {
                using (ListDataSetTableAdapters.WeighMastersTableAdapter weighMastersTableAdapter = new ListDataSetTableAdapters.WeighMastersTableAdapter())
                {
                    if (weighMastersTableAdapter.FillByName(weighMastersDataTable, Name) == 0)
                    {
                        weighMastersDataTable.AddWeighMastersRow(Guid.NewGuid(), Name);
                        weighMastersTableAdapter.Update(weighMastersDataTable);
                        GlobalVars.Weighmaster = Name;
                        SeedTicketInfo.CurrentSeedTicketRow.Weighmaster = Name;
                    }
                }
            }
            ScriptManager.RegisterStartupScript(this, this.GetType(), "showConfirmPopup", "$('#ConfirmPopup').modal('hide')", true);
            Response.Redirect(Request.RawUrl);
        }
        else if (ConfirmType == enumConfirmType.growerUnknown)
        {
            string Description = txtConfirmText.Text;

            if (string.IsNullOrEmpty(Description))
            {
                lblConfirmError.Visible = true;
                lblConfirmError.Text = "You Must Enter A Grower Description";
                UpConfirm.Update();
                ScriptManager.RegisterStartupScript(this, this.GetType(), "showConfirmPopup", "$('#ConfirmPopup').modal('show')", true);
            }
            else if (Description.Length < 6)
            {
                lblConfirmError.Visible = true;
                lblConfirmError.Text = "Enter A Little More Information About The Grower";
                UpConfirm.Update();
                ScriptManager.RegisterStartupScript(this, this.GetType(), "showConfirmPopup", "$('#ConfirmPopup').modal('show')", true);
            }
            else
            {
                RemoveUnknownFromComment();
                txtComment.Text = $"[UNKNOWN GROWER: {Description}]" + System.Environment.NewLine + txtComment.Text;
                txtGrower.Text = GlobalVars.UnknownItem;
                ScriptManager.RegisterStartupScript(this, this.GetType(), "showConfirmPopup", "$('#ConfirmPopup').modal('hide')", true);
                Response.Redirect(Request.RawUrl);
                SeedTicketInfo.CurrentSeedTicketRow.Grower_ID = 0;
                
            }
        }

    }



    protected void btnCancelConfirm_Click(object sender, EventArgs e)
    {
        enumConfirmType ConfirmType = (enumConfirmType)Enum.Parse(typeof(enumConfirmType), hfenumConfirmType.Value);
        if (ConfirmType == enumConfirmType.WeighMaster)
        {

            txtName.Text = "";
            SeedTicketInfo.CurrentSeedTicketRow.SetWeighmasterNull();

        }
        else if (ConfirmType == enumConfirmType.growerNameInvalid || ConfirmType == enumConfirmType.growerUnknown)
        {
            txtGrower.Text = "";
            RemoveUnknownFromComment();
        }
        ScriptManager.RegisterStartupScript(this, this.GetType(), "showConfirmPopup", "$('#ConfirmPopup').modal('hide')", true);
        Response.Redirect(Request.RawUrl);
    }


    public void RemoveUnknownFromComment()
    {
        string Comment = txtComment.Text;
        int StartPos = Comment.IndexOf('[');
        int EndPos = Comment.IndexOf(']');
        bool RemoveNewLine = Comment.Contains("]" + System.Environment.NewLine);
        int EndPrefix = (RemoveNewLine) ? 3 : 1;
        // EndPos += EndPrefix; 
        if (StartPos > -1 && EndPos > StartPos)
        {
            Comment = Comment.Remove(StartPos, (EndPos - StartPos) + EndPrefix);
            txtComment.Text = Comment;
        }

    }


    protected void txtGrower_TextChanged(object sender, EventArgs e)
    {
        CheckGrower();
        

    }


    public void CheckGrower()
    {
        SeedTicketInfo.CurrentSeedTicketRow.SetGrower_IDNull();
        string Grower = txtGrower.Text;
        if (!string.IsNullOrEmpty(Grower))
        {
            if (Grower == GlobalVars.UnknownItem)
            {
                if (string.IsNullOrWhiteSpace(txtComment.Text))
                {
                    ShowConfirmBox(enumConfirmType.growerUnknown, "OK", "Cancel", "Unknown Grower", $"Enter A Description Of the Grower", "", true);
                }
            }
            else
            {
                RemoveUnknownFromComment();
                using (ListDataSetTableAdapters.ProducersListTableAdapter producersListTableAdapter = new ListDataSetTableAdapters.ProducersListTableAdapter())
                {
                    using (ListDataSet.ProducersListDataTable producersListDataTable = new ListDataSet.ProducersListDataTable())
                    {
                        if (producersListTableAdapter.FillByFullName(producersListDataTable, Grower) == 0)
                        {
                            
                            ShowConfirmBox(enumConfirmType.growerNameInvalid, "", "OK", "Invalid Grower", $"The Grower<br/>{Grower}<br/>Does Not Exist.", "", false);
                        }
                        else
                        {
                            SeedTicketInfo.CurrentSeedTicketRow.Grower_ID = producersListDataTable[0].Id; 
                        }
                    }
                }
            }
        }
        else
        {
            RemoveUnknownFromComment();
        }
    }

    
