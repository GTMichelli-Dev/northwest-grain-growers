    public void GetGrower()
    {
        if (!SeedTicketInfo.CurrentSeedTicketRow.IsGrower_IDNull())
        {
            using (ListDataSetTableAdapters.ProducersListTableAdapter producersListTableAdapter = new ListDataSetTableAdapters.ProducersListTableAdapter())
            {
                using (ListDataSet.ProducersListDataTable producersListDataTable = new ListDataSet.ProducersListDataTable())
                {
                    if (producersListTableAdapter.FillByID(producersListDataTable, SeedTicketInfo.CurrentSeedTicketRow.Grower_ID) > 0)
                    {
                        
                         var row = producersListDataTable[0];
                        if (row.Id==0)
                        {
                            txtGrower.Text = "UNKNOWN";

                        }
                        else
                        {
                            txtGrower.Text = row.FullName;
                        }
                    }
                }
            }
        }
    }


    public void SetVarieties()
    {

        using (SeedTicketDataSet.VarietyListDataTable VarietyList = new SeedTicketDataSet.VarietyListDataTable())
        {
            decimal Total = 0;
            foreach (var row in SeedTicketInfo.seedTicketDataSet.Seed_Ticket_Varieties)
            {
                var vlRow = VarietyList.NewVarietyListRow();
                vlRow.Item = row.Variety_ID;
                vlRow.Description = row.Custom_Name;
                vlRow.Percent = (decimal)row.Actual_Percent;
                Total += vlRow.Percent;
                vlRow.Bin = (row.IsBin_NameNull()) ? "" : row.Bin_Name;
                vlRow.Total = 90000;
                VarietyList.AddVarietyListRow(vlRow);
                vlRow.UID = row.UID;
            }
            grdVarieties.DataSource = VarietyList;
            grdVarieties.DataBind();
            if (Total == 0)
            {
                lblVarieties.InnerText = "Varieties";
                spanVariety.Visible = false;
            }
            else if (Total == 100)
            {
                spanVariety.Visible = true;
                //              spanVariety.Attributes.Clear();
                spanVariety.Attributes.Add("class", "font-weight-bold text-success");
                spanVariety.InnerText = "Total 100%";


            }
            else
            {
                spanVariety.Visible = true;
                //                spanVariety.Attributes.Clear();
                spanVariety.Attributes.Add("class", "font-weight-bold text-danger");
                spanVariety.InnerText = $"Total {Total}%";

            }

        }
    }


    protected void txtName_TextChanged(object sender, EventArgs e)
    {
        string Name = txtName.Text;
        
        if (this.IsPostBack)
        {
           

            if (!string.IsNullOrEmpty(txtName.Text))
            {
                using (ListDataSet.WeighMastersDataTable weighMastersDataTable = new ListDataSet.WeighMastersDataTable())
                {
                    using (ListDataSetTableAdapters.WeighMastersTableAdapter weighMastersTableAdapter = new ListDataSetTableAdapters.WeighMastersTableAdapter())
                    {
                        if (weighMastersTableAdapter.FillByName(weighMastersDataTable, Name) == 0)
                        {
                            ShowConfirmBox(enumConfirmType.WeighMaster, "Yes", "No", "Name Not Found", $"The Weighmaster<br/>{Name}<br/>Does Not Exist.<br/> Add Name?", Name, false);
                        }
                        else
                        {
                            GlobalVars.Weighmaster = Name;
                            SeedTicketInfo.CurrentSeedTicketRow.Weighmaster = Name;
                            Response.Redirect(Request.RawUrl);
                        }
                    }
                }

            }
        }
    }




    public void ShowMessage(string Message)
    {
        lblMessage.Text = Message;
        UPMessage.Update();
        ScriptManager.RegisterStartupScript(this, this.GetType(), "MessagePopup", "$('#MessagePopup').modal('show')", true);

    }



    public void ShowConfirmBox(enumConfirmType confirmType, string OKbtnText, string CancelbtnText, string HeaderText, string PromptText, string ConfirmValue1, bool ShowConfirmTextBox)
    {
        lblConfirmError.Visible = false;
        lblPopupHeader.Text = HeaderText;
        hfConfirmVal1.Value = ConfirmValue1;
        lblConfirmDescription.Text = PromptText;
        hfenumConfirmType.Value = confirmType.ToString();
        txtConfirmText.Text = "";
        txtConfirmText.Visible = ShowConfirmTextBox;
        btnCancelConfirm.Visible = (!string.IsNullOrWhiteSpace(CancelbtnText));
        btnConfirm.Visible = (!string.IsNullOrWhiteSpace(OKbtnText));
        btnCancelConfirm.Text = CancelbtnText;
        btnConfirm.Text = OKbtnText;
        UpConfirm.Update();
        ScriptManager.RegisterStartupScript(this, this.GetType(), "showConfirmPopup", "$('#ConfirmPopup').modal('show')", true);
       

    }


   


