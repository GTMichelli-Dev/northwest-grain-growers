            test.AddTestRow("Joh1n", 3);
            test.AddTestRow("John2", 3);
            test.AddTestRow("John3", 3);
            test.AddTestRow("John4", 3);
            test.AddTestRow("John5", 3);
            test.AddTestRow("Johnsd", 3);
            test.AddTestRow("Johnx", 3);
            test.AddTestRow("Johnc", 3);
            test.AddTestRow("Johnv", 3);
            test.AddTestRow("Johnb", 3);
            test.AddTestRow("Johnn", 3);
            test.AddTestRow("Johnm", 3);
            test.AddTestRow("Johned", 3);
            test.AddTestRow("Johncd", 3);
            test.AddTestRow("Johnxs", 3);
            test.AddTestRow("Johnsxs", 3);
            test.AddTestRow("Johnceddd", 3);

            DataSet ds = new DataSet();
            ds.Tables.Add(test);

            grdTotes.DataSource = ds;
            grdTotes.DataBind();
