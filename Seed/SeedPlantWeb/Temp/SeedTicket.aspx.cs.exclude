            txtComment.Text = (SeedTicketInfo.CurrentSeedTicketRow.IsCommentsNull ()) ? "" : SeedTicketInfo.CurrentSeedTicketRow.Comments ;
            txtName.Text  = (SeedTicketInfo.CurrentSeedTicketRow.IsWeighmasterNull() ) ? GlobalVars.Weighmaster  : SeedTicketInfo.CurrentSeedTicketRow.Weighmaster ;
            GetGrower();
            GetWeighType();
