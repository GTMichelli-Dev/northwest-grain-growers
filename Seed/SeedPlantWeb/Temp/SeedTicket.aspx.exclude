                                                        <div class="col-1 d-none d-lg-block  "></div>
                                                    </div>
                                                    <div class="row pt-1 ">
                                                        <div class="col-1 d-none d-lg-block  "></div>
                                                        <div class="col-md-2 co-lg-4  text-left  ">
                                                            <label class="pl-3">Net</label>
                                                        </div>
                                                        <div class="col-md-6 col-lg-5">
                                                            <asp:Label runat="server" ID="lblNet" CssClass="form-control border border-dark text-right" Text=" ------"></asp:Label>
                                                        </div>
                                                        <div class="col-1 d-none d-lg-block  "></div>
                                                    </div>
                                                </ContentTemplate>
                                            </asp:UpdatePanel>

                                        </asp:Panel>
                                        <asp:Panel runat="server" ID="pnlToteWeights" Width="100%" Visible="false" HorizontalAlign="Center">
                                            <div class="row p-3 font-weight-bold  ">
                                                <div class="col">
                                                    <h4 class="text-center " style="width: 100%">
                                                        <asp:Label runat="server" ID="lblToteWeightHeader" Text="Totes" Width="100%"></asp:Label></h4>
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-3 "></div>
                                                <div class="col-6 ">
                                                    <div class="form-group ">
                                                        <label for="txtToteDescription">Description</label>
                                                        <asp:TextBox runat="server" ID="txtToteDescription" AutoCompleteType="Disabled" CssClass="form-control "></asp:TextBox>
                                                    </div>



                                                </div>
                                                <div class="col-3 "></div>

                                            </div>
                                            <div class="row">
                                                <div class="col">
                                                    <asp:Panel runat="server" ID="pnlToteGrid" HorizontalAlign="Center" Width="100%" Height="475px" ScrollBars="Auto">
                                                        <asp:GridView HorizontalAlign="Center" Width="100%" CssClass="table table-bordered table-hover " runat="server" ID="grdTotes" AutoGenerateColumns="False">
                                                            <Columns>
                                                                <asp:BoundField DataField="Name" HeaderText="Name" ReadOnly="True" SortExpression="Name"></asp:BoundField>
                                                                <asp:BoundField DataField="ID" HeaderText="ID" ReadOnly="True" SortExpression="ID"></asp:BoundField>
                                                            </Columns>
                                                        </asp:GridView>

                                                    </asp:Panel>


                                                </div>
                                            </div>
                                        </asp:Panel>
                                        <asp:Panel runat="server" ID="pnlBags" HorizontalAlign="Center" Visible="false" Width="100%">
                                            <div class="row p-3 font-weight-bold  ">
