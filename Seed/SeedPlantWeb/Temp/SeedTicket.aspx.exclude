        </div>
    </div>
    <div class="row" >

        <div class="col d-none d-xl-block "></div>
        <div class=" col-lg-12 col-xl-10  border border-dark">
            <div class="row">

                <div class="col-8 border-right border-dark ">
           
                            <div class="row">
