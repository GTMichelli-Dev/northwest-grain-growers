                                    <div class="form-group">
                                        <label class="col-form-label " for="txtPO">PO</label>
                                        <asp:TextBox runat="server" ID="txtPO" AutoCompleteType="Disabled" AutoPostBack="true" OnTextChanged="txtPO_TextChanged"  CssClass="form-control"></asp:TextBox>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-5">
                                    <div class="form-group">
                                       <asp:UpdatePanel runat="server" ID="UpWeighmaster" >
                                           <ContentTemplate>
