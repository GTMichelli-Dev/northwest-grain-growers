                                                <asp:DropDownList runat="server" CssClass="form-control" ID="ddWeightype" OnTextChanged="ddWeightype_TextChanged" AutoPostBack="true">
                                                </asp:DropDownList>

                                            </ContentTemplate>
                                        </asp:UpdatePanel>
                                    </div>
                                </div>
