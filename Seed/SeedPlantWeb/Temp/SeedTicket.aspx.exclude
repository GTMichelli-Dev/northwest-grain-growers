       <%--<asp:Button ID="Button1" runat="server" Text="Get Name" OnClientClick='GetName();return false;' />--%> 

    <asp:UpdatePanel runat="server" ID="UPHiddenField">
        <ContentTemplate>
               <asp:HiddenField runat="server" ID="HFWeighType" />
        </ContentTemplate>
    </asp:UpdatePanel>

 

    <div class="row pt-2 ">
        <div class="col-12">
            <asp:Label runat="server" ID="lblHeader" Width="100%"  CssClass=" h3 text-center " Text="Seed Ticket"></asp:Label> 

