@using Seed25.Models
@using Seed25.DTO

@* 
<h2>Tickets</h2>
<div class="d-flex align-items-center gap-2 flex-wrap mb-3">
  <span class="fw-semibold me-1">Date:</span>
  <div id="fromDate" class="d-inline-block"></div>
  <span class="mx-1">ľ</span>
  <div id="toDate" class="d-inline-block"></div>

  <span class="ms-3">Location:</span>
  <div id="location-select" class="d-inline-block" style="min-width:260px"></div>
  <a href="#" id="resetGrid" class="text-decoration-underline">Reset grid layout</a>
  <button type="button" id="btnRefresh" class="btn btn-primary ms-2">Refresh</button>
</div>

@(
Html.DevExtreme().DataGrid<SeedTicketSummaryDTO>()
    .ID("ticketsGrid")
    .DataSource(ds => ds.WebApi()
        .Controller("SeedTicket")
        .LoadAction("GetTicketSummary")
        .Key("UID")
        .LoadMethod("GET")
        .LoadParams(new JS("getSummaryParams"))  // from/to/location as query params
    )
    .Width("100%")
    .RemoteOperations(true)                  // client filtering/grouping
    .RowAlternationEnabled(true)
    .ColumnAutoWidth(true)

    .Paging(p => p.Enabled(true).PageSize(50))
    .Pager(p => p.Visible(true)
                 .ShowInfo(true)
                 .ShowPageSizeSelector(true)
                 .AllowedPageSizes(new[] { 25, 50, 100, 500 }))

    // add a toolbar button + set initial state from storage
    .OnToolbarPreparing("ticketsToolbar")
    .OnInitialized("ticketsInit")


    // === make grouping/filtering easy ===
    .FilterRow(fr => fr.Visible(true).ApplyFilter(GridApplyFilterMode.Auto))
    .HeaderFilter(hf => hf.Visible(true))
    .SearchPanel(sp => sp.Visible(true).HighlightCaseSensitive(false))
    .GroupPanel(gp => gp.Visible(true))       // drag headers here to group
    .Grouping(g => g.AutoExpandAll(false))    // keep groups collapsed by default
    .AllowColumnResizing(true)
    .AllowColumnReordering(true)
    .ColumnChooser(cc => cc.Enabled(true).Mode(GridColumnChooserMode.Select))

    // === persist grid state across reloads ===
    .StateStoring(s => s
        .Enabled(true)
        .Type(DevExtreme.AspNet.Mvc.StateStoringType.LocalStorage)
        .StorageKey("ticketsGridState:v1")    // bump the :v1 if you change columns
    )

    .Columns(c => {
        c.AddFor(m => m.Location);
        c.AddFor(m => m.InvoiceDate).DataType(GridColumnDataType.DateTime).Format("M/d/yyyy HH:mm");
        c.AddFor(m => m.Ticket);

        c.AddFor(m => m.StrTotallbs)
            .Caption("Total lbs")
            .Alignment(HorizontalAlignment.Right);

        c.AddFor(m => m.CustomerName);

        c.Add()
            .Caption("Varieties")
            .Width(420)
            .EncodeHtml(false)
            .CellTemplate(new JS("varietiesCell"));

        c.AddFor(m => m.TicketType).Caption("Type");
        c.AddFor(m => m.Status);
        c.AddFor(m => m.TruckId);
        c.AddFor(m => m.PO);
        c.AddFor(m => m.BOL);
        c.AddFor(m => m.Comments);
    })
)
 *@

@section Scripts {

<script>
  // --- Persist paging on/off across refreshes
  const PAGING_KEY = "ticketsGrid:pagingEnabled";

  function getPagingEnabled() {
    const v = localStorage.getItem(PAGING_KEY);
    return v === null ? true : v === "true"; // default ON
  }
  function setPagingEnabled(val) {
    localStorage.setItem(PAGING_KEY, String(val));
  }
  function applyPaging(grid) {
    const enabled = getPagingEnabled();
    grid.option("paging.enabled", enabled);
    grid.option("pager.visible", enabled);
  }

  // Called after grid is initialized Ś apply persisted paging state
  function ticketsInit(e) {
    applyPaging(e.component);
  }

  // Add a toggle button to the grid toolbar
  function ticketsToolbar(e) {
    const grid = e.component;
    const isOn = getPagingEnabled();

    e.toolbarOptions.items.unshift({
      location: "after",
      widget: "dxButton",
      options: {
        text: isOn ? "Paging: On" : "Paging: Off",
        hint: "Toggle paging on/off",
        onClick: function() {
          const newVal = !getPagingEnabled();
          setPagingEnabled(newVal);
          applyPaging(grid);
          this.option("text", newVal ? "Paging: On" : "Paging: Off");
        }
      }
    });
  }

  // (If youĺre using custom state storing for filters/grouping)
  function gridStateLoad() {
    try { return JSON.parse(localStorage.getItem("ticketsGridState:v1")); } catch { return null; }
  }
  function gridStateSave(state) {
    try { localStorage.setItem("ticketsGridState:v1", JSON.stringify(state)); } catch {}
  }
</script>






<script>
  // ---- persistence keys
  const STORE = {
    from: 'seed.fromDate',   // 'YYYY-MM-DD'
    to:   'seed.toDate',     // 'YYYY-MM-DD'
    loc:  'seed.locationId'  // number
  };

   document.getElementById('resetGrid')?.addEventListener('click', function (e) {
    e.preventDefault();
    localStorage.removeItem('ticketsGridState:v1');
    const grid = $("#ticketsGrid").dxDataGrid("instance");
    if (grid) grid.state(null); // resets to defaults
  });


   function varietiesCell(container, options) {
    const list = options?.data?.Varieties || [];
    console.log(list);
    if (!list.length) return;

    // Build lines safely (no HTML needed)
    list.forEach(v => {
      const desc = v?.Description || "";
      const lot  = v?.Lot ? ` (Lot ${v.Lot})` : "";
      $("<div>").text(desc + lot).appendTo(container);
    });
  }

  // ---- date helpers (store as date-only strings to avoid TZ surprises)
  function todayLocal() {
    const n = new Date();
    return new Date(n.getFullYear(), n.getMonth(), n.getDate());
  }
  function toDateOnlyString(d) {
    const y = d.getFullYear(), m = String(d.getMonth()+1).padStart(2,'0'), dd = String(d.getDate()).padStart(2,'0');
    return `${y}-${m}-${dd}`;
  }
  function fromDateOnlyString(s) {
    if (!s) return null;
    const parts = s.split('-').map(Number);
    if (parts.length !== 3) return null;
    return new Date(parts[0], parts[1]-1, parts[2]);
  }
  function ensureRange(from, to) {
    if (from > to) { const tmp = from; from = to; to = tmp;
      if (window.DevExpress?.ui?.notify) DevExpress.ui.notify("From date was after To date Ś swapped.", "warning", 2000);
    }
    return { from, to };
  }

  // ---- location helpers (DevExtreme SelectBox or fallback)
  function getSelectedLocationId() {
    const $el = $("#location-select");
    try {
      const inst = $el.dxSelectBox("instance");
      if (inst) return inst.option("value") || 0;
    } catch {}
    const v = $el.val();
    return v ? parseInt(v, 10) : 0;
  }
  function setSelectedLocationId(id) {
    const $el = $("#location-select");
    try {
      const inst = $el.dxSelectBox("instance");
      if (inst) { inst.option("value", id); return; }
    } catch {}
    $el.val(id);
  }

  // ---- grid refresh
  function refreshTickets() {
    const grid = $("#ticketsGrid").dxDataGrid("instance");
    if (grid) grid.refresh();
  }

  // ---- OnBeforeSend: build request body
  function dxBeforeSend(method, ajaxOptions) {
    if (method !== "load") return;

    // Get current picker values (fallback to stored or today)
    const fromInst = $("#fromDate").dxDateBox("instance");
    const toInst   = $("#toDate").dxDateBox("instance");
    let from = fromInst?.option("value") || fromDateOnlyString(localStorage.getItem(STORE.from)) || todayLocal();
    let to   = toInst?.option("value")   || fromDateOnlyString(localStorage.getItem(STORE.to))   || todayLocal();

    // normalize & enforce range
    from = new Date(from.getFullYear(), from.getMonth(), from.getDate());
    to   = new Date(to.getFullYear(),   to.getMonth(),   to.getDate());
    ({ from, to } = ensureRange(from, to));

    // persist (date-only strings)
    localStorage.setItem(STORE.from, toDateOnlyString(from));
    localStorage.setItem(STORE.to,   toDateOnlyString(to));

    // also persist location
    const locId = getSelectedLocationId() || 0;
    localStorage.setItem(STORE.loc, String(locId));

    // send date-only strings; server treats day start via .Date
    const req = {
      FromDate: toDateOnlyString(from),
      ToDate:   toDateOnlyString(to),
      LocationId: locId
    };
    ajaxOptions.method = "POST";
    ajaxOptions.contentType = "application/json";
    ajaxOptions.data = JSON.stringify(req);
  }

  // ---- init UI and wire up events
  $(function () {
    // init From/To with saved or today
    const fromSaved = fromDateOnlyString(localStorage.getItem(STORE.from)) || todayLocal();
    const toSaved   = fromDateOnlyString(localStorage.getItem(STORE.to))   || todayLocal();

    $("#fromDate").dxDateBox({
      type: "date",
      value: fromSaved,
      displayFormat: "M/d/yyyy",
      onValueChanged: e => {
        // if user clears, set to today
        const v = e.value || todayLocal();
        localStorage.setItem(STORE.from, toDateOnlyString(v));
        refreshTickets();
      }
    });
    $("#toDate").dxDateBox({
      type: "date",
      value: toSaved,
      displayFormat: "M/d/yyyy",
      onValueChanged: e => {
        const v = e.value || todayLocal();
        localStorage.setItem(STORE.to, toDateOnlyString(v));
        refreshTickets();
      }
    });

    // restore saved location (if you store it)
    const savedLoc = parseInt(localStorage.getItem(STORE.loc) || "0", 10) || 0;
    if (savedLoc) setSelectedLocationId(savedLoc);

    // wire refresh button
    $("#btnRefresh").on("click", refreshTickets);

    // auto-refresh when location changes
    const $el = $("#location-select");
    try {
      const inst = $el.dxSelectBox("instance");
      if (inst) inst.on("valueChanged", e => {
        localStorage.setItem(STORE.loc, String(e.value || 0));
        refreshTickets();
      });
      else $el.on("change", () => {
        localStorage.setItem(STORE.loc, String(getSelectedLocationId() || 0));
        refreshTickets();
      });
    } catch {
      $el.on("change", () => {
        localStorage.setItem(STORE.loc, String(getSelectedLocationId() || 0));
        refreshTickets();
      });
    }
  });




    // --------------------------
  // Provide query params for GET (DevExtreme .LoadParams)
  // --------------------------
  function getSummaryParams() {
    let from = fromDateOnlyString(localStorage.getItem(STORE.from)) || todayLocal();
    let to   = fromDateOnlyString(localStorage.getItem(STORE.to))   || todayLocal();
    // enforce From <= To
    if (from > to) { const t = from; from = to; to = t; }
    // persist normalized
    localStorage.setItem(STORE.from, toDateOnlyString(from));
    localStorage.setItem(STORE.to,   toDateOnlyString(to));

    const locIdStored = parseInt(localStorage.getItem(STORE.loc) || "0", 10) || 0;
    const locId = locIdStored || getSelectedLocationId() || 0;
    if (locId && locId !== locIdStored) localStorage.setItem(STORE.loc, String(locId));

    // Returned properties become query string params
    return {
      fromDate: toDateOnlyString(from),
      toDate:   toDateOnlyString(to),
      locationId: locId
    };
  }
</script>
}

