@{
    ViewData["Title"] = "Remote Admin";
}

<div class="container" style="max-width:420px;margin-top:4rem;">
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="h4 mb-3">Remote Admin</h1>
            <p class="text-muted small mb-3">
                Enter a Remote Admin PIN to access the system administration page.
            </p>

            <div class="mb-2">
                <label class="form-label">PIN <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="raPinInput"
                       inputmode="numeric" maxlength="10" placeholder="Enter PIN"
                       autocomplete="off" data-lpignore="true" data-1p-ignore="true"
                       style="-webkit-text-security:disc;" />
            </div>

            <div id="raPinError" class="text-danger small mt-2" hidden></div>

            <div class="d-flex gap-2 mt-3">
                <button type="button" class="btn btn-primary" id="raPinConfirmBtn">Continue</button>
                <a href="/" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            var $err   = document.getElementById('raPinError');
            var $input = document.getElementById('raPinInput');
            var $btn   = document.getElementById('raPinConfirmBtn');

            function showError(msg) {
                $err.textContent = msg;
                $err.removeAttribute('hidden');
            }
            function clearError() {
                $err.textContent = '';
                $err.setAttribute('hidden', 'hidden');
            }

            async function submit() {
                clearError();
                var pin = parseInt($input.value, 10);
                if (!pin || pin <= 0) { showError('A valid PIN is required.'); return; }

                $btn.disabled = true;
                try {
                    var resp = await fetch('/api/Auth/ValidateRemoteAdminPin', {
                        method:  'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body:    JSON.stringify({ Pin: pin }),
                    });
                    if (!resp.ok) {
                        var detail = '';
                        try { var j = await resp.json(); detail = j.message || ''; } catch (e) {}
                        showError(detail || 'PIN rejected.');
                        return;
                    }
                    window.location.href = '/RemoteAdmin';
                } catch (ex) {
                    showError('Network error: ' + ex.message);
                } finally {
                    $btn.disabled = false;
                }
            }

            $btn.addEventListener('click', submit);
            $input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); submit(); }
            });
            setTimeout(function () { $input.focus(); }, 100);
        })();
    </script>
}
