@*
    Shared PIN-prompt modal — singleton instance rendered once in _Layout.cshtml
    so any page can call GM.requestPin({...}) without supplying its own markup.

    Pages must NOT use the IDs gm-pin-prompt* for their own modals. To customize
    the title / prompt / required privilege, pass options to GM.requestPin() —
    see wwwroot/js/gm-pin-prompt.js.
*@
<div class="modal fade" id="gm-pin-prompt-modal" tabindex="-1" aria-labelledby="gm-pin-prompt-label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="gm-pin-prompt-label">Enter PIN</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2" id="gm-pin-prompt-text">Enter your PIN to continue.</p>
                @* autocomplete="new-password" — Chrome ignores plain "off"
                   on inputs that look password-like (the disc-masked text
                   here qualifies). "new-password" is the only value Chrome
                   honors for "do not offer saved values". data-lpignore /
                   data-1p-ignore / data-form-type / spellcheck cover the
                   password managers + spell-check underline. *@
                <input type="text" class="form-control" id="gm-pin-prompt-input"
                       inputmode="numeric" maxlength="10" placeholder="PIN"
                       autocomplete="new-password"
                       data-lpignore="true" data-1p-ignore="true"
                       data-form-type="other" spellcheck="false"
                       style="-webkit-text-security:disc;" />
                <div id="gm-pin-prompt-error" class="text-danger small mt-2" hidden></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="gm-pin-prompt-submit">Continue</button>
            </div>
        </div>
    </div>
</div>
