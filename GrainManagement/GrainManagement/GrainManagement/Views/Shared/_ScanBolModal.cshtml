@*
    ScanBOL modal — drop into any page that has the concept of a "current load
    number." Pages that include this partial should also add a button that
    calls window.scanBol.open(loadNumber, locationId?). The button itself
    should only render when /api/cameras/bol/available reports any.
*@

<div class="modal fade" id="scanBolModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Scan BOL</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">BOL Camera</label>
                        <select id="bol-camera-select" class="form-select"></select>
                        <div id="bol-cam-empty" class="text-danger small mt-2 d-none">
                            No BOL cameras are online right now.
                        </div>
                        <div class="mt-3 small">
                            <div>Load: <strong id="bol-load-label"></strong></div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="ratio ratio-4x3 bg-dark rounded">
                            <img id="bol-stream" alt="BOL camera live feed"
                                 style="object-fit:contain; background:#000;" />
                        </div>
                        <div class="text-muted small mt-1" id="bol-stream-status">No camera selected.</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="bol-take-btn" class="btn btn-primary" disabled>Take BOL Picture</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/pages/scan.bol.js" asp-append-version="true"></script>
