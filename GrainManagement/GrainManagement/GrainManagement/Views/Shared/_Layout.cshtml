@inject ILocationContext LocationCtx
@inject SystemInfoSnapshot SystemInfo
@inject IModuleContext Modules
@inject Microsoft.Extensions.Configuration.IConfiguration AppConfig
@{
    var themeKey = Context.Items["ThemeKey"]?.ToString() ?? "default";
    // Server-configured IANA tz id used by JS display helpers + reports. The
    // helpers fall back to the browser TZ when this is empty.
    var serverTimeZone = AppConfig["TimeZone"] ?? "";
}
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="">
    <meta name="author" content="">
    <meta name="server-timezone" content="@serverTimeZone">
    <script>
        // Server timezone hint for JS datetime display. Storage stays UTC;
        // every render that needs to show a stored value should run it
        // through window.gmFormatServerTime / .gmFormatServerDate so it
        // reads in the configured zone instead of the browser's locale.
        window.gmServerTimeZone = '@serverTimeZone';
    </script>
    <script src="~/js/shared/server-time.js" asp-append-version="true"></script>

   


    <title>GrainManagement</title>
    <link href="~/assets/branding/@(themeKey)/favicon.ico" rel="shortcut icon" type="image/x-icon" />

    @* Uncomment to use the HtmlEditor control *@
    @* <script src="~/js/devextreme/dx-quill.js"></script> *@

    @* Uncomment to use the Gantt control *@
    @*<link href="~/css/devextreme/dx-gantt.css" rel="stylesheet" />*@

    @* Uncomment to use the Diagram control *@
    @*<link href="~/css/devextreme/dx-diagram.css" rel="stylesheet" />*@

    <link href="~/css/devextreme/bootstrap.css" rel="stylesheet" />

    @* Predefined themes: https://js.devexpress.com/DevExtreme/Guide/Themes_and_Styles/Predefined_Themes/ *@
    <link href="~/css/devextreme/dx.light.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/app.base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/@(themeKey).css" asp-append-version="true" />
    <link href="~/css/pages/scales.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/pages/warehouse.intake.css" asp-append-version="true" />
    <link href="~/css/icons.css" rel="stylesheet" />
    <link href="~/css/pages/load.type.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)
</head>

<body style="padding-top: 3.5rem;">

    <!-- Startup overlay — blocks input until EF warm-up is complete (hidden by default) -->
    <div id="gm-startup-overlay" style="
        position:fixed; inset:0; z-index:9999;
        background:rgba(255,255,255,0.92);
        display:none; align-items:center; justify-content:center; flex-direction:column;
        pointer-events:all; cursor:wait;">
        <div class="spinner-border text-success mb-3" role="status" style="width:3rem;height:3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div class="fw-bold text-muted" style="font-size:1.1rem;">Starting up&hellip; warming database</div>
    </div>

    <nav class="navbar navbar-dark gm-navbar fixed-top navbar-expand-md">
        <div class="container-fluid">
            <div class="d-flex align-items-center">
                <a class="navbar-brand d-flex align-items-center gap-2 me-2 mb-0" href="/">
                    <img class="gm-logo" src="~/assets/branding/@(themeKey)/logo.png" alt="Logo" style="height:34px; width:auto;" />
                </a>

                <!-- Location Selector (hidden for Central/Admin deployments) -->
                @if (!Modules.IsCentral)
                {
                    <div class="me-3">
                        <select id="gm-location-select" class="form-select form-select-sm gm-location-select">
                            <option value="">-- Select Location --</option>
                        </select>
                    </div>
                }

                @* End Of Day — global launcher for the multi-location loop.
                   Visible only when the current site is a warehouse location;
                   click triggers GM.eod.runMultiLocation() which starts at the
                   current site, then sweeps every other accessible location
                   that still has open weight sheets. *@
                @if (LocationCtx.HasLocation && LocationCtx.CanDoWarehouse)
                {
                    <button type="button" id="gm-nav-eod-btn"
                            class="btn btn-outline-light btn-sm me-3"
                            title="Run End Of Day for this location and any other location with open weight sheets">
                        End Of Day
                    </button>
                }

                <div>
                    <span id="system-info" style="font-size: 0.85rem; color: white;">@SystemInfo.ToDisplayString()</span>
                </div>

                @if (Modules.IsRemote)
                {
                    <a href="/RemoteAdmin" class="ms-2 text-light text-decoration-none" title="Remote Admin (PIN required)" aria-label="Remote Admin"
                       style="font-size:1.05rem;line-height:1;padding:0.25rem 0.5rem;border:1px solid rgba(255,255,255,0.4);border-radius:0.25rem;">
                        &#9881;
                    </a>
                }
            </div>

            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar" aria-expanded="false" aria-controls="navbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div id="navbar" class="collapse navbar-collapse">
                <div class="d-flex ms-auto align-items-center">
                    @if (Modules.IsRemote)
                    {
                        // On Remote we don't use the regular Microsoft Identity login;
                        // access is gated per-action by PIN (see RemoteAdminController).
                        // Show a Logout button only when the Remote Admin PIN cookie is set.
                        if (Context.Request.Cookies.ContainsKey("GrainMgmt_RemoteAdminPin"))
                        {
                            var raUser = Context.Request.Cookies.TryGetValue("GrainMgmt_RemoteAdminUser", out var raRaw)
                                ? Uri.UnescapeDataString(raRaw)
                                : "";
                            <span class="navbar-text text-light me-2" style="font-size:0.9rem;">
                                Remote Administrator@(string.IsNullOrWhiteSpace(raUser) ? "" : ": " + raUser)
                            </span>
                            <a href="/RemoteAdmin/Logout" class="btn btn-outline-light btn-sm">Logout</a>
                        }
                    }
                    else if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="navbar-text text-light me-2">
                            @User.Identity.Name
                        </span>
                        <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut" class="btn btn-outline-light btn-sm">Logout</a>
                    }
                    else
                    {
                        <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn" class="btn btn-outline-light btn-sm">Login</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Global print alert bar (shown/hidden by gm.print-alerts.js via SignalR) -->
    <div id="gm-print-alert" style="display:none;" class="alert alert-danger alert-dismissible mb-0 rounded-0 py-2 text-center">
        <strong id="gm-print-alert-icon">&#9888;</strong>
        <span id="gm-print-alert-msg"></span>
        <button type="button" class="btn-close btn-close-sm" aria-label="Close"></button>
    </div>

    <main class="container-fluid" style="margin-top: 1.5rem;">

        @RenderBody()
    </main>

    @* Shared PIN-prompt modal — single instance for the whole app. Pages use
       GM.requestPin({...}) to drive it; do NOT define your own copy of the
       gm-pin-prompt-* IDs anywhere else. *@
    @await Html.PartialAsync("_GmPinPromptModal")
   


 

    @* Uncomment to use the Gantt control *@
    @*<script src="~/js/devextreme/dx-gantt.js"></script>*@

    @* Uncomment to use the Diagram control *@
    @*<script src="~/js/devextreme/dx-diagram.js"></script>*@

    <script src="~/js/devextreme/jquery.js"></script>
    <script src="~/js/devextreme/bootstrap.js"></script>

    @* Uncomment to use Globalize for localization *@
    @* Docs: https://docs.devexpress.com/AspNetCore/400577#globalize *@
    @*<script src="~/js/devextreme/cldr.js"></script>*@
    @*<script src="~/js/devextreme/cldr/event.js"></script>*@
    @*<script src="~/js/devextreme/cldr/supplemental.js"></script>*@
    @*<script src="~/js/devextreme/cldr/unresolved.js"></script>*@
    @*<script src="~/js/devextreme/globalize.js"></script>*@
    @*<script src="~/js/devextreme/globalize/message.js"></script>*@
    @*<script src="~/js/devextreme/globalize/number.js"></script>*@
    @*<script src="~/js/devextreme/globalize/currency.js"></script>*@
    @*<script src="~/js/devextreme/globalize/date.js"></script>*@

    @* Uncomment to enable client-side export *@
    @*<script src="~/js/devextreme/jszip.js"></script>*@

    <script src="~/js/devextreme/dx.all.js"></script>

    @* Uncomment to provide geo-data for the VectorMap control *@
    @* Docs: https://js.devexpress.com/DevExtreme/Guide/Widgets/VectorMap/Providing_Data/#Data_for_Areas *@
    @*<script src="~/js/devextreme/vectormap-data/world.js"></script>*@
    <script src="~/js/devextreme/exceljs.min.js"></script>
    <script src="~/js/devextreme/filesaver.min.js"></script>
    <script src="~/js/devextreme/aspnet/dx.aspnet.mvc.js"></script>
    <script src="~/js/devextreme/aspnet/dx.aspnet.data.js"></script>
    <script src="~/js/devextreme-license.js"></script>
 
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/gm.cookies.js" asp-append-version="true"></script>
    <script src="~/js/gm.pin-prompt.js" asp-append-version="true"></script>
    <script src="~/js/location-selector.js" asp-append-version="true"></script>
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/gm.print-alerts.js" asp-append-version="true"></script>
    <script src="~/js/gm.eod.js" asp-append-version="true"></script>
    <script>
        (function () {
            var btn = document.getElementById('gm-nav-eod-btn');
            if (!btn) return;
            btn.addEventListener('click', function () {
                if (window.GM && window.GM.eod && typeof window.GM.eod.runMultiLocation === 'function') {
                    window.GM.eod.runMultiLocation();
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
    (function () {
        var overlay = document.getElementById('gm-startup-overlay');
        if (!overlay) return;
        var shown = false;
        function showOverlay() {
            if (shown) return;
            shown = true;
            overlay.style.display = 'flex';
        }
        function hideOverlay() {
            if (!shown) { overlay.remove(); return; }
            overlay.style.transition = 'opacity 0.3s';
            overlay.style.opacity = '0';
            setTimeout(function () { overlay.remove(); }, 350);
        }
        function check() {
            fetch('/api/SystemApi/ready')
                .then(function (r) {
                    if (r.ok) { hideOverlay(); }
                    else { showOverlay(); setTimeout(check, 500); }
                })
                .catch(function () { showOverlay(); setTimeout(check, 500); });
        }
        check();
    })();
    </script>
</body>

</html>
