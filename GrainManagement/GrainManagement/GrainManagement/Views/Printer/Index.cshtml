@{
    ViewData["Title"] = "Printer Configuration";
}
@inject IModuleContext Modules

@if (Modules.IsCentral)
{
    <a href="@Url.Action("Index", "Admin")" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Admin">
        <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
        <span class="gm-module-bar__icon gm-icon gm-icon--settings" aria-hidden="true"></span>
        <span class="gm-module-bar__label">PRINTER CONFIGURATION</span>
    </a>
}
else
{
    <a href="/System" class="gm-module-bar gm-module-bar--system gm-module-bar--link" title="Back to System">
        <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
        <span class="gm-module-bar__icon gm-icon gm-icon--settings" aria-hidden="true"></span>
        <span class="gm-module-bar__label">PRINTER CONFIGURATION</span>
    </a>
}

<div class="gm-pagehead gm-pagehead--sticky">
</div>

<!-- Printer Assignments -->
<div class="card mb-3">
    <div class="card-header py-2"><strong>Printer Assignments</strong></div>
    <div class="card-body py-2">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label mb-0 small fw-bold">Inbound Printer</label>
                <select id="inboundPrinterSelect" class="form-select form-select-sm">
                    <option value="">-- None --</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label mb-0 small fw-bold">Outbound Printer</label>
                <select id="outboundPrinterSelect" class="form-select form-select-sm">
                    <option value="">-- None --</option>
                </select>
            </div>
            <div class="col-md-2">
                <span id="assignmentStatus" class="small"></span>
            </div>
        </div>
    </div>
</div>

<!-- Status bar -->
<div id="serviceStatusBar" class="alert alert-warning py-2 mb-3 d-flex align-items-center">
    <i class="dx-icon dx-icon-refresh dx-icon-spin me-2"></i> Checking print services...
</div>

<!-- Toast container -->
<div id="toastContainer" style="position:fixed;top:70px;right:20px;z-index:9999;min-width:350px;max-width:500px;"></div>

<!-- Services container (cards built dynamically) -->
<div id="servicesContainer"></div>

<!-- No services message -->
<div id="noServicesMessage" class="text-center text-muted py-5" style="display:none;">
    <span class="gm-icon gm-icon--settings" style="font-size:3rem;" aria-hidden="true"></span>
    <h5 class="mt-3">No Print Services Connected</h5>
    <p>Start a Web Print Service and point it to this server's SignalR hub at <code>/hubs/print</code>.</p>
</div>

<!-- Test Print Modal -->
<div class="modal fade" id="testPrintModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Test Print &mdash; <span id="testPrintPrinter"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div id="testPrintSpinner">
                    <i class="dx-icon dx-icon-refresh dx-icon-spin" style="font-size:2rem;"></i>
                    <p class="mt-2">Sending test page...</p>
                </div>
                <div id="testPrintResult" style="display:none;"></div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .service-card { margin-bottom: 1rem; }
        .service-card .card-header { display: flex; justify-content: space-between; align-items: center; }
        .printer-table th, .printer-table td { vertical-align: middle; font-size: 0.875rem; }
    </style>
}

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/pages/printer.management.js" asp-append-version="true"></script>
}
