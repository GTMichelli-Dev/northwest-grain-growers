@{
    ViewData["Title"] = "Seed";
}

<div class="gm-pagehead">
    <div class="gm-pagehead__title">
        <span class="gm-pagehead__icon gm-icon gm-icon--seed" aria-hidden="true"></span>
        <h1 class="gm-tile__title" style="font-size:20px">Seed</h1>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-12 col-lg-4">
        <div class="gm-tile">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--grower" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Receive from Grower</h2>
            </div>
            <p class="gm-tile__text">Receive seed delivered by a grower and create/attach a lot.</p>
            <div class="gm-tile__actions">
                <a class="btn btn-primary w-100" href="/Seed/ReceiveGrower">Start</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="gm-tile">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--transfer" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Receive Transfer</h2>
            </div>
            <p class="gm-tile__text">Receive seed lots transferred from another elevator/location.</p>
            <div class="gm-tile__actions">
                <a class="btn btn-primary w-100" href="/Seed/ReceiveTransfer">Start</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="gm-tile">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--lab" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Condition / Treat</h2>
            </div>
            <p class="gm-tile__text">Placeholder for cleaning/treating/bagging workflows.</p>
            <div class="gm-tile__actions">
                <a class="btn btn-outline-secondary w-100" href="#" onclick="return false;">Coming soon</a>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 gm-quicklinks">
    <a class="gm-link" href="/">Back to Home</a>
</div>
