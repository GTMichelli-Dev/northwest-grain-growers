@{
    ViewData["Title"] = "Sign In";
    var returnUrl   = (ViewBag.ReturnUrl as string) ?? "/";
    var requirePriv = (int)(ViewBag.RequirePriv ?? 0);
    var denied      = (bool)(ViewBag.Denied ?? false);
    // The fallback URL on a wrong-PIN bounce. The privilege gates are
    // routed: Agvantage (15) → /Updates, OfficeAdmin (14) → /, every
    // other priv (or no priv) → /.
    var fallbackUrl = requirePriv == 15 ? "/Updates" : "/";
    var roleLabel = requirePriv switch
    {
        7  => "Remote Admin",
        14 => "Office Admin",
        15 => "Agvantage",
        _  => "User"
    };
}

<div class="container" style="max-width:420px;margin-top:4rem;">
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="h4 mb-3">Sign In</h1>
            <p class="text-muted small mb-3">
                @if (requirePriv > 0)
                {
                    <text>Enter a PIN with the <strong>@roleLabel</strong> privilege to continue.</text>
                }
                else
                {
                    <text>Enter your PIN to sign in.</text>
                }
            </p>
            @if (denied)
            {
                <div class="alert alert-warning small mb-3">
                    The PIN you entered is valid but does not have the privilege required for that page.
                </div>
            }

            <div class="mb-2">
                <label class="form-label">PIN <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="acPinInput"
                       inputmode="numeric" maxlength="10" placeholder="Enter PIN"
                       autocomplete="off" data-lpignore="true" data-1p-ignore="true"
                       style="-webkit-text-security:disc;" />
            </div>

            <div id="acPinError" class="text-danger small mt-2" hidden></div>

            <div class="d-flex gap-2 mt-3">
                <button type="button" class="btn btn-primary" id="acPinConfirmBtn">Sign In</button>
                <a href="@fallbackUrl" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            var $err   = document.getElementById('acPinError');
            var $input = document.getElementById('acPinInput');
            var $btn   = document.getElementById('acPinConfirmBtn');
            var returnUrl   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(returnUrl));
            var fallbackUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(fallbackUrl));
            var requirePriv = @requirePriv;

            function showError(msg) { $err.textContent = msg; $err.removeAttribute('hidden'); }
            function clearError()   { $err.textContent = '';  $err.setAttribute('hidden', 'hidden'); }

            async function submit() {
                clearError();
                var pin = parseInt($input.value, 10);
                if (!pin || pin <= 0) { showError('A valid PIN is required.'); return; }

                $btn.disabled = true;
                try {
                    var body = { Pin: pin };
                    if (requirePriv > 0) body.RequirePriv = requirePriv;

                    var resp = await fetch('/api/Auth/Login', {
                        method:  'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body:    JSON.stringify(body),
                    });
                    if (!resp.ok) {
                        var detail = '';
                        try { var j = await resp.json(); detail = j.message || ''; } catch (e) {}
                        if (resp.status === 401 && requirePriv === 15) {
                            // Agvantage gate has its own bounce-on-fail
                            // contract — keep that behavior so muscle
                            // memory still works for the Updates flow.
                            showError(detail || 'PIN rejected — returning…');
                            setTimeout(function () { window.location.href = fallbackUrl; }, 1200);
                            return;
                        }
                        showError(detail || 'PIN rejected.');
                        return;
                    }
                    window.location.href = returnUrl || '/';
                } catch (ex) {
                    showError('Network error: ' + ex.message);
                } finally {
                    $btn.disabled = false;
                }
            }

            $btn.addEventListener('click', submit);
            $input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); submit(); }
            });
            setTimeout(function () { $input.focus(); }, 100);
        })();
    </script>
}
