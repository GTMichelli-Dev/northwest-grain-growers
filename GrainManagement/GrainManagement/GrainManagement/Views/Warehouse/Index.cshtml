@inject GrainManagement.Services.ILocationContext LocationContext
@{
    ViewData["Title"] = "Warehouse Dashboard";
}

<link rel="stylesheet" href="~/css/pages/warehouse.dashboard.dx.css" asp-append-version="true" />

<div class="gm-module-bar gm-module-bar--warehouse">
    <span class="gm-module-bar__icon gm-icon gm-icon--warehouse" aria-hidden="true"></span>
    <span class="gm-module-bar__label">WAREHOUSE</span>
</div>

<div class="gm-pagehead gm-pagehead--sticky">
    <div class="gm-wdActions" id="wdActions"></div>
</div>

<!-- Shown when no location is selected -->
<div id="gmWdNoLocation" class="gm-wd-nolocation" @(LocationContext.HasLocation ? "hidden" : "")>
    <span class="gm-icon gm-icon--warehouse" aria-hidden="true"></span>
    <p>Select a location above to view the warehouse dashboard.</p>
</div>

<!-- Dashboard content: open weight sheets grid -->
<div id="gmWdContent" class="gm-wd-content" data-location-id="@(LocationContext.HasLocation ? LocationContext.LocationId : 0)" @(LocationContext.HasLocation ? "" : "hidden")>
    <div class="gm-wd-panel">
        <div class="gm-wd-panel__title">Open Weight Sheets</div>
        <div id="wdOpenWsGrid"></div>
    </div>
</div>

<script src="~/js/pages/warehouse.dashboard.dx.js" asp-append-version="true"></script>
