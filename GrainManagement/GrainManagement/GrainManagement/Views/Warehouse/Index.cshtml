@{
    ViewData["Title"] = "Warehouse";
}

<div class="gm-pagehead gm-pagehead--sticky">
    <div class="gm-pagehead__left">
        <div class="gm-pagehead__title">
            <span class="gm-pagehead__icon gm-icon gm-icon--warehouse" aria-hidden="true"></span>
            <h2>Warehouse</h2>
        </div>
    </div>

    <!-- ✅ NEW: Mode buttons between title and location -->
    <div class="gm-pagehead__modes" role="group" aria-label="Warehouse load type">
        <button type="button" class="gm-modebtn" data-mode="intake">Intake</button>
        <button type="button" class="gm-modebtn" data-mode="transfer">Transfer</button>
        <button type="button" class="gm-modebtn" data-mode="outbound">Outbound</button>
      @*   <button type="button" class="gm-modebtn" data-mode="kiosk">Kiosk</button> *@
       
    </div>

    <div class="gm-pagehead__right gm__Location">
        <label class="gm-loc-label" for="gmLocationSelect">Location</label>
        <select id="gmLocationSelect" class="form-select gm-loc-select" style="min-width: 340px;">
            <option value="">Loading…</option>
        </select>
    </div>
</div>

<div id="gmNoLocationSet" class="pt-3" style="display:none;">
    <h3 class="text-danger mb-0">Select Location To Continue</h3>
</div>

<!-- ✅ NEW: Default prompt when location is set but no mode chosen -->
<div id="gmNoModeSet" class="pt-3" style="display:none;">
    <h3 class="text-danger mb-0">Please select a load type</h3>
</div>

<!-- ✅ Shell that will receive partial HTML -->
<div id="gmWsShell" style="display:none;"></div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/pages/warehouse.signalr.js" asp-append-version="true"></script>
    <script src="~/js/pages/warehouse.location.js" asp-append-version="true"></script>
    <script src="~/js/pages/warehouse.index.js" asp-append-version="true"></script>
}
