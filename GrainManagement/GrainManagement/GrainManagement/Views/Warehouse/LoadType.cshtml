@{
    ViewData["Title"] = "New WeightSheet";
}

<a href="/WeightSheets" class="gm-module-bar gm-module-bar--warehouse gm-module-bar--link" title="Back to Weight Sheets">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--warehouse" aria-hidden="true"></span>
    <span class="gm-module-bar__label">NEW WEIGHTSHEET</span>
</a>

<!-- ── Step 1: Seed or Warehouse ─────────────────────────────────── -->
<div id="ltStep1">
    <h3 class="text-center mt-4 mb-3 fw-semibold" style="font-size:2rem;">Seed or Warehouse?</h3>
    <div class="row g-4 justify-content-center">
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--warehouse" href="#" data-lot-type="warehouse">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--warehouse" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Warehouse</h2>
                </div>
                <p class="gm-tile__text">Warehouse receiving lot</p>
            </a>
        </div>
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--seed" href="#" data-lot-type="seed">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--seed" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Seed</h2>
                </div>
                <p class="gm-tile__text">Seed receiving lot</p>
            </a>
        </div>
    </div>
    <div class="row g-4 justify-content-center mt-1">
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--cancel" href="/WeightSheets" id="ltCancelStep1">
                <div class="gm-tile__header">
                    <h2 class="gm-tile__title">Cancel</h2>
                </div>
                <p class="gm-tile__text">Return to weight sheets</p>
            </a>
        </div>
    </div>
</div>

<!-- ── Step 2: Grower Delivery or Transfer ───────────────────────── -->
<div id="ltStep2" hidden>
    <h3 class="text-center mt-4 mb-3 fw-semibold" style="font-size:2rem;">Select Weight Sheet Type</h3>
    <div class="row g-4 justify-content-center">
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--intake" href="#" data-ws-type="delivery">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--delivery" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Grower Delivery</h2>
                </div>
                <p class="gm-tile__text">Inbound from a grower</p>
            </a>
        </div>
        <div class="col-12 col-lg-4">
            <a id="ltTransferTile" class="gm-tile gm-tile--link gm-tile--transfer" href="#" data-ws-type="transfer">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--transfer gm-icon--flip" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Transfer</h2>
                </div>
                <p class="gm-tile__text">Inbound from another location</p>
            </a>
        </div>
    </div>
    <div class="row g-4 justify-content-center mt-1">
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--cancel" href="#" id="ltBackToStep1">
                <div class="gm-tile__header">
                    <h2 class="gm-tile__title">Cancel</h2>
                </div>
                <p class="gm-tile__text">Return to lot type selection</p>
            </a>
        </div>
    </div>
</div>

<!-- Authenticated user display -->
<div id="ltAuthInfo" class="text-center mt-3 text-muted" hidden></div>

<!-- PIN entry uses the shared GM.requestPin modal — see _GmPinPromptModal. -->

@section Scripts {
<script>
(function () {
    'use strict';
    var _lotType = null;   // 'seed' or 'warehouse'
    var _wsType = null;    // 'delivery' or 'transfer'
    var _pin = null;
    var _userName = null;

    $(function () {
        // If we arrived from the Move Load flow with a PIN already validated
        // upstream, skip our own PIN modal. The PIN rides through to the
        // next page via the existing pass-through.
        var _urlParams = new URLSearchParams(window.location.search);
        var _urlPin    = parseInt(_urlParams.get('pin'), 10) || 0;
        if (_urlPin > 0) _pin = _urlPin;

        // If launched from the Move Load flow, the back-to-WeightSheets links
        // should instead bounce back to /GrowerDelivery/Index so the operator
        // resumes their move (with the cached PIN, no re-prompt).
        if (_urlParams.get('returnTo') === 'move') {
            var resumeUrl = buildResumeMoveUrl();
            if (resumeUrl) {
                $('a.gm-module-bar[href="/WeightSheets"]').attr('href', resumeUrl);
                $('#ltCancelStep1').attr('href', resumeUrl);
            }
        }

        function buildResumeMoveUrl() {
            var fromWsId = parseInt(_urlParams.get('fromWsId'), 10) || 0;
            var txnId    = parseInt(_urlParams.get('txnId'),    10) || 0;
            if (!fromWsId || !txnId) return null;
            var qs = new URLSearchParams();
            qs.set('wsId',        String(fromWsId));
            qs.set('txnId',       String(txnId));
            qs.set('resumeMove',  '1');
            if (_pin) qs.set('pin', String(_pin));
            return '/GrowerDelivery/Index?' + qs.toString();
        }

        // ── Step 1: Lot type selection ──────────────────────────────
        $('#ltStep1 [data-lot-type]').on('click', function (e) {
            e.preventDefault();
            _lotType = $(this).data('lot-type');
            // Re-flavor the Transfer tile so its border / glow / icon match
            // the lot type the operator just picked.
            var $t = $('#ltTransferTile');
            $t.removeClass('gm-tile--transfer gm-tile--transfer-seed gm-tile--transfer-warehouse')
              .addClass(_lotType === 'seed' ? 'gm-tile--transfer-seed' : 'gm-tile--transfer-warehouse');
            $('#ltStep1').attr('hidden', '');
            $('#ltStep2').removeAttr('hidden');
        });

        // ── Step 2: Weight sheet type selection ─────────────────────
        $('#ltStep2 [data-ws-type]').on('click', function (e) {
            e.preventDefault();
            _wsType = $(this).data('ws-type');

            if (_pin) {
                // PIN already validated upstream — skip the modal and go
                // straight to navigation.
                navigateForward();
                return;
            }

            GM.requestPin({ prompt: 'Enter your PIN to create a new weight sheet.' })
                .then(function (result) {
                    _pin = result.pin;
                    _userName = result.userName;
                    navigateForward();
                })
                .catch(function () { /* cancelled — stay on step 2 */ });
        });

        // Build the next-page URL and navigate. Used by both the in-modal
        // PIN flow and the upstream-validated PIN shortcut.
        function navigateForward() {
            var ctxParams = new URLSearchParams(window.location.search);
            var passThrough = '';
            ['returnTo', 'txnId', 'fromWsId'].forEach(function (k) {
                var v = ctxParams.get(k);
                if (v) passThrough += '&' + k + '=' + encodeURIComponent(v);
            });

            var url;
            if (_wsType === 'delivery') {
                url = '/GrowerDelivery/NewWeightSheet?pin=' + _pin + '&lotType=' + _lotType + passThrough;
            } else {
                url = '/WeightSheets/Transfer?pin=' + _pin + '&lotType=' + _lotType + passThrough;
            }
            window.location.href = url;
        }

        // ── Cancel button: Step 2 → Step 1 ──────────────────────────
        $('#ltBackToStep1').on('click', function (e) {
            e.preventDefault();
            _lotType = null;
            $('#ltStep2').attr('hidden', '');
            $('#ltStep1').removeAttr('hidden');
        });

        // PIN validation is handled by the shared GM.requestPin in the
        // step-2 click above.
    });
})();
</script>
}
