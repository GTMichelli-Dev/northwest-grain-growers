@* _NewIntakeTruck.cshtml *@

<div class="gm-newtruck">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <div class="gm-newtruck__title">New Intake Truck</div>
    </div>

    <div class="row g-2 gm-newtruck__split">
    

        @* LEFT: Scale + actions (desktop right, mobile second) *@
        <div class="col-12 col-lg-6 order-1">
            <div class="gm-scaleBox gm-scaleBox--ok" id="gmScaleBox">
                <div class="gm-scaleBox__line">
                    <button type="button"
                            class="btn btn-outline-primary gm-scaleBox__pickBtn"
                            id="btnPickScale">
                        Choose Scale
                    </button>

                    <div class="gm-scaleBox__name" id="gmScaleName">No scale selected</div>

                    <div class="gm-scaleBox__status" id="gmScaleStatus">—</div>

                    <div class="gm-scaleBox__weightPill" id="gmScaleWeightPill">
                        <span class="gm-scaleBox__weightVal" id="gmScaleWeight">0</span>
                        <span class="gm-scaleBox__uom">lbs</span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-success" id="btnSaveNewTruck">
                        Save
                    </button>

                    @* Print button (same pattern as KioskCamera) *@
                    <button type="button"
                            class="btn btn-warning gm-btnPrint"
                            id="btnPrintTicket"
                            data-ticket=""
                            data-device-id="">
                        Print
                    </button>
                </div>
            </div>
        </div>
        @* RIGHT: Cameras (desktop left, mobile first) *@
        <div class="col-12 col-lg-6 order-2">
            <div class="gm-camPanel d-none" id="gmNewTruckCams">
                <div class="gm-camStack">

                    @* Kiosk (top) *@
                    <div class="gm-camCard">
                        <div class="gm-camCard__head">
                            <div class="gm-camCard__title">Kiosk</div>
                            <div class="gm-camCard__status" id="gmCamStatusKiosk">—</div>
                        </div>
                        <video id="gmCamKiosk" class="gm-camCard__video" autoplay muted playsinline></video>
                    </div>

                    @* BOL *@
                    <div class="gm-camCard">
                        <div class="gm-camCard__head">
                            <div class="gm-camCard__title">BOL</div>
                            <div class="gm-camCard__status" id="gmCamStatusBol">—</div>
                        </div>
                        <video id="gmCamBol" class="gm-camCard__video" autoplay muted playsinline></video>
                    </div>

                    @* Scale *@
                    <div class="gm-camCard">
                        <div class="gm-camCard__head">
                            <div class="gm-camCard__title">Scale</div>
                            <div class="gm-camCard__status" id="gmCamStatusScale">—</div>
                        </div>
                        <video id="gmCamScale" class="gm-camCard__video" autoplay muted playsinline></video>
                    </div>

                    <div class="text-muted small">
                        Tip: tap/click a video to go full screen.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Pick Scale Modal -->
<div class="modal fade" id="pickScaleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Select Scale</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="gm-scalePicker">

                    <button type="button" class="btn btn-outline-secondary w-100 mb-2" id="btnManualScale">
                        Manual Weight Entry
                    </button>

                    <div class="gm-scalePicker__divider">or choose a scale</div>

                    <div class="gm-scalePicker__listWrap">
                        <div class="gm-scalePicker__list" id="gmScaleList">
                            <!-- populated by JS -->
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<!-- Manual Weight Modal -->
<div class="modal fade" id="manualWeightModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Enter Manual Weight</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <label class="form-label fw-bold" for="manualWeightInput">Weight (1 - 1000000)</label>
                <input class="form-control"
                       id="manualWeightInput"
                       type="number"
                       min="1"
                       max="1000000"
                       step="1"
                       inputmode="numeric" />

                <div class="text-danger mt-2 d-none" id="manualWeightError">
                    Please enter a number from 1 to 1000000.
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnManualWeightOk">OK</button>
            </div>

        </div>
    </div>
</div>
