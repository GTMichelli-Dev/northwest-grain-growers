@model IEnumerable<GrainManagement.Controllers.CameraController.CameraDef>
@{
    ViewData["Title"] = "Cameras";
}

<div class="gm-module-bar gm-module-bar--system">
    <span class="gm-module-bar__icon gm-icon gm-icon--camera" aria-hidden="true"></span>
    <span class="gm-module-bar__label">CAMERAS</span>
</div>

<div class="gm-pagehead">
    <div class="gm-pagehead__title">
        <span class="gm-pagehead__icon gm-icon gm-icon--camera" aria-hidden="true"></span>
        <h1 class="gm-tile__title" style="font-size:20px">Cameras</h1>
    </div>
</div>

<div class="pt-3 gm-camera-container">
    <div class="list-group">
        @foreach (var cam in Model)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <div class="fw-bold">@cam.Name</div>
                    <small class="text-muted">@cam.Id</small>
                </div>
                <div class="d-flex gap-2">
                    <div class="gm-cam-btn-view" data-href="/Camera/View/@cam.Id"></div>
                    <div class="gm-cam-btn-pop" data-href="/Camera/View/@cam.Id?pop=true"></div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $(".gm-cam-btn-view").each(function () {
            var href = $(this).data("href");
            $(this).dxButton({
                text: "View",
                icon: "video",
                stylingMode: "outlined",
                type: "default",
                onClick: function () { window.location.href = href; }
            });
        });
        $(".gm-cam-btn-pop").each(function () {
            var href = $(this).data("href");
            $(this).dxButton({
                text: "Pop Out",
                icon: "export",
                stylingMode: "outlined",
                type: "default",
                onClick: function () { window.open(href, "_blank"); }
            });
        });
    });
</script>
}
