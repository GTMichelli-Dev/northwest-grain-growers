@{
    ViewData["Title"] = "Cameras";
}

<a href="/" class="gm-module-bar gm-module-bar--system gm-module-bar--link" title="Back to Home">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--camera" aria-hidden="true"></span>
    <span class="gm-module-bar__label">CAMERAS</span>
</a>

<div class="gm-pagehead">
    <div class="gm-pagehead__title">
        <span class="gm-pagehead__icon gm-icon gm-icon--camera" aria-hidden="true"></span>
        <h1 class="gm-tile__title" style="font-size:20px">Cameras</h1>
    </div>
    <div class="gm-pagehead__right">
        <span id="cam-status-pill" class="badge bg-secondary">Loading…</span>
    </div>
</div>

<div class="pt-3 gm-camera-container">
    <div id="cam-list" class="list-group"></div>
    <div id="cam-empty" class="alert alert-info d-none mt-3">
        No camera services connected. Start the CameraService process on a host with cameras configured.
    </div>
</div>

@section Scripts {
<script src="~/lib/signalr/signalr.min.js"></script>
<script>
    (function () {
        const $list  = document.getElementById('cam-list');
        const $empty = document.getElementById('cam-empty');
        const $pill  = document.getElementById('cam-status-pill');

        function render(cams) {
            $list.innerHTML = '';
            if (!cams || !cams.length) {
                $empty.classList.remove('d-none');
                $pill.textContent = '0 cameras';
                $pill.className = 'badge bg-secondary';
                return;
            }
            $empty.classList.add('d-none');
            $pill.textContent = cams.length + ' camera' + (cams.length === 1 ? '' : 's');
            $pill.className = 'badge bg-success';

            cams.forEach(function (c) {
                const row = document.createElement('div');
                row.className = 'list-group-item d-flex justify-content-between align-items-center';
                const left = document.createElement('div');
                left.innerHTML =
                    '<div class="fw-bold">' + escapeHtml(c.DisplayName) + '</div>' +
                    '<small class="text-muted">' +
                        escapeHtml(c.ServiceId) + ' / ' + escapeHtml(c.CameraId) +
                        (c.CameraBrand ? ' &middot; ' + escapeHtml(c.CameraBrand) : '') +
                        (c.Active ? '' : ' &middot; <span class="text-danger">inactive</span>') +
                    '</small>';
                const right = document.createElement('div');
                right.className = 'd-flex gap-2';
                const viewBtn = document.createElement('a');
                viewBtn.className = 'btn btn-outline-primary btn-sm';
                viewBtn.textContent = 'View';
                viewBtn.href = '/Camera/View/' + encodeURIComponent(c.ServiceId) + '/' + encodeURIComponent(c.CameraId);
                const popBtn = document.createElement('a');
                popBtn.className = 'btn btn-outline-secondary btn-sm';
                popBtn.textContent = 'Pop out';
                popBtn.target = '_blank';
                popBtn.rel = 'noopener';
                popBtn.href = viewBtn.href + '?pop=true';
                right.appendChild(viewBtn);
                right.appendChild(popBtn);
                row.appendChild(left);
                row.appendChild(right);
                $list.appendChild(row);
            });
        }

        function load() {
            fetch('/api/cameras', { cache: 'no-store' })
                .then(r => r.json())
                .then(render)
                .catch(() => { $pill.textContent = 'error'; $pill.className = 'badge bg-danger'; });
        }

        function escapeHtml(s) {
            if (s == null) return '';
            return String(s).replace(/[&<>"']/g, c => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
            }[c]));
        }

        // Live updates — refresh when services connect/disconnect or announce
        const conn = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/camera')
            .withAutomaticReconnect()
            .build();
        conn.on('ServiceConnected', load);
        conn.on('ServiceDisconnected', load);
        conn.on('CamerasAnnounced', load);
        conn.start().catch(function () { /* SignalR optional — REST still polls below */ });

        load();
        setInterval(load, 15000);
    })();
</script>
}
