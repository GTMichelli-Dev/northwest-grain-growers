@{
    ViewData["Title"] = "Intake Weight Sheets — Warehouse Admin";
}

<a href="/WarehouseAdmin" class="gm-module-bar gm-module-bar--intake gm-module-bar--link" title="Back to Warehouse Administration">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--delivery" aria-hidden="true"></span>
    <span class="gm-module-bar__label">INTAKE WEIGHT SHEETS</span>
</a>

<div class="row g-4 mt-2">

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--intake" href="/WarehouseAdmin/WeightSheets">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--weightsheet" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Weight Sheets</h2>
            </div>
            <p class="gm-tile__text">Review, edit, and manage intake weight sheets across all locations.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--lots" href="/WarehouseAdmin/Lots">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--pallet" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Lots</h2>
            </div>
            <p class="gm-tile__text">View and manage inventory lots across all locations.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--load" href="/WarehouseAdmin/Loads">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--load" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Loads</h2>
            </div>
            <p class="gm-tile__text">View and correct individual intake load records, weights, grading, and bin assignments.</p>
        </a>
    </div>

</div>
