@{
    ViewData["Title"] = "Transfer Weight Sheets — Warehouse Admin";
}

<a href="/WarehouseAdmin" class="gm-module-bar gm-module-bar--transfer gm-module-bar--link" title="Back to Warehouse Administration">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--transfer" aria-hidden="true"></span>
    <span class="gm-module-bar__label">TRANSFER WEIGHT SHEETS</span>
</a>

<div class="row g-4 mt-2">

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--transfer" href="/WarehouseAdmin/TransferWeightSheets">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--weightsheet" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Transfer Weight Sheets</h2>
            </div>
            <p class="gm-tile__text">Review and manage elevator-to-elevator transfer weight sheets.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--load" href="/WarehouseAdmin/TransferLoads">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-tile__icon--bold gm-icon gm-icon--load" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Loads</h2>
            </div>
            <p class="gm-tile__text">View and correct individual transfer load records and weights.</p>
        </a>
    </div>

</div>
