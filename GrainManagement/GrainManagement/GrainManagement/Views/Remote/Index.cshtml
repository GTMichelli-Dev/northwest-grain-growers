@model IEnumerable<GrainManagement.Controllers.RemoteController.RemoteDef>
@{
    ViewData["Title"] = "Remote Access";
}

<div class="gm-module-bar gm-module-bar--remote">
    <span class="gm-module-bar__icon gm-icon gm-icon--remote" aria-hidden="true"></span>
    <span class="gm-module-bar__label">REMOTE</span>
</div>

<div class="pt-3 gm-remote-container">
    <div class="list-group w-100" style="max-width:500px;">
        @foreach (var rem in Model)
        {
            <div class="list-group-item d-flex justify-content-center align-items-center">
                <a class="btn btn-primary w-100" href="@rem.Url" target="_blank" rel="noopener">@rem.Name</a>
            </div>
        }
    </div>
</div>
