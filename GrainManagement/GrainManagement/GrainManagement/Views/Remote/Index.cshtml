@{
    ViewData["Title"] = "Remote Access";
}

<a href="/" class="gm-module-bar gm-module-bar--remote gm-module-bar--link" title="Back to Home">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--remote" aria-hidden="true"></span>
    <span class="gm-module-bar__label">REMOTE</span>
</a>

<div class="card mt-3">
    <div class="card-body">
        <div class="d-flex flex-wrap align-items-end gap-3 mb-3">
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-district">District</label>
                <select id="rb-district" class="form-select form-select-sm" style="min-width:13rem;">
                    <option value="0">All Locations</option>
                </select>
            </div>
        </div>

        <div id="rb-list">
            <div class="text-muted small">Loading…</div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/remote.index.js" asp-append-version="true"></script>
}
