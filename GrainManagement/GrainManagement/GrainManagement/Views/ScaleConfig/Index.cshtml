@{
    ViewData["Title"] = "Scale Configuration";
}
@inject IModuleContext Modules

@if (Modules.IsCentral)
{
    <a href="@Url.Action("Index", "Admin")" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Admin">
        <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
        <span class="gm-module-bar__icon gm-icon gm-icon--scale" aria-hidden="true"></span>
        <span class="gm-module-bar__label">SCALE CONFIGURATION</span>
    </a>
}
else
{
    <a href="/System" class="gm-module-bar gm-module-bar--system gm-module-bar--link" title="Back to System">
        <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
        <span class="gm-module-bar__icon gm-icon gm-icon--scale" aria-hidden="true"></span>
        <span class="gm-module-bar__label">SCALE CONFIGURATION</span>
    </a>
}

<div class="gm-pagehead gm-pagehead--sticky">
</div>

<!-- Status bar -->
<div id="serviceStatusBar" class="alert alert-warning py-2 mb-3 d-flex align-items-center">
    <i class="dx-icon dx-icon-refresh dx-icon-spin me-2"></i> Checking scale services...
</div>

<!-- Toast container -->
<div id="toastContainer" style="position:fixed;top:70px;right:20px;z-index:9999;min-width:350px;max-width:500px;"></div>

<!-- Services container (cards built dynamically) -->
<div id="servicesContainer"></div>

<!-- No services message -->
<div id="noServicesMessage" class="text-center text-muted py-5" style="display:none;">
    <span class="gm-icon gm-icon--scale" style="font-size:3rem;" aria-hidden="true"></span>
    <h5 class="mt-3">No Scale Services Connected</h5>
    <p>Start a Scale Reader Service and point it to this server's SignalR hub.</p>
</div>

<!-- Add/Edit Scale Modal -->
<div class="modal fade" id="scaleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="scaleModalTitle">Add Scale</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalServiceId" />
                <input type="hidden" id="modalMode" value="add" />
                <input type="hidden" id="modalOriginalScaleId" />
                <div class="mb-2">
                    <label class="form-label mb-0 small fw-bold">Description</label>
                    <input type="text" class="form-control form-control-sm" id="fldDescription" placeholder="e.g. Truck Scale 1" />
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0 small fw-bold">Location</label>
                    <select class="form-select form-select-sm" id="fldLocation">
                        <option value="">-- Select Location --</option>
                    </select>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <label class="form-label mb-0 small">Brand / Protocol</label>
                        <select class="form-select form-select-sm" id="fldBrand">
                            <option value="SMA">SMA (Generic)</option>
                            <option value="Rice_Lake">Rice Lake</option>
                            <option value="Avery_Weigh_Tronix">Avery Weigh-Tronix</option>
                            <option value="Cardinal">Cardinal</option>
                        </select>
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <label class="form-label mb-0 small">IP Address</label>
                        <input type="text" class="form-control form-control-sm" id="fldIpAddress" placeholder="Enter IP Address Of Scale" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Port</label>
                        <input type="number" class="form-control form-control-sm" id="fldPort" value="0" min="0" max="65535" />
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0 small">Request Command</label>
                    <input type="text" class="form-control form-control-sm" id="fldRequestCommand" placeholder="W\r\n (leave blank for brand default)" />
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0 small">Encoding</label>
                    <select class="form-select form-select-sm" id="fldEncoding">
                        <option value="ascii">ASCII</option>
                        <option value="utf-8">UTF-8</option>
                    </select>
                </div>
                <div class="mb-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="fldEnabled" checked />
                        <label class="form-check-label" for="fldEnabled">Enabled</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnSaveScale">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Live Weight Test Modal -->
<div class="modal fade" id="liveWeightModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Live Weight &mdash; <span id="liveWeightScaleName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div style="background-color:#000;border-radius:16px;padding:20px 40px;max-width:500px;margin:0 auto;">
                    <div style="font-family:'Courier New',monospace;font-size:clamp(2.5rem,5vw,4rem);font-weight:bold;color:#0f0;text-align:right;letter-spacing:4px;white-space:nowrap;">
                        <span id="liveWeightValue">0</span>
                        <span style="font-size:2rem;color:#0a0;margin-left:10px;" id="liveWeightUnit">lb</span>
                    </div>
                    <div id="liveWeightStatus" style="font-size:1.2rem;font-weight:bold;text-align:center;letter-spacing:2px;min-height:1.4em;margin-top:8px;"></div>
                </div>
                <div class="mt-3 text-start">
                    <a class="small text-muted" data-bs-toggle="collapse" href="#rawDiag" role="button"><i class="dx-icon dx-icon-info"></i> Diagnostic</a>
                    <div class="collapse mt-1" id="rawDiag">
                        <div class="bg-dark text-light p-2 rounded" style="font-family:'Courier New',monospace;font-size:12px;">
                            <div>Raw: <span id="diagRaw" style="color:#0f0;">--</span></div>
                            <div>Parsed: <span id="diagParsed" style="color:#ff0;">--</span></div>
                            <div>Status: <span id="diagStatus" style="color:#0f0;">--</span></div>
                            <div>Ok: <span id="diagOk" style="color:#ff0;">--</span></div>
                            <div>Motion: <span id="diagMotion" style="color:#ff0;">--</span></div>
                            <div>Last Update: <span id="diagLastUpdate" style="color:#888;">--</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .service-card { margin-bottom: 1rem; }
        .service-card .card-header { display: flex; justify-content: space-between; align-items: center; }
        .service-card .badge-connected { background-color: #28a745; }
        .service-card .badge-disconnected { background-color: #dc3545; }
        .scale-table th, .scale-table td { vertical-align: middle; font-size: 0.875rem; }
    </style>
}

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/pages/scaleconfig.index.js" asp-append-version="true"></script>
}
