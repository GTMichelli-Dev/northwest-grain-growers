@{
    ViewData["Title"] = "Scales";
}

<div class="scales-container">
    <h1>Scales</h1>

    <div id="connStatus" class="mb-2">Connecting…</div>

    <div class="table-responsive">
        <table class="table table-striped table-sm" id="scalesTable">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Description</th>
                    <th>Weight</th>
                    <th>Ok</th>
                    <th>Motion</th>
                    <th>Status</th>
                    <th>Last Update (UTC)</th>
                </tr>
            </thead>
            <tbody id="scalesBody">
                <tr><td colspan="7">Loading…</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/scales.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/pages/scales.index.js" asp-append-version="true"></script>
}
