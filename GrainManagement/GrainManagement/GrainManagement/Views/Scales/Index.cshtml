@{
    ViewData["Title"] = "Scales";
}

<div class="gm-module-bar gm-module-bar--system">
    <span class="gm-module-bar__icon gm-icon gm-icon--scale" aria-hidden="true"></span>
    <span class="gm-module-bar__label">SCALES</span>
</div>

<div class="gm-pagehead">
    <div class="gm-pagehead__title">
        <span class="gm-pagehead__icon gm-icon gm-icon--scale" aria-hidden="true"></span>
        <h1 class="gm-tile__title" style="font-size:20px">Scales</h1>
    </div>
    <div class="gm-pagehead__actions">
        <a href="/ScaleConfig" class="btn btn-sm btn-outline-secondary"><i class="dx-icon dx-icon-preferences"></i> Configure</a>
    </div>
</div>

<div class="scales-container">

    <div id="connStatus" class="mb-2">Connecting…</div>

    <div class="table-responsive">
        <table class="table table-striped table-sm" id="scalesTable">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Location</th>
                    <th>Description</th>
                    <th>Weight</th>
                    <th>Ok</th>
                    <th>Motion</th>
                    <th>Status</th>
                    <th>Last Update (UTC)</th>
                </tr>
            </thead>
            <tbody id="scalesBody">
                <tr><td colspan="8">Loading…</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/scales.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/pages/scales.index.js" asp-append-version="true"></script>
}
