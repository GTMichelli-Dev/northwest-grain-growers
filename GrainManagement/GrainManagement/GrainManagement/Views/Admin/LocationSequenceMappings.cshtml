@{
    ViewData["Title"] = "Location Sequence Mappings";
}

<style>
    .lsm-container {
        width: 50%;
        margin: 0 auto;
    }
    @@media (max-width: 991.98px) {
        .lsm-container {
            width: 100%;
        }
    }
</style>

<a href="@Url.Action("Index", "Admin")" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Admin">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--locations" aria-hidden="true"></span>
    <span class="gm-module-bar__label">LOCATION SEQUENCE MAPPINGS</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky">
</div>

<div id="lsmAlert" hidden role="alert"></div>

<div class="gm-gd lsm-container">
    <div class="gm-gd-section">
        <div class="gm-gd-section__title">Location Sequence Mappings</div>
        <div id="lsmGrid"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/admin.locationsequencemappings.js" asp-append-version="true"></script>
}
