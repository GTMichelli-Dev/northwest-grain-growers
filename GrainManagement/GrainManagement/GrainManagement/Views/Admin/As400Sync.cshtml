@{
    ViewData["Title"] = "AS400 Sync";
}

<a href="/Updates" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Updates">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--settings" aria-hidden="true"></span>
    <span class="gm-module-bar__label">AS400 SYNC</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky"></div>

<div class="gm-gd">
    <div class="gm-gd-section">
        <div class="gm-gd-section__title d-flex align-items-center justify-content-between">
            <span>
                AS400 Sync
                <span id="as400-version" class="text-muted small ms-2"></span>
            </span>
            <span id="as400-conn" class="badge bg-secondary">Connecting...</span>
        </div>

        <p class="text-muted mb-3">
            Pull updates from Agvantage on demand. Auto-update is disabled; clicking
            a button below triggers exactly one run for that data set. Only one job
            can run at a time.
        </p>

        <div class="d-flex flex-wrap gap-2 mb-3">
            <button type="button" class="btn btn-primary" id="as400-btn-accounts" disabled>
                <i class="dx-icon dx-icon-user me-1"></i>
                Sync Accounts
            </button>
            <button type="button" class="btn btn-primary" id="as400-btn-products" disabled>
                <i class="dx-icon dx-icon-product me-1"></i>
                Sync Items
            </button>
            <button type="button" class="btn btn-primary" id="as400-btn-splitgroups" disabled>
                <i class="dx-icon dx-icon-group me-1"></i>
                Sync Split Groups
            </button>
        </div>

        <div class="card">
            <div class="card-header py-2">
                <strong>Status</strong>
                <span id="as400-status-job" class="ms-2 text-muted"></span>
            </div>
            <div class="card-body py-3">
                <div id="as400-status-stage" class="fw-semibold mb-1">Idle.</div>
                <div id="as400-status-message" class="text-muted small mb-2">
                    Service not connected.
                </div>

                <div class="progress" style="height: 10px;">
                    <div id="as400-progress-bar"
                         class="progress-bar"
                         role="progressbar"
                         style="width: 0%; transition: width 0.25s ease-out;"></div>
                </div>

                <div class="d-flex justify-content-between mt-1 small text-muted">
                    <span id="as400-status-counter">&nbsp;</span>
                    <span id="as400-status-time">&nbsp;</span>
                </div>
            </div>
        </div>

        <details class="mt-3">
            <summary class="text-muted small">Recent activity</summary>
            <pre id="as400-log" class="small mt-2 mb-0"
                 style="max-height: 280px; overflow:auto; background:#f8f9fa; padding:.5rem; border:1px solid #dee2e6;"></pre>
        </details>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            "use strict";

            var SERVICE_ID = "as400sync";

            var elConn       = document.getElementById("as400-conn");
            var elVersion    = document.getElementById("as400-version");
            var elBtnAcc     = document.getElementById("as400-btn-accounts");
            var elBtnProd    = document.getElementById("as400-btn-products");
            var elBtnSplit   = document.getElementById("as400-btn-splitgroups");
            var elJob        = document.getElementById("as400-status-job");
            var elStage      = document.getElementById("as400-status-stage");
            var elMessage    = document.getElementById("as400-status-message");
            var elBar        = document.getElementById("as400-progress-bar");
            var elCounter    = document.getElementById("as400-status-counter");
            var elTime       = document.getElementById("as400-status-time");
            var elLog        = document.getElementById("as400-log");

            var serviceConnected = false;
            var jobRunning       = false;
            var flashTimerId     = null;

            function setConnBadge(state) {
                elConn.classList.remove("bg-secondary", "bg-success", "bg-danger", "bg-warning");
                if (state === "connected") {
                    elConn.textContent = "Service connected";
                    elConn.classList.add("bg-success");
                } else if (state === "disconnected") {
                    elConn.textContent = "Service offline";
                    elConn.classList.add("bg-danger");
                } else if (state === "hub-disconnected") {
                    elConn.textContent = "Hub disconnected";
                    elConn.classList.add("bg-warning");
                } else {
                    elConn.textContent = "Connecting...";
                    elConn.classList.add("bg-secondary");
                }
                refreshButtons();
            }

            function refreshButtons() {
                var disabled = !serviceConnected || jobRunning;
                elBtnAcc.disabled   = disabled;
                elBtnProd.disabled  = disabled;
                elBtnSplit.disabled = disabled;
            }

            function fmtNum(n) {
                if (n === null || n === undefined) return "";
                return Number(n).toLocaleString();
            }

            function appendLog(line) {
                var ts = new Date().toLocaleTimeString();
                elLog.textContent = "[" + ts + "] " + line + "\n" + elLog.textContent;
            }

            function setBar(pct, indeterminate) {
                var clamped = Math.max(0, Math.min(100, pct));
                elBar.style.width = clamped + "%";
                if (indeterminate) {
                    elBar.classList.add("progress-bar-striped", "progress-bar-animated");
                } else {
                    elBar.classList.remove("progress-bar-striped", "progress-bar-animated");
                }
            }

            // After a successful run we fill the bar green for 3 seconds, then
            // drop it back to 0 so the operator gets a clear "done" signal
            // without leaving the bar full forever. Cancelled if another run
            // starts inside the window.
            function clearFlash() {
                if (flashTimerId !== null) {
                    clearTimeout(flashTimerId);
                    flashTimerId = null;
                }
                elBar.classList.remove("bg-success");
            }

            function flashSuccessAndReset() {
                clearFlash();
                setBar(100, false);
                elBar.classList.add("bg-success");
                flashTimerId = setTimeout(function () {
                    flashTimerId = null;
                    elBar.classList.remove("bg-success");
                    setBar(0, false);
                    elCounter.textContent = "";
                }, 3000);
            }

            function applyStatus(s) {
                if (!s) return;
                var stage = s.Stage || s.stage || "";
                var job   = s.Job   || s.job   || "";
                var msg   = s.Message || s.message || "";
                var cur   = s.Current != null ? s.Current : s.current;
                var tot   = s.Total   != null ? s.Total   : s.total;
                var ver   = s.Version || s.version;
                if (ver) elVersion.textContent = "v" + ver;

                elJob.textContent = job ? "(" + job + ")" : "";
                elStage.textContent = stage || "Idle.";
                elMessage.textContent = msg || "";

                // Bar width tracks current/total exactly. When the total
                // isn't known yet (Counting / count query failed), show an
                // animated striped bar so the user sees motion without a
                // misleading numeric position.
                var counterText = "";
                var hasTotal = (tot != null && Number(tot) > 0);
                var curN = (cur != null) ? Number(cur) : 0;
                var totN = hasTotal ? Number(tot) : 0;

                if (stage === "Done") {
                    counterText = hasTotal
                        ? fmtNum(totN) + " of " + fmtNum(totN) + " records upserted"
                        : fmtNum(curN) + " records upserted";
                    setBar(100, false);
                } else if (stage === "Error") {
                    counterText = hasTotal
                        ? fmtNum(curN) + " of " + fmtNum(totN) + " records upserted"
                        : (curN > 0 ? fmtNum(curN) + " records upserted" : "");
                    setBar(0, false);
                } else if (hasTotal) {
                    counterText = fmtNum(curN) + " of " + fmtNum(totN) + " records upserted";
                    var pct = (curN / totN) * 100;
                    setBar(pct, false);
                } else if (curN > 0) {
                    // Streaming with unknown total — animated indeterminate.
                    counterText = fmtNum(curN) + " records upserted";
                    setBar(100, true);
                } else {
                    // Idle / connecting / counting — empty animated.
                    counterText = "";
                    setBar(0, stage === "Counting");
                }

                elCounter.textContent = counterText;
                elTime.textContent = new Date().toLocaleTimeString();

                jobRunning = !!stage && stage !== "Idle" && stage !== "Done" && stage !== "Error";
                refreshButtons();
            }

            function setIdle() {
                elJob.textContent = "";
                elStage.textContent = "Idle.";
                elMessage.textContent = serviceConnected
                    ? "Click a button above to start a sync."
                    : "Service not connected.";
                setBar(0, false);
                elCounter.textContent = "";
                elTime.textContent = "";
                jobRunning = false;
                refreshButtons();
            }

            if (typeof signalR === "undefined") {
                elStage.textContent = "SignalR client not loaded.";
                elMessage.textContent = "Cannot establish a hub connection.";
                return;
            }

            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/as400sync")
                .withAutomaticReconnect()
                .build();

            connection.on("ServiceConnected", function (serviceId) {
                if (serviceId === SERVICE_ID) {
                    serviceConnected = true;
                    setConnBadge("connected");
                    appendLog("Service connected: " + serviceId);
                    connection.invoke("RequestSnapshot", SERVICE_ID).catch(function () { });
                }
            });

            connection.on("ServiceDisconnected", function (serviceId) {
                if (serviceId === SERVICE_ID) {
                    serviceConnected = false;
                    setConnBadge("disconnected");
                    setIdle();
                    appendLog("Service disconnected: " + serviceId);
                }
            });

            connection.on("Status", function (s) {
                applyStatus(s);
                if (s) {
                    var line = (s.Job || s.job || "") + " " + (s.Stage || s.stage || "") +
                               (s.Message ? " — " + s.Message : (s.message ? " — " + s.message : ""));
                    appendLog(line.trim());
                }
            });

            connection.on("Completed", function (r) {
                jobRunning = false;
                refreshButtons();
                var job = (r && (r.Job || r.job)) || "";
                var msg = (r && (r.Message || r.message)) || "Completed.";
                elStage.textContent = job + " complete.";
                elMessage.textContent = msg;
                flashSuccessAndReset();
                appendLog("DONE: " + job + " — " + msg);
            });

            connection.on("Error", function (e) {
                jobRunning = false;
                refreshButtons();
                clearFlash();
                var msg = (e && (e.Message || e.message)) || "Sync failed.";
                elStage.textContent = "Error";
                elMessage.textContent = msg;
                setBar(0, false);
                appendLog("ERROR: " + msg);
            });

            connection.onreconnecting(function () { setConnBadge("hub-disconnected"); });
            connection.onreconnected(function () { joinAndProbe(); });
            connection.onclose(function () { setConnBadge("hub-disconnected"); });

            function joinAndProbe() {
                connection.invoke("JoinWatcher")
                    .then(function () { return connection.invoke("GetConnectedServices"); })
                    .then(function (services) {
                        services = services || [];
                        if (services.indexOf(SERVICE_ID) >= 0) {
                            serviceConnected = true;
                            setConnBadge("connected");
                            connection.invoke("RequestSnapshot", SERVICE_ID).catch(function () { });
                        } else {
                            serviceConnected = false;
                            setConnBadge("disconnected");
                            setIdle();
                        }
                    })
                    .catch(function (err) {
                        console.error("AS400 sync hub probe failed", err);
                        setConnBadge("hub-disconnected");
                    });
            }

            function startJob(method) {
                if (!serviceConnected || jobRunning) return;
                clearFlash();
                jobRunning = true;
                refreshButtons();
                elStage.textContent = "Requesting...";
                elMessage.textContent = "Waiting for the AS400 service to start the job.";
                setBar(0, true);
                connection.invoke(method, SERVICE_ID).catch(function (err) {
                    jobRunning = false;
                    refreshButtons();
                    elStage.textContent = "Error";
                    elMessage.textContent = err && err.message ? err.message : "Failed to send command.";
                    appendLog("ERROR sending " + method + ": " + (err && err.message));
                });
            }

            elBtnAcc.addEventListener("click",   function () { startJob("RunAccounts"); });
            elBtnProd.addEventListener("click",  function () { startJob("RunProducts"); });
            elBtnSplit.addEventListener("click", function () { startJob("RunSplitGroups"); });

            connection.start()
                .then(joinAndProbe)
                .catch(function (err) {
                    console.error("AS400 sync hub connect failed", err);
                    setConnBadge("hub-disconnected");
                    elMessage.textContent = "Failed to connect to /hubs/as400sync.";
                });
        })();
    </script>
}
