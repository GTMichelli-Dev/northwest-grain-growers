@{
    ViewData["Title"] = "Account Item Filters";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin.accountitemfilters.css" asp-append-version="true" />
}



<a href="javascript:history.back()" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--filter" aria-hidden="true"></span>
    <span class="gm-module-bar__label">ACCOUNT ITEM FILTERS</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky">
</div>

@* Alert banner *@
<div id="aifAlert" hidden role="alert"></div>
<p class="text-muted text-center">The filters below only allow the grower in the list to bring in the item for the selected location</p>
@* ── Filter / Add panel ────────────────────────────────────────────────────── *@
<div class="gm-aif-card">
    <div class="gm-aif-card__title">Filter &amp; Add</div>

    <div class="gm-aif-filter-row">
        @* Account picker — first *@
        <div class="gm-aif-field">
            <label class="form-label" for="aifAccount">Account</label>
            <div id="aifAccount"></div>
        </div>

        @* Item picker — all warehouse items *@
        <div class="gm-aif-field">
            <label class="form-label" for="aifItem">Item</label>
            <div id="aifItem"></div>
        </div>

        @* Location picker *@
        <div class="gm-aif-field">
            <label class="form-label" for="aifLocation">Licensed Location</label>
            <div id="aifLocation"></div>
        </div>

        @* Action buttons *@
        <div class="gm-aif-field gm-aif-field--actions">
            <button type="button" id="aifAddBtn" class="btn btn-success" disabled>
                Add Filter
            </button>
            <button type="button" id="aifClearBtn" class="btn btn-outline-secondary">
                Clear
            </button>
        </div>
    </div>

    <div id="aifAddError" class="text-danger small mt-2" hidden></div>
</div>

@* ── Results list ─────────────────────────────────────────────────────────── *@
<div class="gm-aif-card " id="aifResultsCard">
    <div class="gm-aif-card__title">
        Current Filters
        <span id="aifCount" class="gm-aif-count"></span>
    </div>

    <div id="aifList"></div>
</div>

@section Scripts {
    <script src="~/js/pages/admin.accountitemfilters.js" asp-append-version="true"></script>
}
