@{
    ViewData["Title"] = "States & Counties";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/admin.statecounties.css" asp-append-version="true" />
}

<a href="@Url.Action("Index", "Admin")" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Admin">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--us-map" aria-hidden="true"></span>
    <span class="gm-module-bar__label">STATES & COUNTIES</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky">
</div>

@* Alert banner *@
<div id="scAlert" hidden role="alert"></div>

@* ── States grid ─────────────────────────────────────────────────────────── *@
<div class="gm-sc-card">
    <div class="gm-sc-card__title">States</div>
    <div id="scStatesGrid"></div>
</div>

@* ── Counties grid ───────────────────────────────────────────────────────── *@
<div class="gm-sc-card" id="scCountiesCard" hidden>
    <div class="gm-sc-card__title">
        Counties for <span id="scStateName" class="gm-sc-state-label"></span>
        <span id="scCountyCount" class="gm-sc-count"></span>
    </div>
    <div id="scCountiesGrid"></div>
</div>

@section Scripts {
    <script src="~/js/pages/admin.statecounties.js" asp-append-version="true"></script>
}
