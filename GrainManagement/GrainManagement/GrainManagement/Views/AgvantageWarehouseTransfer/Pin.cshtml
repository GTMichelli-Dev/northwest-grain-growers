@{
    ViewData["Title"] = "Agvantage";
    var returnUrl = (ViewBag.ReturnUrl as string) ?? "/AgvantageWarehouseTransfer";
}

<div class="container" style="max-width:420px;margin-top:4rem;">
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="h4 mb-3">Agvantage</h1>
            <p class="text-muted small mb-3">
                Enter an Agvantage PIN (privilege 15) to access this page.
                A wrong or missing PIN will return you to the Updates page.
            </p>

            <div class="mb-2">
                <label class="form-label">PIN <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="agPinInput"
                       inputmode="numeric" maxlength="10" placeholder="Enter PIN"
                       autocomplete="off" data-lpignore="true" data-1p-ignore="true"
                       style="-webkit-text-security:disc;" />
            </div>

            <div id="agPinError" class="text-danger small mt-2" hidden></div>

            <div class="d-flex gap-2 mt-3">
                <button type="button" class="btn btn-primary" id="agPinConfirmBtn">Continue</button>
                <a href="/Updates" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            var $err   = document.getElementById('agPinError');
            var $input = document.getElementById('agPinInput');
            var $btn   = document.getElementById('agPinConfirmBtn');
            var returnUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(returnUrl));

            function showError(msg) { $err.textContent = msg; $err.removeAttribute('hidden'); }

            async function submit() {
                var pin = parseInt($input.value, 10);
                if (!pin || pin <= 0) {
                    showError('A valid PIN is required.');
                    // Brief pause so the operator sees the message, then
                    // bounce back to /Updates per the spec.
                    setTimeout(function () { window.location.href = '/Updates'; }, 1200);
                    return;
                }

                $btn.disabled = true;
                try {
                    var resp = await fetch('/api/Auth/ValidateAgvantagePin', {
                        method:  'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body:    JSON.stringify({ Pin: pin }),
                    });
                    if (!resp.ok) {
                        showError('PIN rejected — returning to Updates…');
                        // Server rejected (wrong PIN, no privilege, etc.)
                        // The spec says "if invalid then return to /Updates".
                        setTimeout(function () { window.location.href = '/Updates'; }, 1200);
                        return;
                    }
                    window.location.href = returnUrl || '/AgvantageWarehouseTransfer';
                } catch (ex) {
                    showError('Network error: ' + ex.message);
                    setTimeout(function () { window.location.href = '/Updates'; }, 1500);
                } finally {
                    $btn.disabled = false;
                }
            }

            $btn.addEventListener('click', submit);
            $input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); submit(); }
            });
            setTimeout(function () { $input.focus(); }, 100);
        })();
    </script>
}
