@{
    ViewData["Title"] = "Agvantage Warehouse Transfer";
}

<a href="/Updates" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Updates">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--warehouse" aria-hidden="true"></span>
    <span class="gm-module-bar__label">AGVANTAGE WAREHOUSE TRANSFER</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky"></div>

<div class="gm-gd">
    <div class="gm-gd-section">
        <div class="gm-gd-section__title d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <span>
                Push closed weight sheets to Agvantage
                <span id="awt-version" class="text-muted small ms-2"></span>
            </span>
            <span id="awt-conn" class="badge bg-secondary">Connecting...</span>
        </div>

        <p class="text-muted mb-3">
            Pick a date range, district, and one or more locations. Closed weight
            sheets matching the filter appear in the grid; uncheck any you don't
            want to send. Upload writes one row per intake (with up to 10 split
            accounts) and two rows per transfer (out at source, in at destination)
            into Agvantage's <code>u5siload</code> table.
        </p>

        <div class="row g-2 mb-3 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label mb-0 small">From (Pacific)</label>
                <input type="date" id="awt-from" class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label mb-0 small">To (Pacific)</label>
                <input type="date" id="awt-to" class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label mb-0 small">District</label>
                <select id="awt-district" class="form-select form-select-sm">
                    <option value="">Loading...</option>
                </select>
            </div>
            <div class="col-12 col-md-2">
                <button type="button" id="awt-refresh" class="btn btn-sm btn-outline-primary w-100" disabled>
                    Refresh
                </button>
            </div>
        </div>

        @* Locations selector — collapsible. The JS auto-collapses this
           panel when an upload starts so the status / progress card has
           room without scrolling, and re-expands it on Done / Error. *@
        <div id="awt-locations-section" class="mb-3" hidden>
            <div class="d-flex align-items-center gap-2 mb-1">
                <button type="button"
                        id="awt-loc-toggle"
                        class="btn btn-sm btn-link p-0 text-decoration-none"
                        data-bs-toggle="collapse"
                        data-bs-target="#awt-locations-collapse"
                        aria-expanded="true"
                        aria-controls="awt-locations-collapse">
                    <i class="dx-icon dx-icon-chevrondown" id="awt-loc-toggle-icon" style="margin-right:4px;"></i>
                    <strong class="small">Locations <span id="awt-loc-summary" class="text-muted fw-normal"></span></strong>
                </button>
                <button type="button" id="awt-loc-all" class="btn btn-sm btn-link p-0 ms-2">Select All</button>
                <span class="text-muted">|</span>
                <button type="button" id="awt-loc-none" class="btn btn-sm btn-link p-0">None</button>
            </div>
            <div id="awt-locations-collapse" class="collapse show">
                <div id="awt-locations" class="d-flex flex-wrap gap-3 border rounded p-2" style="max-height:140px; overflow:auto;"></div>
            </div>
        </div>

        <div class="d-flex align-items-center justify-content-between mb-2">
            <strong>Closed Weight Sheets</strong>
            <span id="awt-sheet-summary" class="small text-muted"></span>
        </div>
        <div id="awt-sheet-grid"></div>

        <div class="d-flex justify-content-end mt-3 gap-2 flex-wrap">
            <button type="button" id="awt-upload" class="btn btn-primary" disabled>
                <i class="dx-icon dx-icon-upload me-1"></i>
                Upload selected to Agvantage
            </button>
            <button type="button" id="awt-clear" class="btn btn-outline-danger" title="Clear Last Uploads On Agvantage">
                <i class="dx-icon dx-icon-trash me-1"></i>
                Clear Last Uploads On Agvantage
            </button>
            <button type="button" id="awt-preview" class="btn btn-outline-secondary" disabled
                    title="Preview the selected weight sheets as a single PDF">
                <i class="dx-icon dx-icon-doc me-1"></i>
                Preview PDF
            </button>
        </div>

        <hr />

        <div class="card">
            <div class="card-header py-2">
                <strong>Status</strong>
                <span id="awt-status-job" class="ms-2 text-muted"></span>
            </div>
            <div class="card-body py-3">
                <div id="awt-status-stage" class="fw-semibold mb-1">Idle.</div>
                <div id="awt-status-message" class="text-muted small mb-2">
                    Pick filters above and click Upload to start.
                </div>

                <div class="progress" style="height: 10px;">
                    <div id="awt-progress-bar"
                         class="progress-bar"
                         role="progressbar"
                         style="width: 0%; transition: width 0.25s ease-out;"></div>
                </div>

                <div class="d-flex justify-content-between mt-1 small text-muted">
                    <span id="awt-status-counter">&nbsp;</span>
                    <span id="awt-status-time">&nbsp;</span>
                </div>

                <div id="awt-errors" class="mt-3" hidden>
                    <strong class="small text-danger">Errors</strong>
                    <ul id="awt-errors-list" class="small text-danger mb-0"></ul>
                </div>
            </div>
        </div>

        <details class="mt-3">
            <summary class="text-muted small">Recent activity</summary>
            <pre id="awt-log" class="small mt-2 mb-0"
                 style="max-height: 240px; overflow:auto; background:#f8f9fa; padding:.5rem; border:1px solid #dee2e6;"></pre>
        </details>
    </div>
</div>

@* PDF preview modal — same iframe pattern as the End-Of-Day audit. The
   blob URL is set by the JS Preview button click handler. *@
<div class="modal fade" id="awt-pdf-modal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="height:90vh;">
        <div class="modal-content" style="height:100%;">
            <div class="modal-header py-2 bg-dark text-light">
                <h5 class="modal-title">Selected Weight Sheets</h5>
                <button type="button" class="btn-close btn-close-white" id="awt-pdf-close-x" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0 position-relative" style="background:#222;">
                <div id="awt-pdf-spinner" class="position-absolute top-50 start-50 translate-middle text-light text-center">
                    <div class="spinner-border" role="status"></div>
                    <div class="mt-2">Building PDF...</div>
                </div>
                <iframe id="awt-pdf-iframe" style="width:100%;height:100%;border:0;display:none;background:#fff;"></iframe>
            </div>
            <div class="modal-footer">
                <a href="#" class="btn btn-outline-primary" id="awt-pdf-download" target="_blank" download="WeightSheets.pdf" hidden>
                    <i class="dx-icon dx-icon-download me-1"></i>Download
                </a>
                <button type="button" class="btn btn-secondary" id="awt-pdf-close">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/agvantage.warehouse-transfer.js" asp-append-version="true"></script>
}
