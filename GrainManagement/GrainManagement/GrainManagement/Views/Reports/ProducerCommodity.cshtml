@{
    ViewData["Title"] = "Producer Commodity Report By District";
}

<a href="/Reports" class="gm-module-bar gm-module-bar--reports gm-module-bar--link" title="Back to Reports">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--reports" aria-hidden="true"></span>
    <span class="gm-module-bar__label">PRODUCER COMMODITY REPORT BY DISTRICT</span>
</a>

<div class="card mt-3">
    <div class="card-body">
        <div class="d-flex flex-wrap align-items-end gap-3 mb-3">
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-district">District</label>
                <select id="rb-district" class="form-select form-select-sm" style="min-width:11rem;">
                    <option value="0">All</option>
                </select>
            </div>
            <div>
                <label class="form-label small mb-1 fw-bold">Locations</label>
                <div id="rb-location-tags" style="min-width:18rem;"></div>
            </div>
            <div>
                <label class="form-label small mb-1 fw-bold">Crops</label>
                <div id="rb-crop-tags" style="min-width:14rem;"></div>
            </div>
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-from">Start Date (Pacific)</label>
                <input type="date" id="rb-from" class="form-control form-control-sm" style="width:9.5rem;" />
            </div>
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-to">End Date (Pacific)</label>
                <input type="date" id="rb-to" class="form-control form-control-sm" style="width:9.5rem;" />
            </div>
            <div>
                <button id="rb-pick-producer" type="button" class="btn btn-sm btn-outline-secondary" title="Pick by Primary Account / Split Group">
                    <i class="fa fa-user"></i> Producer…
                </button>
                <span id="rb-producer-summary" class="text-muted small ms-1"></span>
            </div>
            <div>
                <button id="rb-apply" type="button" class="btn btn-sm btn-primary">Apply</button>
            </div>
            <div>
                <input type="search" id="rb-search" class="form-control form-control-sm" placeholder="Search…" style="width:11rem;" />
            </div>
            <div>
                <button id="rb-export" type="button" class="btn btn-sm btn-outline-success">
                    <i class="fa fa-file-excel"></i> Excel
                </button>
            </div>
        </div>

        <div id="rb-grid"></div>
    </div>
</div>

<div class="modal fade" id="rb-producer-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title">Pick a Producer / Split Group</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="small text-muted mb-2">
                    Filter the report to weight sheets whose primary account, primary account id,
                    split group #, or split group description matches what you type below. Leave
                    blank for no producer filter.
                </p>
                <input type="text" id="rb-producer-input" class="form-control" placeholder="Account name, account id, or split group #" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" id="rb-producer-clear">Clear</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="rb-producer-apply" data-bs-dismiss="modal">Use</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/reports.producer-commodity.js" asp-append-version="true"></script>
}
