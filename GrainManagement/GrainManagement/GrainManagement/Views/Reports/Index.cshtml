@using GrainManagement.Reporting
@inject IModuleContext Modules
@{
    ViewData["Title"] = "Reports";
    var reportName = ViewBag.ReportName as string;
}

<a href="/" class="gm-module-bar gm-module-bar--reports gm-module-bar--link" title="Back to Home">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--reports" aria-hidden="true"></span>
    <span class="gm-module-bar__label">REPORTS</span>
</a>

<div class="row mt-3">
    <!-- Report list sidebar -->
    <div class="col-md-3 col-lg-2">
        <h5>Available Reports</h5>

        @if (Modules.IsEnabled("WarehouseIntake") || Modules.IsEnabled("WarehouseAdmin"))
        {
            <h6 class="text-muted mt-3">Warehouse</h6>
            <ul class="list-unstyled">
                <li><a href="/Reports?report=Load Ticket" class="btn btn-sm btn-outline-primary w-100 text-start mb-1">Load Ticket</a></li>
            </ul>
        }

        @if (Modules.IsEnabled("Seed") || Modules.IsEnabled("SeedAdmin"))
        {
            <h6 class="text-muted mt-3">Seed</h6>
            <ul class="list-unstyled">
                <li class="text-muted small">No seed reports yet</li>
            </ul>
        }
    </div>

    <!-- Document Viewer -->
    <div class="col-md-9 col-lg-10">
        @if (!string.IsNullOrEmpty(reportName))
        {
            @(Html.DevExpress().WebDocumentViewer("reportViewer")
                .Height("800px")
                .Bind(reportName))
        }
        else
        {
            <div class="text-center text-muted mt-5" style="font-size: 1.25rem;">
                Select a report from the list to view it.
            </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/viewer.part.bundle.css" />
}

@section Scripts {
    <script src="~/js/viewer.part.bundle.js"></script>
}
