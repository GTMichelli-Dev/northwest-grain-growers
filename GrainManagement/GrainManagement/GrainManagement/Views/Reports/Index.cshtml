@{
    ViewData["Title"] = "Reports";
}

<div class="gm-pagehead">
    <div class="gm-pagehead__title">
        <span class="gm-pagehead__icon gm-icon gm-icon--reports" aria-hidden="true"></span>
        <h1 class="gm-tile__title" style="font-size:20px">Reports</h1>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-12 col-lg-4">
        <div class="gm-tile">
            <div class="gm-tile__header">
                <div class="gm-tile__icon">📈</div>
                <h2 class="gm-tile__title">Daily Totals</h2>
            </div>
            <p class="gm-tile__text">Quick view of intake, outbound, and transfers by location.</p>
            <div class="gm-tile__actions">
                <a class="btn btn-primary w-100" href="/Home/Dashboard">Open</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="gm-tile">
            <div class="gm-tile__header">
                <div class="gm-tile__icon">🧾</div>
                <h2 class="gm-tile__title">Ticket / Lot History</h2>
            </div>
            <p class="gm-tile__text">Placeholder for ticket lookup, lot history, and audit reporting.</p>
            <div class="gm-tile__actions">
                <a class="btn btn-outline-secondary w-100" href="#" onclick="return false;">Coming soon</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="gm-tile">
            <div class="gm-tile__header">
                <div class="gm-tile__icon">🏷️</div>
                <h2 class="gm-tile__title">Inventory</h2>
            </div>
            <p class="gm-tile__text">Placeholder for inventory summaries, aging, and movement reports.</p>
            <div class="gm-tile__actions">
                <a class="btn btn-outline-secondary w-100" href="#" onclick="return false;">Coming soon</a>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 gm-quicklinks">
    <a class="gm-link" href="/">Back to Home</a>
</div>
