@{
    ViewData["Title"] = "Daily Weight Sheet Series Report";
}

<a href="/Reports" class="gm-module-bar gm-module-bar--reports gm-module-bar--link" title="Back to Reports">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--reports" aria-hidden="true"></span>
    <span class="gm-module-bar__label">DAILY WEIGHT SHEET SERIES REPORT</span>
</a>

<div class="card mt-3">
    <div class="card-body">
        <div class="d-flex flex-wrap align-items-end gap-3 mb-3">
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-district">District</label>
                <select id="rb-district" class="form-select form-select-sm" style="min-width:11rem;">
                    <option value="">— Select —</option>
                </select>
            </div>
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-location">Location</label>
                <select id="rb-location" class="form-select form-select-sm" style="min-width:13rem;">
                    <option value="">— Select —</option>
                </select>
            </div>
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-from">Start Date (Pacific)</label>
                <input type="date" id="rb-from" class="form-control form-control-sm" style="width:9.5rem;" />
            </div>
            <div>
                <label class="form-label small mb-1 fw-bold" for="rb-to">End Date (Pacific)</label>
                <input type="date" id="rb-to" class="form-control form-control-sm" style="width:9.5rem;" />
            </div>
            <div>
                <button id="rb-apply" type="button" class="btn btn-sm btn-primary">Apply</button>
            </div>
        </div>

        <div id="rb-results">
            <div class="text-muted small">Pick a district, location, and date range, then click <strong>Apply</strong>.</div>
        </div>
    </div>
</div>

<div class="modal fade" id="rb-pdf-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl" style="max-width:1100px;">
        <div class="modal-content" style="height:88vh;">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="rb-pdf-title">Report</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0" style="overflow:hidden;">
                <iframe id="rb-pdf-iframe" src="about:blank" style="width:100%;height:100%;border:0;"></iframe>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/reports.daily-series.js" asp-append-version="true"></script>
}
