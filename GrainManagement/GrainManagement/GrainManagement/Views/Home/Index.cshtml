@{
    ViewData["Title"] = "Home";
}
@inject ILocationContext LocationCtx
@inject IModuleContext Modules

@if (!Modules.IsCentral && !LocationCtx.HasLocation)
{
    <div class="gm-hero">
        <div class="gm-hero__inner">
            <h1 class="gm-hero__title">Grain Management</h1>
        </div>
    </div>
    <div style="text-align: center; margin-top: 3rem;">
        <p style="color: red; font-weight: bold; font-size: 2rem;">
            Select a Location to Begin
        </p>
    </div>
    return;
}

@if (Modules.IsCentral)
{
    <div class="gm-hero gm-hero--compact">
        <div class="gm-hero__inner">
            <div class="gm-nav-buttons d-flex flex-wrap gap-2">
                <a class="gm-nav-btn gm-nav-btn--reports" href="/Reports" title="Reports">
                    <span class="gm-nav-btn__icon gm-icon gm-icon--reports" aria-hidden="true"></span>
                    <span class="gm-nav-btn__title">Reports</span>
                    <span class="gm-nav-btn__desc">Daily totals, history, inventory, and management summaries</span>
                </a>
                <a class="gm-nav-btn gm-nav-btn--remote" href="/Remote" title="Remote">
                    <span class="gm-nav-btn__icon gm-icon gm-icon--remote" aria-hidden="true"></span>
                    <span class="gm-nav-btn__title">Remote</span>
                    <span class="gm-nav-btn__desc">Remote access to other locations</span>
                </a>
                <a class="gm-nav-btn gm-nav-btn--warehouse" href="/WarehouseAdmin" title="Warehouse">
                    <span class="gm-nav-btn__icon gm-icon gm-icon--warehouse" aria-hidden="true"></span>
                    <span class="gm-nav-btn__title">Warehouse</span>
                    <span class="gm-nav-btn__desc">Manage weight sheets and warehouse records across locations</span>
                </a>
                <a class="gm-nav-btn gm-nav-btn--seed" href="/SeedAdmin" title="Seed">
                    <span class="gm-nav-btn__icon gm-icon gm-icon--seed" aria-hidden="true"></span>
                    <span class="gm-nav-btn__title">Seed</span>
                    <span class="gm-nav-btn__desc">Seed purchasing, treatments, and seed records across locations</span>
                </a>
                <a class="gm-nav-btn gm-nav-btn--transfer" href="/Updates" title="Updates">
                    <span class="gm-nav-btn__icon gm-icon gm-icon--transfer" aria-hidden="true"></span>
                    <span class="gm-nav-btn__title">Updates</span>
                    <span class="gm-nav-btn__desc">Pull and push data with Agvantage</span>
                </a>
            </div>
        </div>
    </div>

    <div class="gm-gd mt-3">
        <div class="gm-gd-section">
            <div class="gm-gd-section__title d-flex flex-wrap align-items-center justify-content-between gap-2">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <span>Activity by Location</span>
                    <span id="cd-last-updated" class="small text-muted fw-normal">Loading...</span>
                </div>
                <div class="d-flex flex-wrap align-items-center gap-2">
                    <button type="button" id="cd-export" class="btn btn-sm btn-outline-success" title="Download to Excel">
                        <i class="fa fa-file-excel"></i> Excel
                    </button>
                    <input type="search" id="cd-search" class="form-control form-control-sm"
                           placeholder="Search..." style="width:11rem;" />
                    <label class="form-label mb-0 small">From</label>
                    <input type="date" id="cd-from" class="form-control form-control-sm" style="width:9.5rem;" />
                    <label class="form-label mb-0 small">To</label>
                    <input type="date" id="cd-to" class="form-control form-control-sm" style="width:9.5rem;" />
                    <div class="form-check ms-2">
                        <input class="form-check-input" type="checkbox" id="cd-active-only" checked />
                        <label class="form-check-label small" for="cd-active-only">Show only active</label>
                    </div>
                </div>
            </div>

            <div id="cd-grid"></div>
        </div>
    </div>

    @* Central deployments use the button bar above; the legacy tile grid is
       intentionally omitted here. *@
}
else
{
    <div class="gm-hero">
        <div class="gm-hero__inner">
            <h1 class="gm-hero__title">Grain Management@(LocationCtx.HasLocation ? " - " + LocationCtx.LocationName + " (" + LocationCtx.LocationId + ")" : "")</h1>
        </div>
    </div>

    <div class="row g-4 mt-2">

        @if (Modules.IsEnabled("WarehouseIntake") && (!LocationCtx.HasLocation || LocationCtx.CanDoWarehouse))
        {
            <div class="col-12 col-lg-4">
                <a class="gm-tile gm-tile--link gm-tile--warehouse" href="/WeightSheets">
                    <div class="gm-tile__header">
                        <div class="gm-tile__icon gm-icon gm-icon--warehouse" aria-hidden="true"></div>
                        <h2 class="gm-tile__title">Weight Sheets</h2>
                    </div>
                    <p class="gm-tile__text">Receiving from growers, elevator-to-elevator transfers, shipping, and inventory.</p>
                </a>
            </div>
        }

        @if (Modules.IsEnabled("Seed") && (!LocationCtx.HasLocation || LocationCtx.CanDoSeed))
        {
            <div class="col-12 col-lg-4">
                <a class="gm-tile gm-tile--link gm-tile--seed" href="/Seed">
                    <div class="gm-tile__header">
                        <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                        <h2 class="gm-tile__title">Seed</h2>
                    </div>
                    <p class="gm-tile__text">Receiving from growers, elevator-to-elevator transfers, shipping, and inventory.</p>
                </a>
            </div>
        }

        @if (Modules.IsEnabled("Reporting"))
        {
            <div class="col-12 col-lg-4">
                <a class="gm-tile gm-tile--link gm-tile--reports" href="/Reports">
                    <div class="gm-tile__header">
                        <div class="gm-tile__icon gm-icon gm-icon--reports" aria-hidden="true"></div>
                        <h2 class="gm-tile__title">Reports</h2>
                    </div>
                    <p class="gm-tile__text">Daily totals, history, inventory reports, and management summaries.</p>
                </a>
            </div>
        }

        @if (Modules.IsEnabled("System"))
        {
            <div class="col-12 col-lg-4">
                <a class="gm-tile gm-tile--link gm-tile--system" href="/System">
                    <div class="gm-tile__header">
                        <div class="gm-tile__icon gm-icon gm-icon--settings" aria-hidden="true"></div>
                        <h2 class="gm-tile__title">System</h2>
                    </div>
                    <p class="gm-tile__text">Cameras, scales, and hardware configuration</p>
                </a>
            </div>
        }

        @if (Modules.IsEnabled("Printers"))
        {
            <div class="col-12 col-lg-4">
                <a class="gm-tile gm-tile--link gm-tile--system" href="/Printer">
                    <div class="gm-tile__header">
                        <div class="gm-tile__icon gm-icon gm-icon--settings" aria-hidden="true"></div>
                        <h2 class="gm-tile__title">Printers</h2>
                    </div>
                    <p class="gm-tile__text">Manage print services, printer assignments, and test printing.</p>
                </a>
            </div>
        }

    </div>
}

@section Scripts {
    @if (Modules.IsCentral)
    {
        <script src="~/js/pages/home.central-dashboard.js" asp-append-version="true"></script>
    }
}
