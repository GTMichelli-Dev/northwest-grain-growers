@{
    ViewData["Title"] = "Home";
}
@inject ICurrentUser CurrentUser
@inject ILocationContext LocationCtx
@inject IModuleContext Modules

<div class="gm-hero">
    <div class="gm-hero__inner">
        @if (Modules.IsCentral)
        {
            <h1 class="gm-hero__title">Grain Management &ndash; Administrator</h1>
        }
        else
        {
            <h1 class="gm-hero__title">Grain Management@(LocationCtx.HasLocation ? " - " + LocationCtx.LocationName + " (" + LocationCtx.LocationId + ")" : "")</h1>
        }
    </div>
</div>

@if (!Modules.IsCentral && !LocationCtx.HasLocation)
{
    <div style="text-align: center; margin-top: 3rem;">
        <p style="color: red; font-weight: bold; font-size: 2rem;">
            Select a Location to Begin
        </p>
    </div>
    return;
}

<div class="row g-4 mt-2">

    @if (Modules.IsEnabled("WarehouseIntake") && (!LocationCtx.HasLocation || LocationCtx.CanDoWarehouse))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--warehouse" href="/WeightSheets">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--warehouse" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Weight Sheets</h2>
                </div>
                <p class="gm-tile__text">Receiving from growers, elevator-to-elevator transfers, shipping, and inventory.</p>
            </a>
        </div>
    }

    @if (Modules.IsEnabled("Seed") && (!LocationCtx.HasLocation || LocationCtx.CanDoSeed))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--seed" href="/Seed">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Seed</h2>
                </div>
                <p class="gm-tile__text">Receiving from growers, elevator-to-elevator transfers, shipping, and inventory.</p>
            </a>
        </div>
    }

    @if (Modules.IsEnabled("Reporting"))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--reports" href="/Reports">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--reports" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Reports</h2>
                </div>
                <p class="gm-tile__text">Daily totals, history, inventory reports, and management summaries.</p>
            </a>
        </div>
    }

    @if (Modules.IsEnabled("System"))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--system" href="/System">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--settings" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">System</h2>
                </div>
                <p class="gm-tile__text">Cameras, scales, and hardware configuration</p>
            </a>
        </div>
    }

    @if (Modules.IsEnabled("Printers"))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--system" href="/Printer">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--settings" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Printers</h2>
                </div>
                <p class="gm-tile__text">Manage print services, printer assignments, and test printing.</p>
            </a>
        </div>
    }

    @if (Modules.IsCentral)
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--remote" href="/Remote">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--remote" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Remote</h2>
                </div>
                <p class="gm-tile__text">Remote access to other locations</p>
            </a>
        </div>
    }

    @if (Modules.IsEnabled("DatabaseAdmin"))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--admin" href="/Admin">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--admin" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Maintenance</h2>
                </div>
                <p class="gm-tile__text">Account, Product, User Setup</p>
            </a>
        </div>
    }

    @if (Modules.IsEnabled("WarehouseAdmin"))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--warehouse" href="/WarehouseAdmin">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--warehouse" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Warehouse Administration</h2>
                </div>
                <p class="gm-tile__text">Manage weight sheets, loads, and warehouse records across all locations.</p>
            </a>
        </div>
    }

    @if (Modules.IsEnabled("SeedAdmin"))
    {
        <div class="col-12 col-lg-4">
            <a class="gm-tile gm-tile--link gm-tile--seed" href="/SeedAdmin">
                <div class="gm-tile__header">
                    <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                    <h2 class="gm-tile__title">Seed Administration</h2>
                </div>
                <p class="gm-tile__text">Manage seed purchasing, treatments, and seed records across all locations.</p>
            </a>
        </div>
    }

</div>
