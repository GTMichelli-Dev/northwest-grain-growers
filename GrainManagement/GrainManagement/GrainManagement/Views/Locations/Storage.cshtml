@{
    ViewData["Title"] = "Storage — " + ViewBag.LocationName;
    int locationId = ViewBag.LocationId;
    string locationName = ViewBag.LocationName;
}

<a href="/Locations" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Locations">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--locations" aria-hidden="true"></span>
    <span class="gm-module-bar__label">STORAGE — @locationName.ToUpper()</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky d-flex align-items-center gap-3 mt-3 mb-2">
    <h5 class="mb-0 fw-semibold">Containers</h5>
    <button type="button" class="btn btn-sm btn-outline-secondary" id="btnContainerLocations">
        <i class="dx-icon dx-icon-folder"></i> Manage Storage Areas
    </button>
</div>

<!-- Containers grid -->
<div style="max-width: 960px; margin: 0 auto;">
    <div id="containersGrid"></div>
</div>

<!-- Container Locations popup -->
<div id="containerLocationsPopup">
    <div id="clGrid"></div>
</div>

@section Scripts {
<script>
    var LOCATION_ID = @locationId;

    // ── Container Locations (Storage Areas) popup ─────────────────────────────

    var clStore = DevExpress.data.AspNet.createStore({
        key: "ContainerLocationId",
        loadUrl:   "/api/locations/" + LOCATION_ID + "/ContainerLocations",
        insertUrl: "/api/locations/" + LOCATION_ID + "/ContainerLocations",
        updateUrl: "/api/locations/" + LOCATION_ID + "/ContainerLocations/0",
        deleteUrl: "/api/locations/" + LOCATION_ID + "/ContainerLocations/0",
        onBeforeSend: function (op, ajaxSettings) {
            if (op === "load") return;
            if (op === "update" || op === "delete") {
                var key = ajaxSettings.data.key ?? ajaxSettings.data.values?.ContainerLocationId;
                ajaxSettings.url = ajaxSettings.url.replace("/0", "/" + key);
                if (op === "update") ajaxSettings.data = ajaxSettings.data.values;
            }
            if (op === "insert") ajaxSettings.data = ajaxSettings.data.values;
            ajaxSettings.contentType = "application/json";
            if (typeof ajaxSettings.data !== "string") ajaxSettings.data = JSON.stringify(ajaxSettings.data);
        },
        errorHandler: function (e) {
            try {
                var resp = JSON.parse(e.xhr.responseText);
                if (resp.message) {
                    DevExpress.ui.notify(resp.message, "error", 4000);
                    e.message = resp.message;
                }
            } catch (_) {}
        }
    });

    $("#containerLocationsPopup").dxPopup({
        title: "Storage Areas — @locationName",
        width: 700,
        height: 500,
        showCloseButton: true,
        onShown: function () {
            var el = document.getElementById("clGrid");
            var instance = DevExpress.ui.dxDataGrid.getInstance(el);
            if (instance) {
                instance.refresh();
            } else {
                $(el).dxDataGrid({
                    dataSource: clStore,
                    showBorders: true,
                    rowAlternationEnabled: true,
                    editing: {
                        mode: "row",
                        allowAdding: true,
                        allowUpdating: true,
                        allowDeleting: true,
                        confirmDelete: true
                    },
                    onInitNewRow: function (e) {
                        e.data.IsActive = true;
                        e.data.Idx = 1;
                        e.promise = clStore.load().then(function (items) {
                            var maxIdx = items.reduce(function (m, x) { return Math.max(m, x.Idx || 0); }, 0);
                            e.data.Idx = maxIdx + 1;
                        });
                    },
                    columns: [
                        { dataField: "Description", caption: "Storage Area", minWidth: 200, validationRules: [{ type: "required" }] },
                        { dataField: "Idx", caption: "Sort", width: 70, dataType: "number" },
                        { dataField: "IsActive", caption: "Active", width: 80, dataType: "boolean" },
                        {
                            type: "buttons", width: 90,
                            buttons: [
                                { name: "edit",   icon: "edit",   hint: "Edit" },
                                { name: "delete", icon: "trash",  hint: "Delete" },
                                { name: "save",   icon: "save",   hint: "Save" },
                                { name: "cancel", icon: "revert", hint: "Cancel" }
                            ]
                        }
                    ],
                    onRowUpdating: function (e) {
                        e.newData = Object.assign({}, e.oldData, e.newData);
                    },
                    onRowInserted: function () { containersGrid().refresh(); },
                    onRowUpdated:  function () { containersGrid().refresh(); },
                    onRowRemoved:  function () { containersGrid().refresh(); }
                });
            }
        }
    });

    $("#btnContainerLocations").on("click", function () {
        $("#containerLocationsPopup").dxPopup("instance").show();
    });

    // ── Container Types store ─────────────────────────────────────────────────

    var ctStore = new DevExpress.data.CustomStore({
        key: "ContainerTypeId",
        load: function () { return $.getJSON("/api/locations/" + LOCATION_ID + "/ContainerTypes"); },
        byKey: function (key) {
            return this.load().then(function (list) {
                return list.find(function (x) { return x.ContainerTypeId === key; });
            });
        }
    });

    var clLookupStore = new DevExpress.data.CustomStore({
        key: "ContainerLocationId",
        load: function () { return $.getJSON("/api/locations/" + LOCATION_ID + "/ContainerLocations"); },
        byKey: function (key) {
            return this.load().then(function (list) {
                return list.find(function (x) { return x.ContainerLocationId === key; });
            });
        }
    });

    // ── Containers grid ───────────────────────────────────────────────────────

    var containerStore = DevExpress.data.AspNet.createStore({
        key: "ContainerId",
        loadUrl:   "/api/locations/" + LOCATION_ID + "/Containers",
        insertUrl: "/api/locations/" + LOCATION_ID + "/Containers",
        updateUrl: "/api/locations/" + LOCATION_ID + "/Containers/0",
        deleteUrl: "/api/locations/" + LOCATION_ID + "/Containers/0",
        onBeforeSend: function (op, ajaxSettings) {
            if (op === "load") return;
            if (op === "update" || op === "delete") {
                var key = ajaxSettings.data.key ?? ajaxSettings.data.values?.ContainerId;
                ajaxSettings.url = ajaxSettings.url.replace("/0", "/" + key);
                if (op === "update") ajaxSettings.data = ajaxSettings.data.values;
            }
            if (op === "insert") ajaxSettings.data = ajaxSettings.data.values;
            ajaxSettings.contentType = "application/json";
            if (typeof ajaxSettings.data !== "string") ajaxSettings.data = JSON.stringify(ajaxSettings.data);
        },
        errorHandler: function (e) {
            try {
                var resp = JSON.parse(e.xhr.responseText);
                if (resp.message) {
                    DevExpress.ui.notify(resp.message, "error", 4000);
                    e.message = resp.message;
                }
            } catch (_) {}
        }
    });

    function containersGrid() { return DevExpress.ui.dxDataGrid.getInstance(document.getElementById("containersGrid")); }

    $("#containersGrid").dxDataGrid({
        dataSource: containerStore,
        showBorders: true,
        rowAlternationEnabled: true,
        columnAutoWidth: true,
        wordWrapEnabled: true,
        toolbar: {
            items: [
                {
                    location: "before",
                    widget: "dxButton",
                    options: {
                        text: "Add Container",
                        icon: "plus",
                        type: "success",
                        stylingMode: "contained",
                        onClick: function () { containersGrid().addRow(); }
                    }
                },
                "searchPanel"
            ]
        },
        onRowUpdating: function (e) {
            e.newData = Object.assign({}, e.oldData, e.newData);
        },
        onInitNewRow: function (e) {
            e.data.ContainerTypeId = 1;   // default: Bin
            e.data.CapacityLb      = 0;
            e.data.IsActive        = true;
            // auto-select storage area if only one exists
            clLookupStore.load().done(function (areas) {
                if (areas.length === 1) {
                    e.data.ContainerLocationId = areas[0].ContainerLocationId;
                }
            });
        },
        editing: {
            mode: "popup",
            allowAdding: true,
            allowUpdating: true,
            allowDeleting: true,
            confirmDelete: true,
            popup: {
                title: "Container",
                showTitle: true,
                width: 480,
                height: "auto"
            },
            form: {
                colCount: 1,
                labelLocation: "left",
                items: [
                    { dataField: "Description", label: { text: "Description" }, validationRules: [{ type: "required" }] },
                    {
                        dataField: "ContainerLocationId",
                        label: { text: "Storage Area" },
                        editorType: "dxSelectBox",
                        editorOptions: {
                            dataSource: clLookupStore,
                            valueExpr: "ContainerLocationId",
                            displayExpr: "Description",
                            searchEnabled: true,
                            showClearButton: true,
                            placeholder: "Select storage area..."
                        }
                    },
                    {
                        dataField: "ContainerTypeId",
                        label: { text: "Type" },
                        editorType: "dxSelectBox",
                        editorOptions: {
                            dataSource: ctStore,
                            valueExpr: "ContainerTypeId",
                            displayExpr: "Description",
                            searchEnabled: true,
                            showClearButton: true,
                            placeholder: "Select type..."
                        }
                    },
                    { dataField: "CapacityLb", label: { text: "Capacity (lb)" }, dataType: "number" },
                    { dataField: "IsActive", label: { text: "Active" }, dataType: "boolean" },
                    { dataField: "Notes", label: { text: "Notes" }, editorType: "dxTextArea", editorOptions: { height: 80 } }
                ]
            }
        },
        columns: [
            {
                dataField: "IsActive", caption: "Active", width: 75,
                cellTemplate: function (el, info) {
                    el.text(info.value ? "Active" : "Inactive");
                    if (!info.value) el.css("color", "red");
                }
            },
            { dataField: "Description", caption: "Container", minWidth: 180 },
            {
                dataField: "ContainerLocationId", caption: "Storage Area",
                lookup: { dataSource: clLookupStore, valueExpr: "ContainerLocationId", displayExpr: "Description" }
            },
            {
                dataField: "ContainerTypeId", caption: "Type",
                lookup: { dataSource: ctStore, valueExpr: "ContainerTypeId", displayExpr: "Description" }
            },
            { dataField: "CapacityLb", caption: "Capacity (lb)", width: 110, dataType: "number", format: { type: "fixedPoint", precision: 0 } },
            { dataField: "Notes", caption: "Notes", minWidth: 120 },
            {
                caption: "", width: 64, allowSorting: false, allowFiltering: false,
                cellTemplate: function (cell, info) {
                    var $wrap = $("<div>").css({ display: "flex", gap: "2px" });
                    $("<div>").dxButton({
                        icon: "edit",
                        type: "default",
                        stylingMode: "text",
                        hint: "Edit",
                        height: 28,
                        width: 28,
                        onClick: function () { containersGrid().editRow(info.rowIndex); }
                    }).appendTo($wrap);
                    $("<div>").dxButton({
                        icon: "trash",
                        type: "danger",
                        stylingMode: "text",
                        hint: "Delete",
                        height: 28,
                        width: 28,
                        onClick: function () { containersGrid().deleteRow(info.rowIndex); }
                    }).appendTo($wrap);
                    $wrap.appendTo(cell);
                }
            },
            { type: "buttons", width: 0, visible: false }
        ]
    });
</script>
}
