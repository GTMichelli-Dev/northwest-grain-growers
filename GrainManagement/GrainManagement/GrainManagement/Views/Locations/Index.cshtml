<link rel="stylesheet" href="~/css/pages/locations.css" asp-append-version="true" />

<a href="@Url.Action("Index", "Admin")" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Admin">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--locations" aria-hidden="true"></span>
    <span class="gm-module-bar__label">LOCATIONS</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky">
</div>

<div id="locationsGrid"></div>

<!-- ── LocationCounties popup ──────────────────────────────────────── -->
<div id="lcPopup"></div>

<!-- ── LocationItems popup ────────────────────────────────────────── -->
<div id="liPopup"></div>

<!-- ── LocationQuantityMethods popup ─────────────────────────────── -->
<div id="lqmPopup"></div>

@section Scripts {
    <script src="~/js/pages/locations.counties.js" asp-append-version="true"></script>
    <script src="~/js/pages/locations.items.js" asp-append-version="true"></script>
    <script src="~/js/pages/locations.quantitymethods.js" asp-append-version="true"></script>
    <script>
        let districtsCache = null;

        const districtsStore = new DevExpress.data.CustomStore({
            key: "DistrictId",

            load: function () {
                if (districtsCache) return districtsCache;
                districtsCache = $.getJSON("/api/locations/Districts");
                return districtsCache;
            },

            byKey: function (key) {
                const k = Number(key);
                return (districtsCache ? districtsCache : this.load())
                    .then(list => list.find(x => x.DistrictId === k));
            }
        });

        const locationsStore = DevExpress.data.AspNet.createStore({
            key: "LocationId",
            loadUrl: "/api/locations",
            insertUrl: "/api/locations",
            updateUrl: "/api/locations"
        });

        // Cache: locationId → [itemName, ...]
        var _itemFiltersMap = {};

        // ✅ PRELOAD districts AND item filters BEFORE grid init
        $.when(districtsStore.load(), $.getJSON("/api/locations/AllItemFilters")).done(function (_, itemResult) {
            _itemFiltersMap = itemResult[0] || {};

            $("#locationsGrid").dxDataGrid({
                dataSource: locationsStore,
                keyExpr: "LocationId",

                remoteOperations: {
                    paging: true,
                    filtering: false,
                    sorting: false
                },

                toolbar: {
                    items: [
                        {
                            location: "after",
                            template: function () {
                                return $("<div>").dxTextBox({
                                    width: 240,
                                    placeholder: "Search locations...",
                                    mode: "search",
                                    onValueChanged: function (e) {
                                        const grid = $("#locationsGrid").dxDataGrid("instance");
                                        grid.searchByText(e.value);
                                    }
                                });
                            }
                        },
                        {
                            location: "after",
                            template: function () {
                                return $("<div>").css({ display: "flex", alignItems: "center", gap: "8px" })
                                    .append($("<span>").text("Paging").css({ fontWeight: 600 }))
                                    .append($("<div>").dxSwitch({
                                        value: true,
                                        hint: "Turn paging on/off",
                                        onValueChanged: function (e) {
                                            const grid = $("#locationsGrid").dxDataGrid("instance");
                                            grid.option("paging.enabled", e.value);
                                            grid.option("pager.visible", e.value);
                                        }
                                    }));
                            }
                        }
                    ]
                },

                showBorders: true,
                columnAutoWidth: true,
                wordWrapEnabled: true,
                rowAlternationEnabled: true,
                hoverStateEnabled: true,

                searchPanel: { visible: false },

                export: {
                    enabled: true,
                    allowExportSelectedData: false,
                },
                onExporting: function (e) {
                    // Exports ALL rows matching the current search/filter state,
                    // across every page — not just the visible page. Since
                    // this grid uses a remote store, DevExtreme loads the full
                    // filtered result set (isLoadingAll) for the export.
                    var workbook = new ExcelJS.Workbook();
                    var worksheet = workbook.addWorksheet('Locations');
                    DevExpress.excelExporter.exportDataGrid({
                        component: e.component,
                        worksheet: worksheet,
                    }).then(function () {
                        return workbook.xlsx.writeBuffer();
                    }).then(function (buffer) {
                        saveAs(
                            new Blob([buffer], { type: 'application/octet-stream' }),
                            'Locations.xlsx'
                        );
                    });
                    e.cancel = true;
                },

                editing: {
                    mode: "popup",
                    allowAdding: true,
                    allowUpdating: true,
                    popup: {
                        title: "Location",
                        showTitle: true,
                        width: 520,
                        height: "auto"
                    },
                    form: {
                        colCount: 1,
                        labelLocation: "left",
                        items: [
                            { dataField: "IsActive", label: { text: "Active" } },
                            { dataField: "LocationId", label: { text: "ID" }, editorOptions: { readOnly: true } },
                            { dataField: "Code", label: { text: "Code" } },
                            { dataField: "Name", label: { text: "Name" } },
                            {
                                dataField: "DistrictId",
                                label: { text: "District" },
                                editorType: "dxSelectBox",
                                editorOptions: {
                                    dataSource: districtsStore,
                                    valueExpr: "DistrictId",
                                    displayExpr: "Name",
                                    searchEnabled: true,
                                    placeholder: "Select district..."
                                }
                            },
                            { dataField: "UseForSeed", label: { text: "Use For Seed" } },
                            { dataField: "UseForWarehouse", label: { text: "Use For Warehouse" } },
                            { dataField: "Licensed", label: { text: "Licensed" } },
                            {
                                dataField: "RequireDumpType",
                                label: { text: "Require Dump Type" },
                                editorType: "dxCheckBox",
                                helpText: "Prompts the operator for an end-dump answer on each new load at this location."
                            }
                        ]
                    }
                },

                columns: [

                    {
                        dataField: "IsActive",
                        caption: "Active",
                        width: 80,
                        cellTemplate: function (cellElement, cellInfo) {
                            const isActive = cellInfo.value;
                            cellElement.text(isActive ? "Active" : "Inactive");
                            if (!isActive) cellElement.css("color", "red");
                        }
                    },
                    { dataField: "LocationId", caption: "ID", width: 60 },
                    { dataField: "Code", caption: "Code", minWidth: 160 },
                    { dataField: "Name", caption: "Name", minWidth: 160, sortOrder: "asc" },
                    {
                        dataField: "DistrictId",
                        caption: "District",
                        lookup: {
                            dataSource: districtsStore,
                            valueExpr: "DistrictId",
                            displayExpr: "Name"
                        }
                    },
                    {
                        dataField: "UseForSeed",
                        caption: "Seed",
                        cellTemplate: function (cellElement, cellInfo) {
                            const value = cellInfo.value;
                            cellElement.text(value ? "Yes" : "No");
                            if (!value) cellElement.css("color", "red");
                        }
                    },
                    {
                        dataField: "UseForWarehouse",
                        caption: "Warehouse",
                        cellTemplate: function (cellElement, cellInfo) {
                            const value = cellInfo.value;
                            cellElement.text(value ? "Yes" : "No");
                            if (!value) cellElement.css("color", "red");
                        }
                    },
                    {
                        dataField: "Licensed",
                        caption: "Licensed",
                        cellTemplate: function (cellElement, cellInfo) {
                            const value = cellInfo.value;
                            cellElement.text(value ? "Yes" : "No");
                            if (!value) cellElement.css("color", "red");
                        }
                    },
                    {
                        dataField: "RequireDumpType",
                        caption: "Dump Type",
                        cellTemplate: function (cellElement, cellInfo) {
                            const value = cellInfo.value;
                            cellElement.text(value ? "Required" : "—");
                            if (value) cellElement.css({ color: "#1565c0", fontWeight: 600 });
                        }
                    },
                    {
                        caption: "Filtered Items",
                        minWidth: 180,
                        allowSorting: false,
                        allowFiltering: false,
                        cssClass: "loc-filtered-items-cell",
                        cellTemplate: function (cellElement, cellInfo) {
                            var locId = cellInfo.data.LocationId;
                            var names = _itemFiltersMap[locId];
                            if (!names || names.length === 0) {
                                cellElement.html("<em style='color:#999'>All Items</em>");
                            } else {
                                cellElement.text(names.join(", ")).css({ fontSize: "0.85em", color: "#555" });
                            }
                        }
                    },
                    {
                        caption: "",
                        width: 670,
                        allowSorting: false,
                        allowFiltering: false,
                        cellTemplate: function (cellElement, cellInfo) {
                            var btnWidth = 125;
                            var $row = $("<div>").css({ display: "flex", gap: "4px" });

                            $("<div>").dxButton({
                                text: "Storage",
                                icon: "home",
                                width: btnWidth,
                                height: 30,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Manage storage areas and containers for this location",
                                onClick: function () {
                                    window.location.href = "/Locations/Storage?locationId=" + cellInfo.data.LocationId;
                                }
                            }).appendTo($row);

                            $("<div>").dxButton({
                                text: "Items",
                                icon: "product",
                                width: btnWidth,
                                height: 30,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Manage filtered items for this location",
                                onClick: function () {
                                    LocationItems.open(
                                        cellInfo.data.LocationId,
                                        cellInfo.data.Name
                                    );
                                }
                            }).appendTo($row);

                            $("<div>").dxButton({
                                text: "Counties",
                                icon: "map",
                                width: btnWidth,
                                height: 30,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Manage counties for this location",
                                onClick: function () {
                                    LocationCounties.open(
                                        cellInfo.data.LocationId,
                                        cellInfo.data.Name
                                    );
                                }
                            }).appendTo($row);

                            $("<div>").dxButton({
                                text: "Options",
                                icon: "preferences",
                                width: btnWidth,
                                height: 30,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Manage weight methods and options for this location",
                                onClick: function () {
                                    LocationQuantityMethods.open(
                                        cellInfo.data.LocationId,
                                        cellInfo.data.Name
                                    );
                                }
                            }).appendTo($row);

                            $("<div>").dxButton({
                                text: "Edit",
                                icon: "edit",
                                width: btnWidth,
                                height: 30,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Edit location",
                                onClick: function () {
                                    var grid = $("#locationsGrid").dxDataGrid("instance");
                                    grid.editRow(cellInfo.rowIndex);
                                }
                            }).appendTo($row);

                            cellElement.append($row);
                        }
                    },
                    { type: "buttons", width: 0, visible: false }
                ]
            });

        });

    </script>
}
