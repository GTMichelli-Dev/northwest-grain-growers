<link rel="stylesheet" href="~/css/pages/locations.css" asp-append-version="true" />

<div class="gm-pagehead">
    <div class="gm-pagehead__title">
        <span class="gm-pagehead__icon gm-icon gm-icon--locations" aria-hidden="true"></span>
        <h1 class="gm-tile__title" style="font-size:20px">Locations</h1>
    </div>
</div>

<a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary btn-sm gm-locations-back-btn">
    <i class="dx-icon dx-icon-arrowleft"></i> Back to Admin
</a>

<div id="locationsGrid"></div>

<!-- ── LocationCounties popup ──────────────────────────────────────── -->
<div id="lcPopup"></div>

<!-- ── LocationItems popup ────────────────────────────────────────── -->
<div id="liPopup"></div>

@section Scripts {
    <script src="~/js/pages/locations.counties.js" asp-append-version="true"></script>
    <script src="~/js/pages/locations.items.js" asp-append-version="true"></script>
    <script>
        let districtsCache = null;

        const districtsStore = new DevExpress.data.CustomStore({
            key: "DistrictId",

            load: function () {
                if (districtsCache) return districtsCache;
                districtsCache = $.getJSON("/api/locations/Districts");
                return districtsCache;
            },

            byKey: function (key) {
                const k = Number(key);
                return (districtsCache ? districtsCache : this.load())
                    .then(list => list.find(x => x.DistrictId === k));
            }
        });

        const locationsStore = DevExpress.data.AspNet.createStore({
            key: "LocationId",
            loadUrl: "/api/locations",
            insertUrl: "/api/locations",
            updateUrl: "/api/locations"
        });

        // Cache: locationId → [itemName, ...]
        var _itemFiltersMap = {};

        // ✅ PRELOAD districts AND item filters BEFORE grid init
        $.when(districtsStore.load(), $.getJSON("/api/locations/AllItemFilters")).done(function (_, itemResult) {
            _itemFiltersMap = itemResult[0] || {};

            $("#locationsGrid").dxDataGrid({
                dataSource: locationsStore,
                keyExpr: "LocationId",

                remoteOperations: {
                    paging: true,
                    filtering: false,
                    sorting: false
                },

                toolbar: {
                    items: [
                        {
                            location: "after",
                            template: function () {
                                return $("<div>").dxTextBox({
                                    width: 240,
                                    placeholder: "Search locations...",
                                    mode: "search",
                                    onValueChanged: function (e) {
                                        const grid = $("#locationsGrid").dxDataGrid("instance");
                                        grid.searchByText(e.value);
                                    }
                                });
                            }
                        },
                        {
                            location: "after",
                            template: function () {
                                return $("<div>").css({ display: "flex", alignItems: "center", gap: "8px" })
                                    .append($("<span>").text("Paging").css({ fontWeight: 600 }))
                                    .append($("<div>").dxSwitch({
                                        value: true,
                                        hint: "Turn paging on/off",
                                        onValueChanged: function (e) {
                                            const grid = $("#locationsGrid").dxDataGrid("instance");
                                            grid.option("paging.enabled", e.value);
                                            grid.option("pager.visible", e.value);
                                        }
                                    }));
                            }
                        }
                    ]
                },

                showBorders: true,
                columnAutoWidth: true,
                wordWrapEnabled: true,
                rowAlternationEnabled: true,
                hoverStateEnabled: true,

                searchPanel: { visible: false },

                editing: {
                    mode: "popup",
                    allowAdding: true,
                    allowUpdating: true,
                    popup: {
                        title: "Location",
                        showTitle: true,
                        width: 520,
                        height: "auto"
                    },
                    form: {
                        colCount: 1,
                        labelLocation: "left",
                        items: [
                            { dataField: "IsActive", label: { text: "Active" } },
                            { dataField: "LocationId", label: { text: "ID" }, editorOptions: { readOnly: true } },
                            { dataField: "Code", label: { text: "Code" } },
                            { dataField: "Name", label: { text: "Name" } },
                            {
                                dataField: "DistrictId",
                                label: { text: "District" },
                                editorType: "dxSelectBox",
                                editorOptions: {
                                    dataSource: districtsStore,
                                    valueExpr: "DistrictId",
                                    displayExpr: "Name",
                                    searchEnabled: true,
                                    placeholder: "Select district..."
                                }
                            },
                            { dataField: "UseForSeed", label: { text: "Use For Seed" } },
                            { dataField: "UseForWarehouse", label: { text: "Use For Warehouse" } }
                        ]
                    }
                },

                columns: [

                    {
                        dataField: "IsActive",
                        caption: "Active",
                        width: 80,
                        cellTemplate: function (cellElement, cellInfo) {
                            const isActive = cellInfo.value;
                            cellElement.text(isActive ? "Active" : "Inactive");
                            if (!isActive) cellElement.css("color", "red");
                        }
                    },
                    { dataField: "LocationId", caption: "ID", width: 60 },
                    { dataField: "Code", caption: "Code", minWidth: 230 },
                    { dataField: "Name", caption: "Name", minWidth: 230 },
                    {
                        dataField: "DistrictId",
                        caption: "District",
                        width: 90,
                        lookup: {
                            dataSource: districtsStore,
                            valueExpr: "DistrictId",
                            displayExpr: "Name"
                        }
                    },
                    {
                        dataField: "UseForSeed",
                        caption: "Use For Seed",
                        width: 110,
                        cellTemplate: function (cellElement, cellInfo) {
                            const value = cellInfo.value;
                            cellElement.text(value ? "Yes" : "No");
                            if (!value) cellElement.css("color", "red");
                        }
                    },
                    {
                        dataField: "UseForWarehouse",
                        caption: "Use For Warehouse",
                        width: 140,
                        cellTemplate: function (cellElement, cellInfo) {
                            const value = cellInfo.value;
                            cellElement.text(value ? "Yes" : "No");
                            if (!value) cellElement.css("color", "red");
                        }
                    },
                    {
                        caption: "Filtered Items",
                        minWidth: 300,
                        allowSorting: false,
                        allowFiltering: false,
                        cssClass: "loc-filtered-items-cell",
                        cellTemplate: function (cellElement, cellInfo) {
                            var locId = cellInfo.data.LocationId;
                            var names = _itemFiltersMap[locId];
                            if (!names || names.length === 0) {
                                cellElement.html("<em style='color:#999'>All Items</em>");
                            } else {
                                cellElement.text(names.join(", ")).css({ fontSize: "0.85em", color: "#555" });
                            }
                        }
                    },
                    {
                        caption: "",
                        width: 555,
                        allowSorting: false,
                        allowFiltering: false,
                        cellTemplate: function (cellElement, cellInfo) {
                            var btnWidth = 175;
                            var $row = $("<div>").css({ display: "flex", gap: "6px" });

                            $("<div>").dxButton({
                                text: "Filtered Items",
                                icon: "product",
                                width: btnWidth,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Manage filtered items for this location",
                                onClick: function () {
                                    LocationItems.open(
                                        cellInfo.data.LocationId,
                                        cellInfo.data.Name
                                    );
                                }
                            }).appendTo($row);

                            $("<div>").dxButton({
                                text: "Counties",
                                icon: "map",
                                width: btnWidth,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Manage counties for this location",
                                onClick: function () {
                                    LocationCounties.open(
                                        cellInfo.data.LocationId,
                                        cellInfo.data.Name
                                    );
                                }
                            }).appendTo($row);

                            $("<div>").dxButton({
                                text: "Edit",
                                icon: "edit",
                                width: btnWidth,
                                stylingMode: "outlined",
                                type: "default",
                                hint: "Edit location",
                                onClick: function () {
                                    var grid = $("#locationsGrid").dxDataGrid("instance");
                                    grid.editRow(cellInfo.rowIndex);
                                }
                            }).appendTo($row);

                            cellElement.append($row);
                        }
                    },
                    { type: "buttons", width: 0, visible: false }
                ]
            });

        });

    </script>
}
