@{
    ViewData["Title"] = "Weight Sheet Details";
    var wsType = (ViewData["WsType"] as string ?? "delivery").ToLower();
    var isTransfer = wsType == "transfer";
    var barClass = isTransfer ? "gm-module-bar--transfer" : "gm-module-bar--intake";
    var iconClass = isTransfer ? "gm-icon--transfer" : "gm-icon--delivery";
    var barLabel = isTransfer ? "TRANSFER WEIGHT SHEET" : "GROWER INTAKE WEIGHT SHEET";
}

<link rel="stylesheet" href="~/css/pages/grower.delivery.css" asp-append-version="true" />

<a id="dlModuleBar" href="/WeightSheets" class="gm-module-bar @barClass gm-module-bar--link" title="Back to Weight Sheets" hidden>
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span id="dlModuleBarIcon" class="gm-module-bar__icon gm-icon @iconClass" aria-hidden="true"></span>
    <span id="dlModuleBarLabel" class="gm-module-bar__label">@barLabel</span>
</a>

<div class="gm-pagehead gm-pagehead--sticky">
</div>

<div class="gm-gd gm-gd--loads">

    <div id="dlAlert" class="alert" role="alert" hidden></div>

    <!-- ── Weight sheet details header ────────────────────────────────────── -->
    <div id="dlWsHeader" class="gm-dl-header" style="padding:8px 14px;font-size:0.8em;" hidden>
        <!-- Row 1 — WS ID, Lot, Variety, Account, Split — all on one line -->
        <div class="gm-dl-header__details" style="gap:16px;">
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">WS</span>
                <span class="gm-dl-header__wsid" id="dlWsIdFormatted" style="font-size:1.05rem;"></span>
            </div>
            <div class="gm-dl-header__detail" id="dlWsDirectionDetail" hidden>
                <span class="gm-dl-header__detail-label">Type</span>
                <span class="gm-dl-header__detail-value fw-semibold" id="dlWsDirection">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Lot #</span>
                <span class="gm-dl-header__detail-value" id="dlWsLotNumber">—</span>
                <button type="button" class="btn btn-outline-secondary btn-sm gm-dl-header__edit-btn" id="dlEditLotBtn" title="Reassign Lot">
                    <i class="dx-icon dx-icon-add"></i>
                </button>
                <a id="dlEditLotLink" href="#" class="btn btn-outline-info btn-sm gm-dl-header__edit-btn" title="Edit Lot Properties" hidden>
                    <i class="dx-icon dx-icon-arrowright"></i>
                </a>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Variety</span>
                <span class="gm-dl-header__detail-value" id="dlWsCrop">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Account</span>
                <span class="gm-dl-header__detail-value" id="dlWsAccount">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Split #</span>
                <span class="gm-dl-header__detail-value fw-semibold" id="dlWsSplitId">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Split</span>
                <span class="gm-dl-header__detail-value" id="dlWsSplit">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Date</span>
                <span class="gm-dl-header__detail-value" id="dlWsDate">—</span>
            </div>
        </div>
        <!-- Row 2 — BOL: rate type, hauler, miles, rate + edit btn + comment inline -->
        <div class="gm-dl-header__details" style="margin-top:4px; gap:16px; border-top:1px solid #eee; padding-top:4px;">
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label" id="dlWsRateTypeLabel">BOL</span>
                <span class="gm-dl-header__detail-value" id="dlWsRateType">—</span>
                <button type="button" class="btn btn-outline-secondary btn-sm gm-dl-header__edit-btn" id="dlEditHaulerBtn" title="Change BOL Type">
                    <i class="dx-icon dx-icon-edit"></i>
                </button>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Hauler</span>
                <span class="gm-dl-header__detail-value" id="dlWsHauler">—</span>
            </div>
            <div class="gm-dl-header__detail" id="dlWsMilesDetail" hidden>
                <span class="gm-dl-header__detail-label">Miles</span>
                <span class="gm-dl-header__detail-value" id="dlWsMiles">—</span>
            </div>
            <div class="gm-dl-header__detail" id="dlWsCalcRateDetail" hidden>
                <span class="gm-dl-header__detail-label">Rate</span>
                <span class="gm-dl-header__detail-value" id="dlWsCalcRate">—</span>
            </div>
            <div class="gm-dl-header__detail" id="dlWsCustomDescDetail" hidden>
                <span class="gm-dl-header__detail-label" id="dlWsCustomDescLabel">Desc</span>
                <span class="gm-dl-header__detail-value" id="dlWsCustomDesc">—</span>
            </div>
            <div class="gm-dl-header__detail" id="dlWsCustomRateDetail" hidden>
                <span class="gm-dl-header__detail-label">Rate</span>
                <span class="gm-dl-header__detail-value" id="dlWsCustomRate">—</span>
            </div>
            <div class="gm-dl-header__detail" style="flex:1 1 auto; min-width:200px;">
                <span class="gm-dl-header__detail-label">Comment</span>
                <input type="text" class="form-control form-control-sm" id="dlWsComment"
                       placeholder="Add a comment…" style="font-size:0.8rem; height:26px;" />
                <button type="button" class="btn btn-outline-primary btn-sm" id="dlSaveCommentBtn"
                        title="Save" style="display:none; padding:1px 8px; font-size:0.75rem;">
                    Save
                </button>
            </div>
        </div>
    </div>

    <!-- ── Loads grid ──────────────────────────────────────────────────────── -->
    <div id="dlListPanel" hidden>
        <div class="gm-gd-section">

            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="d-flex align-items-center gap-3">
                    <div class="gm-gd-section__title" style="margin-bottom:0">Weight Sheet Loads</div>
                    <span class="badge bg-secondary" id="dlStatTotal" title="Total loads">0 loads</span>
                    <span class="badge bg-success" id="dlStatComplete" title="Completed loads">0 complete</span>
                    <span class="badge bg-primary" id="dlStatTotalNet" title="Total net weight">Net: 0 lbs</span>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="dlPrintSummaryBtn" title="Print weight sheet" hidden>
                        <i class="dx-icon dx-icon-print"></i> Print
                    </button>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="dlSetPendingBtn" title="Mark this Weight Sheet as Finished" hidden>
                        <i class="dx-icon dx-icon-clock"></i> Weight Sheet Finished
                    </button>
                    <button type="button" class="btn btn-warning btn-sm" id="dlFinishAndCloseLotBtn" title="Finish this Weight Sheet and Close the Lot" hidden>
                        <i class="dx-icon dx-icon-clear"></i> Finish &amp; Close Lot
                    </button>
                    <button type="button" class="btn btn-outline-success btn-sm" id="dlReopenBtn" title="Re-open this Weight Sheet" hidden>
                        <i class="dx-icon dx-icon-undo"></i> Re-open
                    </button>
                    <a class="btn btn-primary btn-sm" id="dlNewLoadBtn" href="/GrowerDelivery/Index">
                        <i class="dx-icon dx-icon-add"></i> New Load
                    </a>
                </div>
            </div>

            <div id="dlLoadsGrid"></div>

        </div>
    </div>

    <!-- ── Attribute edit popup ────────────────────────────────────────────── -->
    <div class="modal fade" id="dlAttrModal" tabindex="-1" aria-labelledby="dlAttrModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="dlAttrModalLabel">Edit Quality</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="dlAttrTxnId" />

                    <div class="mb-3">
                        <label class="form-label" id="dlAttr1Label">Attribute 1</label>
                        <input type="number" class="form-control" id="dlAttr1Value"
                               min="0.01" step="0.01" placeholder="0.00" inputmode="decimal" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" id="dlAttr2Label">Attribute 2</label>
                        <input type="number" class="form-control" id="dlAttr2Value"
                               min="0.01" step="0.01" placeholder="0.00" inputmode="decimal" />
                    </div>

                    <div id="dlAttrError" class="text-danger small" hidden></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="dlAttrSaveBtn">Save</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Change BOL Type modal ───────────────────────────────────────────── -->
    <div class="modal fade" id="dlHaulerModal" tabindex="-1" aria-labelledby="dlHaulerModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="dlHaulerModalLabel">Change BOL Type</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning mb-3" style="font-size:0.875rem;">
                        <i class="dx-icon dx-icon-warning" style="margin-right:4px;"></i>
                        <strong>Warning:</strong> Changing the BOL type will affect <strong>all loads</strong> on this weight sheet.
                    </div>

                    <div class="px-3 py-2 border border-2 border-warning rounded bg-warning bg-opacity-10">
                        <label class="form-label fw-bold text-dark mb-1" style="font-size:1.05rem;">
                            What is the BOL Type? <span class="text-danger">*</span>
                        </label>
                        <div style="max-width:360px;" class="mt-2">
                            <div id="dlBolTypeSelect"></div>
                        </div>
                        <div id="dlBolTypeHint" class="text-muted small mt-1" hidden></div>

                        <!-- A/F: Hauler + Miles + Calculated Rate -->
                        <div id="dlBolHaulerMiles" class="mt-3" hidden>
                            <div class="gm-gd-fields gm-gd-fields--2col">
                                <div class="gm-gd-field">
                                    <label class="form-label">Hauler <span class="text-danger">*</span></label>
                                    <div id="dlBolHauler"></div>
                                </div>
                                <div class="gm-gd-field" style="max-width:120px;">
                                    <label class="form-label">Miles <span class="text-danger">*</span></label>
                                    <div id="dlBolMiles"></div>
                                </div>
                                <div class="gm-gd-field" id="dlBolCalcRateGroup" style="max-width:200px;" hidden>
                                    <label class="form-label">Calculated Rate</label>
                                    <input type="text" class="form-control" id="dlBolCalcRate" readonly style="text-align:right;" />
                                </div>
                            </div>
                        </div>

                        <!-- C: Hauler + Rate Desc + Rate -->
                        <div id="dlBolCustom" class="mt-3" hidden>
                            <div class="gm-gd-fields gm-gd-fields--2col">
                                <div class="gm-gd-field">
                                    <label class="form-label">Hauler <span class="text-danger">*</span></label>
                                    <div id="dlBolCustomHauler"></div>
                                </div>
                                <div class="gm-gd-field">
                                    <label class="form-label">Rate Description <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="dlBolCustomRateDesc" placeholder="Describe the custom rate..." />
                                </div>
                                <div class="gm-gd-field" style="max-width:120px;">
                                    <label class="form-label">Rate <span class="text-danger">*</span></label>
                                    <div id="dlBolCustomRate"></div>
                                </div>
                            </div>
                        </div>

                        <div id="dlHaulerError" class="text-danger small mt-2" hidden></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="dlHaulerSaveBtn">Update BOL Type</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Bin selection popup ─────────────────────────────────────────────── -->
    <div class="modal fade" id="dlBinModal" tabindex="-1" aria-labelledby="dlBinModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="dlBinModalLabel">Select Bin</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="dlBinGrid"></div>
                    <div id="dlBinError" class="text-danger small mt-2" hidden></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="dlBinSaveBtn" disabled>Assign Bin</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Reprint popup ────────────────────────────────────────────────── -->
    <div class="modal fade" id="dlReprintModal" tabindex="-1" aria-labelledby="dlReprintModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="dlReprintModalLabel">Print Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="dlReprintTxnId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Send to Printer</label>
                        <select class="form-select" id="dlReprintPrinterSelect">
                            <option value="">Loading printers…</option>
                        </select>
                    </div>
                    <div id="dlReprintError" class="text-danger small" hidden></div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-outline-secondary" id="dlBrowserPrintBtn" title="Open PDF in browser">
                        <i class="dx-icon dx-icon-print"></i> Browser Print
                    </button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="dlReprintSendBtn">Print</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Void delivery popup ───────────────────────────────────────────── -->
    <div class="modal fade" id="dlVoidModal" tabindex="-1" aria-labelledby="dlVoidModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="dlVoidModalLabel">Void Ticket</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="dlVoidTxnId" />
                    <div class="mb-3">
                        <label class="form-label">Void Reason <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="dlVoidReason" rows="3"
                                  placeholder="Enter reason for voiding this ticket…"></textarea>
                    </div>
                    <!-- PIN is captured via GM.requestPin when "Void Ticket" is clicked. -->
                    <div id="dlVoidError" class="text-danger small" hidden></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="dlVoidSaveBtn">Void Ticket</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Restore Ticket — uses the shared GM.requestPin modal directly,
         no dedicated dialog needed (PIN is the only input). -->


    <!-- PIN gate is the shared GM.requestPin modal — rendered once by _Layout. -->

    <!-- ── Reassign Lot popup ──────────────────────────────────────────────── -->
    <div class="modal fade" id="dlLotModal" tabindex="-1" aria-labelledby="dlLotModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="dlLotModalLabel">Reassign Lot</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning mb-3" style="font-size:0.875rem;">
                        <i class="dx-icon dx-icon-warning" style="margin-right:4px;"></i>
                        <strong>Warning:</strong> Changing the lot will affect <strong>all loads</strong> on this weight sheet.
                    </div>

                    <!-- Current lot info bar -->
                    <div class="d-flex align-items-center justify-content-between mb-3 p-2 bg-light rounded" id="dlLotCurrentBar">
                        <div style="font-size:0.85rem;">
                            <span class="text-muted">Current lot:</span>
                            <strong id="dlLotCurrentLotNum">—</strong>
                            <span class="text-muted ms-2" id="dlLotCurrentCrop"></span>
                            <span class="text-muted ms-2" id="dlLotCurrentSplit"></span>
                            <span class="text-muted ms-2" id="dlLotCurrentAccount"></span>
                        </div>
                    </div>

                    <!-- Available lots label + New Lot button -->
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="fw-semibold" style="font-size:0.9rem;">Available Lots</div>
                        <a class="btn btn-outline-primary btn-sm" id="dlNewLotBtn"
                           href="/GrowerDelivery/WeightSheetLots">
                            <i class="dx-icon dx-icon-add"></i> New Lot
                        </a>
                    </div>

                    <div id="dlLotGrid"></div>

                    <div class="mt-3 d-flex align-items-end gap-3">
                        <!-- PIN is collected upfront via the PIN-gate modal before
                             this dialog opens. The hidden input keeps the existing
                             saveLot() submit code path working without rework. -->
                        <input type="hidden" id="dlLotPin" />
                        <div id="dlLotError" class="text-danger small" hidden></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="dlLotSaveBtn" disabled>Reassign Lot</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Lot-close blocker: incomplete loads on OTHER weight sheets ──────── -->
    <div class="modal fade" id="dlCloseLotIncompleteModal" tabindex="-1" aria-labelledby="dlCloseLotIncompleteLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="dlCloseLotIncompleteLabel">Cannot Close Lot — Incomplete Loads</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">The lot cannot be closed until every load on it is complete (outbound weight + bin). The following loads still need finishing:</p>
                    <ul class="mb-0" id="dlCloseLotIncompleteList"></ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Lot-close protein warning (allows Finish & Close Lot with confirm) ─ -->
    <div class="modal fade" id="dlCloseLotProteinModal" tabindex="-1" aria-labelledby="dlCloseLotProteinLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="dlCloseLotProteinLabel">Loads Missing Protein</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">The following loads on this lot have no protein recorded. You can still finish &amp; close the lot.</p>
                    <ul class="mb-0" id="dlCloseLotProteinList"></ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-warning" id="dlCloseLotProteinContinue">Finish &amp; Close Lot Anyway</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Incomplete-loads modal (blocks Set Finished) ─────────────────────── -->
    <div class="modal fade" id="dlIncompleteModal" tabindex="-1" aria-labelledby="dlIncompleteLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="dlIncompleteLabel">Cannot Set Finished — Incomplete Loads</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">The following loads need an outbound weight and a bin before this weight sheet can be set to Finished:</p>
                    <ul class="mb-0" id="dlIncompleteList"></ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Protein-missing warning (allows Set Finished with confirm) ───────── -->
    <div class="modal fade" id="dlProteinWarnModal" tabindex="-1" aria-labelledby="dlProteinWarnLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="dlProteinWarnLabel">Loads Missing Protein</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">The following loads have no protein recorded. You can still set this weight sheet to Finished.</p>
                    <ul class="mb-0" id="dlProteinList"></ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-warning" id="dlProteinWarnContinue">Set Finished Anyway</button>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @* signalr.min.js is loaded by _Layout. warehouse.signalr.js exposes
        gmWarehouseRealtime.onWeightSheetUpdated() so this page can refresh
        when other operators modify the same sheet. *@
    <script src="~/js/pages/warehouse.signalr.js" asp-append-version="true"></script>
    <script src="~/js/pages/grower.deliveryloads.js" asp-append-version="true"></script>
}
