@{
    ViewData["Title"] = "Grower Delivery";
}

<link rel="stylesheet" href="~/css/pages/grower.delivery.css" asp-append-version="true" />

<a id="gdModuleBar" href="/WeightSheets/LoadType" class="gm-module-bar gm-module-bar--intake gm-module-bar--link" title="Back to Weight Sheet Type" hidden>
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span id="gdModuleBarIcon" class="gm-module-bar__icon gm-icon gm-icon--delivery" aria-hidden="true"></span>
    <span id="gdModuleBarLabel" class="gm-module-bar__label">GROWER DELIVERY</span>
</a>

<div class="gm-gd">

    <div id="gmGdAlert" class="alert" role="alert" hidden></div>

    <!-- ── Weight sheet details header (shown when wsId is active) ── -->
    <div id="gdWsHeader" class="gm-dl-header" hidden>
        <div class="gm-dl-header__title">
            <span class="gm-dl-header__label">Weight Sheet</span>
            <span class="gm-dl-header__wsid" id="gdWsIdFormatted"></span>
            <span class="gm-dl-header__loadid" id="gdLoadIdDisplay" hidden style="margin-left:12px; font-size:0.9em; color:#555;">
                <span style="font-weight:600;">Load ID:</span>
                <span id="gdLoadIdValue"></span>
            </span>
            <div class="ms-auto d-flex gap-2">
                <button type="button" class="btn btn-outline-danger" id="gdCancelDeliveryBtn">
                    Cancel
                </button>
                <!-- Delete: only revealed by grower.delivery.js when editing
                     an existing load that hasn't been weighed out (no
                     EndQty / DirectQty / CompletedAt). PIN-gated server-side
                     by Privileges.DeleteLoad (14, with admin priv 7 bypass). -->
                <button type="button" class="btn btn-danger" id="gdDeleteLoadBtn" hidden>
                    Delete Load
                </button>
                <button type="button" class="btn btn-outline-primary" id="gdMoveLoadBtn" hidden>
                    Move Load
                </button>
                <button type="submit" form="gmGdForm" class="btn btn-primary" id="gmGdSubmitTop" hidden>
                    Save Load
                </button>
            </div>
        </div>
        <!-- Row 1 — Lot # & Crop -->
        <div class="gm-dl-header__details">
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Lot #</span>
                <span class="gm-dl-header__detail-value" id="gdWsLotId">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Crop</span>
                <span class="gm-dl-header__detail-value" id="gdWsCrop">—</span>
            </div>
        </div>
        <!-- Row 2 — Account & Split -->
        <div class="gm-dl-header__details" style="margin-top:8px;">
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Primary Account</span>
                <span class="gm-dl-header__detail-value" id="gdWsAccount">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Split</span>
                <span class="gm-dl-header__detail-value" id="gdWsSplit">—</span>
            </div>
        </div>
        <!-- Row 3 — Hauler & BOL Type -->
        <div class="gm-dl-header__details" style="margin-top:8px;">
            <div class="gm-dl-header__detail" id="gdWsHaulerField">
                <span class="gm-dl-header__detail-label">Hauler</span>
                <span class="gm-dl-header__detail-value" id="gdWsHauler">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Rate Type</span>
                <span class="gm-dl-header__detail-value" id="gdWsBolType">—</span>
            </div>
        </div>
        <!-- Row 4 — Conditional BOL details -->
        <div class="gm-dl-header__details" style="margin-top:8px;" id="gdWsBolDetailsRow" hidden>
            <div class="gm-dl-header__detail" id="gdWsMilesField" hidden>
                <span class="gm-dl-header__detail-label">Miles</span>
                <span class="gm-dl-header__detail-value" id="gdWsMiles">—</span>
            </div>
            <div class="gm-dl-header__detail" id="gdWsCalcRateField" hidden>
                <span class="gm-dl-header__detail-label">Calculated Rate</span>
                <span class="gm-dl-header__detail-value" id="gdWsCalcRate">—</span>
            </div>
            <div class="gm-dl-header__detail" id="gdWsCustomDescField" hidden>
                <span class="gm-dl-header__detail-label">Rate Description</span>
                <span class="gm-dl-header__detail-value" id="gdWsCustomDesc">—</span>
            </div>
            <div class="gm-dl-header__detail" id="gdWsCustomRateField" hidden>
                <span class="gm-dl-header__detail-label">Rate</span>
                <span class="gm-dl-header__detail-value" id="gdWsCustomRate">—</span>
            </div>
        </div>
    </div>

    <!-- ── Change BOL Type Modal ── -->
    <div class="modal fade" id="gdBolModal" tabindex="-1" aria-labelledby="gdBolModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="gdBolModalLabel">Change BOL Type</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning mb-3" style="font-size:0.875rem;">
                        <i class="dx-icon dx-icon-warning" style="margin-right:4px;"></i>
                        <strong>Warning:</strong> Changing the BOL type will affect <strong>all loads</strong> on this weight sheet.
                    </div>

                    <!-- Yellow BOL section — matches NewWeightSheet style -->
                    <div class="px-3 py-2 border border-2 border-warning rounded bg-warning bg-opacity-10">
                        <label class="form-label fw-bold text-dark mb-1" style="font-size:1.05rem;">
                            What is the BOL Type? <span class="text-danger">*</span>
                        </label>
                        <div style="max-width:360px;" class="mt-2">
                            <div id="gdBolTypeSelect"></div>
                        </div>
                        <div id="gdBolTypeHint" class="text-muted small mt-1" hidden></div>

                        <!-- A/F: Hauler + Miles + Calculated Rate -->
                        <div id="gdBolHaulerMiles" class="mt-3" hidden>
                            <div class="gm-gd-fields gm-gd-fields--2col">
                                <div class="gm-gd-field">
                                    <label class="form-label">Hauler <span class="text-danger">*</span></label>
                                    <div id="gdBolHauler"></div>
                                </div>
                                <div class="gm-gd-field" style="max-width:120px;">
                                    <label class="form-label">Miles <span class="text-danger">*</span></label>
                                    <div id="gdBolMiles"></div>
                                </div>
                                <div class="gm-gd-field" id="gdBolCalcRateGroup" style="max-width:200px;" hidden>
                                    <label class="form-label">Calculated Rate</label>
                                    <input autocomplete="off" type="text" class="form-control" id="gdBolCalcRate" readonly style="text-align:right;" />
                                </div>
                            </div>
                        </div>

                        <!-- C: Hauler + Rate Desc + Rate -->
                        <div id="gdBolCustom" class="mt-3" hidden>
                            <div class="gm-gd-fields gm-gd-fields--2col">
                                <div class="gm-gd-field">
                                    <label class="form-label">Hauler <span class="text-danger">*</span></label>
                                    <div id="gdBolCustomHauler"></div>
                                </div>
                                <div class="gm-gd-field">
                                    <label class="form-label">Rate Description <span class="text-danger">*</span></label>
                                    <input autocomplete="off" type="text" class="form-control" id="gdBolCustomRateDesc" placeholder="Describe the custom rate..." />
                                </div>
                                <div class="gm-gd-field" style="max-width:120px;">
                                    <label class="form-label">Rate <span class="text-danger">*</span></label>
                                    <div id="gdBolCustomRate"></div>
                                </div>
                            </div>
                        </div>

                        <div id="gdBolError" class="text-danger small mt-2" hidden></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="gdBolSaveBtn">Update BOL Type</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Change Lot Modal ── -->
    <div class="modal fade" id="gdLotChangeModal" tabindex="-1" aria-labelledby="gdLotChangeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="gdLotChangeModalLabel">Change Lot</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning mb-3" style="font-size:0.875rem;">
                        <i class="dx-icon dx-icon-warning" style="margin-right:4px;"></i>
                        <strong>Warning:</strong> Changing the lot will affect <strong>all loads</strong> on this weight sheet.
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="fw-semibold">Select a Lot</div>
                        <a class="btn btn-outline-primary btn-sm" href="/GrowerDelivery/WeightSheetLots">
                            <i class="dx-icon dx-icon-add"></i> New Lot
                        </a>
                    </div>

                    <input autocomplete="off" type="text" class="form-control form-control-sm mb-2" id="gdLotChangeSearch" placeholder="Search lots..." />
                    <div id="gdLotChangeGrid"></div>

                    <!-- PIN is captured upfront via GM.requestPin before this modal opens. -->
                    <div id="gdLotChangeError" class="text-danger small mt-2" hidden></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="gdLotChangeSaveBtn" disabled>Change Lot</button>
                </div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_WeightSheets")
    @await Html.PartialAsync("_NewWeightSheet")

    <form id="gmGdForm" novalidate>
        <input autocomplete="off" type="hidden" id="gdLocationId"    name="LocationId" />
        <input autocomplete="off" type="hidden" id="gdWeightSheetUid" name="WeightSheetUid" />
        <input autocomplete="off" type="hidden" id="gdAccountId"      name="AccountId" />
        <input autocomplete="off" type="hidden" id="gdProductId"      name="ProductId" />
        <input autocomplete="off" type="hidden" id="gdLotId"          name="LotId" />
        <input autocomplete="off" type="hidden" id="gdSplitGroupId"   name="SplitGroupId" />
        <input autocomplete="off" type="hidden" id="gdContainerId"    name="ContainerId" />

        <!-- ── New Lot Modal (outside gated body so Bootstrap can show it) ── -->
        <div class="modal fade" id="gdNewLotModal" tabindex="-1"
             aria-labelledby="gdNewLotModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="gdNewLotModalLabel">Create New Lot</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <div class="form-label fw-bold text-muted small">Product</div>
                            <div id="gdNewLotProductName" class="fw-bold">—</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="gdNewLotDesc">
                                Lot Description <span class="text-danger">*</span>
                            </label>
                            <input autocomplete="off" type="text" class="form-control" id="gdNewLotDesc"
                                   maxlength="200" placeholder="e.g. 2025 Winter Wheat Bin 1" />
                        </div>
                        <div id="gdNewLotError" class="text-danger small mt-1" hidden></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary"
                                id="gdNewLotSave">Create Lot</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Form body — hidden until a location is selected ────────── -->
        <div id="gdFormBody" hidden>

            <!-- ── Section 1: Weight Capture ──────────────────────────── -->
            <div class="gm-gd-section gm-gd-section--compact">
                <!-- Method + Truck ID + Bin + Protein, all on one line. Bin
                     gets the flex--grow + min-width:0 treatment so it
                     shrinks first when the row gets crowded. -->
                <div class="gm-gd-method-row">
                    <div class="gm-gd-method-row__field" style="min-width:160px;flex:0 0 auto;">
                        <label class="form-label">Weight Method</label>
                        <div id="gdQtyMethod"></div>
                        <input autocomplete="off" type="hidden" id="gdQtyMethodId" name="QtyMethodId" />
                        <input autocomplete="off" type="hidden" id="gdQtyMethodCode" />
                    </div>
                    <div class="gm-gd-method-row__field" style="width:140px;flex:0 0 auto;">
                        <label class="form-label" for="gdTruckId">Truck ID</label>
                        <input autocomplete="off" type="text" class="form-control" id="gdTruckId" name="TruckId"
                               maxlength="100" placeholder="Truck ID" />
                    </div>
                    <div class="gm-gd-method-row__field" style="flex:0 1 220px;min-width:0;">
                        <label class="form-label">Bin</label>
                        <div id="gdContainer"></div>
                        <input autocomplete="off" type="hidden" id="gdContainerId" />
                    </div>
                    <div class="gm-gd-method-row__field" style="width:70px;flex:0 0 auto;">
                        <label class="form-label" for="gdProtein">Protein (%)</label>
                        <input autocomplete="off" type="number" class="form-control text-end" id="gdProtein" name="Protein"
                               min="0" max="100" step="0.01" placeholder="0.00" inputmode="decimal" style="text-align:right;" />
                    </div>
                </div>

                <!-- ══ Scale mode (TRUCK_SCALE): In / Out / Net in one row ══ -->
                <div id="gdScaleMode" class="gm-gd-weight-row">
                    <!-- In Weight -->
                    <div class="gm-gd-weight-cell" id="gdGrossRow">
                        <div class="gm-gd-weight-cell__head">
                            <span class="gm-gd-weight-cell__label">In Weight <span class="badge bg-secondary" id="gdGrossSourceBadge" hidden></span></span>
                            <span class="gm-gd-weight-cell__time" id="gdGrossTime"></span>
                        </div>
                        <div class="gm-gd-weight-cell__value" id="gdGrossDisplay">— lbs</div>
                        <button type="button" class="btn btn-outline-primary btn-sm gm-gd-weight-cell__btn" id="gdCaptureGross">Capture</button>
                        <input autocomplete="off" type="hidden" id="gdStartQty" name="StartQty" />
                        <input autocomplete="off" type="hidden" id="gdStartedAt" name="StartedAt" />
                        <input autocomplete="off" type="hidden" id="gdStartQtyIsManual" />
                    </div>

                    <!-- Out Weight — hidden until In captured -->
                    <div class="gm-gd-weight-cell" id="gdTareRow" hidden>
                        <div class="gm-gd-weight-cell__head">
                            <span class="gm-gd-weight-cell__label">Out Weight <span class="badge bg-secondary" id="gdTareSourceBadge" hidden></span></span>
                            <span class="gm-gd-weight-cell__time" id="gdTareTime"></span>
                        </div>
                        <div class="gm-gd-weight-cell__value" id="gdTareDisplay">— lbs</div>
                        <button type="button" class="btn btn-outline-secondary btn-sm gm-gd-weight-cell__btn" id="gdCaptureTare" disabled>Capture</button>
                        <input autocomplete="off" type="hidden" id="gdEndQty" name="EndQty" />
                        <input autocomplete="off" type="hidden" id="gdCompletedAt" name="CompletedAt" />
                        <input autocomplete="off" type="hidden" id="gdEndQtyIsManual" />
                    </div>

                    <!-- Net — shown once CompletedAt is set -->
                    <div class="gm-gd-weight-cell gm-gd-weight-cell--net" id="gdScaleNetRow" hidden>
                        <div class="gm-gd-weight-cell__head">
                            <span class="gm-gd-weight-cell__label">Net</span>
                        </div>
                        <div class="gm-gd-weight-cell__value gm-gd-weight-cell__value--net" id="gdNetDisplay">— lbs</div>
                    </div>
                </div>

                <!-- ══ DirectQty mode (MANUAL/RAIL/BULKLOAD) ══ -->
                <div id="gdDirectMode" class="gm-gd-weight-row" hidden>
                    <div class="gm-gd-weight-cell">
                        <div class="gm-gd-weight-cell__head">
                            <span class="gm-gd-weight-cell__label">Net Weight <span class="badge bg-secondary">Manual</span></span>
                            <span class="gm-gd-weight-cell__time" id="gdDirectTime"></span>
                        </div>
                        <div class="gm-gd-weight-cell__value" id="gdDirectDisplay">— lbs</div>
                        <button type="button" class="btn btn-outline-primary btn-sm gm-gd-weight-cell__btn" id="gdEnterAmountBtn">Enter Amount</button>
                        <input autocomplete="off" type="hidden" id="gdDirectQty" name="DirectQty" />
                        <input autocomplete="off" type="hidden" id="gdDirectStartedAt" />
                        <input autocomplete="off" type="hidden" id="gdDirectCompletedAt" />
                    </div>
                </div>
            </div>

            <!-- ── Load Details (Moisture + Driver hidden; Protein and Truck
                 ID promoted to the Method row above; BOL Image tile now
                 lives next to the BOL field). -->
            <div class="gm-gd-section gm-gd-section--compact">
                <!-- Hidden Moisture + Driver inputs kept in the form so any
                     existing JS / save payload that reads them stays valid;
                     just not displayed. -->
                <input autocomplete="off" type="hidden" id="gdMoisture" name="Moisture" />
                <input autocomplete="off" type="hidden" id="gdDriver"   name="Driver" />

                <!-- BOL row:
                     [Bill of Lading + Scan] [BOL tile]   ...   [In tile][Out tile]
                     All three thumbnails top-aligned; In/Out are pushed to
                     the far right via margin-left:auto on their wrapper. -->
                <div class="gm-gd-fields gm-gd-fields--load-row2" style="align-items:flex-start; gap:12px;">
                    <div class="gm-gd-field gm-gd-field--bol" style="flex:0 1 480px;min-width:0;">
                        <label class="form-label" for="gdBOL">Bill of Lading</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="gdBOL" name="BOL"
                                   maxlength="100" placeholder="Bill of Lading"
                                   autocomplete="off" data-lpignore="true" data-1p-ignore="true" data-form-type="other" />
                            <button type="button" class="btn btn-outline-secondary" id="gdBolScanBtn" title="Scan BOL">
                                <i class="dx-icon dx-icon-photo"></i> Scan
                            </button>
                        </div>
                    </div>
                    <div class="gm-gd-thumb" id="gdThumbBol" style="flex:0 0 auto;">
                        <div class="gm-gd-thumb__placeholder">
                            <i class="dx-icon dx-icon-photo" style="font-size:24px;opacity:.4;"></i>
                        </div>
                        <div class="gm-gd-thumb__label">BOL</div>
                    </div>
                    <div class="gm-gd-thumbs" style="margin-left:auto;align-items:flex-start;">
                        <div class="gm-gd-thumb" id="gdThumbIn">
                            <div class="gm-gd-thumb__placeholder">
                                <i class="dx-icon dx-icon-photo" style="font-size:24px;opacity:.4;"></i>
                            </div>
                            <div class="gm-gd-thumb__label">In</div>
                        </div>
                        <div class="gm-gd-thumb" id="gdThumbOut">
                            <div class="gm-gd-thumb__placeholder">
                                <i class="dx-icon dx-icon-photo" style="font-size:24px;opacity:.4;"></i>
                            </div>
                            <div class="gm-gd-thumb__label">Out</div>
                        </div>
                    </div>
                </div>

                <!-- Notes full width -->
                <div style="margin-top:8px;">
                    <div class="gm-gd-field">
                        <label class="form-label" for="gdNotes">Notes</label>
                        <textarea class="form-control" id="gdNotes" name="Notes"
                                  rows="1" maxlength="1000" placeholder="Optional"></textarea>
                    </div>
                </div>
            </div>

        </div><!-- /#gdFormBody -->

    </form>

    <!-- ── Enter Amount Modal (DirectQty mode) ───────────────── -->
    <div class="modal fade" id="gdEnterAmountModal" tabindex="-1" aria-labelledby="gdEnterAmountModalLabel">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="gdEnterAmountModalLabel">Enter Weight</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Weight (lbs) <span class="text-danger">*</span></label>
                        <input autocomplete="off" type="number" class="form-control text-end" id="gdDirectAmountInput"
                               min="1" step="1" placeholder="0" inputmode="numeric" style="text-align:right;" />
                    </div>
                    <!-- PIN is captured upfront via GM.requestPin before this modal opens. -->
                    <div id="gdDirectAmountError" class="text-danger small" hidden></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="gdDirectAmountConfirm">Confirm</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Temp Ticket Picker Modal (opens from Retrieve Temp Weight) ── -->
    <div class="modal fade" id="gdTempTicketModal" tabindex="-1" aria-labelledby="gdTempTicketModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="gdTempTicketModalLabel">Retrieve Temp Weight</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="gdTempTicketList" class="row g-3">
                        <span class="text-muted small">Loading temp tickets…</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Temp Ticket Image Viewer (opens when a thumbnail is clicked) ── -->
    <div class="modal fade" id="gdTempTicketImageModal" tabindex="-1" aria-labelledby="gdTempTicketImageModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="gdTempTicketImageModalLabel">Temp Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <div class="d-flex justify-content-between mb-2 small">
                        <span id="gdTempTicketImageMeta" class="text-muted"></span>
                        <span id="gdTempTicketImageWeight" class="fw-bold"></span>
                    </div>
                    <img id="gdTempTicketImageImg" alt="Temp ticket capture" style="max-width:100%;max-height:60vh;object-fit:contain;" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="gdTempTicketImageUseBtn">
                        <i class="dx-icon dx-icon-check"></i> Use This Weight
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Capture Weight Modal (Scale mode) ─────────────────── -->
    <div class="modal fade" id="gdCaptureWeightModal" tabindex="-1" aria-labelledby="gdCaptureWeightModalLabel">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="gdCaptureWeightModalLabel">Select Scale</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="gdCaptureScaleList" class="d-grid gap-2 mb-3">
                        <span class="text-muted small">Loading scales...</span>
                    </div>
                    <hr />
                    <!-- Retrieve Temp Weight — shown above Manual Entry only on
                         inbound capture (captureTarget === 'start') and only
                         when at least one unconsumed temp ticket exists for
                         this server today. Wired up in grower.delivery.js. -->
                    <button type="button" class="btn btn-success w-100 mb-2" id="gdRetrieveTempBtn" hidden>
                        <i class="dx-icon dx-icon-clock"></i> Retrieve Temp Weight
                        <span class="badge bg-light text-dark ms-1" id="gdRetrieveTempCount">0</span>
                    </button>
                    <button type="button" class="btn btn-outline-secondary w-100" id="gdCaptureManualBtn">
                        <i class="dx-icon dx-icon-edit"></i> Manual Entry
                    </button>

                    <!-- Manual entry sub-panel (hidden until Manual clicked) -->
                    <div id="gdCaptureManualPanel" class="mt-3" hidden>
                        <div class="mb-2">
                            <label class="form-label">Weight (lbs) <span class="text-danger">*</span></label>
                            <input autocomplete="off" type="number" class="form-control text-end" id="gdCaptureManualInput"
                                   min="0" step="1" placeholder="0" inputmode="numeric" style="text-align:right;" />
                        </div>
                        <!-- PIN is captured upfront via GM.requestPin before this panel is revealed. -->
                        <button type="button" class="btn btn-primary w-100" id="gdCaptureManualConfirm">
                            Confirm Manual Weight
                        </button>
                    </div>

                    <div id="gdCaptureWeightError" class="text-danger small mt-2" hidden></div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- New-WS PIN gate uses the shared GM.requestPin modal — see _GmPinPromptModal. -->

<!-- ── Move Load modal ──────────────────────────────────────── -->
<div class="modal fade" id="gdMoveLoadModal" tabindex="-1" aria-labelledby="gdMoveLoadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="gdMoveLoadModalLabel">Move Load to Another Weight Sheet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info" style="font-size:0.875rem;">
                    Select a destination weight sheet for this load. Any sheet at this
                    location/server that is still <strong>open</strong> (under 25 loads)
                    is listed. Or create a new weight sheet for this lot and move there.
                </div>

                <!-- Cross-lot/variety warning — populated by JS on selection -->
                <div id="gdMoveLotWarn" class="alert alert-danger" style="font-size:0.9rem;" hidden>
                    <i class="dx-icon dx-icon-warning" style="margin-right:4px;"></i>
                    <strong>Warning:</strong>
                    <span id="gdMoveLotWarnText"></span>
                </div>

                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="fw-semibold">Available Weight Sheets</div>
                    <button type="button" class="btn btn-outline-primary btn-sm" id="gdMoveCreateWsBtn">
                        <i class="dx-icon dx-icon-add"></i> Create New Weight Sheet
                    </button>
                </div>

                <div id="gdMoveCandidatesGrid"></div>

                <div id="gdMoveError" class="text-danger small mt-2" hidden></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="gdMoveConfirmBtn" disabled>Move Load</button>
            </div>
        </div>
    </div>
</div>

<!-- Move-Load PIN gate uses the shared GM.requestPin modal — see _GmPinPromptModal. -->

<!-- ── Weight edit PIN confirmation modal ───────────────────── -->
<div class="modal fade" id="gdWeightEditPinModal" tabindex="-1" aria-labelledby="gdWeightEditPinLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title" id="gdWeightEditPinLabel">Confirm Weight Change</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">A previously recorded weight has been modified. Enter your PIN to authorize this change.</p>
                <div id="gdWeightEditPinChanges" class="small mb-3"></div>
                <div>
                    <label class="form-label">PIN <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="gdWeightEditPin"
                           inputmode="numeric" maxlength="10" placeholder="Enter PIN"
                           autocomplete="off" data-lpignore="true" data-1p-ignore="true"
                           data-form-type="other"
                           style="max-width:160px; -webkit-text-security:disc;" />
                </div>
                <div id="gdWeightEditPinError" class="text-danger small mt-2" hidden></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" id="gdWeightEditPinConfirm">Confirm & Save</button>
            </div>
        </div>
    </div>
</div>

<!-- ── Delete-load confirmation popup ────────────────────────────────────-->
<div class="modal fade" id="gdDeleteLoadModal" tabindex="-1" aria-labelledby="gdDeleteLoadLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="gdDeleteLoadLabel">Delete Load?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">This permanently removes the load.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="gdDeleteLoadConfirmBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@* BOL camera picker — populated lazily; safe to include unconditionally
   because the Scan BOL button stays hidden when no BOL cameras exist. *@
@await Html.PartialAsync("_ScanBolModal")

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/pages/load-images.js" asp-append-version="true"></script>
    <script src="~/js/pages/grower.delivery.js" asp-append-version="true"></script>
}
