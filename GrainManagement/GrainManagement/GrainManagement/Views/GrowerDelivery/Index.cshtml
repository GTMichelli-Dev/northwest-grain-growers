@{
    ViewData["Title"] = "Grower Delivery";
}

<link rel="stylesheet" href="~/css/pages/grower.delivery.css" asp-append-version="true" />

@await Html.PartialAsync("_ScaleWeight")

<div class="gm-pagehead gm-pagehead--sticky">
    <div class="gm-pagehead__title">
        <span class="gm-pagehead__icon gm-icon gm-icon--delivery" aria-hidden="true"></span>
        <span>Grower Delivery</span>
    </div>
    <div class="gm-pagehead__right">
        <a class="btn btn-outline-secondary btn-sm" id="gdCancelBtn" href="/Warehouse/LoadType">Cancel</a>
    </div>
</div>

<div class="gm-gd">

    <div id="gmGdAlert" class="alert" role="alert" hidden></div>

    <!-- ── Weight sheet details header (shown when wsId is provided) ── -->
    <div id="gdWsHeader" class="gm-dl-header" hidden>
        <div class="gm-dl-header__title">
            <span class="gm-dl-header__label">Weight Sheet</span>
            <span class="gm-dl-header__wsid" id="gdWsIdFormatted"></span>
        </div>
        <div class="gm-dl-header__details">
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Lot</span>
                <span class="gm-dl-header__detail-value" id="gdWsLot">—</span>
            </div>
            <div class="gm-dl-header__detail">
                <span class="gm-dl-header__detail-label">Hauler</span>
                <span class="gm-dl-header__detail-value" id="gdWsHauler">—</span>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_WeightSheets")
    @await Html.PartialAsync("_NewWeightSheet")

    <form id="gmGdForm" novalidate>
        <input type="hidden" id="gdLocationId"    name="LocationId" />
        <input type="hidden" id="gdWeightSheetUid" name="WeightSheetUid" />

        <!-- ── New Lot Modal (outside gated body so Bootstrap can show it) ── -->
        <div class="modal fade" id="gdNewLotModal" tabindex="-1"
             aria-labelledby="gdNewLotModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="gdNewLotModalLabel">Create New Lot</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <div class="form-label fw-bold text-muted small">Product</div>
                            <div id="gdNewLotProductName" class="fw-bold">—</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="gdNewLotDesc">
                                Lot Description <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" id="gdNewLotDesc"
                                   maxlength="200" placeholder="e.g. 2025 Winter Wheat Bin 1" />
                        </div>
                        <div id="gdNewLotError" class="text-danger small mt-1" hidden></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary"
                                id="gdNewLotSave">Create Lot</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Form body — hidden until a location is selected ────────── -->
        <div id="gdFormBody" hidden>

            <!-- ── Section 1: Delivery Details ──────────────────────── -->
            <div class="gm-gd-section">
                <div class="gm-gd-section__title">Delivery Details</div>
                <div class="gm-gd-fields gm-gd-fields--2col">

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdAccount">Grower Account <span class="text-danger">*</span></label>
                        <div id="gdAccount"></div>
                        <input type="hidden" id="gdAccountId" name="AccountId" />
                    </div>

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdProduct">Product <span class="text-danger">*</span></label>
                        <div id="gdProduct"></div>
                        <input type="hidden" id="gdProductId" name="ProductId" />
                    </div>

                    <div class="gm-gd-field gm-gd-field--full">
                        <label class="form-label">Lot <span class="text-danger">*</span></label>
                        <div class="gm-gd-lot-row">
                            <div id="gdLot" class="gm-gd-lot-select"></div>
                            <button type="button" class="btn btn-outline-primary gm-gd-lot-new"
                                    id="gdNewLotBtn" disabled title="Select a product first">
                                + New Lot
                            </button>
                        </div>
                        <input type="hidden" id="gdLotId" name="LotId" />
                    </div>

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdSplitGroup">Split Group</label>
                        <div id="gdSplitGroup"></div>
                        <input type="hidden" id="gdSplitGroupId" name="SplitGroupId" />
                    </div>

                </div>
            </div>

            <!-- ── Section 2: Weight Capture ──────────────────────────── -->
            <div class="gm-gd-section">
                <div class="gm-gd-section__title">Weights</div>

                <div class="gm-gd-weight">

                    <!-- Gross -->
                    <div class="gm-gd-weight__row" id="gdGrossRow">
                        <div class="gm-gd-weight__meta">
                            <div class="gm-gd-weight__label">Gross</div>
                            <div class="gm-gd-weight__time" id="gdGrossTime">—</div>
                        </div>
                        <div class="gm-gd-weight__value" id="gdGrossDisplay">— lbs</div>
                        <button type="button" class="btn btn-outline-primary gm-gd-weight__capture" id="gdCaptureGross">
                            Capture Gross
                        </button>
                        <input type="hidden" id="gdStartQty" name="StartQty" />
                        <input type="hidden" id="gdStartedAt" name="StartedAt" />
                    </div>

                    <!-- Tare -->
                    <div class="gm-gd-weight__row" id="gdTareRow">
                        <div class="gm-gd-weight__meta">
                            <div class="gm-gd-weight__label">Tare</div>
                            <div class="gm-gd-weight__time" id="gdTareTime">—</div>
                        </div>
                        <div class="gm-gd-weight__value" id="gdTareDisplay">— lbs</div>
                        <button type="button" class="btn btn-outline-secondary gm-gd-weight__capture" id="gdCaptureTare" disabled>
                            Capture Tare
                        </button>
                        <input type="hidden" id="gdEndQty" name="EndQty" />
                        <input type="hidden" id="gdCompletedAt" name="CompletedAt" />
                    </div>

                    <!-- Net -->
                    <div class="gm-gd-weight__row gm-gd-weight__row--net">
                        <div class="gm-gd-weight__meta">
                            <div class="gm-gd-weight__label">Net</div>
                        </div>
                        <div class="gm-gd-weight__value gm-gd-weight__value--net" id="gdNetDisplay">— lbs</div>
                        <div class="gm-gd-weight__capture"></div><!-- spacer -->
                    </div>

                </div>
            </div>

            <!-- ── Section 3: Load Details ────────────────────────────── -->
            <div class="gm-gd-section">
                <div class="gm-gd-section__title">Load Details</div>
                <div class="gm-gd-fields gm-gd-fields--3col">

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdMoisture">Moisture (%)</label>
                        <input type="number" class="form-control" id="gdMoisture" name="Moisture"
                               min="0" max="100" step="0.01" placeholder="0.00" inputmode="decimal" />
                    </div>

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdProtein">Protein (%)</label>
                        <input type="number" class="form-control" id="gdProtein" name="Protein"
                               min="0" max="100" step="0.01" placeholder="0.00" inputmode="decimal" />
                    </div>

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdBOL">BOL</label>
                        <input type="text" class="form-control" id="gdBOL" name="BOL"
                               maxlength="100" placeholder="Bill of Lading" />
                    </div>

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdTruckId">Truck ID</label>
                        <input type="text" class="form-control" id="gdTruckId" name="TruckId"
                               maxlength="100" placeholder="Truck identifier" />
                    </div>

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdDriver">Driver</label>
                        <input type="text" class="form-control" id="gdDriver" name="Driver"
                               maxlength="100" placeholder="Driver name" />
                    </div>

                </div>
            </div>

            <!-- ── Section 4: Container & Notes ──────────────────────── -->
            <div class="gm-gd-section">
                <div class="gm-gd-section__title">Additional Info</div>
                <div class="gm-gd-fields gm-gd-fields--2col">

                    <div class="gm-gd-field">
                        <label class="form-label" for="gdContainer">Destination Container</label>
                        <div id="gdContainer"></div>
                        <input type="hidden" id="gdContainerId" name="ToContainerId" />
                    </div>

                    <div class="gm-gd-field gm-gd-field--full">
                        <label class="form-label" for="gdNotes">Notes</label>
                        <textarea class="form-control" id="gdNotes" name="Notes"
                                  rows="3" maxlength="1000" placeholder="Optional delivery notes…"></textarea>
                    </div>

                </div>
            </div>

            <!-- ── Submit ─────────────────────────────────────────────── -->
            <div class="gm-gd-actions">
                <button type="submit" class="btn btn-primary btn-lg" id="gmGdSubmit">
                    Save Delivery
                </button>
            </div>

        </div><!-- /#gdFormBody -->

    </form>
</div>

@section Scripts {
    <script src="~/js/pages/grower.delivery.js" asp-append-version="true"></script>
}
