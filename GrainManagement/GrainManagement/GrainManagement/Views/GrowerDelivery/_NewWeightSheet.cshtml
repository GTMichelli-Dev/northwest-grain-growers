<!-- ── New Weight Sheet Panel ─────────────────────────────────────────────── -->
<div id="gdNewWsPanel" hidden>
    <div class="gm-gd-section">

        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="gm-gd-section__title" style="margin-bottom:0">Select Weight Sheet Lot</div>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="gdCancelNewWsBtn">
                ← Back
            </button>
        </div>

        <!-- ── Available WS lots at this location ── -->
        <div id="gdNwsLotList" class="mb-4">
            <!-- Populated by JS: rows or empty-state message -->
        </div>

        <!-- ── Create a new weight sheet lot ── -->
        <div class="gm-gd-nws-create">

            <div class="gm-gd-section__title">Create New Weight Sheet Lot</div>

            <div class="gm-gd-fields gm-gd-fields--2col">

                <div class="gm-gd-field">
                    <label class="form-label">
                        Account <span class="text-danger">*</span>
                    </label>
                    <div id="gdNwsAccount"></div>
                </div>

                <div class="gm-gd-field">
                    <label class="form-label">
                        Split Group <span class="text-danger">*</span>
                    </label>
                    <div id="gdNwsSplitGroup"></div>
                </div>

                <div class="gm-gd-field gm-gd-field--full">
                    <label class="form-label">Lot Description</label>
                    <input type="text" class="form-control" id="gdNwsLotDesc"
                           readonly placeholder="Auto-filled from split group selection" />
                </div>

            </div>

            <div id="gdNwsCreateError" class="text-danger small mt-2" hidden></div>

            <div class="mt-3">
                <button type="button" class="btn btn-outline-primary" id="gdCreateWsLotBtn">
                    + Create Lot
                </button>
            </div>

        </div>

        <!-- ── Proceed button ── -->
        <hr class="my-4" />

        <div class="d-flex align-items-center gap-3">
            <button type="button" class="btn btn-primary" id="gdCreateWsBtn" disabled>
                Create Weight Sheet
            </button>
            <span id="gdNwsSelectedLotName" class="text-muted small fst-italic"></span>
        </div>

        <div id="gdNewWsError" class="text-danger small mt-2" hidden></div>

    </div>
</div>
