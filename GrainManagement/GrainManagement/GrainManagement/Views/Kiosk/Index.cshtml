@{
    Layout = null;
    var themeKey = Context.Items["ThemeKey"]?.ToString() ?? "default";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=1280, height=800, initial-scale=1.0, user-scalable=no" />
    <title>Kiosk</title>
    <link href="~/assets/branding/@(themeKey)/favicon.ico" rel="shortcut icon" type="image/x-icon" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; }
        body {
            min-height: 100%;
            background: #ffffff;
            color: #111;
            font-family: 'Segoe UI', Arial, sans-serif;
            user-select: none;
            -webkit-user-select: none;
            cursor: default;
            overflow: hidden;
        }

        #kiosk-wrapper {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        /* Fixed 1280x800 canvas — same dimensions as the BasicWeigh kiosk
           so it drops onto the same touchscreen panels without rescaling. */
        #kiosk {
            width: 1280px;
            height: 800px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            background: #ffffff;
        }

        /* ===== HEADER ===== */
        #kiosk-header {
            height: 104px;
            display: flex;
            align-items: center;
            padding: 0 20px;
            background: #ffffff;
            border-bottom: 1px solid #e8e8e8;
            flex-shrink: 0;
            position: relative;
        }
        /* Brand mark sized for at-a-glance recognition across the room
           (60px → 66px → 80px through successive feedback rounds). */
        #brand-logo {
            height: 80px;
            width: auto;
            cursor: pointer;
        }
        #kiosk-id {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.9rem;
            color: #555;
            font-family: 'Courier New', monospace;
            letter-spacing: 1px;
            text-align: right;
        }

        /* ===== WEIGHT DISPLAY ===== */
        #weight-area {
            text-align: center;
            padding: 14px 0;
            flex-shrink: 0;
        }
        #weight-display {
            font-family: 'Courier New', monospace;
            font-weight: 900;
            text-align: center;
            display: inline-flex;
            align-items: baseline;
            justify-content: center;
            padding: 10px 20px;
            border-radius: 16px;
            background: #ffffff;
            border: 3px solid #ccc;
            letter-spacing: 2px;
            width: 1180px;
            white-space: nowrap;
            overflow: hidden;
            transition: color 0.2s, background 0.2s, border-color 0.2s;
        }
        /* +20% on the digits for at-a-glance readability across the room. */
        #weight-display.size-huge   { font-size: 11.4rem; line-height: 1.1; }
        #weight-display.size-medium { font-size: 4.8rem;  line-height: 1.1; }
        /* Light-mode weight states match BasicWeigh: black digits on white
           when ok, black on yellow on motion, white on red on error. */
        #weight-display.weight-ok     { color: #000; background: #ffffff; }
        #weight-display.weight-motion { color: #000; background: #ffc107; border-color: #d39e00; }
        #weight-display.weight-error  { color: #fff; background: #dc3545; border-color: #b02a37; }
        #weight-unit  { font-size: 3rem; opacity: 0.6; margin-left: 10px; flex-shrink: 0; }
        #scale-status {
            font-size: 1.4rem;
            font-weight: bold;
            letter-spacing: 3px;
            min-height: 1.6em;
            margin-top: 4px;
            color: #333;
        }

        /* ===== CONTENT AREA ===== */
        #content-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 10px 40px;
        }

        .kiosk-state { display: none; width: 100%; text-align: center; }
        .kiosk-state.active { display: flex; flex-direction: column; align-items: center; justify-content: center; }

        /* ===== BIG MESSAGE ===== */
        /* Bumped again (+20% on top of the prior +30%) for at-a-glance
           readability — the operator is often across the room. */
        .big-message {
            font-size: 5.4rem;
            font-weight: 900;
            letter-spacing: 3px;
            text-transform: uppercase;
            line-height: 1.2;
            color: #111;
        }
        .big-message.muted { color: #555; opacity: 0.85; }
        .big-message.attention { animation: pulse 2s ease-in-out infinite; }
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50%      { opacity: 0.55; }
        }
        .three-line { font-size: 4.7rem; font-weight: 900; line-height: 1.4; color: #111; text-transform: uppercase; letter-spacing: 3px; }

        /* SCALE ERROR prompt — same size as .big-message, but red on the
           light theme so the operator can't miss it across the room. */
        .scale-error-text { color: #dc3545; }

        /* ===== LIST SELECTOR (setup pickers) ===== */
        .list-selector { width: 100%; max-width: 800px; }
        .list-title {
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            margin-bottom: 12px;
            text-transform: uppercase;
            color: #222;
        }
        .list-hint { font-size: 1rem; color: #555; margin-bottom: 16px; letter-spacing: 1px; }
        .list-container {
            background: #ffffff;
            border: 2px solid #ccc;
            border-radius: 12px;
            max-height: 420px;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: #bbb #fff;
            /* Leaves a row's worth of breathing room above and below
               the selected item when scrollIntoView pulls it into view,
               so the highlight never sits flush against the rounded
               border (which used to look like the selection was being
               hidden under the panel edge). */
            scroll-padding-top: 24px;
            scroll-padding-bottom: 24px;
        }
        .list-item {
            padding: 16px 24px;
            font-size: 1.6rem;
            color: #222;
            border-bottom: 1px solid #e0e0e0;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            gap: 20px;
        }
        .list-item:last-child { border-bottom: none; }
        .list-item.selected {
            background: #28a745;
            color: #ffffff;
            font-weight: 700;
        }
        .list-item.selected::before { content: '\25B6  '; }
        .list-item .list-id {
            color: #c97a00;
            font-family: 'Courier New', monospace;
            font-weight: 700;
        }
        .list-item.selected .list-id { color: #fff; }

        .direct-entry {
            margin-top: 12px;
            font-family: 'Courier New', monospace;
            font-size: 1.5rem;
            color: #007bff;
            min-height: 2rem;
            letter-spacing: 4px;
        }
        .list-buttons {
            display: flex;
            justify-content: center;
            margin-top: 16px;
            gap: 20px;
        }
        .list-btn {
            padding: 16px 40px;
            font-size: 1.4rem;
            font-weight: 700;
            border: 3px solid;
            border-radius: 12px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .list-btn-select { background: #28a745; border-color: #1e7e34; color: #fff; }
        .list-btn-cancel { background: #dc3545; border-color: #bd2130; color: #fff; }

        /* ===== FULLSCREEN OVERLAYS ===== */
        .overlay-screen {
            position: absolute;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            z-index: 100;
        }
        .overlay-screen.active { display: flex; }
        .overlay-red { background: #dc3545; color: #fff; }
        .overlay-message {
            font-size: 4.5rem;
            font-weight: 800;
            letter-spacing: 3px;
            text-transform: uppercase;
            text-align: center;
            padding: 40px;
        }
        .overlay-sub { font-size: 2rem; opacity: 0.95; margin-top: 10px; }

        .ticket-prompt {
            text-align: center;
        }
        .ticket-prompt .label {
            font-size: 4.7rem;
            font-weight: 900;
            margin-bottom: 16px;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #333;
        }
        .ticket-prompt .value {
            font-family: 'Courier New', monospace;
            font-size: 5rem;
            font-weight: bold;
            color: #007bff;
            letter-spacing: 8px;
            min-height: 6rem;
            background: #fff;
            border: 2px solid #ccc;
            border-radius: 12px;
            padding: 6px 24px;
            display: inline-block;
        }

        .lime-screen {
            background: #32cd32;
            color: #000;
        }
        .lime-screen .big-message { color: #000; font-weight: 900; }

        /* ===== IN-PAGE ALERT MODAL =====
           Bootstrap-styled alert+modal pair so the kiosk never has to
           fall back on browser-chrome window.confirm popups (those steal
           focus + key events from the kiosk's own state machine). */
        .kiosk-alert-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.55);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 200;
        }
        .kiosk-alert-backdrop.active { display: flex; }
        .kiosk-alert-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
            min-width: 540px;
            max-width: 760px;
            overflow: hidden;
            border: 1px solid #dee2e6;
        }
        .kiosk-alert-body {
            padding: 0;
        }
        .kiosk-alert-banner {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 22px 26px;
            background: #f8d7da;
            color: #58151c;
            border-bottom: 1px solid #f1aeb5;
        }
        .kiosk-alert-banner .icon {
            font-size: 2.2rem;
            line-height: 1;
            flex-shrink: 0;
        }
        .kiosk-alert-title {
            font-size: 1.6rem;
            font-weight: 800;
            margin-bottom: 4px;
        }
        .kiosk-alert-message {
            font-size: 1.15rem;
            line-height: 1.35;
        }
        .kiosk-alert-footer {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            padding: 16px 22px;
            background: #fff;
        }
        .kiosk-alert-btn {
            padding: 12px 32px;
            font-size: 1.15rem;
            font-weight: 700;
            border-radius: 8px;
            border: 2px solid;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .kiosk-alert-btn-cancel { background: #fff; border-color: #adb5bd; color: #495057; }
        .kiosk-alert-btn-cancel:hover { background: #f1f3f5; }
        .kiosk-alert-btn-confirm { background: #dc3545; border-color: #b02a37; color: #fff; }
        .kiosk-alert-btn-confirm:hover { background: #b02a37; }
        .kiosk-alert-keys {
            margin-top: 6px;
            font-size: 0.85rem;
            color: #6c757d;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>
<div id="kiosk-wrapper">
<div id="kiosk">
    <!-- HEADER -->
    <div id="kiosk-header">
        @* Same B&W logo the load tickets render. The .resx in the
           XtraReports embeds it as base64; the file on disk is logoBW.jpg
           under the brand folder. *@
        <img id="brand-logo"
             src="~/assets/branding/@(themeKey)/logoBW.jpg"
             alt="Brand"
             title="Hold for 3 seconds to edit kiosk parameters" />
        <div id="kiosk-id">&nbsp;</div>
    </div>

    <!-- WEIGHT DISPLAY (shown in normal mode) -->
    <div id="weight-area" style="display:none;">
        <div id="weight-display" class="size-huge weight-ok">
            <span id="weight-value">0</span><span id="weight-unit"> lb</span>
        </div>
        <div id="scale-status">&nbsp;</div>
    </div>

    <!-- CONTENT AREA -->
    <div id="content-area">

        <!-- SETUP: Picker (re-used for all 4 setup steps) -->
        <div id="state-setup" class="kiosk-state active">
            <div class="list-selector">
                <div class="list-title" id="setup-title">Setup</div>
                <div class="list-hint" id="setup-hint">Use &#9650; / &#9660; to highlight, type ID directly, or scroll &mdash; press Enter to confirm</div>
                <div class="list-container" id="setup-list"></div>
                <div class="direct-entry" id="setup-direct">&nbsp;</div>
                <div class="list-buttons">
                    <button class="list-btn list-btn-select" id="setup-select">Confirm (Enter)</button>
                </div>
            </div>
        </div>

        <!-- NORMAL: Drive on -->
        <div id="state-driveon" class="kiosk-state">
            <div class="big-message attention">Drive On Scale To Start</div>
        </div>

        <!-- SCALE ERROR (scale itself reports Ok=false; comms still up) -->
        <div id="state-scale-error" class="kiosk-state">
            <div class="big-message attention scale-error-text">Scale Error</div>
            <div class="big-message muted" style="font-size:1.6rem; letter-spacing:2px; margin-top:14px; animation:none;">
                Check scale connection
            </div>
        </div>

        <!-- NORMAL: Truck on scale (Scan / Or / Wait) -->
        <div id="state-ready" class="kiosk-state">
            <div class="three-line">Scan Ticket</div>
            <div class="three-line muted">Or</div>
            <div class="three-line">Wait For Clerk</div>
        </div>

        <!-- ENTERING TICKET (Phase 3) -->
        <div id="state-entering-ticket" class="kiosk-state">
            <div class="ticket-prompt">
                <div class="label">Enter Ticket #</div>
                <div class="value" id="ticket-value">&nbsp;</div>
            </div>
        </div>

        <!-- MOTION-WAIT (Phase 3) -->
        <div id="state-motion-wait" class="kiosk-state">
            <div class="big-message attention">Waiting for Scale to Settle...</div>
        </div>

        <!-- COMPLETE / PRINTING (Phase 3 / 4) -->
        <div id="state-complete" class="kiosk-state lime-screen">
            <div class="big-message">Ticket Printed</div>
            <div id="complete-ticket-no" style="font-family:'Courier New',monospace; font-weight:900; font-size:3.5rem; color:#000; margin-top:6px;">&nbsp;</div>

            <div id="complete-detail" style="margin-top:18px; font-size:1.6rem; color:#000; text-align:center; line-height:1.6;">
                <div><span style="font-weight:700;">Location:</span>  <span id="complete-location">&mdash;</span></div>
                <div><span style="font-weight:700;">Commodity:</span> <span id="complete-commodity">&mdash;</span></div>
                <div><span style="font-weight:700;">Account:</span>   <span id="complete-account">&mdash;</span></div>
                <div><span style="font-weight:700;">Truck #:</span>   <span id="complete-truck">&mdash;</span></div>
            </div>

            <!-- Inbound: just the stored weight -->
            <div id="complete-inbound-weights" style="margin-top:16px; font-size:2rem; font-weight:900; color:#000;" hidden>
                <span>Stored Weight:</span>
                <span id="complete-inbound-weight" style="font-family:'Courier New',monospace; margin-left:10px;">&mdash;</span>
            </div>

            <!-- Outbound: gross / tare / net stack -->
            <div id="complete-outbound-weights" style="margin-top:16px; font-size:1.7rem; font-weight:800; color:#000; text-align:center; line-height:1.55;" hidden>
                <div><span>Gross:</span> <span id="complete-gross" style="font-family:'Courier New',monospace; font-weight:900;">&mdash;</span></div>
                <div><span>Tare:</span>  <span id="complete-tare"  style="font-family:'Courier New',monospace; font-weight:900;">&mdash;</span></div>
                <div><span>Net:</span>   <span id="complete-net"   style="font-family:'Courier New',monospace; font-weight:900;">&mdash;</span></div>
            </div>

            <div style="margin-top:16px; font-size:1.3rem; color:#000;">Press Enter to reprint &middot; Drive off to reset</div>
        </div>
    </div>

    <!-- FULLSCREEN OVERLAYS -->
    <div id="overlay-comm-error" class="overlay-screen overlay-red">
        <div class="overlay-message">Communication Error</div>
        <div class="overlay-sub">Contact Office</div>
    </div>
    <div id="overlay-ticket-error" class="overlay-screen overlay-red">
        <div class="overlay-message" id="ticket-error-msg">Ticket Not Found</div>
        <div class="overlay-sub" id="ticket-error-sub">Please try again</div>
    </div>

    <!-- In-page Bootstrap-style alert modal (replaces window.confirm) -->
    <div id="kiosk-alert" class="kiosk-alert-backdrop" role="dialog" aria-modal="true" aria-labelledby="kiosk-alert-title">
        <div class="kiosk-alert-card">
            <div class="kiosk-alert-body">
                <div class="kiosk-alert-banner">
                    <span class="icon" aria-hidden="true">&#9888;</span>
                    <div>
                        <div id="kiosk-alert-title" class="kiosk-alert-title">Confirm</div>
                        <div id="kiosk-alert-message" class="kiosk-alert-message">Are you sure?</div>
                        <div class="kiosk-alert-keys">Enter to confirm &middot; Esc to cancel</div>
                    </div>
                </div>
            </div>
            <div class="kiosk-alert-footer">
                <button type="button" id="kiosk-alert-cancel" class="kiosk-alert-btn kiosk-alert-btn-cancel">Cancel</button>
                <button type="button" id="kiosk-alert-ok"     class="kiosk-alert-btn kiosk-alert-btn-confirm">Confirm</button>
            </div>
        </div>
    </div>
</div>
</div>

<script src="~/lib/signalr/signalr.min.js"></script>
<script>
// Register the kiosk service worker so a cold reboot with the website
// offline still loads the cached kiosk shell (instead of the browser's
// "can't reach this page" error). The kiosk's own SignalR retry loop
// + the red No-Communication overlay take it from there until the
// server comes back online.
if ('serviceWorker' in navigator) {
    window.addEventListener('load', function () {
        try {
            navigator.serviceWorker.register('/kiosk-sw.js')
                .catch(function (err) { console.warn('Kiosk SW register failed:', err); });
        } catch (e) { /* swallow */ }
    });
}
</script>
<script>
(function () {
    'use strict';

    // ==================================================================
    //  CONFIG
    // ==================================================================
    var COOKIE_LOCATION   = 'GrainMgmt_KioskLocationId';
    var COOKIE_PRINTER    = 'GrainMgmt_KioskPrinterId';
    var COOKIE_SCALE      = 'GrainMgmt_KioskScaleId';
    var COOKIE_KIOSKTYPE  = 'GrainMgmt_KioskType';
    var COOKIE_DAYS       = 36500;     // ~100 years -- "permanent"
    var WEIGHT_THRESHOLD  = 1000;      // truck-on-scale threshold (lbs)
    var COMM_ERROR_MS     = 2000;      // 2 seconds without scale data -> red
    var LONGPRESS_MS      = 3000;      // hold logo for 3s to re-enter setup

    var KIOSK_TYPES = [
        { id: 0, name: 'Single' },
        { id: 1, name: 'Inbound' },
        { id: 2, name: 'Outbound' },
    ];

    // ==================================================================
    //  COOKIE HELPERS
    // ==================================================================
    function setCookie(name, value, days) {
        var d = new Date();
        d.setTime(d.getTime() + (days * 86400000));
        document.cookie = name + '=' + encodeURIComponent(value)
            + '; expires=' + d.toUTCString() + '; path=/; SameSite=Lax';
    }
    function getCookie(name) {
        var m = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return m ? decodeURIComponent(m[2]) : null;
    }
    function clearAllSetupCookies() {
        [COOKIE_LOCATION, COOKIE_PRINTER, COOKIE_SCALE, COOKIE_KIOSKTYPE].forEach(function (n) {
            document.cookie = n + '=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/';
        });
    }

    // ==================================================================
    //  STATE
    // ==================================================================
    var params = {
        locationId: parseInt(getCookie(COOKIE_LOCATION),  10) || null,
        printerId:  getCookie(COOKIE_PRINTER) || null,
        scaleId:    parseInt(getCookie(COOKIE_SCALE),     10) || null,
        kioskType:  (function () { var v = getCookie(COOKIE_KIOSKTYPE); return v == null ? null : parseInt(v, 10); })(),
    };

    // Resolved label data (filled in after each picker resolves)
    var resolved = {
        locationName: null,
        printerName:  null,
        scaleName:    null,
    };

    var setupSteps = ['location', 'printer', 'scale', 'kioskType'];
    var setupIndex = 0;

    var setupItems = [];      // current picker's items
    var setupSelected = 0;    // highlight index
    var setupDirect = '';     // direct-entry buffer

    var currentScreen = 'setup';

    // ==================================================================
    //  DOM
    // ==================================================================
    var el = {
        list:     document.getElementById('setup-list'),
        title:    document.getElementById('setup-title'),
        hint:     document.getElementById('setup-hint'),
        direct:   document.getElementById('setup-direct'),
        kioskId:  document.getElementById('kiosk-id'),
        weightArea: document.getElementById('weight-area'),
        weightVal:  document.getElementById('weight-value'),
        scaleStatus: document.getElementById('scale-status'),
        commErr:    document.getElementById('overlay-comm-error'),
    };

    // ==================================================================
    //  KIOSK ID BANNER (top-right)
    // ==================================================================
    function refreshKioskIdBanner() {
        if (params.locationId == null || params.printerId == null
            || params.scaleId == null || params.kioskType == null)
        {
            el.kioskId.textContent = 'Setup required';
            return;
        }
        var typeName = (KIOSK_TYPES.find(function (k) { return k.id === params.kioskType; }) || { name: '?' }).name;
        el.kioskId.innerHTML =
            (resolved.locationName || ('Loc ' + params.locationId)) + '  &middot;  ' +
            'Scale ' + (resolved.scaleName || params.scaleId) + ' (' + typeName + ')  &middot;  ' +
            (resolved.printerName || params.printerId);
    }

    // ==================================================================
    //  SCREEN ROUTER
    // ==================================================================
    function showScreen(name) {
        currentScreen = name;
        document.querySelectorAll('.kiosk-state').forEach(function (s) { s.classList.remove('active'); });
        var t = document.getElementById('state-' + name);
        if (t) t.classList.add('active');

        // Weight display visible only in normal-mode states + scale-error
        // (so the operator can see the scale's actual state).
        var showWeight = (name === 'driveon' || name === 'ready'
                         || name === 'entering-ticket' || name === 'motion-wait'
                         || name === 'scale-error');
        el.weightArea.style.display = showWeight ? '' : 'none';

        var wd = document.getElementById('weight-display');
        wd.classList.remove('size-huge', 'size-medium');
        wd.classList.add(
            name === 'driveon' || name === 'ready' || name === 'scale-error'
                ? 'size-huge'
                : 'size-medium');
    }

    // ==================================================================
    //  SETUP PICKERS
    // ==================================================================
    function startSetup() {
        // Find the first unset step
        setupIndex = 0;
        if (params.locationId != null) setupIndex = 1;
        if (params.locationId != null && params.printerId != null) setupIndex = 2;
        if (params.locationId != null && params.printerId != null && params.scaleId != null) setupIndex = 3;
        if (allParamsSet()) {
            transitionToNormal();
            return;
        }
        showScreen('setup');
        renderCurrentStep();
    }

    function reEnterSetup() {
        clearAllSetupCookies();
        params = { locationId: null, printerId: null, scaleId: null, kioskType: null };
        resolved = { locationName: null, printerName: null, scaleName: null };
        setupIndex = 0;
        showScreen('setup');
        renderCurrentStep();
    }

    function allParamsSet() {
        return params.locationId != null
            && params.printerId  != null
            && params.scaleId    != null
            && params.kioskType  != null;
    }

    function renderCurrentStep() {
        setupSelected = 0;
        setupDirect = '';
        el.direct.innerHTML = '&nbsp;';

        var step = setupSteps[setupIndex];

        if (step === 'location') {
            el.title.textContent = 'Step 1 / 4 — Select Location';
            loadLocations();
        } else if (step === 'printer') {
            el.title.textContent = 'Step 2 / 4 — Select Printer';
            loadPrinters();
        } else if (step === 'scale') {
            el.title.textContent = 'Step 3 / 4 — Select Scale';
            loadScales();
        } else if (step === 'kioskType') {
            el.title.textContent = 'Step 4 / 4 — Select Kiosk Type';
            renderItems(KIOSK_TYPES.map(function (k) {
                return { id: k.id, name: k.name };
            }));
        }
        refreshKioskIdBanner();
    }

    function loadLocations() {
        renderLoading();
        $.getJSON('/api/Scale/Locations', function (rows) {
            var items = (rows || []).map(function (l) {
                return { id: l.LocationId, name: l.Name };
            });
            renderItems(items);
        }).fail(function () {
            renderItems([]);
            el.hint.textContent = 'Failed to load locations.';
        });
    }

    function loadScales() {
        renderLoading();
        $.getJSON('/api/Scale/CachedScales', function (rows) {
            var items = (rows || []).map(function (s) {
                return { id: s.id || s.Id, name: s.description || s.Description || ('Scale ' + (s.id || s.Id)) };
            }).filter(function (i) { return i.id; });
            renderItems(items);
        }).fail(function () {
            renderItems([]);
            el.hint.textContent = 'Failed to load scales.';
        });
    }

    // Printers come from connected WebPrintService instances via PrintHub.
    // We open a short-lived hub connection just for this picker step.
    var printerCache = [];
    function loadPrinters() {
        renderLoading();
        printerCache = [];

        if (typeof signalR === 'undefined') {
            renderItems([]);
            el.hint.textContent = 'SignalR client not loaded.';
            return;
        }

        var conn = new signalR.HubConnectionBuilder().withUrl('/hubs/print').build();
        conn.on('PrinterListReceived', function (payload) {
            // payload shape from WebPrintService: { ServiceId, Printers: [{ PrinterId, FriendlyName }, ...] }
            var serviceId = payload.ServiceId || payload.serviceId || '';
            var printers  = payload.Printers  || payload.printers  || [];
            printers.forEach(function (p) {
                var pid = p.PrinterId || p.printerId || p.Name || p.name;
                var nm  = p.FriendlyName || p.friendlyName || p.Name || p.name || pid;
                if (!pid) return;
                var key = serviceId + ':' + pid;
                if (printerCache.some(function (e) { return e.id === key; })) return;
                printerCache.push({ id: key, name: nm + ' — ' + serviceId });
            });
            renderItems(printerCache.slice());
        });

        conn.start().then(function () {
            return conn.invoke('RequestPrinterList');
        }).then(function () {
            // Give services up to 1.5s to respond.
            setTimeout(function () {
                if (printerCache.length === 0) {
                    renderItems([]);
                    el.hint.textContent = 'No connected print services responded. Make sure WebPrintService is running.';
                }
                try { conn.stop(); } catch (e) {}
            }, 1500);
        }).catch(function (err) {
            renderItems([]);
            el.hint.textContent = 'Failed to query printers: ' + (err && err.message ? err.message : err);
        });
    }

    function renderLoading() {
        el.list.innerHTML = '<div class="list-item">Loading...</div>';
        setupItems = [];
        setupSelected = 0;
    }

    function renderItems(items) {
        setupItems = items || [];
        setupSelected = 0;
        if (setupItems.length === 0) {
            el.list.innerHTML = '<div class="list-item">(no items)</div>';
            return;
        }
        el.list.innerHTML = '';
        setupItems.forEach(function (item, i) {
            var row = document.createElement('div');
            row.className = 'list-item' + (i === 0 ? ' selected' : '');
            row.setAttribute('data-index', String(i));
            var nameSpan = document.createElement('span');
            nameSpan.textContent = item.name || '(unnamed)';
            var idSpan   = document.createElement('span');
            idSpan.className = 'list-id';
            idSpan.textContent = String(item.id);
            row.appendChild(nameSpan);
            row.appendChild(idSpan);
            row.addEventListener('click', function () {
                setupSelected = i; updateSelection();
            });
            el.list.appendChild(row);
        });
        updateSelection();
    }

    function updateSelection() {
        Array.from(el.list.querySelectorAll('.list-item')).forEach(function (r, i) {
            r.classList.toggle('selected', i === setupSelected);
        });
        scrollSelectedIntoView();
    }

    function scrollSelectedIntoView() {
        var item = el.list.querySelector('.list-item.selected');
        if (!item) return;
        // Native scrollIntoView respects the container's scroll-padding,
        // so the row always lands with breathing room rather than flush
        // against the rounded border. block:'nearest' avoids surprise
        // jumps when the row is already on-screen.
        try {
            item.scrollIntoView({ block: 'nearest', inline: 'nearest', behavior: 'auto' });
        } catch (e) {
            // Fallback for very old runtimes — manual edge alignment with
            // a 24px buffer so the row isn't clipped by the border-radius.
            var c = el.list;
            var pad = 24;
            if (item.offsetTop - pad < c.scrollTop) {
                c.scrollTop = Math.max(0, item.offsetTop - pad);
            } else if (item.offsetTop + item.offsetHeight + pad > c.scrollTop + c.clientHeight) {
                c.scrollTop = item.offsetTop + item.offsetHeight + pad - c.clientHeight;
            }
        }
    }

    // Highlight the row whose ID matches the direct-entry buffer if any.
    function tryHighlightDirectEntry() {
        if (!setupDirect) return;
        for (var i = 0; i < setupItems.length; i++) {
            if (String(setupItems[i].id).indexOf(setupDirect) === 0) {
                setupSelected = i;
                updateSelection();
                return;
            }
        }
    }

    function commitCurrentStep() {
        if (setupItems.length === 0) return;

        // If direct-entry buffer is non-empty, prefer the EXACT id match.
        var picked = null;
        if (setupDirect) {
            for (var i = 0; i < setupItems.length; i++) {
                if (String(setupItems[i].id) === setupDirect) { picked = setupItems[i]; break; }
            }
        }
        if (!picked) picked = setupItems[setupSelected];
        if (!picked) return;

        var step = setupSteps[setupIndex];
        if (step === 'location') {
            params.locationId = parseInt(picked.id, 10);
            resolved.locationName = picked.name;
            setCookie(COOKIE_LOCATION, params.locationId, COOKIE_DAYS);
        } else if (step === 'printer') {
            params.printerId = String(picked.id);
            resolved.printerName = picked.name;
            setCookie(COOKIE_PRINTER, params.printerId, COOKIE_DAYS);
        } else if (step === 'scale') {
            params.scaleId = parseInt(picked.id, 10);
            resolved.scaleName = picked.name;
            setCookie(COOKIE_SCALE, params.scaleId, COOKIE_DAYS);
        } else if (step === 'kioskType') {
            params.kioskType = parseInt(picked.id, 10);
            setCookie(COOKIE_KIOSKTYPE, params.kioskType, COOKIE_DAYS);
        }

        setupIndex++;
        if (setupIndex >= setupSteps.length) {
            transitionToNormal();
        } else {
            renderCurrentStep();
        }
    }

    // ==================================================================
    //  NORMAL MODE (Phase 2)
    //  ─ Subscribe to /hubs/scale, filter to the configured scale, render
    //    weight + motion + error styling, and pick the right state based
    //    on the current weight.
    //  ─ A 250ms watchdog timer flips a fullscreen red comm-error overlay
    //    on whenever the time since the last ScaleUpdated event exceeds 2s.
    // ==================================================================
    var COMM_WATCHDOG_INTERVAL_MS = 250;
    var scaleConnection = null;
    var lastScaleData = null;        // last ScaleDto we received
    var lastScaleAtMs = 0;           // ms since last update
    var commErrorActive = false;
    var commErrorSinceMs = 0;        // when the red overlay first came up
    var watchdogTimer = null;

    // Forever-retry SignalR policy. Default WithAutomaticReconnect()
    // bails after [0, 2, 10, 30]s — a long outage leaves the kiosk dead.
    // This keeps trying every 5s for as long as the page is open.
    function kioskRetryPolicy() {
        return { nextRetryDelayInMilliseconds: function () { return 5000; } };
    }

    function transitionToNormal() {
        refreshKioskIdBanner();
        // Land on drive-on until SignalR delivers a real reading. The
        // watchdog will flip to comm-error if nothing shows up in 2s.
        showScreen('driveon');
        ensureScaleConnection();
        ensureWarehouseConnection();
        ensureWatchdog();
    }

    function ensureScaleConnection() {
        if (scaleConnection) return;
        if (typeof signalR === 'undefined') {
            console.error('SignalR client not loaded; cannot subscribe to scale.');
            return;
        }

        scaleConnection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/scale')
            .withAutomaticReconnect(kioskRetryPolicy())
            .build();

        scaleConnection.on('ScaleUpdated', function (dto) {
            if (!dto) return;
            // Filter to OUR scale only — the hub broadcasts every scale.
            var id = dto.Id != null ? dto.Id : dto.id;
            if (params.scaleId == null || id !== params.scaleId) return;
            onScaleUpdate(dto);
        });

        // Re-join the scale group on every reconnect so targeted pushes
        // resume after the server restarts.
        scaleConnection.onreconnected(function () {
            try { scaleConnection.invoke('JoinScale', params.scaleId); } catch (e) {}
        });

        // Belt-and-suspenders: if the auto-retry policy ever gives up
        // (rare, but possible on certain transport errors), kick off a
        // fresh start cycle so the connection self-heals.
        scaleConnection.onclose(function () {
            scheduleScaleReconnect();
        });

        startScaleConnection();
    }

    var scaleReconnectTimer = null;
    function scheduleScaleReconnect() {
        if (scaleReconnectTimer) return;
        scaleReconnectTimer = setTimeout(function () {
            scaleReconnectTimer = null;
            startScaleConnection();
        }, 5000);
    }

    function startScaleConnection() {
        if (!scaleConnection) return;
        if (scaleConnection.state === 'Connected') return;
        scaleConnection.start().then(function () {
            try { scaleConnection.invoke('JoinScale', params.scaleId); } catch (e) {}
        }).catch(function (err) {
            console.error('Scale hub connect failed; retrying in 5s:', err);
            scheduleScaleReconnect();
        });
    }

    // ==================================================================
    //  PHASE 4 — WAIT-FOR-CLERK FLOW
    //  ─ Subscribe to WarehouseHub's per-location group, listen for
    //    weightSheetUpdated, ask the API "is anything for this kiosk?".
    //    A 200 response means a load matching this kiosk's direction
    //    just landed — drop into the same lime-green state-complete the
    //    operator-driven flow uses (Phase 3 already wired the reprint
    //    debounce + 700-lb reset).
    // ==================================================================
    var warehouseConnection = null;
    var lastClerkWsId = 0;

    function ensureWarehouseConnection() {
        if (warehouseConnection) return;
        if (typeof signalR === 'undefined') return;
        if (params.locationId == null) return;

        warehouseConnection = new signalR.HubConnectionBuilder()
            .withUrl('/hubs/warehouse')
            .withAutomaticReconnect(kioskRetryPolicy())
            .build();

        warehouseConnection.on('weightSheetUpdated', function (payload) {
            if (!payload) return;
            var wsId = payload.WeightSheetId || payload.weightSheetId || 0;
            if (wsId <= 0) return;

            // De-bounce duplicate broadcasts for the same WS within ~750ms
            // (multi-step server saves can fire several events).
            var now = Date.now();
            if (wsId === lastClerkWsId && (now - clerkLastEvalMs) < 750) return;
            lastClerkWsId = wsId;
            clerkLastEvalMs = now;

            evaluateClerkSave(wsId);
        });

        warehouseConnection.onreconnected(function () {
            try { warehouseConnection.invoke('JoinLocation', params.locationId); } catch (e) {}
        });
        warehouseConnection.onclose(function () {
            scheduleWarehouseReconnect();
        });

        startWarehouseConnection();
    }

    var warehouseReconnectTimer = null;
    function scheduleWarehouseReconnect() {
        if (warehouseReconnectTimer) return;
        warehouseReconnectTimer = setTimeout(function () {
            warehouseReconnectTimer = null;
            startWarehouseConnection();
        }, 5000);
    }

    function startWarehouseConnection() {
        if (!warehouseConnection) return;
        if (warehouseConnection.state === 'Connected') return;
        warehouseConnection.start().then(function () {
            try { warehouseConnection.invoke('JoinLocation', params.locationId); } catch (e) {}
        }).catch(function (err) {
            console.error('Warehouse hub connect failed; retrying in 5s:', err);
            scheduleWarehouseReconnect();
        });
    }

    var clerkLastEvalMs = 0;
    function evaluateClerkSave(wsId) {
        // Skip if the kiosk operator is already in the middle of their
        // own ticket flow — don't yank the screen out from under them.
        if (currentScreen === 'entering-ticket' || currentScreen === 'motion-wait') return;
        // Skip if the kiosk just printed for itself — Phase 3's complete
        // screen is already showing the same ticket; the duplicate event
        // would only refresh it, which is fine but unnecessary.

        var url = '/api/Kiosk/PendingTicketForKiosk?wsId=' + encodeURIComponent(wsId)
                + '&kioskType=' + encodeURIComponent(params.kioskType);
        fetch(url, { credentials: 'same-origin' })
            .then(function (r) {
                if (r.status === 204) return null;        // nothing for this kiosk
                if (!r.ok) return null;
                return r.json();
            })
            .then(function (data) {
                if (!data) return;

                // Map the pull-payload onto the Phase 3 showCompleted
                // contract (TransactionId, InboundLbs, OutboundLbs, NetLbs)
                // and reuse the same lime-green render path so reprint
                // debounce + 700-lb reset come along for free.
                var weightAtPrint = (data.OutboundLbs != null)
                    ? Number(data.OutboundLbs)
                    : Number(data.InboundLbs || 0);

                var resp = {
                    TransactionId: data.TransactionId,
                    WeightSheetId: data.WeightSheetId,
                    LocationId:    data.LocationId,
                    LocationName:  data.LocationName || '',
                    Commodity:     data.Commodity    || '',
                    Account:       data.Account      || '',
                    TruckId:       data.TruckId      || '',
                    InboundLbs:    Number(data.InboundLbs || 0),
                    OutboundLbs:   data.OutboundLbs != null ? Number(data.OutboundLbs) : null,
                    NetLbs:        Number(data.NetLbs || 0),
                    IsOutbound:    !!data.IsOutbound,
                };
                showCompleted(resp, weightAtPrint);
            })
            .catch(function () { /* swallow */ });
    }

    function ensureWatchdog() {
        if (watchdogTimer) return;
        watchdogTimer = setInterval(function () {
            // Skip if we never landed in normal mode.
            if (currentScreen === 'setup') return;

            var nowMs = Date.now();
            var stale = lastScaleAtMs === 0 || (nowMs - lastScaleAtMs) > COMM_ERROR_MS;
            if (stale && !commErrorActive) {
                commErrorActive = true;
                commErrorSinceMs = nowMs;
                el.commErr.classList.add('active');
            } else if (!stale && commErrorActive) {
                commErrorActive = false;
                commErrorSinceMs = 0;
                el.commErr.classList.remove('active');
            }

            // While the overlay is up, periodically nudge the SignalR
            // connections back into a Connecting state. The forever-retry
            // policies handle most cases automatically, but a manual kick
            // every few seconds means a connection that landed in
            // 'Disconnected' for any reason will resume on its own.
            //
            // We deliberately do NOT reload the page here — when the
            // server is genuinely offline the browser would just navigate
            // to its own can't-reach-this-page error and never retry.
            // The kiosk simply waits, with the red overlay showing, until
            // SignalR succeeds in reconnecting.
            if (commErrorActive) {
                startScaleConnection();
                startWarehouseConnection();
            }
        }, COMM_WATCHDOG_INTERVAL_MS);
    }

    function onScaleUpdate(dto) {
        lastScaleData = dto;
        lastScaleAtMs = Date.now();

        // If the comm-error overlay was up, drop it immediately — fresh
        // data is fresh data.
        if (commErrorActive) {
            commErrorActive = false;
            el.commErr.classList.remove('active');
        }

        renderWeight(dto);
        updateNormalScreen(dto);
    }

    function renderWeight(dto) {
        var weight = Number(dto.Weight != null ? dto.Weight : (dto.weight || 0));
        var ok     = (dto.Ok != null) ? !!dto.Ok : !!dto.ok;
        var motion = (dto.Motion != null) ? !!dto.Motion : !!dto.motion;

        var wd = document.getElementById('weight-display');
        wd.classList.remove('weight-ok', 'weight-motion', 'weight-error');

        if (!ok) {
            // Scale-reported error (Ok=false). Different from comm error
            // (signal IS coming, the scale itself is unhappy).
            el.weightVal.textContent = '------';
            wd.classList.add('weight-error');
            el.scaleStatus.style.color = '#dc3545';
            el.scaleStatus.textContent = 'SCALE ERROR';
        } else if (motion) {
            el.weightVal.textContent = Math.round(weight).toLocaleString();
            wd.classList.add('weight-motion');
            el.scaleStatus.style.color = '#856404';
            el.scaleStatus.textContent = 'MOTION';
        } else {
            el.weightVal.textContent = Math.round(weight).toLocaleString();
            wd.classList.add('weight-ok');
            el.scaleStatus.style.color = '';
            el.scaleStatus.innerHTML = '&nbsp;';
        }
    }

    function updateNormalScreen(dto) {
        // Phase 3 / 4 own the entering-ticket / motion-wait / complete
        // states — only react when the page is on an idle / scale-error
        // screen we can safely re-route.
        if (currentScreen !== 'driveon'
            && currentScreen !== 'ready'
            && currentScreen !== 'scale-error') return;

        var weight = Number(dto.Weight != null ? dto.Weight : (dto.weight || 0));
        var ok     = (dto.Ok != null) ? !!dto.Ok : !!dto.ok;

        if (!ok) {
            // Scale itself reports unhealthy — surface it as the prompt
            // so the operator sees "SCALE ERROR" across the room rather
            // than a misleading "Drive On" or "Scan Ticket" instruction.
            if (currentScreen !== 'scale-error') showScreen('scale-error');
            return;
        }

        if (Math.abs(weight) >= WEIGHT_THRESHOLD) {
            if (currentScreen !== 'ready') showScreen('ready');
        } else {
            if (currentScreen !== 'driveon') showScreen('driveon');
        }
    }

    // ==================================================================
    //  PHASE 3 — SCAN-TICKET FLOW
    // ==================================================================
    var MOTION_TIMEOUT_MS    = 10000;   // give the scale 10s to settle
    var REPRINT_DEBOUNCE_MS  = 3000;    // 1 reprint per 3s max
    var RESET_WEIGHT_DELTA   = 700;     // lbs of change after print -> reset
    var TICKET_MAX_LEN       = 12;      // safety cap on typed digits

    var ticketBuffer   = '';
    var validatedTicket = null;        // { TransactionId, WeightSheetId, ... }
    var motionTimer    = null;
    var completedAtMs  = 0;            // timestamp of last print
    var completedWeight = null;        // weight at print time (for 700-lb reset)
    var lastReprintMs  = 0;            // for the 3s debounce

    var elTicketValue   = document.getElementById('ticket-value');
    var elTicketErrMsg  = document.getElementById('ticket-error-msg');
    var elTicketErrSub  = document.getElementById('ticket-error-sub');
    var elTicketErrOver = document.getElementById('overlay-ticket-error');
    var elCompleteInfo  = document.getElementById('complete-info');

    function setTicketBuffer(v) {
        ticketBuffer = (v || '').slice(0, TICKET_MAX_LEN);
        elTicketValue.textContent = ticketBuffer || ' ';
    }

    function startTicketEntry() {
        setTicketBuffer('');
        showScreen('entering-ticket');
    }

    function abortTicketEntry() {
        setTicketBuffer('');
        showScreen('ready');
    }

    function showTicketError(reason) {
        elTicketErrMsg.textContent = reason || 'Ticket Not Found';
        elTicketErrSub.textContent = 'Press any key to continue';
        elTicketErrOver.classList.add('active');
        // Auto-clear after 3s (or earlier on keypress).
        setTimeout(function () {
            elTicketErrOver.classList.remove('active');
            // Drop back to whichever idle screen the weight justifies.
            if (lastScaleData) updateNormalScreen(lastScaleData);
            else showScreen('ready');
        }, 3000);
    }

    function submitTicket() {
        if (!ticketBuffer) return;

        var txn = ticketBuffer;
        // Show a transient "checking" hint via the existing motion-wait
        // big message — repurposed for the brief validation roundtrip.
        showScreen('motion-wait');
        document.querySelector('#state-motion-wait .big-message').textContent = 'Checking Ticket...';

        fetch('/api/Kiosk/ticket/' + encodeURIComponent(txn), { credentials: 'same-origin' })
            .then(function (r) {
                if (r.ok) return r.json().then(function (j) { return { ok: true, data: j }; });
                return r.json().catch(function () { return {}; }).then(function (e) {
                    return { ok: false, reason: (e && e.reason) || 'Cannot Find Ticket' };
                });
            })
            .then(function (res) {
                document.querySelector('#state-motion-wait .big-message').textContent = 'Waiting for Scale to Settle...';
                if (!res.ok) {
                    setTicketBuffer('');
                    showTicketError(res.reason);
                    return;
                }
                validatedTicket = res.data;
                startMotionWait();
            })
            .catch(function (err) {
                showTicketError('Network Error');
            });
    }

    // Motion-settle: poll lastScaleData up to 10s. Bails on scale-error
    // or comm-error. Spinner is the existing motion-wait state which
    // continues to show the live big weight digits.
    function startMotionWait() {
        if (motionTimer) clearTimeout(motionTimer);

        // If already settled and ok, save immediately.
        if (lastScaleData && !lastScaleData.Motion && lastScaleData.Ok && !commErrorActive) {
            doSaveOutbound(); return;
        }

        motionTimer = setTimeout(function () {
            motionTimer = null;
            showTicketError('Motion Did Not Settle');
            validatedTicket = null;
        }, MOTION_TIMEOUT_MS);
    }

    function checkMotionSettled() {
        if (!motionTimer) return;
        if (commErrorActive) return;       // can't trust the reading
        if (!lastScaleData) return;
        if (lastScaleData.Ok && !lastScaleData.Motion) {
            clearTimeout(motionTimer);
            motionTimer = null;
            doSaveOutbound();
        }
    }

    function doSaveOutbound() {
        if (!validatedTicket || !lastScaleData) return;

        var weight = Math.round(Number(lastScaleData.Weight || 0));

        fetch('/api/Kiosk/ticket/weighout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({
                TransactionId:    validatedTicket.TransactionId,
                WeightLbs:        weight,
                PrinterId:        params.printerId,
                KioskLocationId:  params.locationId,
                KioskScaleId:     params.scaleId,
            }),
        }).then(function (r) {
            if (!r.ok) {
                return r.json().catch(function () { return {}; }).then(function (e) {
                    showTicketError((e && e.reason) || 'Save Failed');
                    validatedTicket = null;
                });
            }
            return r.json().then(function (j) {
                validatedTicket = null;
                // Reuse the Phase 4 detail endpoint so the lime-green
                // screen shows location / commodity / account / truck-id
                // for kiosk-driven weigh-outs too. Falls back to the
                // bare save response if the lookup fails.
                fetch('/api/Kiosk/PendingTicketForKiosk?wsId=' + encodeURIComponent(j.WeightSheetId)
                      + '&kioskType=' + encodeURIComponent(params.kioskType),
                      { credentials: 'same-origin' })
                    .then(function (r2) { return r2.ok ? r2.json() : null; })
                    .catch(function () { return null; })
                    .then(function (rich) {
                        if (rich && rich.TransactionId === j.TransactionId) {
                            // Carry forward inbound/outbound/net from the
                            // save response (fresh-from-DB, authoritative).
                            rich.InboundLbs  = j.InboundLbs;
                            rich.OutboundLbs = j.OutboundLbs;
                            rich.NetLbs      = j.NetLbs;
                            rich.IsOutbound  = true;
                            showCompleted(rich, weight);
                        } else {
                            showCompleted(j, weight);
                        }
                    });
            });
        }).catch(function (err) {
            showTicketError('Save Failed');
            validatedTicket = null;
        });
    }

    function fmtLbs(n) {
        if (n === null || n === undefined || isNaN(n)) return '— lb';
        return Math.round(Number(n)).toLocaleString() + ' lb';
    }
    function setText(id, v) {
        var elx = document.getElementById(id);
        if (elx) elx.textContent = (v === null || v === undefined || v === '') ? '—' : v;
    }

    function showCompleted(saveResp, outWeight) {
        completedAtMs   = Date.now();
        completedWeight = outWeight;
        lastReprintMs   = Date.now();    // initial print counts toward the 3s window

        var inLbs  = Number(saveResp.InboundLbs  || 0);
        var outRaw = (saveResp.OutboundLbs != null && saveResp.OutboundLbs !== '')
            ? Number(saveResp.OutboundLbs)
            : (outWeight != null ? Number(outWeight) : null);
        var hasOutbound = (saveResp.IsOutbound === true)
            || (saveResp.OutboundLbs != null && saveResp.OutboundLbs !== '' && Number(saveResp.OutboundLbs) > 0);
        var netLbs = Number(saveResp.NetLbs);
        if (!isFinite(netLbs) || netLbs <= 0) {
            netLbs = (hasOutbound && outRaw != null) ? Math.abs(inLbs - outRaw) : 0;
        }

        // Header — ticket #
        document.getElementById('complete-ticket-no').textContent =
            '#  ' + (saveResp.TransactionId || '—');

        // Identity block
        setText('complete-location',  saveResp.LocationName);
        setText('complete-commodity', saveResp.Commodity);
        setText('complete-account',   saveResp.Account);
        setText('complete-truck',     saveResp.TruckId);

        // Weight block — Inbound shows only the stored weight (StartQty),
        // Outbound shows Gross / Tare / Net.
        var elIn  = document.getElementById('complete-inbound-weights');
        var elOut = document.getElementById('complete-outbound-weights');
        if (hasOutbound) {
            elIn.hidden = true; elOut.hidden = false;
            // For receive loads, gross = inbound (loaded truck), tare = outbound (empty truck)
            var gross = Math.max(inLbs, outRaw || 0);
            var tare  = Math.min(inLbs, outRaw || 0);
            setText('complete-gross', fmtLbs(gross));
            setText('complete-tare',  fmtLbs(tare));
            setText('complete-net',   fmtLbs(netLbs));
        } else {
            elIn.hidden = false; elOut.hidden = true;
            setText('complete-inbound-weight', fmtLbs(inLbs));
        }

        showScreen('complete');
    }

    function tryReprint() {
        if (currentScreen !== 'complete') return;
        var nowMs = Date.now();
        if (nowMs - lastReprintMs < REPRINT_DEBOUNCE_MS) return;
        lastReprintMs = nowMs;

        // We don't keep validatedTicket once saved — pull the txn id out
        // of the visible info string is brittle, so cache from save.
        if (!completedTicketTxnId) return;

        fetch('/api/Kiosk/ticket/reprint', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({
                TransactionId: completedTicketTxnId,
                PrinterId: params.printerId,
            }),
        }).catch(function () { /* swallow — debounce already gates */ });
    }

    var completedTicketTxnId = null;

    // 700-lb reset: when the truck drives off the scale (weight delta from
    // the print-time reading exceeds RESET_WEIGHT_DELTA), drop back to
    // ready/driveon for the next truck.
    function checkPostPrintReset() {
        if (currentScreen !== 'complete') return;
        if (completedWeight == null || !lastScaleData) return;
        var w = Number(lastScaleData.Weight || 0);
        if (Math.abs(w - completedWeight) >= RESET_WEIGHT_DELTA) {
            completedWeight = null;
            completedTicketTxnId = null;
            // Re-evaluate idle screen based on the new weight.
            updateNormalScreen(lastScaleData);
        }
    }

    // Hook the scale watcher so motion-settle and post-print reset can
    // observe each tick. We layer on top of the Phase 2 onScaleUpdate
    // by wrapping it.
    var origOnScaleUpdate = onScaleUpdate;
    onScaleUpdate = function (dto) {
        origOnScaleUpdate(dto);
        if (currentScreen === 'motion-wait') checkMotionSettled();
        if (currentScreen === 'complete')    checkPostPrintReset();
    };

    // Latch the txn id for reprint as soon as save succeeds.
    var origShowCompleted = showCompleted;
    showCompleted = function (saveResp, outWeight) {
        completedTicketTxnId = saveResp.TransactionId;
        origShowCompleted(saveResp, outWeight);
    };

    // ==================================================================
    //  KEYBOARD HANDLER
    // ==================================================================
    document.addEventListener('keydown', function (e) {
        // Modal is up — it owns Enter / Esc and swallows everything else
        // so the kiosk state machine doesn't act on keypresses meant for
        // the prompt.
        if (alertIsOpen()) {
            if (e.key === 'Enter')  { e.preventDefault(); settleAlert(true);  return; }
            if (e.key === 'Escape') { e.preventDefault(); settleAlert(false); return; }
            e.preventDefault();
            return;
        }
        if (currentScreen === 'setup') {
            handleSetupKey(e);
            return;
        }
        handleKioskKey(e);
    });

    function handleKioskKey(e) {
        var k = e.key;

        // Dismiss the ticket-error overlay on any key, drop to idle.
        if (elTicketErrOver.classList.contains('active')) {
            elTicketErrOver.classList.remove('active');
            if (lastScaleData) updateNormalScreen(lastScaleData);
            else showScreen('ready');
            e.preventDefault();
            return;
        }

        if (currentScreen === 'complete') {
            if (k === 'Enter') { e.preventDefault(); tryReprint(); }
            return;
        }

        if (currentScreen === 'entering-ticket') {
            if (k === 'Enter')      { e.preventDefault(); submitTicket(); return; }
            if (k === 'Escape' || k === 'Backspace' || k === 'Delete') {
                e.preventDefault();
                if (k === 'Backspace' && ticketBuffer.length > 0) {
                    setTicketBuffer(ticketBuffer.slice(0, -1));
                } else {
                    abortTicketEntry();
                }
                return;
            }
            if (/^[0-9]$/.test(k)) { e.preventDefault(); setTicketBuffer(ticketBuffer + k); return; }
            return;
        }

        // From any idle/ready state, a digit starts ticket entry.
        if (currentScreen === 'ready' || currentScreen === 'driveon') {
            if (/^[0-9]$/.test(k)) {
                e.preventDefault();
                startTicketEntry();
                setTicketBuffer(k);
                return;
            }
        }
    }

    function handleSetupKey(e) {
        var k = e.key;
        if (k === 'ArrowUp') {
            e.preventDefault();
            setupDirect = '';
            el.direct.innerHTML = '&nbsp;';
            if (setupItems.length > 0) {
                setupSelected = Math.max(0, setupSelected - 1);
                updateSelection();
            }
        } else if (k === 'ArrowDown') {
            e.preventDefault();
            setupDirect = '';
            el.direct.innerHTML = '&nbsp;';
            if (setupItems.length > 0) {
                setupSelected = Math.min(setupItems.length - 1, setupSelected + 1);
                updateSelection();
            }
        } else if (k === 'Enter') {
            e.preventDefault();
            commitCurrentStep();
        } else if (k === 'Backspace' || k === 'Delete') {
            e.preventDefault();
            setupDirect = setupDirect.slice(0, -1);
            el.direct.textContent = setupDirect || ' ';
            tryHighlightDirectEntry();
        } else if (k === 'Escape') {
            e.preventDefault();
            setupDirect = '';
            el.direct.innerHTML = '&nbsp;';
        } else if (/^[0-9]$/.test(k)) {
            e.preventDefault();
            if (setupDirect.length < 12) {
                setupDirect += k;
                el.direct.textContent = setupDirect;
                tryHighlightDirectEntry();
            }
        }
    }

    // ==================================================================
    //  IN-PAGE ALERT MODAL
    //  ─ Promise-returning replacement for window.confirm so the kiosk
    //    never has to fall back on browser-chrome popups (which would
    //    steal Enter / Esc from the kiosk's own state machine).
    // ==================================================================
    var alertEl       = document.getElementById('kiosk-alert');
    var alertTitleEl  = document.getElementById('kiosk-alert-title');
    var alertMsgEl    = document.getElementById('kiosk-alert-message');
    var alertOkBtn    = document.getElementById('kiosk-alert-ok');
    var alertCancelEl = document.getElementById('kiosk-alert-cancel');
    var alertResolver = null;

    function kioskConfirm(opts) {
        if (typeof opts === 'string') opts = { message: opts };
        opts = opts || {};
        alertTitleEl.textContent = opts.title   || 'Confirm';
        alertMsgEl.textContent   = opts.message || 'Are you sure?';
        alertOkBtn.textContent   = opts.okLabel || 'Confirm';
        alertCancelEl.textContent= opts.cancelLabel || 'Cancel';

        alertEl.classList.add('active');
        return new Promise(function (resolve) {
            alertResolver = resolve;
        });
    }

    function settleAlert(result) {
        if (!alertResolver) return;
        var r = alertResolver;
        alertResolver = null;
        alertEl.classList.remove('active');
        try { r(!!result); } catch (e) { /* swallow */ }
    }

    alertOkBtn.addEventListener('click',     function () { settleAlert(true);  });
    alertCancelEl.addEventListener('click',  function () { settleAlert(false); });
    alertEl.addEventListener('click', function (e) {
        // Click outside the card cancels — like Bootstrap's backdrop dismiss.
        if (e.target === alertEl) settleAlert(false);
    });

    function alertIsOpen() { return alertResolver !== null; }

    // ==================================================================
    //  LONG-PRESS LOGO -> RE-ENTER SETUP
    // ==================================================================
    (function () {
        var logo = document.getElementById('brand-logo');
        var t = null;
        function start() {
            if (t) return;
            t = setTimeout(function () {
                t = null;
                kioskConfirm({
                    title:    'Edit Kiosk Parameters?',
                    message:  'Current settings will be cleared. You will be walked back through Location, Printer, Scale, and Kiosk Type.',
                    okLabel:  'Edit',
                    cancelLabel: 'Cancel',
                }).then(function (ok) {
                    if (ok) reEnterSetup();
                });
            }, LONGPRESS_MS);
        }
        function stop() { if (t) { clearTimeout(t); t = null; } }
        logo.addEventListener('mousedown',  start);
        logo.addEventListener('touchstart', start);
        logo.addEventListener('mouseup',    stop);
        logo.addEventListener('mouseleave', stop);
        logo.addEventListener('touchend',   stop);
        logo.addEventListener('touchcancel',stop);
    })();

    document.addEventListener('contextmenu', function (e) { e.preventDefault(); });

    // ==================================================================
    //  BOOT
    // ==================================================================
    // Lightweight $.getJSON so we don't pull all of jQuery in.
    var $ = window.$ || (window.$ = {});
    $.getJSON = function (url, cb) {
        return fetch(url, { credentials: 'same-origin' })
            .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
            .then(function (j) { if (cb) cb(j); return { fail: function () { return this; } }; })
            .catch(function (err) {
                console.error('getJSON ' + url + ' failed:', err);
                return { fail: function (h) { try { h(err); } catch (e) {} return this; } };
            });
    };

    if (allParamsSet()) {
        // Best-effort label resolution so the kiosk-id banner reads nicely
        // (so the operator can sanity-check on first paint).
        $.getJSON('/api/Scale/Locations', function (rows) {
            var l = (rows || []).find(function (x) { return x.LocationId === params.locationId; });
            if (l) { resolved.locationName = l.Name; refreshKioskIdBanner(); }
        });
        $.getJSON('/api/Scale/CachedScales', function (rows) {
            var s = (rows || []).find(function (x) { return (x.id || x.Id) === params.scaleId; });
            if (s) { resolved.scaleName = s.description || s.Description; refreshKioskIdBanner(); }
        });
        transitionToNormal();
    } else {
        startSetup();
    }
})();
</script>
</body>
</html>
