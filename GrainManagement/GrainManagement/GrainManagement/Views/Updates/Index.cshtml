@{
    ViewData["Title"] = "Updates";
}

<a href="/" class="gm-module-bar gm-module-bar--admin gm-module-bar--link" title="Back to Home">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--transfer" aria-hidden="true"></span>
    <span class="gm-module-bar__label">UPDATES</span>
</a>

<div class="row g-4 mt-2">
    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--warehouse" href="/AgvantageWarehouseTransfer">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--warehouse" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Agvantage Warehouse Transfer</h2>
            </div>
            <p class="gm-tile__text">Push warehouse weight-sheet activity to Agvantage.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--seed" href="#">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Agvantage Seed Transfer</h2>
            </div>
            <p class="gm-tile__text">Push seed activity to Agvantage.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--admin" href="/Admin/As400Sync">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--transfer" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Updates From Agvantage</h2>
            </div>
            <p class="gm-tile__text">Pull Accounts, Items, and Split Groups from Agvantage on demand.</p>
        </a>
    </div>
</div>
