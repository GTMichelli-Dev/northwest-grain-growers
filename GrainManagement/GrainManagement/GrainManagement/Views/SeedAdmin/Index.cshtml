@{
    ViewData["Title"] = "Seed Administration";
}

<a href="/" class="gm-module-bar gm-module-bar--seed gm-module-bar--link" title="Back to Home">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--seed" aria-hidden="true"></span>
    <span class="gm-module-bar__label">SEED ADMINISTRATION</span>
</a>

<div class="row g-4 mt-2">

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--seed" href="/SeedAdmin/Raw">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Raw Seed</h2>
            </div>
            <p class="gm-tile__text">Manage raw seed purchase orders, lots, and receipts across all locations.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--seed" href="/SeedAdmin/Treated">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Treated &amp; Cleaned Seed</h2>
            </div>
            <p class="gm-tile__text">Manage seed treatment applications and cleaned seed sales records.</p>
        </a>
