@{
    ViewData["Title"] = "Raw Seed — Seed Admin";
}

<a href="/SeedAdmin" class="gm-module-bar gm-module-bar--seed gm-module-bar--link" title="Back to Seed Administration">
    <i class="dx-icon dx-icon-arrowleft gm-module-bar__arrow"></i>
    <span class="gm-module-bar__icon gm-icon gm-icon--seed" aria-hidden="true"></span>
    <span class="gm-module-bar__label">RAW SEED</span>
</a>

<div class="row g-4 mt-2">

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--seed" href="/SeedAdmin/PurchaseOrders">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Purchase Orders</h2>
            </div>
            <p class="gm-tile__text">Review and manage raw seed purchase orders across all locations.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--seed" href="/SeedAdmin/Lots">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Lots</h2>
            </div>
            <p class="gm-tile__text">View and manage raw seed inventory lots across all locations.</p>
        </a>
    </div>

    <div class="col-12 col-lg-4">
        <a class="gm-tile gm-tile--link gm-tile--seed" href="/SeedAdmin/Receipts">
            <div class="gm-tile__header">
                <div class="gm-tile__icon gm-icon gm-icon--seed" aria-hidden="true"></div>
                <h2 class="gm-tile__title">Receipts</h2>
            </div>
            <p class="gm-tile__text">View and correct individual raw seed receipt records and weights.</p>
        </a>
    </div>

</div>
