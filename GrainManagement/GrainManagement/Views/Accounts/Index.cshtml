@{
    ViewData["Title"] = "Accounts";
}

<h2>Accounts</h2>

<div id="accountsGrid"></div>

@section Scripts {
    <script>
        $(function () {

            var accountsStore = new DevExpress.data.CustomStore({
                key: "Uid",
                load: function (loadOptions) {
                    return DevExpress.data.AspNet.createStore({
                        key: "Uid",
                        loadUrl: "/api/AccountsApi"
                    }).load(loadOptions);
                },
                update: function (key, values) {
                    var d = $.Deferred();
                    var data = $.extend({ Uid: key }, values);

                    $.ajax({
                        url: "/api/AccountsApi/" + key,
                        method: "PUT",
                        data: JSON.stringify(data),
                        contentType: "application/json"
                    })
                    .done(function (result) {
                        d.resolve(result);
                    })
                    .fail(function (xhr) {
                        var msg = "Update failed.";
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            msg = xhr.responseJSON.message;
                        }
                        d.reject(msg);
                    });

                    return d.promise();
                }
            });

            $("#accountsGrid").dxDataGrid({
                dataSource: accountsStore,
                keyExpr: "Uid",
                remoteOperations: false,       // let filtering/sorting happen on client
                showBorders: true,
                columnAutoWidth: true,
                rowAlternationEnabled: true,
                hoverStateEnabled: true,

                searchPanel: {
                    visible: true,
                    width: 260,
                    placeholder: "Search accounts..."
                },

                columns: [
                    {
                        dataField: "AccountId",
                        caption: "Account #",
                        width: 120,
                        allowEditing: false
                    },
                    {
                        dataField: "EntityName",
                        caption: "Entity Name"
                    },
                    {
                        dataField: "LookupName",
                        caption: "Lookup Name"
                    },
                    {
                        dataField: "OwnerFirstName",
                        caption: "Owner First"
                    },
                    {
                        dataField: "OwnerLastName",
                        caption: "Owner Last"
                    },
                    {
                        dataField: "IsProducer",
                        caption: "Producer",
                        dataType: "boolean",
                        width: 100
                    },
                    {
                        dataField: "IsHauler",
                        caption: "Hauler",
                        dataType: "boolean",
                        width: 100
                    },
                    {
                        dataField: "HedgedAccount",
                        caption: "Hedged",
                        dataType: "boolean",
                        width: 100
                    },
                    {
                        dataField: "Active",
                        caption: "Active",
                        dataType: "boolean",
                        width: 90
                    },
                    {
                        dataField: "Notes",
                        caption: "Notes"
                    }
                ],

                editing: {
                    mode: "popup",
                    allowUpdating: true,
                    allowAdding: false,   // turn on later if you want create
                    allowDeleting: false, // add like Users if you want delete
                    useIcons: true,
                    popup: {
                        title: "Edit Account",
                        showTitle: true,
                        width: 700,
                        height: 480
                    },
                    form: {
                        colCount: 2,
                        items: [
                            {
                                dataField: "AccountId",
                                label: { text: "Account #" },
                                editorOptions: { readOnly: true }
                            },
                            {
                                dataField: "EntityName",
                                label: { text: "Entity Name" },
                                isRequired: true
                            },
                            {
                                dataField: "LookupName",
                                label: { text: "Lookup Name" }
                            },
                            {
                                dataField: "OwnerFirstName",
                                label: { text: "Owner First" }
                            },
                            {
                                dataField: "OwnerLastName",
                                label: { text: "Owner Last" }
                            },
                            {
                                dataField: "IsProducer",
                                label: { text: "Producer" },
                                editorType: "dxCheckBox"
                            },
                            {
                                dataField: "IsHauler",
                                label: { text: "Hauler" },
                                editorType: "dxCheckBox"
                            },
                            {
                                dataField: "HedgedAccount",
                                label: { text: "Hedged" },
                                editorType: "dxCheckBox"
                            },
                            {
                                dataField: "Active",
                                label: { text: "Active" },
                                editorType: "dxCheckBox"
                            },
                            {
                                dataField: "Notes",
                                colSpan: 2,
                                editorType: "dxTextArea",
                                editorOptions: {
                                    height: 80
                                }
                            }
                        ]
                    }
                }
            });
        });
    </script>
}
