                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        Bin, SUM(Net) AS NetWeight, SUM(Net) / 60 AS Bushels, SUM(NetProtein) / SUM(Net) * 10 AS AvgProtein
FROM            (SELECT        Bin, Protein, Net * Protein AS NetProtein, Net
                          FROM            (SELECT        BLoads.Location_Id, BLoads.Bin, BLoads.Net, BLoads.UID, ISNULL(CASE WHEN Inbound_Loads.UID IS NULL THEN Transfer_Loads.Protein ELSE Inbound_Loads.Protien END, 0) 
                                                                              * 0.1 AS Protein
                                                    FROM            (SELECT        Location_Id, Bin, Weight_In - Weight_Out AS Net, UID
                                                                              FROM            Loads
                                                                              WHERE        (Weight_In - Weight_Out &gt; 0) AND (Bin IS NOT NULL) AND (Weight_Out IS NOT NULL) AND (DATEDIFF(Day, @StartDate, Time_In) &gt;= 0) AND (DATEDIFF(Day, Time_In, 
                                                                                                        @EndDate) &gt;= 0) AND (Location_Id = @Location_Id)) AS BLoads LEFT OUTER JOIN
                                                                              Transfer_Loads ON BLoads.UID = Transfer_Loads.Load_UID LEFT OUTER JOIN
                                                                              Inbound_Loads ON BLoads.UID = Inbound_Loads.Load_UID
                                                    WHERE        (ISNULL(CASE WHEN Inbound_Loads.UID IS NULL THEN Transfer_Loads.Protein ELSE Inbound_Loads.Protien END, 0) &gt; 0)) AS PLoads) AS TLoads
GROUP BY Bin</CommandText>
