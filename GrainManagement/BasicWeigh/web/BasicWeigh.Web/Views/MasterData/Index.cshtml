@{
    ViewData["Title"] = "Edit Tables";
    var kioskCount = (int)ViewBag.KioskCount;
    var showKiosk = kioskCount > 0;
    var useQuickBooks = (bool)ViewBag.UseQuickBooks;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">Edit Tables</h3>
    <div>
        <span id="qbSyncStatus" class="me-2 text-muted small"></span>
        @if (useQuickBooks)
        {
            <button id="btnQBSync" class="btn btn-success btn-sm" onclick="triggerQBSync()" style="display:none;">
                <i class="fa fa-download"></i> Sync from QuickBooks
            </button>
        }
    </div>
</div>

@if (useQuickBooks)
{
    <div id="qbStatusBanner" class="alert alert-warning py-1 mb-2 d-flex align-items-center" role="alert">
        <div><i class="fa fa-spinner fa-spin"></i> Checking QuickBooks connection...</div>
    </div>
}

<ul class="nav nav-tabs" id="masterDataTabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#customersTab">Customers</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#carriersTab">Carriers & Trucks</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#locationsTab">Locations</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#destinationsTab">Destinations</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#commoditiesTab">Commodities</button>
    </li>
</ul>

<div class="tab-content mt-3">
    <div class="tab-pane fade show active" id="customersTab">
        <div id="customersGrid"></div>
    </div>
    <div class="tab-pane fade" id="carriersTab">
        <div id="carriersGrid"></div>
    </div>
    <div class="tab-pane fade" id="locationsTab">
        <div id="locationsGrid"></div>
    </div>
    <div class="tab-pane fade" id="destinationsTab">
        <div id="destinationsGrid"></div>
    </div>
    <div class="tab-pane fade" id="commoditiesTab">
        <div id="commoditiesGrid"></div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        var showKiosk = @(showKiosk ? "true" : "false");
        var useQuickBooks = @(useQuickBooks ? "true" : "false");

        function createIdStore(endpoint) {
            return new DevExpress.data.CustomStore({
                key: 'id',
                load: function () {
                    return $.getJSON('/api/masterdata/' + endpoint);
                },
                insert: function (values) {
                    return $.ajax({
                        url: '/api/masterdata/' + endpoint,
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(values)
                    });
                },
                update: function (key, values) {
                    values.id = key;
                    return $.ajax({
                        url: '/api/masterdata/' + endpoint,
                        method: 'PUT',
                        contentType: 'application/json',
                        data: JSON.stringify(values)
                    });
                },
                remove: function (key) {
                    return $.ajax({
                        url: '/api/masterdata/' + endpoint + '/' + key,
                        method: 'DELETE'
                    });
                }
            });
        }

        function initNameActiveGrid(selector, endpoint, nameField, nameCaption, qbManaged) {
            var lockName = useQuickBooks && qbManaged;
            var cols = [
                { dataField: 'id', caption: 'ID', width: 60, allowEditing: false },
                { dataField: nameField, caption: nameCaption, sortOrder: 'asc', allowEditing: !lockName, validationRules: lockName ? [] : [{ type: 'required' }] },
                { dataField: 'active', caption: 'Active', dataType: 'boolean', width: 100 }
            ];
            if (showKiosk) {
                cols.push({ dataField: 'useAtKiosk', caption: 'Kiosk', dataType: 'boolean', width: 100 });
            }

            $(selector).dxDataGrid({
                hoverStateEnabled: true,
                dataSource: createIdStore(endpoint),
                showBorders: true,
                filterRow: { visible: true },
                headerFilter: { visible: true },
                allowColumnReordering: true,
                allowColumnResizing: true,
                columnChooser: { enabled: true, mode: 'select' },
                stateStoring: {
                    enabled: true,
                    type: 'localStorage',
                    storageKey: 'masterData_' + endpoint
                },
                editing: {
                    mode: 'batch',
                    allowAdding: !lockName,
                    allowUpdating: true,
                    allowDeleting: !lockName
                },
                columns: cols
            });
        }

        initNameActiveGrid('#customersGrid', 'customers', 'customerName', 'Customer Name', true);
        initNameActiveGrid('#locationsGrid', 'locations', 'locationName', 'Location Name', false);
        initNameActiveGrid('#destinationsGrid', 'destinations', 'destinationName', 'Destination Name', false);
        initNameActiveGrid('#commoditiesGrid', 'commodities', 'commodityName', 'Commodity Name', true);

        // Carriers grid with trucks sub-grid (master-detail)
        var customerSuggestions = [];
        $.getJSON('/api/masterdata/customers-not-carriers').done(function (data) {
            customerSuggestions = data;
        });

        var carrierCols = [
            { dataField: 'id', caption: 'ID', width: 60, allowEditing: false },
            {
                dataField: 'carrierName', caption: 'Carrier Name', sortOrder: 'asc', validationRules: [{ type: 'required' }],
                editCellTemplate: function (cellElement, cellInfo) {
                    if (cellInfo.row.isNewRow) {
                        $('<div>').dxAutocomplete({
                            dataSource: customerSuggestions,
                            value: cellInfo.value || '',
                            minSearchLength: 0,
                            showDropDownButton: true,
                            onValueChanged: function (e) {
                                cellInfo.setValue(e.value);
                            }
                        }).appendTo(cellElement);
                    } else {
                        $('<div>').dxTextBox({
                            value: cellInfo.value || '',
                            onValueChanged: function (e) {
                                cellInfo.setValue(e.value);
                            }
                        }).appendTo(cellElement);
                    }
                }
            },
            { dataField: 'active', caption: 'Active', dataType: 'boolean', width: 100 }
        ];
        if (showKiosk) {
            carrierCols.push({ dataField: 'useAtKiosk', caption: 'Kiosk', dataType: 'boolean', width: 100 });
        }

        var carrierStore = createIdStore('carriers');

        $('#carriersGrid').dxDataGrid({
            hoverStateEnabled: true,
            dataSource: carrierStore,
            showBorders: true,
            filterRow: { visible: true },
            headerFilter: { visible: true },
            allowColumnReordering: true,
            allowColumnResizing: true,
            columnChooser: { enabled: true, mode: 'select' },
            stateStoring: {
                enabled: true,
                type: 'localStorage',
                storageKey: 'masterData_carriers'
            },
            editing: {
                mode: 'batch',
                allowAdding: true,
                allowUpdating: true,
                allowDeleting: true
            },
            columns: carrierCols,
            onInitNewRow: function () {
                $.getJSON('/api/masterdata/customers-not-carriers').done(function (data) {
                    customerSuggestions = data;
                });
            },
            masterDetail: {
                enabled: true,
                template: function (container, options) {
                    var carrierData = options.data;
                    var carrierName = carrierData.carrierName;

                    var truckCols = [
                        { dataField: 'id', caption: 'ID', width: 60, allowEditing: false },
                        { dataField: 'truckId', caption: 'Truck ID', sortOrder: 'asc', validationRules: [{ type: 'required' }] },
                        { dataField: 'description', caption: 'Description' },
                        { dataField: 'notes', caption: 'Notes' }
                    ];
                    if (showKiosk) {
                        truckCols.push({ dataField: 'useAtKiosk', caption: 'Kiosk', dataType: 'boolean', width: 100 });
                    }

                    $('<div>').dxDataGrid({
                        hoverStateEnabled: true,
                        dataSource: new DevExpress.data.CustomStore({
                            key: 'id',
                            load: function () {
                                return $.getJSON('/api/masterdata/trucks/' + encodeURIComponent(carrierName));
                            },
                            insert: function (values) {
                                values.carrierName = carrierName;
                                return $.ajax({
                                    url: '/api/masterdata/trucks',
                                    method: 'POST',
                                    contentType: 'application/json',
                                    data: JSON.stringify(values)
                                });
                            },
                            update: function (key, values) {
                                values.id = key;
                                values.carrierName = carrierName;
                                return $.ajax({
                                    url: '/api/masterdata/trucks',
                                    method: 'PUT',
                                    contentType: 'application/json',
                                    data: JSON.stringify(values)
                                });
                            },
                            remove: function (key) {
                                return $.ajax({
                                    url: '/api/masterdata/trucks/' + key,
                                    method: 'DELETE'
                                });
                            }
                        }),
                        showBorders: true,
                        columnAutoWidth: true,
                        editing: {
                            mode: 'batch',
                            allowAdding: true,
                            allowUpdating: true,
                            allowDeleting: true
                        },
                        columns: truckCols
                    }).appendTo(container);
                }
            }
        });
    });
</script>
<script src="~/js/signalr/signalr.min.js"></script>
<script>
    // --- QuickBooks Sync via SignalR (loaded after signalr.min.js) ---
    (function () {
        var syncConnection = new signalR.HubConnectionBuilder()
            .withUrl("/scaleHub")
            .withAutomaticReconnect()
            .build();

        syncConnection.on("QBSyncStatus", function (message) {
            $('#qbSyncStatus').text(message);
        });

        syncConnection.on("QBSyncComplete", function (summary) {
            $('#qbSyncStatus').text(summary);
            $('#btnQBSync').prop('disabled', false).html('<i class="fa fa-download"></i> Sync from QuickBooks');
            var grids = ['#customersGrid', '#carriersGrid', '#locationsGrid', '#destinationsGrid', '#commoditiesGrid'];
            grids.forEach(function (sel) {
                var instance = $(sel).dxDataGrid('instance');
                if (instance) instance.refresh();
            });
        });

        syncConnection.on("QBNotRunning", function (message) {
            $('#qbSyncStatus').text('');
            $('#btnQBSync').prop('disabled', false).html('<i class="fa fa-download"></i> Sync from QuickBooks');
            var html = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                '<i class="fa fa-exclamation-triangle"></i> ' + message +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            if (!$('#qb-alert-container').length) $('body').prepend('<div id="qb-alert-container" style="position:fixed;top:10px;right:10px;z-index:9999;max-width:500px;"></div>');
            $('#qb-alert-container').html(html);
        });

        function updateQBBanner(connected) {
            var banner = document.getElementById('qbStatusBanner');
            var btn = document.getElementById('btnQBSync');
            if (banner) {
                if (connected) {
                    banner.style.cssText = 'background-color:#d1e7dd !important;border-color:#badbcc !important;color:#0f5132 !important;padding:6px 16px !important;margin-bottom:8px !important;border-radius:6px !important;display:flex !important;align-items:center !important;';
                    banner.innerHTML = '<div><i class="fa fa-check-circle"></i> <strong>QuickBooks Connected</strong> — Customer and Commodity names are managed by QuickBooks. Use the <strong>Sync from QuickBooks</strong> button to update.</div>';
                } else {
                    banner.style.cssText = 'background-color:#f8d7da !important;border-color:#f5c2c7 !important;color:#842029 !important;padding:6px 16px !important;margin-bottom:8px !important;border-radius:6px !important;display:flex !important;align-items:center !important;';
                    banner.innerHTML = '<div><i class="fa fa-times-circle"></i> <strong>QuickBooks Not Connected</strong> — Please start the QBSyncService and try again.</div>';
                }
            }
            if (btn) btn.style.display = connected ? '' : 'none';
        }

        syncConnection.on("QBServiceStatusChanged", function (connected) {
            updateQBBanner(connected);
        });

        syncConnection.start().then(function () {
            return syncConnection.invoke("CheckQBServiceConnected");
        }).then(function (connected) {
            updateQBBanner(connected);
        }).catch(function (err) {
            console.error("SignalR connect error:", err);
            updateQBBanner(false);
        });

        window.triggerQBSync = function () {
            // Check if QB service is connected first
            syncConnection.invoke("CheckQBServiceConnected").then(function (connected) {
                if (!connected) {
                    var html = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                        '<i class="fa fa-exclamation-triangle"></i> QuickBooks Sync Service is not connected. Please start the QBSyncService and try again.' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
                    if (!$('#qb-alert-container').length) $('body').prepend('<div id="qb-alert-container" style="position:fixed;top:10px;right:10px;z-index:9999;max-width:500px;"></div>');
                    $('#qb-alert-container').html(html);
                    return;
                }
                $('#btnQBSync').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Syncing...');
                $('#qbSyncStatus').text('Requesting sync...');
                syncConnection.invoke("TriggerQBSync").catch(function (err) {
                    $('#qbSyncStatus').text('Error: ' + err);
                    $('#btnQBSync').prop('disabled', false).html('<i class="fa fa-download"></i> Sync from QuickBooks');
                });
            }).catch(function (err) {
                $('#qbSyncStatus').text('Error checking service: ' + err);
            });
        };
    })();
</script>
}
