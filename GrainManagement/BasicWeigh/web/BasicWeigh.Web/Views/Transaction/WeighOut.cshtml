@model BasicWeigh.Web.Models.Transaction
@inject BasicWeigh.Web.Data.ScaleDbContext Db
@{
    ViewData["Title"] = "Weigh Out - Ticket " + Model.Ticket;
    var isDemoMode = Db.AppSetup.FirstOrDefault()?.DemoMode == true;
}

<style>
    .get-weight-display {
        background-color: #000;
        color: #00ff41;
        font-family: 'Courier New', monospace;
        font-size: 2.5rem;
        font-weight: bold;
        text-align: right;
        padding: 12px 24px;
        border-radius: 12px;
        letter-spacing: 3px;
        max-width: 320px;
        margin: 0 auto 10px;
    }
    .get-weight-status {
        font-size: 0.9rem;
        font-weight: bold;
        text-align: center;
        letter-spacing: 2px;
        min-height: 1.2em;
    }
    .get-weight-unit {
        font-size: 1.2rem;
        color: #0a0;
        margin-left: 8px;
    }
    .manual-weight-input {
        font-family: 'Courier New', monospace;
        font-size: 1.5rem;
        font-weight: bold;
        text-align: right;
        letter-spacing: 2px;
    }
</style>

<h3>Weigh Out - Ticket @Model.Ticket</h3>
<div id="validationAlert" class="alert alert-danger alert-dismissible fade" role="alert" style="display:none;">
    <span id="validationMsg"></span>
    <button type="button" class="btn-close" onclick="$('#validationAlert').removeClass('show').hide();"></button>
</div>

<form asp-action="WeighOut" asp-route-id="@Model.Ticket" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="manualOutWeight" id="manualWeightFlag" value="false" />

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Ticket Number</label>
                        <input type="text" class="form-control" style="max-width: 140px;" value="@Model.Ticket" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Commodity</label>
                        <select name="Commodity" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var c in (List<BasicWeigh.Web.Models.Commodity>)ViewBag.Commodities)
                            {
                                <option value="@c.CommodityName" selected="@(Model.Commodity == c.CommodityName ? "selected" : null)">@c.CommodityName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Customer</label>
                        <select name="Customer" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var c in (List<BasicWeigh.Web.Models.Customer>)ViewBag.Customers)
                            {
                                <option value="@c.CustomerName" selected="@(Model.Customer == c.CustomerName ? "selected" : null)">@c.CustomerName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Carrier</label>
                        <select name="Carrier" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var name in (List<string>)ViewBag.CarrierOptions)
                            {
                                <option value="@name" selected="@(Model.Carrier == name ? "selected" : null)">@name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Truck ID</label>
                        <div class="input-group">
                            <select name="TruckId" id="truckSelect" class="form-select" disabled>
                                <option value="">-- Select Carrier First --</option>
                            </select>
                            <button type="button" class="btn btn-outline-primary" id="addTruckBtn" disabled title="Add New Truck">+</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <input type="hidden" name="manualInWeight" id="manualInWeightFlag" value="@(Model.ManualInbound ? "true" : "false")" />

                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <select name="Location" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var l in (List<BasicWeigh.Web.Models.Location>)ViewBag.Locations)
                            {
                                <option value="@l.LocationName" selected="@(Model.Location == l.LocationName ? "selected" : null)">@l.LocationName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Destination</label>
                        <select name="Destination" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var d in (List<BasicWeigh.Web.Models.Destination>)ViewBag.Destinations)
                            {
                                <option value="@d.DestinationName" selected="@(Model.Destination == d.DestinationName ? "selected" : null)">@d.DestinationName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea name="Notes" class="form-control" rows="2">@Model.Notes</textarea>
                    </div>

                    <div class="row mb-3">
                        <div class="col-7">
                            <label class="form-label">In Weight (lb) <span id="manualInBadge" class="badge bg-warning text-dark" style="display: @(Model.ManualInbound ? "inline" : "none");">Manual</span></label>
                            <div class="input-group">
                                <input type="text" name="InWeight" id="inWeightDisplay" class="form-control text-end fw-bold" style="font-size: 1.1rem; letter-spacing: 1px; max-width: 160px;"
                                       value="@Model.InWeight" readonly />
                                <button type="button" class="btn btn-primary" id="getInWeightBtn">Get Weight</button>
                            </div>
                        </div>
                        <div class="col-5">
                            <label class="form-label">Date In</label>
                            <input type="datetime-local" name="DateIn" id="dateInInput" class="form-control form-control-sm"
                                   value="@Model.DateIn.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-7">
                            <label class="form-label">Out Weight (lb) <span id="manualBadge" class="badge bg-warning text-dark" style="display: @(Model.ManualOutbound ? "inline" : "none");">Manual</span></label>
                            <div class="input-group">
                                <input type="text" name="OutWeight" id="outWeightInput" class="form-control text-end fw-bold" style="font-size: 1.1rem; letter-spacing: 1px; max-width: 160px;"
                                       value="@(Model.OutWeight ?? 0)" readonly />
                                <button type="button" class="btn btn-primary" id="getWeightBtn">Get Weight</button>
                            </div>
                        </div>
                        <div class="col-5">
                            <label class="form-label">Date Out</label>
                            <input type="datetime-local" name="DateOut" id="dateOutInput" class="form-control form-control-sm"
                                   value="@(Model.DateOut?.ToString("yyyy-MM-ddTHH:mm") ?? DateTime.Now.ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>
                    </div>

                    <div class="row mb-3 py-2 rounded" style="background: var(--bw-surface-alt);">
                        <div class="col-3 text-center">
                            <label class="form-label fw-bold small mb-0">Gross</label>
                            <div id="grossWeight" class="fw-bold" style="font-size: 1.05rem;">0</div>
                        </div>
                        <div class="col-3 text-center">
                            <label class="form-label fw-bold small mb-0">Tare</label>
                            <div id="tareWeight" class="fw-bold" style="font-size: 1.05rem;">0</div>
                        </div>
                        <div class="col-3 text-center">
                            <label class="form-label fw-bold small mb-0" style="color: var(--bw-primary);">Net</label>
                            <div id="netWeight" class="fw-bold" style="font-size: 1.4rem; color: var(--bw-primary);">0</div>
                        </div>
                        <div class="col-3 text-center">
                            <label class="form-label fw-bold small mb-0" style="color: var(--bw-primary);">Net Tons</label>
                            <div id="netTons" class="fw-bold" style="font-size: 1.4rem; color: var(--bw-primary);">0.00</div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-success btn-lg me-2">Save</button>
                        <a asp-action="InboundTrucks" class="btn btn-secondary btn-lg">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Get Weight Modal -->
<div class="modal fade" id="getWeightModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Get Weight from Scale</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="scaleWeightView">
                    <div class="get-weight-display" id="gwDisplay">
                        <span id="gwValue">0</span>
                        <span class="get-weight-unit" id="gwUnit">lb</span>
                        <div class="get-weight-status" id="gwStatus">&nbsp;</div>
                    </div>
                </div>
                @if (isDemoMode)
                {
                <div id="gwSimPanel" class="mt-3 p-2 rounded" style="background: var(--bw-sim-bg); border: 1px solid var(--bw-sim-border);">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="fw-bold text-warning" style="font-size: 0.8rem;">SIMULATOR</span>
                    </div>
                    <div class="mb-1">
                        <label class="form-label mb-0 small fw-bold">Weight: <span id="gwSimLabel">0</span> lb</label>
                        <input type="range" class="form-range" id="gwSimSlider" min="0" max="200000" step="20" value="0" />
                    </div>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="gwSimMotion" />
                            <label class="form-check-label small fw-bold" for="gwSimMotion">Motion</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="gwSimError" />
                            <label class="form-check-label small fw-bold text-danger" for="gwSimError">Error</label>
                        </div>
                    </div>
                </div>
                }
                <div id="manualWeightView" style="display:none;">
                    <div class="mb-2">
                        <label class="form-label fw-bold">Enter Weight Manually</label>
                        <div class="input-group">
                            <input type="number" id="manualWeightInput" class="form-control manual-weight-input"
                                   min="0" max="40000000" step="1" value="0" />
                            <span class="input-group-text fw-bold">lb</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning" id="gwManualBtn">Manual</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="gwSaveBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Truck Modal -->
<div class="modal fade" id="addTruckModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Truck</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Carrier</label>
                    <input type="text" id="modalCarrier" class="form-control" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">Truck ID</label>
                    <input type="text" id="modalTruckId" class="form-control" maxlength="50" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTruckBtn">Add Truck</button>
            </div>
        </div>
    </div>
</div>

<!-- Unsaved changes alert (hidden by default) -->
<div class="alert alert-warning alert-dismissible fade py-1 mb-2 position-fixed top-0 start-50 translate-middle-x mt-3"
     role="alert" id="unsavedAlert" style="display:none; z-index:9999;">
    <strong>Unsaved changes!</strong> You have unsaved changes. Click <strong>Save</strong> to keep them.
    <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
</div>

@section Scripts {
<script>
    $(function () {
        var isDirty = false;
        var isSaving = false;

        $('form').on('change input', 'input, select, textarea', function () {
            if (!isDirty) {
                isDirty = true;
                $('#unsavedAlert').fadeIn().addClass('show');
            }
        });

        $('form').on('submit', function () { isSaving = true; });

        $(window).on('beforeunload', function () {
            if (isDirty && !isSaving) return 'You have unsaved changes.';
        });

        $('a').on('click', function (e) {
            if (isDirty && !isSaving) {
                if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                    e.preventDefault();
                }
            }
        });

        var customerSelect = $('select[name="Customer"]');
        var carrierSelect = $('select[name="Carrier"]');
        var truckSelect = $('#truckSelect');
        var addTruckBtn = $('#addTruckBtn');
        var initialTruckId = '@(Model.TruckId ?? "")';
        var outWeightInput = $('#outWeightInput');
        var inWeightInput = $('#inWeightDisplay');
        var manualFlag = $('#manualWeightFlag');
        var manualInFlag = $('#manualInWeightFlag');

        // --- Get Weight Modal ---
        var gwModal = null;
        var gwPollTimer = null;
        var isManualMode = false;
        var lastScaleData = { weight: 0, motion: false, error: false };
        var weightTarget = 'out'; // 'in' or 'out'

        function pollScaleWeight() {
            $.getJSON('/api/scale/weight', function (data) {
                lastScaleData = data;
                var display = $('#gwDisplay');
                var val = $('#gwValue');
                var unit = $('#gwUnit');
                var status = $('#gwStatus');
                var saveBtn = $('#gwSaveBtn');

                if (data.error) {
                    val.text('------');
                    unit.text('');
                    display.css('color', '#ff0000');
                    status.css('color', '#ff0000').text('ERROR');
                    saveBtn.prop('disabled', true);
                } else if (data.motion) {
                    val.text(data.weight.toLocaleString());
                    unit.text('lb');
                    display.css('color', '#ffff00');
                    status.css('color', '#ffff00').text('MOTION');
                    saveBtn.prop('disabled', true);
                } else {
                    val.text(data.weight.toLocaleString());
                    unit.text('lb');
                    display.css('color', '#00ff41');
                    status.html('&nbsp;');
                    saveBtn.prop('disabled', false);
                }
            });
        }

        // Mini simulator inside modal (demo mode only)
        var gwSimSlider = $('#gwSimSlider');
        var gwSimLabel = $('#gwSimLabel');
        var gwUserDragging = false;

        function pushGwSim() {
            var weight = parseInt(gwSimSlider.val());
            var motion = $('#gwSimMotion').is(':checked');
            var error = $('#gwSimError').is(':checked');
            gwSimLabel.text(weight.toLocaleString());
            $.ajax({
                url: '/api/scale/simulate',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ weight: weight, motion: motion, error: error })
            });
        }

        gwSimSlider.on('mousedown touchstart', function () { gwUserDragging = true; });
        $(document).on('mouseup touchend', function () { gwUserDragging = false; });
        gwSimSlider.on('input', pushGwSim);
        $('#gwSimMotion').on('change', pushGwSim);
        $('#gwSimError').on('change', pushGwSim);

        function syncGwSim(data) {
            if (gwUserDragging) return;
            gwSimSlider.val(data.weight || 0);
            gwSimLabel.text((data.weight || 0).toLocaleString());
            $('#gwSimMotion').prop('checked', !!data.motion);
            $('#gwSimError').prop('checked', !!data.error);
        }

        function openGetWeightModal(target) {
            weightTarget = target;
            isManualMode = false;
            $('#scaleWeightView').show();
            $('#manualWeightView').hide();
            $('#gwSimPanel').show();
            $('#gwManualBtn').show();
            $('#gwSaveBtn').prop('disabled', true);
            $('#getWeightModal .modal-title').text('Get ' + (target === 'in' ? 'In' : 'Out') + ' Weight from Scale');
            gwModal = new bootstrap.Modal('#getWeightModal');
            gwModal.show();
            // Load current weight into simulator slider
            $.getJSON('/api/scale/weight', function (data) { syncGwSim(data); });
            pollScaleWeight();
            gwPollTimer = setInterval(function () {
                pollScaleWeight();
                $.getJSON('/api/scale/weight', function (data) { syncGwSim(data); });
            }, 500);
        }

        $('#getWeightBtn').on('click', function () { openGetWeightModal('out'); });
        $('#getInWeightBtn').on('click', function () { openGetWeightModal('in'); });

        $('#getWeightModal').on('hidden.bs.modal', function () {
            if (gwPollTimer) { clearInterval(gwPollTimer); gwPollTimer = null; }
        });

        $('#gwManualBtn').on('click', function () {
            isManualMode = true;
            $('#scaleWeightView').hide();
            $('#gwSimPanel').hide();
            $('#manualWeightView').show();
            $(this).hide();
            $('#gwSaveBtn').prop('disabled', false);
            $('#manualWeightInput').val('').focus();
        });

        function nowDateTimeLocal() {
            var now = new Date();
            var y = now.getFullYear();
            var mo = String(now.getMonth() + 1).padStart(2, '0');
            var d = String(now.getDate()).padStart(2, '0');
            var h = String(now.getHours()).padStart(2, '0');
            var mi = String(now.getMinutes()).padStart(2, '0');
            return y + '-' + mo + '-' + d + 'T' + h + ':' + mi;
        }

        function updateCalcWeights() {
            var inW = parseInt(inWeightInput.val()) || 0;
            var outW = parseInt(outWeightInput.val()) || 0;
            var gross = Math.max(inW, outW);
            var tare = Math.min(inW, outW);
            var net = Math.abs(inW - outW);
            var netTons = (net / 2000).toFixed(2);
            $('#grossWeight').text(gross.toLocaleString());
            $('#tareWeight').text(tare.toLocaleString());
            $('#netWeight').text(net.toLocaleString());
            $('#netTons').text(netTons);
        }

        // Initial calc on page load
        updateCalcWeights();

        $('#gwSaveBtn').on('click', function () {
            var weightVal, isManual;
            if (isManualMode) {
                weightVal = parseInt($('#manualWeightInput').val()) || 0;
                isManual = true;
            } else {
                weightVal = lastScaleData.weight;
                isManual = false;
            }

            if (weightTarget === 'in') {
                inWeightInput.val(weightVal);
                manualInFlag.val(isManual ? 'true' : 'false');
                if (isManual) { $('#manualInBadge').show(); } else { $('#manualInBadge').hide(); }
                $('#dateInInput').val(nowDateTimeLocal());
            } else {
                outWeightInput.val(weightVal);
                manualFlag.val(isManual ? 'true' : 'false');
                if (isManual) { $('#manualBadge').show(); } else { $('#manualBadge').hide(); }
                $('#dateOutInput').val(nowDateTimeLocal());
            }
            updateCalcWeights();
            gwModal.hide();
        });

        // Validate weights before save
        function showValidation(msg) {
            $('#validationMsg').text(msg);
            $('#validationAlert').show().addClass('show');
            $('html, body').animate({ scrollTop: 0 }, 300);
        }

        $('form').on('submit', function (e) {
            var outW = parseInt(outWeightInput.val()) || 0;
            if (outW <= 0) {
                e.preventDefault();
                showValidation('Please click "Get Weight" to capture the outbound scale weight before saving.');
                return false;
            }
        });

        // --- Customer/Carrier/Truck logic ---
        customerSelect.on('change', function () {
            if (!carrierSelect.val() && $(this).val()) {
                carrierSelect.val($(this).val());
                carrierSelect.trigger('change');
            }
        });

        function loadTrucks(carrier, selectTruckId) {
            if (!carrier) {
                truckSelect.html('<option value="">-- Select Carrier First --</option>').prop('disabled', true);
                addTruckBtn.prop('disabled', true);
                return;
            }
            $.getJSON('/api/masterdata/trucks/' + encodeURIComponent(carrier), function (trucks) {
                truckSelect.html('<option value="">-- Select --</option>');
                trucks.forEach(function (t) {
                    truckSelect.append($('<option>').val(t.truckId).text(t.truckId));
                });
                truckSelect.prop('disabled', false);
                addTruckBtn.prop('disabled', false);
                if (selectTruckId) truckSelect.val(selectTruckId);
            });
        }

        carrierSelect.on('change', function () {
            loadTrucks($(this).val());
        });

        if (carrierSelect.val()) {
            loadTrucks(carrierSelect.val(), initialTruckId);
        }

        addTruckBtn.on('click', function () {
            $('#modalCarrier').val(carrierSelect.val());
            $('#modalTruckId').val('');
            new bootstrap.Modal('#addTruckModal').show();
            setTimeout(function () { $('#modalTruckId').focus(); }, 500);
        });

        $('#saveTruckBtn').on('click', function () {
            var carrier = $('#modalCarrier').val();
            var truckId = $('#modalTruckId').val().trim();
            if (!truckId) return;

            $.ajax({
                url: '/api/masterdata/trucks',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ truckId: truckId, carrierName: carrier }),
                success: function () {
                    bootstrap.Modal.getInstance('#addTruckModal').hide();
                    loadTrucks(carrier, truckId);
                }
            });
        });

        $('#modalTruckId').on('keypress', function (e) {
            if (e.which === 13) { e.preventDefault(); $('#saveTruckBtn').click(); }
        });
    });
</script>
}
