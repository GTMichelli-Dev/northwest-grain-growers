@inject BasicWeigh.Web.Data.ScaleDbContext Db
@{
    Layout = null;
    var appSetup = Db.AppSetup.FirstOrDefault();
    var appName = appSetup?.Header1 ?? "Basic Weigh";
    var theme = appSetup?.Theme ?? "default";
}
<!DOCTYPE html>
<html lang="en" data-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password - @appName</title>
    <link href="~/css/devextreme/bootstrap.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        body {
            background: var(--bw-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }
        .login-card {
            max-width: 400px;
            width: 100%;
            border: 2px solid var(--bw-primary);
            border-radius: 12px;
        }
    </style>
</head>
<body>
    <div class="card login-card">
        <div class="card-header text-center py-3" style="background: var(--bw-surface-alt);">
            <h5 style="color: var(--bw-primary); margin: 0;">Change Password</h5>
            <small class="text-muted">Your password has been reset. Please choose a new password.</small>
        </div>
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
            }

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">New Password</label>
                    <input type="password" name="newPassword" class="form-control" required minlength="4" autofocus />
                </div>
                <div class="mb-3">
                    <label class="form-label">Confirm Password</label>
                    <input type="password" name="confirmPassword" class="form-control" required minlength="4" />
                </div>
                <button type="submit" class="btn btn-primary w-100">Change Password</button>
            </form>
        </div>
    </div>

    <script src="~/js/devextreme/jquery.js"></script>
    <script src="~/js/devextreme/bootstrap.js"></script>
</body>
</html>
