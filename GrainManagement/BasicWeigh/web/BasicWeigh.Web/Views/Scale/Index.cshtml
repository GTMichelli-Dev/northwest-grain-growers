@{
    ViewData["Title"] = "Scale Management";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">Scale Management</h3>
    <a href="/Setup" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left"></i> Back to Setup</a>
</div>

<!-- Scale Assignment -->
<div class="card mb-3">
    <div class="card-header py-2"><strong>Scale Assignment</strong></div>
    <div class="card-body py-2">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label mb-0 small fw-bold">Active Scale</label>
                <select id="scaleSelect" class="form-select form-select-sm" style="max-width:200px;" onchange="saveAssignment()">
                    <option value="">-- None --</option>
                </select>
            </div>
            <div class="col-md-2">
                <span id="assignmentStatus" class="small"></span>
            </div>
        </div>
    </div>
</div>

<!-- Status bar -->
<div id="serviceStatusBar" class="alert alert-warning py-2 mb-3 d-flex align-items-center">
    <i class="fa fa-spinner fa-spin me-2"></i> Checking scale services...
</div>

<!-- Toast container -->
<div id="scaleToastContainer" style="position:fixed;top:70px;right:20px;z-index:9999;min-width:350px;max-width:500px;"></div>

<!-- Services container -->
<div id="servicesContainer"></div>

<!-- No services message -->
<div id="noServicesMessage" class="text-center text-muted py-5" style="display:none;">
    <i class="fa fa-balance-scale fa-3x mb-3 d-block"></i>
    <h5>No Scale Services Connected</h5>
    <p>Start a Scale Reader Service and point it to this server's SignalR hub.</p>
</div>

<!-- Add/Edit Scale Modal -->
<div class="modal fade" id="scaleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="scaleModalTitle">Add Scale</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="scaleModalServiceId" />
                <input type="hidden" id="scaleModalMode" value="add" />
                <input type="hidden" id="scaleModalOriginalId" />
                <div class="mb-2">
                    <label class="form-label mb-0 small">Scale ID</label>
                    <input type="text" class="form-control form-control-sm" id="scaleScaleId" placeholder="e.g. truck-scale-1" />
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0 small">Display Name</label>
                    <input type="text" class="form-control form-control-sm" id="scaleDisplayName" placeholder="e.g. Truck Scale 1" />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <label class="form-label mb-0 small">Brand / Protocol</label>
                        <select class="form-select form-select-sm" id="scaleBrand">
                            <option value="Generic SMA">Generic SMA</option>
                        </select>
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <label class="form-label mb-0 small">IP Address</label>
                        <input type="text" class="form-control form-control-sm" id="scaleIp" placeholder="Enter IP address" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Port</label>
                        <input type="number" class="form-control form-control-sm" id="scalePort" value="10001" min="1" max="65535" />
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0 small">Request Command (optional override)</label>
                    <input type="text" class="form-control form-control-sm" id="scaleRequestCommand" placeholder="W\r\n (leave blank for brand default)" />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <label class="form-label mb-0 small">Poll Interval (ms)</label>
                        <input type="number" class="form-control form-control-sm" id="scalePollingInterval" value="750" min="100" max="10000" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Timeout (ms)</label>
                        <input type="number" class="form-control form-control-sm" id="scaleTimeout" value="1000" min="100" max="10000" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Active</label>
                        <select class="form-select form-select-sm" id="scaleActive">
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                    </div>
                </div>
                <div id="brandNotes" class="small text-muted" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveScale()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Live Weight Modal -->
<div class="modal fade" id="liveWeightModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Live Weight — <span id="liveWeightScaleName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div style="background-color:#000;border-radius:16px;padding:20px 40px;max-width:500px;margin:0 auto;">
                    <div id="liveWeightDisplay" style="font-family:'Courier New',monospace;font-size:clamp(2.5rem,5vw,4rem);font-weight:bold;color:#0f0;text-align:right;letter-spacing:4px;white-space:nowrap;">
                        <span id="liveWeightValue">0</span>
                        <span style="font-size:2rem;color:#0a0;margin-left:10px;" id="liveWeightUnit">lb</span>
                    </div>
                    <div id="liveWeightStatus" style="font-size:1.2rem;font-weight:bold;text-align:center;letter-spacing:2px;min-height:1.4em;margin-top:8px;"></div>
                </div>
                <div class="mt-3 text-start">
                    <a class="small text-muted" data-bs-toggle="collapse" href="#rawDiag" role="button"><i class="fa fa-terminal"></i> Diagnostic</a>
                    <div class="collapse mt-1" id="rawDiag">
                        <div class="bg-dark text-light p-2 rounded" style="font-family:'Courier New',monospace;font-size:12px;">
                            <div>Raw: <span id="diagRawText" style="color:#0f0;">--</span></div>
                            <div>Hex: <span id="diagRawHex" style="color:#888;">--</span></div>
                            <div>Parsed: <span id="diagParsed" style="color:#ff0;">--</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/signalr/signalr.min.js"></script>
<script>
    var connectedServices = {};
    var scaleBrands = [];
    var savedScaleId = '@(ViewBag.ScaleId ?? "")';
    var liveWeightScaleId = null;

    function escHtml(s) { return s ? s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : ''; }
    function escAttr(s) { return s ? s.replace(/'/g,"\\'").replace(/"/g,'&quot;') : ''; }

    // ===== SIGNALR =====
    var connection = new signalR.HubConnectionBuilder().withUrl('/scaleHub').build();

    connection.on('ScaleServiceReady', function (data) {
        connectedServices[data.serviceId] = data;
        renderServices();
        updateStatusBar();
    });

    connection.on('ScaleListReceived', function (data) {
        connectedServices[data.serviceId] = data;
        renderServices();
        updateStatusBar();
    });

    connection.on('ScaleServiceStatusChanged', function (serviceIds) {
        // Remove disconnected services
        Object.keys(connectedServices).forEach(function (sid) {
            if (serviceIds.indexOf(sid) < 0) delete connectedServices[sid];
        });
        updateStatusBar();
        renderServices();
    });

    connection.on('ScaleWeight', function (data) {
        // Update live weight modal if open for this scale
        if (liveWeightScaleId && data.scaleId === liveWeightScaleId) {
            var weightVal = document.getElementById('liveWeightValue');
            var weightUnit = document.getElementById('liveWeightUnit');
            var status = document.getElementById('liveWeightStatus');
            if (data.ok) {
                weightVal.textContent = data.weight.toLocaleString();
                weightVal.style.color = data.motion ? '#ffc107' : '#0f0';
                weightUnit.style.color = data.motion ? '#cc9900' : '#0a0';
                status.innerHTML = data.motion
                    ? '<span style="color:#ffc107;">MOTION</span>'
                    : '<span style="color:#0a0;">STABLE</span>';
            } else {
                weightVal.textContent = '---';
                weightVal.style.color = '#f00';
                weightUnit.style.color = '#a00';
                status.innerHTML = '<span style="color:#f00;">ERROR</span>';
            }
            // Update diagnostic raw response
            var rawText = document.getElementById('diagRawText');
            var rawHex = document.getElementById('diagRawHex');
            var parsed = document.getElementById('diagParsed');
            if (rawText) rawText.textContent = data.rawResponse || '--';
            if (rawHex) rawHex.textContent = data.rawHex || '--';
            if (parsed) parsed.textContent = 'weight=' + data.weight + ' motion=' + data.motion + ' ok=' + data.ok + ' status=' + data.status;
        }
    });

    connection.on('ScaleCrudResult', function (data) {
        showToast(data.success ? 'success' : 'danger', data.message || (data.success ? 'Done' : 'Failed'));
        if (data.success) {
            connection.invoke('RequestScaleList').catch(function () {});
        }
    });

    connection.start().then(function () {
        connection.invoke('RequestScaleList').catch(function () {});
    });

    // ===== STATUS BAR =====
    function updateStatusBar() {
        var bar = document.getElementById('serviceStatusBar');
        var noMsg = document.getElementById('noServicesMessage');
        var count = Object.keys(connectedServices).length;
        if (count > 0) {
            bar.className = 'alert alert-success py-2 mb-3 d-flex align-items-center';
            bar.innerHTML = '<i class="fa fa-check-circle me-2"></i> <strong>' + count + ' Scale Service(s) Connected</strong>';
            noMsg.style.display = 'none';
        } else {
            bar.className = 'alert alert-warning py-2 mb-3 d-flex align-items-center';
            bar.innerHTML = '<i class="fa fa-exclamation-triangle me-2"></i> <strong class="text-danger">No Scale Services Connected</strong>' +
                '— Start a Scale Reader Service and point it to this server\'s SignalR hub.';
            noMsg.style.display = 'block';
        }
    }
    setTimeout(function () { if (Object.keys(connectedServices).length === 0) updateStatusBar(); }, 3000);

    // ===== RENDER SERVICES =====
    function renderServices() {
        var container = document.getElementById('servicesContainer');
        var html = '';
        updateAssignmentDropdown();

        Object.keys(connectedServices).forEach(function (serviceId) {
            var svc = connectedServices[serviceId];
            var cams = svc.scales || [];

            html += '<div class="card mb-3"><div class="card-header py-2 d-flex justify-content-between align-items-center">';
            html += '<div><span class="badge bg-success me-2">Connected</span> <strong>' + escHtml(serviceId) + '</strong>';
            html += ' <span class="text-muted">(' + cams.length + ' scale' + (cams.length !== 1 ? 's' : '') + ')</span></div>';
            html += '<button class="btn btn-outline-primary btn-sm" onclick="addScale(\'' + escAttr(serviceId) + '\')"><i class="fa fa-plus"></i> Add Scale</button>';
            html += '</div><div class="card-body p-0"><table class="table table-sm table-striped mb-0">';
            html += '<thead><tr><th>Scale ID</th><th>Display Name</th><th>Brand</th><th>IP : Port</th>';
            html += '<th>Active</th><th style="width:200px;">Actions</th></tr></thead><tbody>';

            cams.forEach(function (s) {
                html += '<tr>';
                html += '<td>' + escHtml(s.scaleId) + '</td>';
                html += '<td>' + escHtml(s.displayName) + '</td>';
                html += '<td>' + escHtml(s.scaleBrand) + '</td>';
                html += '<td>' + escHtml(s.ipAddress) + ':' + s.port + '</td>';
                html += '<td>' + (s.active ? '<span class="text-success fw-bold">&#10003;</span>' : '<span class="text-muted">&#10007;</span>') + '</td>';
                html += '<td>';
                html += '<button class="btn btn-outline-info btn-sm me-1" onclick="showLiveWeight(\'' + escAttr(serviceId) + '\',\'' + escAttr(s.scaleId) + '\',\'' + escAttr(s.displayName) + '\')"><i class="fa fa-tachometer"></i> Live</button>';
                html += '<button class="btn btn-outline-warning btn-sm me-1" onclick="editScale(\'' + escAttr(serviceId) + '\',\'' + escAttr(s.scaleId) + '\')">Edit</button>';
                html += '<button class="btn btn-outline-danger btn-sm" onclick="deleteScale(\'' + escAttr(serviceId) + '\',\'' + escAttr(s.scaleId) + '\')">Delete</button>';
                html += '</td></tr>';
            });

            html += '</tbody></table></div></div>';
        });

        container.innerHTML = html;
    }

    // ===== SCALE ASSIGNMENT =====
    function updateAssignmentDropdown() {
        var sel = document.getElementById('scaleSelect');
        var currentVal = sel.value || savedScaleId;
        var options = '<option value="">-- None --</option>';

        Object.keys(connectedServices).forEach(function (sid) {
            var scales = connectedServices[sid].scales || [];
            scales.forEach(function (s) {
                if (!s.active) return;
                var val = sid + ':' + s.scaleId;
                var label = s.displayName || s.scaleId;
                if (Object.keys(connectedServices).length > 1) label += ' (' + sid + ')';
                options += '<option value="' + escAttr(val) + '">' + escHtml(label) + '</option>';
            });
        });

        sel.innerHTML = options;
        sel.value = currentVal;
    }

    function saveAssignment() {
        var val = document.getElementById('scaleSelect').value;
        var status = document.getElementById('assignmentStatus');
        status.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Saving...';

        fetch('/api/scales/assignment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ scaleId: val })
        }).then(function (r) {
            if (r.ok) {
                savedScaleId = val;
                status.innerHTML = '<span class="text-success">&#10003; Saved</span>';
                setTimeout(function () { status.innerHTML = ''; }, 2000);
            } else {
                status.innerHTML = '<span class="text-danger">Failed</span>';
            }
        }).catch(function () {
            status.innerHTML = '<span class="text-danger">Failed</span>';
        });
    }

    // ===== SCALE CRUD =====
    function addScale(serviceId) {
        document.getElementById('scaleModalServiceId').value = serviceId;
        document.getElementById('scaleModalMode').value = 'add';
        document.getElementById('scaleModalOriginalId').value = '';
        document.getElementById('scaleModalTitle').textContent = 'Add Scale';
        document.getElementById('scaleScaleId').value = '';
        document.getElementById('scaleScaleId').readOnly = false;
        document.getElementById('scaleDisplayName').value = '';
        document.getElementById('scaleBrand').value = 'Generic SMA';
        document.getElementById('scaleIp').value = '';
        document.getElementById('scalePort').value = '10001';
        document.getElementById('scaleRequestCommand').value = '';
        document.getElementById('scalePollingInterval').value = '750';
        document.getElementById('scaleTimeout').value = '1000';
        document.getElementById('scaleActive').value = 'true';
        new bootstrap.Modal('#scaleModal').show();
    }

    function editScale(serviceId, scaleId) {
        var svc = connectedServices[serviceId];
        if (!svc) return;
        var scale = (svc.scales || []).find(function (s) { return s.scaleId === scaleId; });
        if (!scale) return;

        document.getElementById('scaleModalServiceId').value = serviceId;
        document.getElementById('scaleModalMode').value = 'edit';
        document.getElementById('scaleModalOriginalId').value = scaleId;
        document.getElementById('scaleModalTitle').textContent = 'Edit Scale';
        document.getElementById('scaleScaleId').value = scale.scaleId;
        document.getElementById('scaleScaleId').readOnly = true;
        document.getElementById('scaleDisplayName').value = scale.displayName || '';
        document.getElementById('scaleBrand').value = scale.scaleBrand || 'Generic SMA';
        document.getElementById('scaleIp').value = scale.ipAddress || '';
        document.getElementById('scalePort').value = scale.port || 10001;
        document.getElementById('scaleRequestCommand').value = scale.requestCommand || '';
        document.getElementById('scalePollingInterval').value = scale.pollingIntervalMs || 750;
        document.getElementById('scaleTimeout').value = scale.timeoutMs || 1000;
        document.getElementById('scaleActive').value = scale.active ? 'true' : 'false';
        new bootstrap.Modal('#scaleModal').show();
    }

    function saveScale() {
        var mode = document.getElementById('scaleModalMode').value;
        var serviceId = document.getElementById('scaleModalServiceId').value;
        var data = {
            scaleId: document.getElementById('scaleScaleId').value.trim(),
            displayName: document.getElementById('scaleDisplayName').value.trim(),
            scaleBrand: document.getElementById('scaleBrand').value,
            ipAddress: document.getElementById('scaleIp').value.trim(),
            port: parseInt(document.getElementById('scalePort').value) || 10001,
            requestCommand: document.getElementById('scaleRequestCommand').value.trim() || null,
            pollingIntervalMs: parseInt(document.getElementById('scalePollingInterval').value) || 750,
            timeoutMs: parseInt(document.getElementById('scaleTimeout').value) || 1000,
            active: document.getElementById('scaleActive').value === 'true'
        };

        if (!data.scaleId) { alert('Scale ID is required'); return; }

        var method = mode === 'edit' ? 'UpdateScaleOnService' : 'AddScaleToService';
        var args = mode === 'edit'
            ? [serviceId, document.getElementById('scaleModalOriginalId').value, data]
            : [serviceId, data];

        connection.invoke.apply(connection, [method].concat(args)).then(function () {
            bootstrap.Modal.getInstance(document.getElementById('scaleModal')).hide();
        }).catch(function (err) {
            showToast('danger', 'Error: ' + err);
        });
    }

    function deleteScale(serviceId, scaleId) {
        if (!confirm('Delete scale "' + scaleId + '"?')) return;
        connection.invoke('DeleteScaleFromService', serviceId, scaleId).catch(function (err) {
            showToast('danger', 'Error: ' + err);
        });
    }

    // ===== LIVE WEIGHT =====
    function showLiveWeight(serviceId, scaleId, displayName) {
        liveWeightScaleId = scaleId;
        document.getElementById('liveWeightScaleName').textContent = displayName || scaleId;
        document.getElementById('liveWeightValue').textContent = '0';
        document.getElementById('liveWeightValue').style.color = '#0f0';
        document.getElementById('liveWeightUnit').style.color = '#0a0';
        document.getElementById('liveWeightStatus').innerHTML = '<span style="color:#888;">Waiting...</span>';
        document.getElementById('diagRawText').textContent = '--';
        document.getElementById('diagRawHex').textContent = '--';
        document.getElementById('diagParsed').textContent = '--';
        new bootstrap.Modal('#liveWeightModal').show();

        document.getElementById('liveWeightModal').addEventListener('hidden.bs.modal', function () {
            liveWeightScaleId = null;
        }, { once: true });
    }

    // ===== TOAST =====
    function showToast(type, message) {
        var container = document.getElementById('scaleToastContainer');
        var colors = {
            success: { bg: '#d1e7dd', border: '#badbcc', text: '#0f5132' },
            danger: { bg: '#f8d7da', border: '#f5c2c7', text: '#842029' },
            info: { bg: '#cff4fc', border: '#b6effb', text: '#055160' }
        };
        var c = colors[type] || colors.info;
        var html = '<div role="alert" style="padding:12px 40px 12px 16px;margin-bottom:8px;border:1px solid ' + c.border +
            ';border-radius:6px;background:' + c.bg + ';color:' + c.text + ';position:relative;">' +
            message + '<button type="button" onclick="this.parentElement.remove()" style="position:absolute;top:8px;right:12px;background:none;border:none;font-size:18px;cursor:pointer;color:' + c.text + ';">&times;</button></div>';
        container.innerHTML = html;
        if (type !== 'danger') setTimeout(function () { container.innerHTML = ''; }, 5000);
    }
</script>
}
