@model BasicWeigh.Web.Models.Transaction
@{
    Layout = null;
    bool hasInPhoto = ViewBag.HasInPhoto == true;
    bool hasOutPhoto = ViewBag.HasOutPhoto == true;
    bool isCompleted = Model.DateOut.HasValue;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Ticket @Model.Ticket</title>
    <style>
        body {
            font-family: 'Courier New', monospace;
            margin: 20px auto;
            font-size: 13px;
            max-width: 950px;
        }
        .photo-ticket-row {
            display: flex;
            gap: 16px;
            align-items: flex-start;
            margin-bottom: 20px;
            page-break-inside: avoid;
        }
        .photo-side {
            flex: 0 0 420px;
        }
        .photo-side img {
            width: 100%;
            border-radius: 4px;
            border: 1px solid #999;
            display: block;
        }
        .photo-side .photo-label {
            text-align: center;
            font-weight: bold;
            font-size: 11px;
            margin-top: 4px;
            color: #555;
        }
        .ticket-side {
            flex: 1;
            min-width: 340px;
        }
        .ticket {
            border: 2px solid #000;
            padding: 16px;
        }
        .ticket-header {
            text-align: center;
            margin-bottom: 12px;
            border-bottom: 1px dashed #000;
            padding-bottom: 8px;
        }
        .ticket-icon {
            width: 40px;
            height: 40px;
            margin-bottom: 6px;
        }
        .ticket-header div {
            font-size: 14px;
            font-weight: bold;
        }
        .ticket-row {
            display: flex;
            justify-content: space-between;
            padding: 2px 0;
        }
        .ticket-row .label {
            font-weight: bold;
            min-width: 110px;
        }
        .ticket-weights {
            border-top: 1px dashed #000;
            border-bottom: 1px dashed #000;
            margin: 8px 0;
            padding: 8px 0;
        }
        .ticket-weights .ticket-row {
            font-size: 14px;
        }
        .net-weight {
            font-size: 18px;
            font-weight: bold;
        }
        .ticket-type-label {
            text-align: center;
            font-weight: bold;
            font-size: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #333;
            margin-bottom: 6px;
            border-bottom: 2px solid #333;
            padding-bottom: 4px;
        }
        .no-photo-ticket {
            max-width: 400px;
            margin: 0 auto 20px;
        }
        .print-btn {
            text-align: center;
            margin-top: 20px;
        }
        @@media print {
            .print-btn { display: none; }
            body { margin: 0; font-size: 12px; }
            .photo-side { flex: 0 0 360px; }
        }
    </style>
</head>
<body>

@* ===== INBOUND SECTION ===== *@
@if (hasInPhoto)
{
    <div class="photo-ticket-row">
        <div class="photo-side">
            <img src="/api/ticket/@Model.Ticket/image?direction=in&v=@DateTime.UtcNow.Ticks" alt="Inbound Photo" />
            <div class="photo-label">Inbound — @Model.DateIn.ToString("MM/dd/yyyy hh:mm tt")</div>
        </div>
        <div class="ticket-side">
            <div class="ticket-type-label">Inbound Ticket</div>
            <div class="ticket">
                @await Html.PartialAsync("_TicketBody", Model, new ViewDataDictionary(ViewData) {
                    { "TicketMode", "inbound" }
                })
            </div>
        </div>
    </div>
}
else if (!isCompleted)
{
    @* Inbound only, no photo — center the ticket *@
    <div class="no-photo-ticket">
        <div class="ticket">
            @await Html.PartialAsync("_TicketBody", Model, new ViewDataDictionary(ViewData) {
                { "TicketMode", "inbound" }
            })
        </div>
    </div>
}

@* ===== OUTBOUND/COMPLETED SECTION ===== *@
@if (isCompleted)
{
    if (hasOutPhoto)
    {
        <div class="photo-ticket-row">
            <div class="photo-side">
                <img src="/api/ticket/@Model.Ticket/image?direction=out&v=@DateTime.UtcNow.Ticks" alt="Outbound Photo" />
                <div class="photo-label">Outbound — @(Model.DateOut?.ToString("MM/dd/yyyy hh:mm tt") ?? "")</div>
            </div>
            <div class="ticket-side">
                <div class="ticket-type-label">Completed Ticket</div>
                <div class="ticket">
                    @await Html.PartialAsync("_TicketBody", Model, new ViewDataDictionary(ViewData) {
                        { "TicketMode", "completed" }
                    })
                </div>
            </div>
        </div>
    }
    else if (!hasInPhoto)
    {
        @* Completed, no photos at all — center the ticket *@
        <div class="no-photo-ticket">
            <div class="ticket">
                @await Html.PartialAsync("_TicketBody", Model, new ViewDataDictionary(ViewData) {
                    { "TicketMode", "completed" }
                })
            </div>
        </div>
    }
    else
    {
        @* Has inbound photo but no outbound — show completed ticket without photo *@
        <div class="no-photo-ticket">
            <div class="ticket-type-label">Completed Ticket</div>
            <div class="ticket">
                @await Html.PartialAsync("_TicketBody", Model, new ViewDataDictionary(ViewData) {
                    { "TicketMode", "completed" }
                })
            </div>
        </div>
    }
}

@if (Model.Void)
{
    <div style="text-align: center; color: red; font-size: 28px; font-weight: bold; margin-top: 10px;">
        *** VOID ***
    </div>
}

<div class="print-btn">
    <button onclick="window.print()" style="padding: 10px 30px; font-size: 16px; cursor: pointer;">Print Ticket</button>
</div>
</body>
</html>
