{
  "Urls": "http://0.0.0.0:5210",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Camera": {
    // Identity for this CameraService instance — used by the web to route
    // capture commands. Override per-host (e.g. "shop-pi", "kiosk-1") so
    // multiple services don't collide on "default".
    "ServiceId": "default",

    // Base URL of the GrainManagement web app this service talks to.
    "ServerUrl": "http://localhost:51791",

    // SignalR hub path on the web app.
    "SignalRHub": "/hubs/camera",

    // Externally-reachable URL of THIS service (used by the web to embed
    // MJPEG live views). Set to the LAN address of this host. Leave empty
    // to disable live view for this service's cameras.
    "StreamBaseUrl": "",

    // Camera brand definitions are loaded from a remote JSON file.
    // Update the URL to point to your repo's raw file for latest camera support.
    // A local fallback (camera-snapshot.json) is bundled with the service.
    "BrandsUrl": "https://raw.githubusercontent.com/GTMichelli-Dev/device-definitions/main/cameras/camera-snapshot.json",
    "BrandsToken": "",

    // Seed values for the FIRST camera — once cameras exist in the local
    // SQLite DB, these are ignored. Manage cameras going forward via the
    // web Camera page (which broadcasts CRUD over SignalR).
    "CameraBrand": "Hikvision",
    "CameraIp": "10.0.60.240",
    "CameraUser": "admin",
    "CameraPassword": "Scales123",
    "UsbDeviceName": "",
    "CameraUrl": "",
    "UsbCommand": "",
    "TimeoutSeconds": 10
  }
}
