@{
    ViewData["Title"] = "Bushels Graph";
    Layout = "_Layout";
}

<h2 style ="text-align: center;">Bushels by Location</h2>


<div style="display: flex; justify-content: center;">
    <div id="lastrefresh" style="font-size:1.1em; margin-bottom: 6px; text-align: center;">
        <span style="opacity:.7; font-size:.9em;">
            Last refresh: <span id="lastRefresh">-</span>
        </span>
    </div>
</div>
<div style="display: flex; justify-content: center; align-items: center;">
    <div id="dateRangeBox" style="width: 320px; margin-bottom: 10px;"></div>
    <button id="manualRefreshBtn" type="button" class="btn btn-outline-dark"
            style="margin-left:5px; margin-bottom:10px; height: 40px; min-width: 90px; display: flex; align-items: center;">
        Refresh
    </button>
</div>






<div id="totalsSummary" style="font-size:1.5em; margin: 8px 0 14px 0;">
    <table style="margin: 0 auto; border-collapse: collapse;">
        <tr>
            <td style="padding: 4px 12px;"><strong>Intake:</strong></td>
            <td style="padding: 4px 12px;"><span id="sumIntakeBu">-</span> bu</td>
            <td style="padding: 4px 12px;"><strong>Outbound:</strong></td>
            <td style="padding: 4px 12px;"><span id="sumOutboundBu">-</span> bu</td>
        </tr>
        <tr>
            <td style="padding: 4px 12px;"><strong>Transferred To:</strong></td>
            <td style="padding: 4px 12px;"><span id="sumToBu">-</span> bu</td>
            <td style="padding: 4px 12px;"><strong>Transferred From:</strong></td>
            <td style="padding: 4px 12px;"><span id="sumFromBu">-</span> bu</td>
        </tr>
    </table>
</div>


<div id="bushelsChart" style="height: 700px; min-height: 20px;"></div>

<script>
    (function () {
        const fmt = new Intl.NumberFormat(undefined, { maximumFractionDigits: 0 });

        function startOfToday(d) { return new Date(d.getFullYear(), d.getMonth(), d.getDate(), 0, 0, 0, 0); }
        function endOfToday(d) { return new Date(d.getFullYear(), d.getMonth(), d.getDate(), 23, 59, 59, 999); }

        function toYMD(d) {
            const y = d.getFullYear();
            const m = String(d.getMonth() + 1).padStart(2, "0");
            const day = String(d.getDate()).padStart(2, "0");
            return `${y}-${m}-${day}`;
        }

        let inFlight = null;
        let aborter = null;

        // default today
        const now = new Date();
        let currentRange = [startOfToday(now), endOfToday(now)];

        $("#dateRangeBox").dxDateRangeBox({
            label: "Filter by date range",
            labelMode: "floating",
            showClearButton: false,
            value: currentRange,
            displayFormat: "shortDate",
            onValueChanged: function (e) {
                if (e.value && e.value.length === 2) {
                    currentRange = e.value;
                    refreshData();
                }
            }
        });

        const chart = $("#bushelsChart").dxChart({
            dataSource: [],
            rotated: true,
            commonSeriesSettings: {
                type: "bar",
                argumentField: "LocationName" // PascalCase
            },
            series: [
                { valueField: "IntakeBushels", name: "Intake (bu)" },
                { valueField: "OutboundBushels", name: "Outbound (bu)" },
                { valueField: "TransferedToBushels", name: "Transferred To (bu)" },
                { valueField: "TransferedFromBushels", name: "Transferred From (bu)" }
            ],
            legend: { verticalAlignment: "top", horizontalAlignment: "center" },
            tooltip: {
                enabled: true,
                customizeTooltip: function (arg) {
                    return { text: `${arg.seriesName}: ${fmt.format(arg.value)} bu` };
                }
            },
            argumentAxis: { label: { overlappingBehavior: "stagger" } },
            valueAxis: { label: { format: "#,##0" } }
        }).dxChart("instance");

        function setSummary(rows) {
            const sum = (field) => rows.reduce((acc, r) => acc + (r[field] || 0), 0);

            const intakeBu = sum("IntakeBushels");
            const outboundBu = sum("OutboundBushels");
            const toBu = sum("TransferedToBushels");
            const fromBu = sum("TransferedFromBushels");

            document.getElementById("sumIntakeBu").textContent = fmt.format(intakeBu);
            document.getElementById("sumOutboundBu").textContent = fmt.format(outboundBu);
            document.getElementById("sumToBu").textContent = fmt.format(toBu);
            document.getElementById("sumFromBu").textContent = fmt.format(fromBu);

            document.getElementById("lastRefresh").textContent = new Date().toLocaleString();
        }

        function setChartHeight(rowCount) {
            // Minimum 20px per row, at least 100px total
            const minHeight = Math.max(100, rowCount * 20);
            document.getElementById("bushelsChart").style.height = minHeight + "px";
        }

        async function refreshData() {
            if (inFlight) return;

            if (aborter) aborter.abort();
            aborter = new AbortController();

            const start = currentRange?.[0] ? toYMD(currentRange[0]) : "";
            const end = currentRange?.[1] ? toYMD(currentRange[1]) : "";
            const url = `/api/dashboard/location-totals?start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`;

            inFlight = (async () => {
                try {
                    const resp = await fetch(url, { signal: aborter.signal });
                    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                    const data = await resp.json();

                    setSummary(data);
                    chart.option("dataSource", data);
                    setChartHeight(data.length);
                } catch (err) {
                    if (err.name !== "AbortError") console.error("Graph refresh failed:", err);
                } finally {
                    inFlight = null;
                }
            })();
        }

        refreshData();
        setInterval(refreshData, 30000);
    })();
</script>
