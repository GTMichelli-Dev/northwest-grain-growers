
<style>
    .no-permissions-row td {
        background-color: #ffe6e6 !important; /* light pink */
    }
</style>
<div id="usersGrid"></div>

@section Scripts {
    <script>
        $(function () {

            // Lookup for privileges (id/description)
            var privilegeStore = new DevExpress.data.CustomStore({
                key: "Id", // server returns { Id, Name } per your controller
                load: function () {
                    return $.getJSON("/api/UsersApi/privileges");
                }
            });

            // Main users store with load/insert/update
            var usersStore = new DevExpress.data.CustomStore({
                key: "Uid", // key is GUid 'Uid' (serialized as 'Uid')
                load: function (loadOptions) {
                    return DevExpress.data.AspNet
                           .createStore({ key: "Uid", loadUrl: "/api/UsersApi" })
                           .load(loadOptions);
                },
                insert: function (values) {
                    var d = $.Deferred();

                    // Ensure privilegeIds is an array
                    if (!values.PrivilegeIds) values.PrivilegeIds = [];

                    $.ajax({
                        url: "/api/UsersApi",
                        method: "POST",
                        data: JSON.stringify(values),
                        contentType: "application/json"
                    })
                    .done(function (createdRow) {
                        d.resolve(createdRow); // grid expects created row
                    })
                    .fail(function (xhr) {
                        var msg = "Create failed.";
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            msg = xhr.responseJSON.message;
                        }
                        d.reject(msg);
                    });

                    return d.promise();
                },
                update: function (key, values) {
                    var d = $.Deferred();
                    var data = $.extend({ Uid: key }, values);

                    $.ajax({
                        url: "/api/UsersApi/" + key,
                        method: "PUT",
                        data: JSON.stringify(data),
                        contentType: "application/json"
                    })
                    .done(function (result) { d.resolve(result); })
                    .fail(function (xhr) {
                        var msg = "Update failed.";
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            msg = xhr.responseJSON.message;
                        }
                        d.reject(msg);
                    });

                    return d.promise();
                },
                remove: function (key) {
                    var d = $.Deferred();

                    $.ajax({
                        url: "/api/UsersApi/" + key,
                        method: "DELETE"
                    })
                    .done(function () { d.resolve(); })
                    .fail(function (xhr) {
                        var msg = "Delete failed.";
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            msg = xhr.responseJSON.message;
                        }
                        d.reject(msg);
                    });

                    return d.promise();
                }
            });

            $("#usersGrid").dxDataGrid({
                dataSource: usersStore,
                keyExpr: "Uid",
                remoteOperations: {
                    paging: true,   // keep paging on the server if you want
                    filtering: false,
                    sorting: false
                },
                showBorders: true,
                columnAutoWidth: true,
                rowAlternationEnabled: true,
                hoverStateEnabled: true,
                searchPanel: {
                    visible: true,
                    width: 240,
                    placeholder: "Search users..."
                },
                export: {
                    enabled: true,
                    allowExportSelectedData: false
                },
                columns: [
                    {
                        dataField: "UserPin",
                        caption: "User Pin",
                        width: 100,
                        customizeText: function (e) {
                            if (e.value === null || e.value === undefined) return "";
                            return e.value.toString().padStart(4, "0");
                        }
                    },
                    { dataField: "Name",    caption: "User Name" },
                   
                    {
                        dataField: "PrivilegeNames",
                        caption: "Permissions",
                        allowEditing: false,
                        calculateDisplayValue: function (rowData) {
                            if (!rowData || !rowData.PrivilegeIds || rowData.PrivilegeIds.length === 0) {
                                return "No Permissions set";
                            }
                            return rowData.PrivilegeNames;
                        }
                    },
                    { dataField: "PrivilegeIds", visible: false } // keep this for editing
                ],
                onRowPrepared: function (e) {
                    console.log('e',e);
                    if (e.rowType === "data") {
                       
                      
                        var hasPerms = e.data && e.data.PrivilegeIds && e.data.PrivilegeIds.length > 0;

                        if (!hasPerms) {
                            e.rowElement.addClass("no-permissions-row");
                        } else {
                            e.rowElement.removeClass("no-permissions-row");
                        }
                    }
                },
                editing: {
                    mode: "popup",
                    allowAdding: true,   // <-- enable create
                    allowUpdating: true,
                    allowDeleting: true,
                    confirmDelete: false,
                    useIcons: true,
                    
                    popup: {
                        title: "User",
                        showTitle: true,
                        width: 600,
                        height: 460
                    },
                    form: {
                        colCount: 1,
                        items: [
                            { dataField: "Name", label: { text: "User Name" }, isRequired: true },
                            { dataField: "UserPin",    label: { text: "User Pin" }, isRequired: true },
                            {
                                dataField: "PrivilegeIds",
                                label: { text: "Permissions" },
                                editorType: "dxTagBox",
                                editorOptions: {
                                    dataSource: privilegeStore,
                                    displayExpr: "Name", // per GetPrivileges() returns {Id, Name}
                                    valueExpr: "Id",
                                    showSelectionControls: true,
                                    applyValueMode: "useButtons",
                                    searchEnabled: true,
                                    placeholder: "Select permissions..."
                                }
                            }
                        ]
                    }
                },

                onRowInserting: function(e) {
                    // Make sure the array property always exists
                    if (!e.data.PrivilegeIds) e.data.PrivilegeIds = [];
                },
                onEditorPreparing: function (e) {
                        if (e.parentType === "dataRow" && e.dataField === "PrivilegeIds") {
                            e.editorOptions.onValueChanged = function (args) {
                                var prev = args.previousValue || [];
                                var val  = args.value || [];

                                var hadBase = prev.indexOf(1) !== -1;
                                var hasBase = val.indexOf(1) !== -1;

                                // If privilege 1 was removed, clear everything
                                if (hadBase && !hasBase) {
                                    val = [];
                                }
                                // If 1 is still NOT present and user tried to add some other privilege
                                else if (!hadBase && !hasBase) {
                                    var newAdded = val.filter(function (id) {
                                        return prev.indexOf(id) === -1;
                                    });
                                    var illegalAdd = newAdded.some(function (id) {
                                        return id !== 1;
                                    });
                                    if (illegalAdd) {
                                        DevExpress.ui.notify(
                                            "You must select privilege 1 before adding other permissions.",
                                            "warning",
                                            3000
                                        );
                                        val = prev.slice(); // revert
                                    }
                                }

                                e.setValue(val);
                            };
                        }
                    },
                onRowUpdating: function (e) {
                    // keep pin/name if not changed
                    if (!e.newData.userPin && e.oldData.userPin) {
                        e.newData.userPin = e.oldData.userPin;
                    }
                    if (!e.newData.name && e.oldData.name) {
                        e.newData.name = e.oldData.name;
                    }
                    // if for some reason privilegeIds not present, keep old values
                    if (!e.newData.privilegeIds && e.oldData.privilegeIds) {
                        e.newData.privilegeIds = e.oldData.privilegeIds;
                    }

                    if (!Object.prototype.hasOwnProperty.call(e.newData, "PrivilegeIds")) {
                        if (Array.isArray(e.oldData.PrivilegeIds)) {
                            e.newData.PrivilegeIds = e.oldData.PrivilegeIds.slice(); // copy
                        } else {
                            e.newData.PrivilegeIds = []; // or leave undefined if you want "no perms"
                        }
                    }

                    // Optional: also preserve pin/name if they weren't edited
                    if (!Object.prototype.hasOwnProperty.call(e.newData, "UserPin")) {
                        e.newData.UserPin = e.oldData.UserPin;
                    }
                    if (!Object.prototype.hasOwnProperty.call(e.newData, "Name")) {
                        e.newData.Name = e.oldData.Name;
                    }


                },
                onEditingStart: function(e) {      // Optionally, you can set the popup title here for edit mode
                    if (e.component && e.data && e.data.Name) {
                        e.component.option("editing.popup.title", "Edit User: " + e.data.Name);
                    }
                },
                onRowRemoving: function(e) {
                    // Show a custom confirm dialog with the user name
                    var userName = e.data && e.data.Name ? e.data.Name : "";
                    var d = $.Deferred();
                    DevExpress.ui.dialog.confirm(
                        "Are you sure you want to delete user '" + userName + "'?",
                        "Confirm Delete"
                    ).done(function(result) {
                        if (result) {
                            d.resolve();
                        } else {
                            d.reject("Delete cancelled");
                        }
                    });
                    e.cancel = d.promise();
                },
                onExporting: function(e) {
                    var workbook  = new ExcelJS.Workbook();
                    var worksheet = workbook.addWorksheet("Users");

                    DevExpress.excelExporter.exportDataGrid({
                        component: e.component,
                        worksheet: worksheet
                    }).then(function() {
                        return workbook.xlsx.writeBuffer();
                    }).then(function(buffer) {
                        saveAs(
                            new Blob([buffer], { type: "application/octet-stream" }),
                            "UsersPermissions.xlsx"
                        );
                    });

                    // Prevent built-in (fake) export — we handle it ourselves
                    e.cancel = true;
               }
 
            });
        });
    </script>
}
