          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="IntakeTotalsDetailTableAdapter" GeneratorDataComponentClassName="IntakeTotalsDetailTableAdapter" Name="IntakeTotalsDetail" UserDataComponentName="IntakeTotalsDetailTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Web.config)" DbObjectName="NW_Data.dbo.Locations" DbObjectType="Table" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        LTRIM(STR(Locations.Id)) + ' - ' + Locations.Description AS [Location Description], Locations.Id AS [Location Id], Locations.District, ISNULL(SUM(tblData.Net), 0) AS Net, ISNULL(tblData.Crop_Id, '') AS [Crop Id], 
                         ISNULL(tblData.Crop_Description, '') AS [Crop Description], ISNULL(tblData.UOM_Description, '') AS UOM, ISNULL(SUM(tblData.Net) / tblData.UOM_Factor, 0) AS [Total Units]
FROM            (SELECT        Location_Id, Net, Close_Date, Crop_Id, Crop_Description, UOM_Code, UOM_Description, UOM_Factor
                          FROM            vwWeigh_Sheet
                          WHERE        (Close_Date IS NOT NULL) AND (DATEDIFF(day, Close_Date, @SelectedStartDate) &lt;= 0) AND (DATEDIFF(day, Close_Date, @SelectedEndDate) &gt;= 0)) AS tblData RIGHT OUTER JOIN
                         Locations ON tblData.Location_Id = Locations.Id
WHERE        (Locations.In_Production = 1)
GROUP BY tblData.Crop_Id, tblData.Crop_Description, tblData.UOM_Code, tblData.UOM_Description, tblData.UOM_Factor, LTRIM(STR(Locations.Id)) + ' - ' + Locations.Description, Locations.Id, Locations.District
HAVING        (Locations.Id &gt; 0)
ORDER BY Locations.District, [Location Id]</CommandText>
                    <Parameters>
                      <Parameter AllowDbNull="false" AutogeneratedName="SelectedStartDate" ColumnName="" DataSourceName="" DataTypeServer="unknown" DbType="DateTime" Direction="Input" ParameterName="@SelectedStartDate" Precision="0" Scale="0" Size="0" SourceColumn="" SourceColumnNullMapping="false" SourceVersion="Current" />
                      <Parameter AllowDbNull="false" AutogeneratedName="SelectedEndDate" ColumnName="" DataSourceName="" DataTypeServer="unknown" DbType="DateTime" Direction="Input" ParameterName="@SelectedEndDate" Precision="0" Scale="0" Size="0" SourceColumn="" SourceColumnNullMapping="false" SourceVersion="Current" />
                    </Parameters>
