          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="WeightSeriesByLocationDateTableAdapter" GeneratorDataComponentClassName="WeightSeriesByLocationDateTableAdapter" Name="WeightSeriesByLocationDate" UserDataComponentName="WeightSeriesByLocationDateTableAdapter">
            <MainSource>
