ons.Id LEFT OUTER JOIN (SELECT Variety.Id AS Variety_Id, Variety.Description AS Variety, Crops.Id AS Crop_Id, Crops.Description AS Crop FROM Crops INNER JOIN Variety_Crop_Groups ON Crops.UID = Variety_Crop_Groups.Crop_UID INNER JOIN Variety ON Variety_Crop_Groups.Variety_UID = Variety.UID) AS Crop_Varieties ON tblAllLoads.Variety_Id = Crop_Varieties.Variety_Id AND tblAllLoads.Crop_Id = Crop_Varieties.Crop_Id GROUP BY tblAllLoads.Location_Id, CONVERT (VARCHAR(10), tblAllLoads.Time_In, 111), tblAllLoads.Crop_Id, tblAllLoads.Variety_Id, tblAllLoads.LoadType, Crops_1.Description + N' - ' + LTRIM(STR(Crops_1.Id)), Crop_Varieties.Variety, tblAllLoads.WS_Id, tblAllLoads.UID, Locations.Description + N' - ' + LTRIM(STR(Locations.Id)) ORDER BY tblAllLoads.WS_Id</CommandText>
