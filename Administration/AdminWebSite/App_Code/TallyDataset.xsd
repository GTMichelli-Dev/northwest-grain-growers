          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="DailyIntakeTotalForAllSitesTableAdapter" GeneratorDataComponentClassName="DailyIntakeTotalForAllSitesTableAdapter" Name="DailyIntakeTotalForAllSites" UserDataComponentName="DailyIntakeTotalForAllSitesTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Web.config)" DbObjectName="SELECT SUM(ABS(Loads.Weight_In - Loads.Weight_Out)) AS Net, COUNT(*) AS Loads FROM Loads INNER JOIN Inbound_Loads ON Loads.UID = Inbound_Loads.Load_UID INNER JOIN Weight_Sheets INNER JOIN Weight_Inbound_Loads ON Weight_Sheets.UID = Weight_Inbound_Loads.Weight_Sheet_UID ON Inbound_Loads.WS_UID = Weight_Sheets.UID WHERE (Loads.Void = 0) AND (DATEDIFF(day, Loads.Time_Out, @SelectedDate) = 0)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        Loads, Net, Net / 60 AS Bushels
