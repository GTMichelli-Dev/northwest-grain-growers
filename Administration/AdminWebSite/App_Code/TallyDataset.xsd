    SUM(tbl.Net) / Unit_Of_Measure.Factor AS Net, 
    SUM(tbl.Loads) AS Loads, 
    SUM(tbl.Intake) / Unit_Of_Measure.Factor AS Intake, 
    CASE WHEN Outbound_Location = 0 THEN '' ELSE Locations_1.Description END AS Outbound_Location, 
    tbl.Outbound_Location AS Outbound_Location_Id, 
