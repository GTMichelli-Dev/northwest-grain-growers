          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="CurrentIntakeTallyTableAdapter" GeneratorDataComponentClassName="CurrentIntakeTallyTableAdapter" Name="CurrentIntakeTally" UserDataComponentName="CurrentIntakeTallyTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Web.config)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="false">
                    <CommandText>SELECT        Locations_1.District, Locations_1.Description AS Location, Locations_1.Id AS Location_Id, tbl.Commodity, tbl.Commodity_Id, tbl.Units, tbl.UOM, tbl.AvgSec, tbl.Net, tbl.Loads, CONVERT(varchar, 
                         DATEADD(SECOND, tbl.AvgSec, 0), 108) AS AverageTime
FROM            (SELECT        Locations.Description AS Location, Locations.Id AS Location_Id, Crops.Description AS Commodity, Lots.Crop_Id AS Commodity_Id, SUM(CONVERT(int, ABS(Loads.Weight_In - Loads.Weight_Out) 
                                                    / (CASE WHEN Crops.Pound_Per_Bushel &lt;= 0 THEN 1 ELSE Crops.Pound_Per_Bushel END))) AS Units, 
                                                    CASE WHEN Unit_Of_Measure = 'T' THEN 'Tons' WHEN Unit_Of_Measure = 'H' THEN 'CWT' ELSE 'Bushels' END AS UOM, Locations.District, AVG(DATEDIFF(second, Loads.Time_In, 
                                                    Loads.Time_Out)) AS AvgSec, SUM(ABS(Loads.Weight_In - Loads.Weight_Out)) AS Net, COUNT(*) AS Loads
                          FROM            Crops LEFT OUTER JOIN
                                                    Loads INNER JOIN
                                                    Inbound_Loads ON Loads.UID = Inbound_Loads.Load_UID INNER JOIN
                                                    Weight_Sheets INNER JOIN
                                                    Lots INNER JOIN
                                                    Weight_Inbound_Loads ON Lots.UID = Weight_Inbound_Loads.Lot_UID ON Weight_Sheets.UID = Weight_Inbound_Loads.Weight_Sheet_UID INNER JOIN
                                                    Locations ON Weight_Sheets.Location_Id = Locations.Id ON Inbound_Loads.WS_UID = Weight_Sheets.UID ON Crops.Id = Lots.Crop_Id
                          WHERE        (Loads.Void = 0) AND (DATEDIFF(day, Loads.Time_Out, GETDATE()) = 0)
                          GROUP BY Locations.Description, Locations.Id, Crops.Description, Lots.Crop_Id, Locations.District, 
                                                    CASE WHEN Unit_Of_Measure = 'T' THEN 'Tons' WHEN Unit_Of_Measure = 'H' THEN 'CWT' ELSE 'Bushels' END) AS tbl INNER JOIN
                         Locations AS Locations_1 ON tbl.Location_Id = Locations_1.Id
WHERE        (Locations_1.In_Production = 1) AND (Locations_1.Active = 1)
ORDER BY Locations_1.District, Location</CommandText>
                    <Parameters />
                  </DbCommand>
                </SelectCommand>
              </DbSource>
