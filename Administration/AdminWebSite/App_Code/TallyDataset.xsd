            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Web.config)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        Locations.Description AS Location, Loads_1.Time_In, derivedtbl_1.Server_Name, derivedtbl_1.Location_Id, Loads_1.Sequence_Id, derivedtbl_1.LastLoadId
FROM            (SELECT        TOP (100) PERCENT Server_Name, Location_Id, LastLoadId
                          FROM            (SELECT        MAX(Load_Id) AS LastLoadId, Server_Name, Location_Id
                                                    FROM            Loads
                                                    GROUP BY Server_Name, Location_Id
                                                    HAVING         (Server_Name &lt;&gt; N'LEO')) AS LastLoad) AS derivedtbl_1 INNER JOIN
                         Loads AS Loads_1 ON derivedtbl_1.Location_Id = Loads_1.Location_Id AND derivedtbl_1.LastLoadId = Loads_1.Load_Id AND derivedtbl_1.Server_Name = Loads_1.Server_Name INNER JOIN
                         Locations ON Loads_1.Location_Id = Locations.Id
WHERE        (Loads_1.Sequence_Id = 1) AND (Loads_1.Time_In &gt; CONVERT(DATETIME, '2019-05-01 00:00:00', 102))
ORDER BY Loads_1.Time_In DESC</CommandText>
