          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="DailyBinTotalsTableAdapter" GeneratorDataComponentClassName="DailyBinTotalsTableAdapter" Name="DailyBinTotals" UserDataComponentName="DailyBinTotalsTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Web.config)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        SUM(BinTotals.Net) AS Net, BinTotals.UOM, BinTotals.WeightSheetDate, BinTotals.Bin, BinTotals.Crop_Id, BinTotals.Crop, BinTotals.Variety_Id, BinTotals.Variety, COUNT(*) AS LoadCount, 
                         Locations.Description + N' - ' + LTRIM(STR(Locations.Id)) AS Location, tblAvgProtien.Average_Protien
FROM            (SELECT        CONVERT(decimal, Loads.Weight_In - Loads.Weight_Out) / CONVERT(decimal, Crops.Pound_Per_Bushel) AS Net, Unit_Of_Measure.Description AS UOM, CONVERT(VARCHAR(10), 
                                                    Weight_Sheets.Creation_Date, 111) AS WeightSheetDate, Loads.Bin, Crops.Id AS Crop_Id, Crops.Description AS Crop, Variety_1.Variety_Id, Variety_1.Variety, Weight_Sheets.Location_Id, 
                                                    Loads.UID
                          FROM            Loads INNER JOIN
                                                    Inbound_Loads ON Loads.UID = Inbound_Loads.Load_UID INNER JOIN
                                                    Weight_Sheets ON Inbound_Loads.WS_UID = Weight_Sheets.UID INNER JOIN
                                                    Weight_Inbound_Loads ON Weight_Sheets.UID = Weight_Inbound_Loads.Weight_Sheet_UID INNER JOIN
                                                    Lots ON Weight_Inbound_Loads.Lot_UID = Lots.UID INNER JOIN
                                                    Crops ON Lots.Crop_Id = Crops.Id INNER JOIN
                                                    Unit_Of_Measure ON Crops.Unit_Of_Measure = Unit_Of_Measure.Code LEFT OUTER JOIN
                                                        (SELECT        Crops_1.Description AS Crop, Crops_1.Id AS Crop_Id, Variety.Description AS Variety, Variety.Id AS Variety_Id
                                                          FROM            Variety_Crop_Groups INNER JOIN
                                                                                    Crops AS Crops_1 ON Variety_Crop_Groups.Crop_UID = Crops_1.UID INNER JOIN
                                                                                    Variety ON Variety_Crop_Groups.Variety_UID = Variety.UID) AS Variety_1 ON Lots.Crop_Id = Variety_1.Crop_Id AND Lots.Variety_Id = Variety_1.Variety_Id
                          WHERE        (Weight_Sheets.Location_Id = @Location_Id) AND (DATEDIFF(day, Weight_Sheets.Creation_Date, @SelectedDate) = 0)
                          UNION
                          SELECT        CONVERT(decimal, Loads_1.Weight_In - Loads_1.Weight_Out) / CONVERT(decimal, Crops_2.Pound_Per_Bushel) AS Net, Unit_Of_Measure_1.Description AS UOM, CONVERT(VARCHAR(10), 
                                                   Weight_Sheets_1.Creation_Date, 111) AS WeightSheetDate, Loads_1.Bin, Crops_2.Id AS Crop_Id, Crops_2.Description AS Crop, Variety_1_1.Variety_Id, Variety_1_1.Variety, 
                                                   Weight_Sheets_1.Location_Id, Loads_1.UID
                          FROM            Loads AS Loads_1 INNER JOIN
                                                   Transfer_Loads ON Loads_1.UID = Transfer_Loads.Load_UID INNER JOIN
                                                   Weight_Sheet_Transfer_Loads ON Transfer_Loads.Transfer_Load_UID = Weight_Sheet_Transfer_Loads.UID INNER JOIN
                                                   Weight_Sheets AS Weight_Sheets_1 ON Weight_Sheet_Transfer_Loads.Weight_Sheet_UID = Weight_Sheets_1.UID INNER JOIN
                                                   Crops AS Crops_2 ON Weight_Sheet_Transfer_Loads.Crop_Id = Crops_2.Id INNER JOIN
                                                   Unit_Of_Measure AS Unit_Of_Measure_1 ON Crops_2.Unit_Of_Measure = Unit_Of_Measure_1.Code LEFT OUTER JOIN
                                                       (SELECT        Crops_1.Description AS Crop, Crops_1.Id AS Crop_Id, Variety_2.Description AS Variety, Variety_2.Id AS Variety_Id
                                                         FROM            Variety_Crop_Groups AS Variety_Crop_Groups_1 INNER JOIN
                                                                                   Crops AS Crops_1 ON Variety_Crop_Groups_1.Crop_UID = Crops_1.UID INNER JOIN
                                                                                   Variety AS Variety_2 ON Variety_Crop_Groups_1.Variety_UID = Variety_2.UID) AS Variety_1_1 ON Weight_Sheet_Transfer_Loads.Crop_Id = Variety_1_1.Crop_Id AND 
                                                   Weight_Sheet_Transfer_Loads.Variety_Id = Variety_1_1.Variety_Id
                          WHERE        (Weight_Sheets_1.Location_Id = @Location_Id) AND (DATEDIFF(day, Weight_Sheets_1.Creation_Date, @SelectedDate) = 0)) AS BinTotals INNER JOIN
                         Locations ON BinTotals.Location_Id = Locations.Id LEFT OUTER JOIN
                             (SELECT        Location_Id, Bin, AVG(Protien) AS Average_Protien
                               FROM            (SELECT        Location_Id, Bin, Protien
                                                         FROM            (SELECT        Loads_2.Location_Id, Loads_2.Bin, ISNULL(Inbound_Loads_1.Protien, 0) + ISNULL(Transfer_Loads_1.Protein, 0) AS Protien
                                                                                   FROM            Loads AS Loads_2 LEFT OUTER JOIN
                                                                                                             Transfer_Loads AS Transfer_Loads_1 ON Loads_2.UID = Transfer_Loads_1.Load_UID LEFT OUTER JOIN
                                                                                                             Inbound_Loads AS Inbound_Loads_1 ON Loads_2.UID = Inbound_Loads_1.Load_UID
                                                                                   WHERE        (Loads_2.Bin IS NOT NULL) AND (Loads_2.Location_Id = @Location_Id) AND (Loads_2.Time_Out IS NOT NULL) AND (DATEDIFF(day, @SelectedDate, Loads_2.Time_Out) 
                                                                                                             = 0)) AS tblLoads
                                                         WHERE        (Protien &gt; 0)) AS tblBins
                               GROUP BY Location_Id, Bin) AS tblAvgProtien ON BinTotals.Bin = tblAvgProtien.Bin AND BinTotals.Location_Id = tblAvgProtien.Location_Id
GROUP BY BinTotals.UOM, BinTotals.WeightSheetDate, BinTotals.Bin, BinTotals.Crop_Id, BinTotals.Crop, BinTotals.Variety_Id, BinTotals.Variety, Locations.Description + N' - ' + LTRIM(STR(Locations.Id)), 
                         tblAvgProtien.Average_Protien</CommandText>
                    <Parameters>
                      <Parameter AllowDbNull="false" AutogeneratedName="Location_Id" ColumnName="" DataSourceName="" DataTypeServer="int" DbType="Int32" Direction="Input" ParameterName="@Location_Id" Precision="0" Scale="0" Size="4" SourceColumn="" SourceColumnNullMapping="false" SourceVersion="Current" />
