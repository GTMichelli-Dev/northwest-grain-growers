            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Web.config)" DbObjectName="SELECT PLoads.Bin, PLoads.Protein, PLoads.Net * PLoads.Protein AS NetProtein, PLoads.Net, Crops.Description + N' - ' + LTRIM(STR(PLoads.Crop_Id)) AS Crop FROM (SELECT BLoads.Location_Id, BLoads.Bin, BLoads.Net, BLoads.UID, CASE WHEN Inbound_Loads.UID IS NULL THEN Weight_Sheet_Transfer_Loads.Crop_Id ELSE Lots.Crop_Id END AS Crop_Id, ISNULL(CASE WHEN Inbound_Loads.UID IS NULL THEN Transfer_Loads.Protein ELSE Inbound_Loads.Protien END, 0) * 0.1 AS Protein FROM Weight_Sheets INNER JOIN Inbound_Loads ON Weight_Sheets.UID = Inbound_Loads.WS_UID INNER JOIN Weight_Inbound_Loads ON Weight_Sheets.UID = Weight_Inbound_Loads.Weight_Sheet_UID INNER JOIN Lots ON Weight_Inbound_Loads.Lot_UID = Lots.UID RIGHT OUTER JOIN Transfer_Loads INNER JOIN Weight_Sheet_Transfer_Loads ON Transfer_Loads.Transfer_Load_UID = Weight_Sheet_Transfer_Loads.UID RIGHT OUTER JOIN (SELECT Location_Id, Bin, Weight_In - Weight_Out AS Net, UID FROM Loads WHERE (Weight_In - Weight_Out &gt; 0) AND (Bin IS NOT NULL) AND (Weight_Out IS NOT NULL) AND (DATEDIFF(Day, @StartDate, Time_In) &gt;= 0) AND (DATEDIFF(Day, Time_In, @EndDate) &gt;= 0) AND (Location_Id = @Location_Id)) AS BLoads ON Transfer_Loads.Load_UID = BLoads.UID ON Inbound_Loads.Load_UID = BLoads.UID WHERE (ISNULL(CASE WHEN Inbound_Loads.UID IS NULL THEN Transfer_Loads.Protein ELSE Inbound_Loads.Protien END, 0) &gt; 0)) AS PLoads INNER JOIN Crops ON PLoads.Crop_Id = Crops.Id" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        Bin, Crop, SUM(Net) AS NetWeight, SUM(Net) / 60 AS Bushels, SUM(NetProtein) / SUM(Net) * 10 AS AvgProtein
FROM            (SELECT        PLoads.Bin, PLoads.Protein, PLoads.Net * PLoads.Protein AS NetProtein, PLoads.Net, Crops.Description + N' - ' + LTRIM(STR(PLoads.Crop_Id)) AS Crop
                          FROM            (SELECT        BLoads.Location_Id, BLoads.Bin, BLoads.Net, BLoads.UID, CASE WHEN Inbound_Loads.UID IS NULL THEN Weight_Sheet_Transfer_Loads.Crop_Id ELSE Lots.Crop_Id END AS Crop_Id, 
                                                                              ISNULL(CASE WHEN Inbound_Loads.UID IS NULL THEN Transfer_Loads.Protein ELSE Inbound_Loads.Protien END, 0) * 0.1 AS Protein
                                                    FROM            Weight_Sheets INNER JOIN
                                                                              Inbound_Loads ON Weight_Sheets.UID = Inbound_Loads.WS_UID INNER JOIN
                                                                              Weight_Inbound_Loads ON Weight_Sheets.UID = Weight_Inbound_Loads.Weight_Sheet_UID INNER JOIN
                                                                              Lots ON Weight_Inbound_Loads.Lot_UID = Lots.UID RIGHT OUTER JOIN
                                                                              Transfer_Loads INNER JOIN
                                                                              Weight_Sheet_Transfer_Loads ON Transfer_Loads.Transfer_Load_UID = Weight_Sheet_Transfer_Loads.UID RIGHT OUTER JOIN
                                                                                  (SELECT        Location_Id, Bin, Weight_In - Weight_Out AS Net, UID
                                                                                    FROM            Loads
                                                                                    WHERE        (Weight_In - Weight_Out &gt; 0) AND (Bin IS NOT NULL) AND (Weight_Out IS NOT NULL) AND (DATEDIFF(Day, @StartDate, Time_In) &gt;= 0) AND (DATEDIFF(Day, Time_In, 
                                                                                                              @EndDate) &gt;= 0) AND (Location_Id = @Location_Id)) AS BLoads ON Transfer_Loads.Load_UID = BLoads.UID ON Inbound_Loads.Load_UID = BLoads.UID
                                                    WHERE        (ISNULL(CASE WHEN Inbound_Loads.UID IS NULL THEN Transfer_Loads.Protein ELSE Inbound_Loads.Protien END, 0) &gt; 0)) AS PLoads INNER JOIN
                                                    Crops ON PLoads.Crop_Id = Crops.Id) AS TLoads
GROUP BY Bin, Crop
order by Bin
</CommandText>
                    <Parameters>
