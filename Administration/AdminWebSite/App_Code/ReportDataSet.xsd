          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="ProducersDeliveredCommodityTableAdapter" GeneratorDataComponentClassName="ProducersDeliveredCommodityTableAdapter" Name="ProducersDeliveredCommodity" UserDataComponentName="ProducersDeliveredCommodityTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Web.config)" DbObjectName="SELECT TOP (100) PERCENT District, Location_Id, Location, Producer_Id, Producer, Commodity_ID, Commodity, SUM(Net) AS Net, SUM(NetUnits) AS NetUnits, Units, Variety_Id, Variety, COUNT(*) AS LoadCount, Landlord FROM (SELECT ABS(Loads.Weight_In - Loads.Weight_Out) AS Net, Loads.Time_Out, Locations.District, Loads.Location_Id, Locations.Description AS Location, Lots.Producer_Id, Producers.Description AS Producer, Crops.Id AS Commodity_ID, Crops.Description AS Commodity, Crops.Pound_Per_Bushel, Unit_Of_Measure.Description AS Units, Unit_Of_Measure.Factor, ABS((Loads.Weight_In - Loads.Weight_Out) / Unit_Of_Measure.Factor) AS NetUnits, Lots.Lot_Number, ISNULL(Lots.Variety_Id, 0) AS Variety_Id, ISNULL(VarietyList.Variety, N'') AS Variety, ISNULL(Lots.Landlord, '') AS Landlord FROM Lots INNER JOIN Weight_Inbound_Loads ON Lots.UID = Weight_Inbound_Loads.Lot_UID INNER JOIN Weight_Sheets ON Weight_Inbound_Loads.Weight_Sheet_UID = Weight_Sheets.UID INNER JOIN Inbound_Loads ON Weight_Sheets.UID = Inbound_Loads.WS_UID INNER JOIN Loads ON Inbound_Loads.Load_UID = Loads.UID INNER JOIN Locations ON Loads.Location_Id = Locations.Id INNER JOIN Crops ON Lots.Crop_Id = Crops.Id INNER JOIN Producers ON Lots.Producer_Id = Producers.Id INNER JOIN Unit_Of_Measure ON Crops.Unit_Of_Measure = Unit_Of_Measure.Code LEFT OUTER JOIN VarietyList ON Lots.Crop_Id = VarietyList.Crop_Id AND Lots.Variety_Id = VarietyList.Item_Id WHERE (Locations.District = ISNULL(@District, Locations.District)) AND (Crops.Description = ISNULL(@Commodity, Crops.Description)) AND (Loads.Time_Out IS NOT NULL) AND (DATEDIFF(day, @StartDate, Weight_Sheets.Creation_Date) &gt;= 0) AND (DATEDIFF(day, Weight_Sheets.Creation_Date, @EndDate) &gt;= 0) AND (Producers.Description LIKE N'%' + @Producer + N'%') AND (Loads.Location_Id = ISNULL(@Location_Id, Loads.Location_Id)) AND (ISNULL(Lots.Variety_Id, 0) = ISNULL(@Variety_Id, ISNULL(Lots.Variety_Id, 0))) OR (Locations.District = ISNULL(@District, Locations.District)) AND (Crops.Description = ISNULL(@Commodity, Crops.Description)) AND (Loads.Time_Out IS NOT NULL) AND (DATEDIFF(day, @StartDate, Weight_Sheets.Creation_Date) &gt;= 0) AND (DATEDIFF(day, Weight_Sheets.Creation_Date, @EndDate) &gt;= 0) AND (Loads.Location_Id = ISNULL(@Location_Id, Loads.Location_Id)) AND (ISNULL(Lots.Variety_Id, 0) = ISNULL(@Variety_Id, ISNULL(Lots.Variety_Id, 0))) AND (@Producer IS NULL)) AS tblLoads GROUP BY District, Location_Id, Location, Producer_Id, Producer, Commodity_ID, Commodity, Units, Variety_Id, Variety, Landlord HAVING (SUM(Net) IS NOT NULL) ORDER BY District, Location, Producer_Id, Commodity, Variety" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        District, Location_Id, Location, Producer_Id, Producer, Commodity_ID, Commodity, Net, NetUnits, Units, Variety_Id, Variety, LoadCount, Landlord
FROM            (SELECT        TOP (100) PERCENT District, Location_Id, Location, Producer_Id, Producer, Commodity_ID, Commodity, SUM(Net) AS Net, SUM(NetUnits) AS NetUnits, Units, Variety_Id, Variety, COUNT(*) 
                                                    AS LoadCount, Landlord
                          FROM            (SELECT        ABS(Loads.Weight_In - Loads.Weight_Out) AS Net, Loads.Time_Out, Locations.District, Loads.Location_Id, Locations.Description AS Location, Lots.Producer_Id, 
                                                                              Producers.Description AS Producer, Crops.Id AS Commodity_ID, Crops.Description AS Commodity, Crops.Pound_Per_Bushel, Unit_Of_Measure.Description AS Units, 
                                                                              Unit_Of_Measure.Factor, ABS((Loads.Weight_In - Loads.Weight_Out) / Unit_Of_Measure.Factor) AS NetUnits, Lots.Lot_Number, ISNULL(Lots.Variety_Id, 0) AS Variety_Id, 
                                                                              ISNULL(VarietyList.Variety, N'') AS Variety, ISNULL(Lots.Landlord, '') AS Landlord
                                                    FROM            Lots INNER JOIN
                                                                              Weight_Inbound_Loads ON Lots.UID = Weight_Inbound_Loads.Lot_UID INNER JOIN
                                                                              Weight_Sheets ON Weight_Inbound_Loads.Weight_Sheet_UID = Weight_Sheets.UID INNER JOIN
                                                                              Inbound_Loads ON Weight_Sheets.UID = Inbound_Loads.WS_UID INNER JOIN
                                                                              Loads ON Inbound_Loads.Load_UID = Loads.UID INNER JOIN
                                                                              Locations ON Loads.Location_Id = Locations.Id INNER JOIN
                                                                              Crops ON Lots.Crop_Id = Crops.Id INNER JOIN
                                                                              Producers ON Lots.Producer_Id = Producers.Id INNER JOIN
                                                                              Unit_Of_Measure ON Crops.Unit_Of_Measure = Unit_Of_Measure.Code LEFT OUTER JOIN
                                                                              VarietyList ON Lots.Crop_Id = VarietyList.Crop_Id AND Lots.Variety_Id = VarietyList.Item_Id
                                                    WHERE        (Locations.District = ISNULL(@District, Locations.District)) AND (Crops.Description = ISNULL(@Commodity, Crops.Description)) AND (Loads.Time_Out IS NOT NULL) AND (DATEDIFF(day, 
                                                                              @StartDate, Weight_Sheets.Creation_Date) &gt;= 0) AND (DATEDIFF(day, Weight_Sheets.Creation_Date, @EndDate) &gt;= 0) AND (Producers.Description LIKE N'%' + @Producer + N'%') AND 
                                                                              (Loads.Location_Id = ISNULL(@Location_Id, Loads.Location_Id)) AND (ISNULL(Lots.Variety_Id, 0) = ISNULL(@Variety_Id, ISNULL(Lots.Variety_Id, 0))) OR
                                                                              (Locations.District = ISNULL(@District, Locations.District)) AND (Crops.Description = ISNULL(@Commodity, Crops.Description)) AND (Loads.Time_Out IS NOT NULL) AND (DATEDIFF(day, 
                                                                              @StartDate, Weight_Sheets.Creation_Date) &gt;= 0) AND (DATEDIFF(day, Weight_Sheets.Creation_Date, @EndDate) &gt;= 0) AND (Loads.Location_Id = ISNULL(@Location_Id, 
                                                                              Loads.Location_Id)) AND (ISNULL(Lots.Variety_Id, 0) = ISNULL(@Variety_Id, ISNULL(Lots.Variety_Id, 0))) AND (@Producer IS NULL)) AS tblLoads
                          GROUP BY District, Location_Id, Location, Producer_Id, Producer, Commodity_ID, Commodity, Units, Variety_Id, Variety, Landlord
                          HAVING         (SUM(Net) IS NOT NULL)
                          ORDER BY District, Location, Producer_Id, Commodity, Variety) AS tbl
WHERE        (Landlord LIKE N'%' + ISNULL(@Landlord, Landlord) + N'%')</CommandText>
