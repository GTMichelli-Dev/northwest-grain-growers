                          FROM            Lots INNER JOIN
                                                    Weight_Inbound_Loads ON Lots.UID = Weight_Inbound_Loads.Lot_UID INNER JOIN
                                                    Weight_Sheets ON Weight_Inbound_Loads.Weight_Sheet_UID = Weight_Sheets.UID INNER JOIN
