          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="LoadsByCropAndDataTableAdapter" GeneratorDataComponentClassName="LoadsByCropAndDataTableAdapter" Name="LoadsByCropAndData" UserDataComponentName="LoadsByCropAndDataTableAdapter">
