                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        Locations.Description AS Location, tbl.Location_Id, Crops.Description AS Crop, tbl.Crop_Id, SUM(tbl.Net) / Unit_Of_Measure.Factor AS Net, SUM(tbl.Loads) AS Loads, SUM(tbl.Intake) 
                         / Unit_Of_Measure.Factor AS Intake, CASE WHEN Outbound_Location = 0 THEN '' ELSE Locations_1.Description END AS Outbound_Location, tbl.Outbound_Location AS Outbound_Location_Id, SUM(tbl.Transfered) 
                         / Unit_Of_Measure.Factor AS Transfered, Unit_Of_Measure.Description AS UOM, SUM(CASE WHEN Outbound_Location = 0 THEN Loads ELSE 0 END) AS IntakeLoads, 
                         SUM(CASE WHEN Outbound_Location = 0 THEN 0 ELSE Loads END) AS TransferLoads
FROM            (SELECT        Location_Id, Net, Outbound_Location, Crop_Id, Creation_Date, Loads, CASE WHEN Net &lt; 0 THEN ABS(Net) ELSE 0 END AS Transfered, CASE WHEN Net &gt;= 0 THEN ABS(Net) 
                                                    ELSE 0 END AS Intake
                          FROM            vwLoadsByCropAndDate
                          WHERE        (DATEDIFF(day, @StartDate, Creation_Date) &gt;= 0) AND (DATEDIFF(day, Creation_Date, @EndDate) &gt;= 0)) AS tbl INNER JOIN
                         Crops ON tbl.Crop_Id = Crops.Id INNER JOIN
                         Locations ON tbl.Location_Id = Locations.Id LEFT OUTER JOIN
                         Locations AS Locations_1 ON tbl.Outbound_Location = Locations_1.Id INNER JOIN
                         Unit_Of_Measure ON Crops.Unit_Of_Measure = Unit_Of_Measure.Code
GROUP BY Locations.Description, tbl.Location_Id, Crops.Description, tbl.Crop_Id, tbl.Outbound_Location, Unit_Of_Measure.Description, Locations_1.Description, Unit_Of_Measure.Factor
HAVING        (tbl.Location_Id = ISNULL(@Location_Id, tbl.Location_Id))</CommandText>
                    <Parameters>
                      <Parameter AllowDbNull="true" AutogeneratedName="Location_Id" ColumnName="Location_Id" DataSourceName="SELECT Location_Id, Net, Outbound_Location, Crop_Id, Creation_Date, Loads, CASE WHEN Net &lt; 0 THEN ABS(Net) ELSE 0 END AS Transfered, CASE WHEN Net &gt;= 0 THEN ABS(Net) ELSE 0 END AS Intake FROM vwLoadsByCropAndDate WHERE (DATEDIFF(day, @StartDate, Creation_Date) &gt;= 0) AND (DATEDIFF(day, Creation_Date, @EndDate) &gt;= 0)" DataTypeServer="int" DbType="Int32" Direction="Input" ParameterName="@Location_Id" Precision="0" Scale="0" Size="4" SourceColumn="Location_Id" SourceColumnNullMapping="false" SourceVersion="Current" />
                      <Parameter AllowDbNull="false" AutogeneratedName="StartDate" ColumnName="" DataSourceName="" DataTypeServer="unknown" DbType="DateTime" Direction="Input" ParameterName="@StartDate" Precision="0" Scale="0" Size="0" SourceColumn="" SourceColumnNullMapping="false" SourceVersion="Current" />
