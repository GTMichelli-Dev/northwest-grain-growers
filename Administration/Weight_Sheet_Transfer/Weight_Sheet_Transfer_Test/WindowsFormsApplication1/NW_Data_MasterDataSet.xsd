                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        In_Out_Load.Net, In_Out_Load.Creation_Date, In_Out_Load.Location_Id, Weight_Sheets.WS_Id, Weight_Sheets.Carrier_Id, Weight_Sheets.Rate, Lots.Lot_Number, Lots.Producer_Id, Weight_Sheets.Closed, 
                         In_Out_Load.Outbound_Location, In_Out_Load.Crop_Id, CASE WHEN Outbound_Location IS NULL THEN ' ' ELSE 'TR' END AS Transfer
FROM            Lots RIGHT OUTER JOIN
                         Weight_Inbound_Loads ON Lots.UID = Weight_Inbound_Loads.Lot_UID RIGHT OUTER JOIN
                             (SELECT        Location_Id, SUM(Net) AS Net, Outbound_Location, Crop_Id, Weight_Sheet_UID, Creation_Date
                               FROM            vw_InOut_LoadType AS vw_InOut_LoadType_1
                               GROUP BY Location_Id, Outbound_Location, Crop_Id, Weight_Sheet_UID, Creation_Date) AS In_Out_Load INNER JOIN
                         Weight_Sheets ON In_Out_Load.Weight_Sheet_UID = Weight_Sheets.UID LEFT OUTER JOIN
                         Weight_Sheet_Transfer_Loads ON In_Out_Load.Weight_Sheet_UID = Weight_Sheet_Transfer_Loads.Weight_Sheet_UID ON Weight_Inbound_Loads.Weight_Sheet_UID = Weight_Sheets.UID
WHERE        (DATEDIFF(day, Weight_Sheets.Creation_Date, @Creation_Date) = 0) AND (Weight_Sheets.Closed = 1) AND (In_Out_Load.Location_Id = @Location)
ORDER BY In_Out_Load.Creation_Date</CommandText>
