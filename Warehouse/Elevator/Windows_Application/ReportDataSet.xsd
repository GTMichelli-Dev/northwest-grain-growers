              <DbSource ConnectionRef="NW_DataConnectionString (Settings)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="false" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>
SELECT        tblAllLoads.WS_Id, tblAllLoads.UID, tblAllLoads.Location_Id, CONVERT(VARCHAR(10), tblAllLoads.Creation_Date, 111) AS WeightSheetDate, COUNT(tblAllLoads.Load_Id) AS Loads, tblAllLoads.Crop_Id, 
                         tblAllLoads.Variety_Id, tblAllLoads.LoadType, Crops_1.Description + N' - ' + LTRIM(STR(Crops_1.Id)) AS Crop, Crop_Varieties.Variety, SUM(tblAllLoads.Net) AS Net, 
                         Locations.Description + N' - ' + LTRIM(STR(Locations.Id)) AS Location, CASE WHEN  COUNT(tblAllLoads.Load_Id) = 0 THEN CONVERT(bit, 1) ELSE CONVERT(bit, 0) END AS Void
FROM            (SELECT        Weight_Sheets_2.UID, tblLds.Time_In, tblLds.Net, tblLds.Load_Id, tblLds.Crop_Id, tblLds.Variety_Id, tblLds.LoadType, Weight_Sheets_2.WS_Id, Weight_Sheets_2.Location_Id, 
                                                    CASE WHEN tblLds.UID IS NULL THEN CONVERT(bit, 1) ELSE CONVERT(bit, 0) END AS Void, Weight_Sheets_2.Creation_Date
                          FROM            (SELECT        Weight_Sheets.WS_Id, Weight_Sheets.UID, Weight_Sheets.Location_Id, Loads.Time_In, CASE WHEN Loads.Weight_Out IS NULL THEN 0 ELSE abs(Loads.Weight_In - Loads.Weight_Out) 
                                                                              END AS Net, Loads.Load_Id, Weight_Sheet_Transfer_Loads.Crop_Id, Weight_Sheet_Transfer_Loads.Variety_Id, 'Transfer' AS LoadType
                                                    FROM            Weight_Sheets INNER JOIN
                                                                              Weight_Sheet_Transfer_Loads ON Weight_Sheets.UID = Weight_Sheet_Transfer_Loads.Weight_Sheet_UID INNER JOIN
                                                                              Transfer_Loads ON Weight_Sheet_Transfer_Loads.UID = Transfer_Loads.Transfer_Load_UID INNER JOIN
                                                                              Loads ON Transfer_Loads.Load_UID = Loads.UID
                                                    WHERE        (Weight_Sheets.Location_Id = @Location_Id) AND (DATEDIFF(day, Loads.Time_In, @SelectedDate) = 0)
                                                    UNION
                                                    SELECT        Weight_Sheets_1.WS_Id, Weight_Sheets_1.UID, Weight_Sheets_1.Location_Id, Loads_1.Time_In, CASE WHEN Loads_1.Weight_Out IS NULL 
                                                                             THEN 0 ELSE abs(Loads_1.Weight_In - Loads_1.Weight_Out) END AS Net, Loads_1.Load_Id, Lots.Crop_Id, Lots.Variety_Id, 'Intake' AS LoadType
                                                    FROM            Weight_Sheets AS Weight_Sheets_1 INNER JOIN
                                                                             Weight_Inbound_Loads ON Weight_Sheets_1.UID = Weight_Inbound_Loads.Weight_Sheet_UID INNER JOIN
                                                                             Lots ON Weight_Inbound_Loads.Lot_UID = Lots.UID INNER JOIN
                                                                             Inbound_Loads ON Weight_Sheets_1.UID = Inbound_Loads.WS_UID INNER JOIN
                                                                             Loads AS Loads_1 ON Inbound_Loads.Load_UID = Loads_1.UID
                                                    WHERE        (Weight_Sheets_1.Location_Id = @Location_Id) AND (DATEDIFF(day, Loads_1.Time_In, @SelectedDate) = 0)) AS tblLds RIGHT OUTER JOIN
                                                    Weight_Sheets AS Weight_Sheets_2 ON tblLds.UID = Weight_Sheets_2.UID
                          WHERE        (Weight_Sheets_2.Location_Id = @Location_Id) AND (DATEDIFF(day, Weight_Sheets_2.Creation_Date, @SelectedDate) = 0)) AS tblAllLoads INNER JOIN
                         Locations ON tblAllLoads.Location_Id = Locations.Id LEFT OUTER JOIN
                         Crops AS Crops_1 ON tblAllLoads.Crop_Id = Crops_1.Id LEFT OUTER JOIN
                             (SELECT        Variety.Id AS Variety_Id, Variety.Description AS Variety, Crops.Id AS Crop_Id, Crops.Description AS Crop
                               FROM            Crops INNER JOIN
                                                         Variety_Crop_Groups ON Crops.UID = Variety_Crop_Groups.Crop_UID INNER JOIN
                                                         Variety ON Variety_Crop_Groups.Variety_UID = Variety.UID) AS Crop_Varieties ON tblAllLoads.Variety_Id = Crop_Varieties.Variety_Id AND tblAllLoads.Crop_Id = Crop_Varieties.Crop_Id
GROUP BY tblAllLoads.Location_Id, CONVERT(VARCHAR(10), tblAllLoads.Creation_Date, 111), tblAllLoads.Crop_Id, tblAllLoads.Variety_Id, tblAllLoads.LoadType, Crops_1.Description + N' - ' + LTRIM(STR(Crops_1.Id)), 
                         Crop_Varieties.Variety, tblAllLoads.WS_Id, tblAllLoads.UID, Locations.Description + N' - ' + LTRIM(STR(Locations.Id))
ORDER BY tblAllLoads.WS_Id</CommandText>
