                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        WS_Id, Commodity, Commodity_Id, Lot_Number, Location_Id, Comment, FSA_Number, Landlord, CreationDate, Closed, SUM(Net) AS Net, CASE WHEN UOM = 'Tons' THEN ROUND(SUM(Units), 2) 
                         ELSE ROUND(SUM(Units), 2) END AS Units, UOM, Customer_Id, Customer, Lot_Open, Location
FROM            (SELECT        Weight_Sheets.WS_Id, Crops.Description AS Commodity, Lots.Crop_Id AS Commodity_Id, Lots.Lot_Number, Weight_Sheets.Location_Id, Lots.Comment, Lots.FSA_Number, Lots.Landlord, 
                                                    CONVERT(VARCHAR(10), Weight_Sheets.Creation_Date, 101) AS CreationDate, Weight_Sheets.Closed, ABS(Loads.Weight_In - Loads.Weight_Out) AS Net, ABS(Loads.Weight_In - Loads.Weight_Out) 
                                                    / (CASE WHEN Crops.Pound_Per_Bushel &lt;= 0 THEN 1 ELSE Crops.Pound_Per_Bushel END) AS Units, 
                                                    CASE WHEN Unit_Of_Measure = 'T' THEN 'Tons' WHEN Unit_Of_Measure = 'H' THEN 'CWT' ELSE 'Bushels' END AS UOM, Lots.Producer_Id AS Customer_Id, Lots.Producer_Description AS Customer, 
                                                    CASE WHEN Close_Date IS NULL THEN CONVERT(BIT, 1) ELSE CONVERT(BIT, 0) END AS Lot_Open, Locations.Description AS Location
                          FROM            Weight_Sheets INNER JOIN
                                                    Weight_Inbound_Loads ON Weight_Sheets.UID = Weight_Inbound_Loads.Weight_Sheet_UID INNER JOIN
                                                    Lots ON Weight_Inbound_Loads.Lot_UID = Lots.UID INNER JOIN
                                                    Inbound_Loads ON Weight_Sheets.UID = Inbound_Loads.WS_UID INNER JOIN
                                                    Loads ON Inbound_Loads.Load_UID = Loads.UID INNER JOIN
                                                    Crops ON Lots.Crop_Id = Crops.Id INNER JOIN
