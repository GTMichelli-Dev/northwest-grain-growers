          <TableAdapter BaseClass="System.ComponentModel.Component" DataAccessorModifier="AutoLayout, AnsiClass, Class, Public" DataAccessorName="DailyTransferWSTableAdapter" GeneratorDataComponentClassName="DailyTransferWSTableAdapter" Name="DailyTransferWS" UserDataComponentName="DailyTransferWSTableAdapter">
            <MainSource>
              <DbSource ConnectionRef="NW_DataConnectionString (Settings)" DbObjectType="Unknown" FillMethodModifier="Public" FillMethodName="Fill" GenerateMethods="Both" GenerateShortCommands="false" GeneratorGetMethodName="GetData" GeneratorSourceName="Fill" GetMethodModifier="Public" GetMethodName="GetData" QueryType="Rowset" ScalarCallRetval="System.Object, mscorlib, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" UseOptimisticConcurrency="true" UserGetMethodName="GetData" UserSourceName="Fill">
                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT        tblWS.WS_Id, tblWS.Commodity, tblWS.Commodity_Id, tblWS.Location_Id, tblWS.CreationDate, tblWS.Closed, SUM(tblWS.Net) AS Net, SUM(tblWS.Units) AS Units, tblWS.UOM, tblWS.Location, tblWS.Source, 
                         tblWS.Source_Id, tblWS.Comment, tblWS.CropUID, tblWS.Variety_Id, Variety.Description AS Variety
FROM            Variety INNER JOIN
                         Variety_Crop_Groups ON Variety.UID = Variety_Crop_Groups.Variety_UID RIGHT OUTER JOIN
                             (SELECT        Weight_Sheets.WS_Id, Crops.UID AS CropUID, Crops.Description AS Commodity, Weight_Sheet_Transfer_Loads.Crop_Id AS Commodity_Id, Weight_Sheets.Location_Id, CONVERT(VARCHAR(10), 
                                                         Weight_Sheets.Creation_Date, 101) AS CreationDate, Weight_Sheets.Closed, ABS(Loads.Weight_In - Loads.Weight_Out) AS Net, ABS(Loads.Weight_In - Loads.Weight_Out) 
                                                         / (CASE WHEN Crops.Pound_Per_Bushel &lt;= 0 THEN 1 ELSE Crops.Pound_Per_Bushel END) AS Units, 
                                                         CASE WHEN Unit_Of_Measure = 'T' THEN 'Tons' WHEN Unit_Of_Measure = 'H' THEN 'CWT' ELSE 'Bushels' END AS UOM, Locations.Description AS Location, Sources.Description AS Source, 
                                                         Weight_Sheet_Transfer_Loads.Source_Id, Weight_Sheets.Comment, Weight_Sheet_Transfer_Loads.Variety_Id
                               FROM            Crops INNER JOIN
                                                         Weight_Sheets INNER JOIN
                                                         Locations ON Weight_Sheets.Location_Id = Locations.Id INNER JOIN
                                                         Weight_Sheet_Transfer_Loads ON Weight_Sheets.UID = Weight_Sheet_Transfer_Loads.Weight_Sheet_UID ON Crops.Id = Weight_Sheet_Transfer_Loads.Crop_Id INNER JOIN
                                                         Transfer_Loads INNER JOIN
                                                         Loads ON Transfer_Loads.Load_UID = Loads.UID ON Weight_Sheet_Transfer_Loads.UID = Transfer_Loads.Transfer_Load_UID INNER JOIN
                                                         Locations AS Sources ON Weight_Sheet_Transfer_Loads.Source_Id = Sources.Id
                               WHERE        (Loads.Void = 0) AND (Weight_Sheets.Void = 0) AND (Loads.Time_Out IS NOT NULL)) AS tblWS ON Variety_Crop_Groups.Crop_UID = tblWS.CropUID AND Variety.Id = tblWS.Variety_Id
GROUP BY tblWS.WS_Id, tblWS.Commodity, tblWS.Commodity_Id, tblWS.Location_Id, tblWS.UOM, tblWS.Location, tblWS.CreationDate, tblWS.Source, tblWS.Source_Id, tblWS.Closed, tblWS.Comment, tblWS.CropUID, 
                         tblWS.Variety_Id, Variety.Description
HAVING        (DATEDIFF(day, tblWS.CreationDate, @SelectedDate) = 0) AND (tblWS.Location_Id = ISNULL(@Location_Id, tblWS.Location_Id))</CommandText>
