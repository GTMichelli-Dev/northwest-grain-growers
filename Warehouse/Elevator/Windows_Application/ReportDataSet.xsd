GROUP BY WS_Id, Commodity, Commodity_Id, Lot_Number, Location_Id, Comment, FSA_Number, Landlord, CreationDate, UOM, Closed, Customer_Id, Customer, Lot_Open, Location
HAVING        (DATEDIFF(day, CreationDate, @SelectedDate) = 0) AND (Location_Id = @Location_Id)</CommandText>
