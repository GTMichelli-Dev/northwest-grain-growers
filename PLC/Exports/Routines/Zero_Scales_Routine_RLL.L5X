</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(tmrReset.DN)MOV(0,MT_ScaleWO.MB1.Command)OTU(Zero_Scale)OTU(ZeroScaleLatch);]]>
