<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[MOV(1000,tmrReset.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Zero_Scale)OTL(ZeroScaleLatch);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(ZeroScaleLatch)OTL(ZeroScaleLatch)MOV(404,MT_ScaleWO.MB1.Command)TON(tmrReset,?,?);]]>
