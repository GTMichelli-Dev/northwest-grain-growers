<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set the Default Cal Factor]]>
</Comment>
<Text>
<![CDATA[XIO(Treater_Pump.TreaterScale.Use_Scale)Pump_Volume_Control(PVC,Pump_Drive_Out,Pump_Drive_In,Treater_Pump);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.TreaterScale.Use_Scale)Pump_Scale_Control(PSC,Pump_Drive_Out,Pump_Drive_In,Treater_Pump,Pump_Rate_Multliplier);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[All The Pump Logic]]>
</Comment>
<Text>
<![CDATA[[XIC(Treater_Pump.Start_Pump) ,XIC(Treater_Pump.Cal.Cal_Started) ,XIC(Treater_Pump.Cal.Calibrating) ]OTU(Treater_Pump.Start_Pump_Reverse);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[[[XIC(Treater_Pump.Start_Pump) XIO(Treater_Pump.TreaterScale.Use_Scale) ,XIC(Treater_Pump.Start_Pump) XIC(Treater_Pump.TreaterScale.Use_Scale) XIO(Treater_Pump.Below_Min_Gals) XIO(Treater_Pump.Below_Min_Start_Gals) ,XIC(Treater_Pump.Manual_Start_Pump) ] XIO(Pump_Reversed) ,XIC(Treater_Pump.Purge_Forward) XIO(Pump_Reversed) ,XIC(Treater_Pump.Purge_Reverse) XIC(Pump_Reversed) ,XIC(Pump_Reversed) XIC(Treater_Pump.Start_Pump_Reverse) ]OTE(Pump_Drive_Out.Forward);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[[XIC(Treater_Pump.Start_Pump) ,XIC(Treater_Pump.Manual_Start_Pump) ] XIC(Pump_Reversed) ,XIC(Treater_Pump.Purge_Forward) XIC(Pump_Reversed) ,XIC(Treater_Pump.Purge_Reverse) XIO(Pump_Reversed) ,XIO(Pump_Reversed) XIC(Treater_Pump.Start_Pump_Reverse) ]OTE(Pump_Drive_Out.Reverse);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(Treater_Pump.Faulted)[XIC(Treater_Pump.Start_Pump) XIO(Treater_Pump.TreaterScale.Use_Scale) ,XIC(Treater_Pump.Manual_Start_Pump) ,XIC(Treater_Pump.Purge_Forward) ,XIC(Treater_Pump.Purge_Reverse) ,XIC(Treater_Pump.Start_Pump) XIC(Treater_Pump.TreaterScale.Use_Scale) XIO(Treater_Pump.Below_Min_Gals) XIO(Treater_Pump.Below_Min_Start_Gals) ]OTE(Pump_Drive_Out.Start);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[[XIO(Treater_Pump.Start_Pump) XIO(Treater_Pump.Manual_Start_Pump) XIO(Treater_Pump.Start_Pump_Reverse) XIO(Treater_Pump.Purge_Forward) XIO(Treater_Pump.Purge_Reverse) ,XIO(Treater_Pump.Purge_Forward) XIO(Treater_Pump.Purge_Reverse) XIO(Treater_Pump.Manual_Start_Pump) XIC(Treater_Pump.Below_Min_Gals) XIC(Treater_Pump.TreaterScale.Use_Scale) XIC(Treater_Pump.TreaterScale.Use_Scale) ,XIC(Treater_Pump.Faulted) ]OTE(Pump_Drive_Out.Stop);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[[XIC(Treater_Pump.Start_Pump) ,XIC(Treater_Pump.Manual_Start_Pump) ]XIO(Treater_Pump.Start_Pump_Reverse)XIO(tmrRotar_Animate.DN)TON(tmrRotar_Animate,?,?);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIO(tmrRotar_Animate.DN)CTU(cntRotar_Animate,?,?);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIC(cntRotar_Animate.DN)RES(cntRotar_Animate);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[MOV(cntRotar_Animate.ACC,Treater_Pump.Rotor_Animate_IDX);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Edit Treater Product]]>
</Comment>
<Text>
<![CDATA[XIC(Treater_Pump.Product.Edit_Product)OTE(Reset_New_Product);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[ONS(Reset_New_Product)COP(Empty_String,Treater_Pump.Product.New_Product,1);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Product.Accept_New)[COP(Treater_Pump.Product.New_Product,Treater_Pump.Product.Description,1) ,OTU(Treater_Pump.Product.Edit_Product) OTU(Treater_Pump.Product.Accept_New) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Product.Cancel_New)OTU(Treater_Pump.Product.Edit_Product)OTU(Treater_Pump.Product.Cancel_New);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Clear Fault In Drive]]>
</Comment>
<Text>
<![CDATA[XIC(Treater_Pump.Clear_Faults)OTU(Treater_Pump.Over_Speed_Limit)OTE(Pump_Drive_Out.ClearFaults);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[XIO(Treater_Pump.Over_Speed_Limit)XIO(Pump_Drive_In.Faulted)OTU(Treater_Pump.Clear_Faults);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[Output showing pump is faulted]]>
</Comment>
<Text>
<![CDATA[[XIC(Pump_Drive_In.Faulted) ,XIC(Treater_Pump.Over_Speed_Limit) ,XIC(Treater_Pump.TreaterScale.Use_Scale) XIC(Treater_Pump.Below_Min_Gals) XIC(Treater_Pump.Start_Pump) ]OTE(Treater_Pump.Faulted);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[Set Drive Speed]]>
</Comment>
<Text>
<![CDATA[XIO(Treater_Pump.Purge_Forward)XIO(Treater_Pump.Purge_Reverse)MOV(Treater_Pump.Speed,Pump_Drive_Out.FreqCommand);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[LEQ(Treater_Pump.Purge_Percent,0)MOV(0.5,Treater_Pump.Purge_Percent);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[Set Drive Speed]]>
</Comment>
<Text>
<![CDATA[[XIC(Treater_Pump.Purge_Forward) ,XIC(Treater_Pump.Purge_Reverse) ]CPT(Pump_Drive_Out.FreqCommand,9000*Treater_Pump.Purge_Percent);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Comment>
<![CDATA[Current Speed Of Pump from 0 to 9000]]>
</Comment>
<Text>
<![CDATA[MOV(Pump_Drive_In.OutputFreq,Treater_Pump.Current_Speed);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[To get the rpm of the motor we need to have a speed factor to multliply the freq drive frequency by.
If the pump speed factor is 0 then we will use a default value]]>
</Comment>
<Text>
<![CDATA[CMP(Treater_Pump.Speed_Factor=0)MOV(0.066,Treater_Pump.Speed_Factor);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[Set the Pumps RPM]]>
</Comment>
<Text>
<![CDATA[MUL(Treater_Pump.Current_Speed,Treater_Pump.Speed_Factor,Treater_Pump.Current_RPM);]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.SpeedLimitPercent,0)MOV(0.8,Treater_Pump.SpeedLimitPercent);]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Text>
<![CDATA[CPT(OverSpeedLimit,9000*Treater_Pump.SpeedLimitPercent);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Text>
<![CDATA[LEQ(Treater_Pump.OverSpeedTimeOut,0)MOV(5000,Treater_Pump.OverSpeedTimeOut);]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Text>
<![CDATA[MOV(Treater_Pump.OverSpeedTimeOut,tmrOverSpeed.PRE);]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Text>
<![CDATA[GEQ(Treater_Pump.Speed,OverSpeedLimit)XIO(Treater_Pump.Manual_Start_Pump)XIO(Treater_Pump.Purge_Forward)XIO(Treater_Pump.Purge_Reverse)XIC(Treater_Pump.Start_Pump)XIO(Treater_Pump.Over_Speed_Limit)XIO(Treater_Pump.Below_Min_Start_Gals)TON(tmrOverSpeed,?,?);]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Text>
<![CDATA[XIC(tmrOverSpeed.DN)XIO(Treater_Pump.Over_Speed_Limit)OTL(Treater_Pump.Over_Speed_Limit);]]>
</Text>
</Rung>
<Rung Number="30" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Over_Speed_Limit)OTL(Treater_Pump.ShowStatus)MOV('Pump Over Speed',Treater_Pump.Status_Msg);]]>
</Text>
</Rung>
<Rung Number="31" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Below_Min_Start_Gals)XIO(Treater_Pump.Below_Min_Gals)OTL(Treater_Pump.ShowStatus)MOV('Below Min Start Gallons',Treater_Pump.Status_Msg);]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Below_Min_Gals)OTL(Treater_Pump.ShowStatus)MOV('Below Min Gallons',Treater_Pump.Status_Msg);]]>
</Text>
</Rung>
<Rung Number="33" Type="N">
<Text>
<![CDATA[XIC(Pump_Drive_In.Faulted)OTL(Treater_Pump.ShowStatus)MOV('Pump VFD Fault',Treater_Pump.Status_Msg);]]>
</Text>
</Rung>
<Rung Number="34" Type="N">
<Text>
<![CDATA[XIO(Treater_Pump.Below_Min_Gals)XIO(Treater_Pump.Below_Min_Start_Gals)XIO(Treater_Pump.Over_Speed_Limit)XIO(Pump_Drive_In.Faulted)OTU(Treater_Pump.ShowStatus)MOV('',Treater_Pump.Status_Msg);]]>
</Text>
</Rung>
<Rung Number="35" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Active_Treatment)[XIC(Treater_Pump.Over_Speed_Limit) ,XIC(Treater_Pump.Faulted) ,XIC(Treater_Pump.Below_Min_Gals) ]OTE(Treater_Pump.NotReady);]]>
</Text>
</Rung>
