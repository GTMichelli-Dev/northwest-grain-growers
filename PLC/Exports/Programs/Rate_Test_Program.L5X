<Routines>
<Routine Name="CalcRate" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[ADD(0,Scale_22:I.MB1.Measuring_Value,CurrentScaleValue);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIO(tmrSecond.DN)TON(tmrSecond,?,?);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(tmrSecond.DN)GRT(LastScaleValue,CurrentScaleValue)ADD(1,TestCount2,TestCount2)CPT(Rate_LBS,((LastScaleValue-CurrentScaleValue))*60);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[LEQ(LastScaleValue,CurrentScaleValue)TON(tmrResetRate_LBS,?,?);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(tmrResetRate_LBS.DN)MOV(0,Rate_LBS);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[EQU(Rate_Factor,0)MOV(1,Rate_Factor);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[CPT(Rate_OZ,(Rate_LBS/Rate_Factor)*128);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[CPT(CWT_OZ,Rate_OZ/100);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[CPT(CWT_OZ_Rate,CWT_Rate/CWT_OZ);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIC(tmrSecond.DN)ADD(1,TestCount,TestCount)MOV(CurrentScaleValue,LastScaleValue);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
