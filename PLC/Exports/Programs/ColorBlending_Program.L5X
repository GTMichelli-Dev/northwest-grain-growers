<Routines>
<Routine Name="Blending" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIC(Auto_Start)XIO(Auto_Stop)OTE(Start_Color);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[MOV(ReverseDuration,tmrReverse.PRE)MOV(10,ctrColorIdx.PRE);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[MOV(0,BlendColorCount)MOV(0,CountIdx)FOR(ColorCount,CountIdx,0,9,1);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(Start_Color)ONS(Initialize)OTL(ColorIndexChanged)MOV(0,IDX);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(tmrDuration.DN)OTL(NextColor);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIC(Colors[IDX].Active)NEQ(IDX,CurColorIdx)XIO(NextColorSet)[MOV(IDX,NewColorIdx) ,OTL(NextColorSet) ,MOV(NewColorIdx,CurColorIdx) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(NextColor)OTU(NextColorSet)OTU(NextColor)OTL(ColorIndexChanged);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[CPT(tmrDuration.PRE,Colors[CurColorIdx].Duration*1000);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[GRT(BlendColorCount,1)MOV(PumpDelay,tmrDelay.PRE);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[LEQ(BlendColorCount,1)MOV(0,tmrDelay.PRE);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[[XIO(Treater_Pump[2].Manual_Start_Pump) CPT(Treater_Pump[2].Rate,Colors[CurColorIdx].Blue) ,XIO(Treater_Pump[4].Manual_Start_Pump) CPT(Treater_Pump[4].Rate,Colors[CurColorIdx].Yellow) ,XIO(Treater_Pump[3].Manual_Start_Pump) CPT(Treater_Pump[3].Rate,Colors[CurColorIdx].Red) ,XIO(Treater_Pump[0].Manual_Start_Pump) CPT(Treater_Pump[0].Rate,Colors[CurColorIdx].White) ,XIO(Treater_Pump[23].Manual_Start_Pump) CPT(Treater_Pump[23].Rate,Colors[CurColorIdx].Polymer) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[XIO(Start_Color)TON(tmrReverse,?,?);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[XIC(Pause)XIO(tmrDuration.DN)XIO(tmrDelay.TT)TON(tmrDuration,?,?);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[XIC(Pause)XIO(tmrDelay.DN)XIO(tmrDuration.TT)TON(tmrDelay,?,?);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[XIC(tmrDelay.DN)OTU(ColorIndexChanged);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[XIO(No_Color)XIO(Treater_Pump[2].Manual_Start_Pump)XIC(Start_Color)XIC(Pause)[XIO(tmrDelay.TT) ,EQU(tmrDelay.PRE,0) ]GRT(Treater_Pump[2].Rate,0)OTE(Treater_Pump[2].Start_Pump);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[XIO(No_Color)XIO(Treater_Pump[4].Manual_Start_Pump)XIC(Start_Color)XIC(Pause)[XIO(tmrDelay.TT) ,EQU(tmrDelay.PRE,0) ]GRT(Treater_Pump[4].Rate,0)OTE(Treater_Pump[4].Start_Pump);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[XIO(No_Color)XIO(Treater_Pump[3].Manual_Start_Pump)XIC(Start_Color)XIC(Pause)[XIO(tmrDelay.TT) ,EQU(tmrDelay.PRE,0) ]GRT(Treater_Pump[3].Rate,0)OTE(Treater_Pump[3].Start_Pump);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[XIO(No_Color)XIO(Treater_Pump[23].Manual_Start_Pump)XIC(Start_Color)XIC(Pause)[XIO(tmrDelay.TT) ,EQU(tmrDelay.PRE,0) ]GRT(Treater_Pump[23].Rate,0)OTE(Treater_Pump[23].Start_Pump);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[XIO(Treater_Pump[0].Manual_Start_Pump)XIC(Start_Color)XIC(Pause)[XIO(tmrDelay.TT) ,EQU(tmrDelay.PRE,0) ]GRT(Treater_Pump[0].Rate,0)OTE(Treater_Pump[0].Start_Pump);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Text>
<![CDATA[XIO(Start_Color)GRT(tmrReverse.PRE,0)ONS(SetReverseRate)[MOV(ReverseRate,Treater_Pump[20].Rate) ,MOV(ReverseRate,Treater_Pump[21].Rate) ,MOV(ReverseRate,Treater_Pump[22].Rate) ,MOV(ReverseRate,Treater_Pump[23].Rate) ,MOV(ReverseRate,Treater_Pump[0].Rate) ,OTE(ReverseStart) ];]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Text>
<![CDATA[[GRT(tmrReverse.PRE,0) XIC(tmrReverse.TT) ,XIC(TestReverse) ][OTE(Treater_Pump[20].Start_Pump_Reverse) ,OTE(Treater_Pump[21].Start_Pump_Reverse) ,OTE(Treater_Pump[22].Start_Pump_Reverse) ,OTE(Treater_Pump[23].Start_Pump_Reverse) ,OTE(Treater_Pump[0].Start_Pump_Reverse) ];]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Text>
<![CDATA[XIO(NextColorSet)ADD(1,IDX,IDX);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Text>
<![CDATA[GRT(IDX,9)MOV(0,IDX);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="ColorCount" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIC(Colors[CountIdx].Active)ADD(1,BlendColorCount,BlendColorCount);]]>
