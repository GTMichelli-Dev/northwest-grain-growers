<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIC(Start)ONS(ons.0)XIO(EnterAdj)OTL(EnterAdj)OTU(Done)OTU(Error)MOV(0,Step)MOV(0,Status);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(EnterAdj)EQU(0,Step)[[ONS(ons.5) MOV(100,TON[3].PRE) MSG(MSG_CalFreeCellCapacity) ,TON(TON[3],?,?) ] ,XIC(TON[3].DN) XIO(MSG_CalFreeCellCapacity.ST) [XIC(MSG_CalFreeCellCapacity.DN) RES(TON[3]) MOV(1,Step) ,XIC(MSG_CalFreeCellCapacity.ER) MOV(900,Step) ] ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(EnterAdj)EQU(1,Step)[[ONS(ons.6) MOV(100,TON[4].PRE) MSG(MSG_CalFreeCellOutput) ,TON(TON[4],?,?) ] ,XIC(TON[4].DN) XIO(MSG_CalFreeCellOutput.ST) [XIC(MSG_CalFreeCellOutput.DN) RES(TON[4]) MOV(2,Step) ,XIC(MSG_CalFreeCellOutput.ER) MOV(900,Step) ] ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(EnterAdj)EQU(2,Step)[[ONS(ons.4) MOV(100,TON[6].PRE) MSG(MSG_CalFreeUnit) ,TON(TON[6],?,?) ] ,XIC(TON[6].DN) XIO(MSG_CalFreeUnit.ST) [XIC(MSG_CalFreeUnit.DN) RES(TON[6]) MOV(10,Step) ,XIC(MSG_CalFreeUnit.ER) MOV(900,Step) ] ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(EnterAdj)EQU(10,Step)[[ONS(ons.7) MOV(100,TON[5].PRE) MOV(1,TmpTrigger) MSG(MSG_CalFreeTrigger) ,TON(TON[5],?,?) ] ,XIC(TON[5].DN) XIO(MSG_CalFreeTrigger.ST) [XIC(MSG_CalFreeTrigger.DN) RES(TON[5]) MOV(20,Step) ,XIC(MSG_CalFreeTrigger.ER) MOV(900,Step) ] ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIC(EnterAdj)EQU(20,Step)[[ONS(ons.8) MOV(100,TON[0].PRE) MSG(MSG_CalFreeStatus) ,TON(TON[0],?,?) ] ,XIC(TON[0].DN) XIO(MSG_CalFreeStatus.ST) XIC(MSG_CalFreeStatus.DN) RES(TON[0]) MOV(TmpAdjStatus,Status) [EQU(2047,Status) MOV(21,Step) ,[CMP(Status < 0) OTL(Error) ,EQU(0,Status) OTL(Done) ] OTU(EnterAdj) OTU(Start) ] ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(EnterAdj)EQU(21,Step)[[ONS(ons.9) MOV(100,TON[1].PRE) MSG(MSG_CalFreeStatus) ,TON(TON[1],?,?) ] ,XIC(TON[1].DN) XIO(MSG_CalFreeStatus.ST) [XIC(MSG_CalFreeStatus.DN) RES(TON[1]) MOV(TmpAdjStatus,Status) MOV(20,Step) ,XIC(MSG_CalFreeStatus.ER) MOV(900,Step) ] ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[XIC(EnterAdj)EQU(900,Step)OTL(Error)OTU(EnterAdj)OTU(Start);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
