<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[MOV(ReverseDuration,tmrReverse.PRE)MOV(10,Current_Color_Index.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[ONS(Start)RES(Current_Color_Index);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIO(SelectedColors[Current_Color_Index.ACC].Active)OTE(Inactive_Color);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[ONS(Current_Color_Index.CU)XIO(Inactive_Color)[COP(SelectedColors[Current_Color_Index.ACC],Current_Color,1) ,CPT(Blue_Pump.Rate,Current_Color.Blue*(Total_Oz_Min/2)) ,CPT(Yellow_Pump.Rate,Current_Color.Yellow*(Total_Oz_Min/2)) ,CPT(Red_Pump.Rate,Current_Color.Red*(Total_Oz_Min/2)) ,CPT(White_Pump.Rate,Current_Color.White*(Total_Oz_Min/2)) ,CPT(Polymer_Pump.Rate,Current_Color.Polymer*(Total_Oz_Min/2)) ,MOV(PumpDelay,tmrDelay.PRE) MOV(Current_Color.Duration,tmrDuration.PRE) ,MOV(0,tmrDelay.PRE) MOV(0,tmrDuration.PRE) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIO(Inactive_Color)XIO(Start)XIO(tmrReverse.DN)TON(tmrReverse,?,?);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(Inactive_Color)XIO(tmrDuration.DN)XIO(tmrDelay.TT)TON(tmrDuration,?,?);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIO(Inactive_Color)XIO(tmrDelay.DN)XIO(tmrDuration.TT)TON(tmrDelay,?,?);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[[XIO(Inactive_Color) XIC(Start) XIC(Pause) XIC(tmrDuration.TT) XIC(SelectedColors[Current_Color_Index.ACC].Active) GRT(Yellow_Pump.Rate,0) ,XIC(Yellow_Pump.Manual_Start_Pump) ]OTE(Yellow_Pump.Start_Pump);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[[XIO(Inactive_Color) XIC(Start) XIC(Pause) XIC(tmrDuration.TT) XIC(SelectedColors[Current_Color_Index.ACC].Active) GRT(Blue_Pump.Rate,0) ,XIC(Blue_Pump.Manual_Start_Pump) ]OTE(Blue_Pump.Start_Pump);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIO(Inactive_Color) XIC(Start) XIC(Pause) XIC(tmrDuration.TT) XIC(SelectedColors[Current_Color_Index.ACC].Active) GRT(Red_Pump.Rate,0) ,XIC(Red_Pump.Manual_Start_Pump) ]OTE(Red_Pump.Start_Pump);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[[XIO(Inactive_Color) XIC(Start) XIC(Pause) XIC(tmrDuration.TT) XIC(SelectedColors[Current_Color_Index.ACC].Active) GRT(White_Pump.Rate,0) ,XIC(White_Pump.Manual_Start_Pump) ]OTE(White_Pump.Start_Pump);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[[XIO(Inactive_Color) XIC(Pause) XIC(tmrDuration.TT) XIC(Current_Color.Active) GRT(Polymer_Pump.Rate,0) ,XIC(Polymer_Pump.Manual_Start_Pump) ]OTE(Polymer_Pump.Start_Pump);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[[XIC(tmrDelay.DN) ,XIO(SelectedColors[Current_Color_Index.ACC].Active) ADD(Current_Color_Index.ACC,1,Current_Color_Index.ACC) ]CTU(Current_Color_Index,?,?);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[XIC(Current_Color_Index.DN)RES(Current_Color_Index);]]>
</Text>
</Rung>
