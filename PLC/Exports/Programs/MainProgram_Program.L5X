<Text>
<![CDATA[XIC(Get_Values)EQU(10,Step)[[ONS(ons.2) MOV(100,TON[0].PRE) MSG(MSG_ReadCap) ,TON(TON[0],?,?) ] ,XIC(TON[0].DN) XIO(MSG_ReadCap.ST) [XIC(MSG_ReadCap.DN) MOV(TmpCapacity,ScaleCapacity) MOV(100,Step) ,XIC(MSG_ReadCap.ER) MOV(110,Step) ] RES(TON[0]) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
