<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIC(TareStable)ONS(ons.0)MOV(400,Command)OTL(WriteTrigger);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(ZeroStable)ONS(ons.1)MOV(401,Command)OTL(WriteTrigger);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(TareImmediate)ONS(ons.2)MOV(403,Command)OTL(WriteTrigger);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(ZeroImmediate)ONS(ons.3)MOV(404,Command)OTL(WriteTrigger);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(ClearTare)ONS(ons.5)MOV(402,Command)OTL(WriteTrigger);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIC(PreTare)ONS(ons.6)MOV(PreTareValue,MB_CmdValue)MOV(201,Command)OTL(WriteTrigger);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(WriteTrigger)ONS(ons.7)MOV(Command,MB_Command)OTU(Done)OTU(Error)OTU(WriteTrigger);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[[EQU(MB_Response,Command) ONS(ons.8) OTL(Done) ,NEQ(WeightCmd,Prev_WeightCmd) ONS(ons.9) MOV(WeightCmd,Prev_WeightCmd) ]OTL(RestoreTrigger);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[CMP(MB_Response < 0)OTL(Error)OTL(RestoreTrigger);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIC(RestoreTrigger)MOV(0.0,MB_CmdValue)MOV(WeightCmd,MB_Command)OTU(TareStable)OTU(ZeroStable)OTU(TareImmediate)OTU(ZeroImmediate)OTU(ClearTare)OTU(PreTare)OTU(RestoreTrigger);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[XIC(DataOK)[CMP(MB_Response >= 0) CMP(MB_Response <= 3) ,CMP(MB_Response >= 5) CMP(MB_Response <= 7) ]MOV(MB_Value,RealTimeWeight);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
