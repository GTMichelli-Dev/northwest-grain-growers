<Rung Number="1" Type="N">
<Text>
<![CDATA[XIO(tmrSecond.DN)TON(tmrSecond,?,?);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(tmrSecond.DN)GEQ(LastScaleValue,CurrentScaleValue)ADD(1,TestCount2,TestCount2)CPT(Rate_LBS,((LastScaleValue-CurrentScaleValue))*60);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[EQU(0,LBS_Gal)MOV(1,LBS_Gal);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[CPT(Rate_OZ,(Rate_LBS/LBS_Gal)*128);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIC(tmrSecond.DN)ADD(1,TestCount,TestCount)MOV(CurrentScaleValue,LastScaleValue);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
