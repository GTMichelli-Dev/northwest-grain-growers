<Rung Number="7" Type="N">
<Text>
<![CDATA[[XIO(Inactive_Color) XIC(Start) XIC(Pause) XIC(tmrDuration.TT) XIC(SelectedColors[Current_Color_Index.ACC].Active) GRT(Yellow_Pump.Rate,0) ,XIC(Yellow_Pump.Manual_Start_Pump) ]OTE(Yellow_Pump.Start_Pump);]]>
