<Rung Number="3" Type="N">
<Text>
<![CDATA[ONS(Current_Color_Index.CU)XIO(Inactive_Color)[COP(SelectedColors[Current_Color_Index.ACC],Current_Color,1) ,CPT(Blue_Pump.Rate,Current_Color.Blue*(Total_Oz_Min/2)) ,CPT(Yellow_Pump.Rate,Current_Color.Yellow*(Total_Oz_Min/2)) ,CPT(Red_Pump.Rate,Current_Color.Red*(Total_Oz_Min/2)) ,CPT(White_Pump.Rate,Current_Color.White*(Total_Oz_Min/2)) ,CPT(Polymer_Pump.Rate,Current_Color.Polymer*(Total_Oz_Min/2)) ,MOV(PumpDelay,tmrDelay.PRE) MOV(Current_Color.Duration,tmrDuration.PRE) ,MOV(0,tmrDelay.PRE) MOV(0,tmrDuration.PRE) ];]]>
