<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Set the Default Cal Factor]]>
</Comment>
<Text>
<![CDATA[LEQ(Treater_Pump.Product.Cal_Factor,0)MOV(1,Treater_Pump.Product.Cal_Factor);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[OTU(Treater_Pump.Below_Warning_Gals)OTU(Treater_Pump.Below_Min_Gals)OTU(Treater_Pump.Below_Min_Start_Gals);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[See If the operator is fine Tuning System]]>
</Comment>
<Text>
<![CDATA[XIC(Treater_Pump.Product.Apply_Adjustment)NEQ(Treater_Pump.Product.Cal_Actual,0)NEQ(Treater_Pump.Product.Cal_Indicated,0)CPT(Treater_Pump.Product.Cal_Factor,(Treater_Pump.Product.Cal_Indicated/Treater_Pump.Product.Cal_Actual)*Treater_Pump.Product.Cal_Factor);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Product.Apply_Adjustment)MOV(0,Treater_Pump.Product.Cal_Indicated)MOV(0,Treater_Pump.Product.Cal_Actual)OTU(Treater_Pump.Product.Apply_Adjustment);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIO(Treater_Pump.Cal.Calibrating)Pump_Speed_Calc(Pump_Speed_Calc,Treater_Pump.Rate,Treater_Pump.Cal.Cal_Points,Treater_Pump.Speed,Treater_Pump.Product.Cal_Factor);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(Treater_Pump.Cal.Calibrating)Pump_Rate_Calc(Pump_Rate_Calc,Treater_Pump.Current_Speed,Treater_Pump.Cal.Cal_Points,Treater_Pump.Current_Rate,Treater_Pump.Product.Cal_Factor);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[GRT(Treater_Pump.Rate,Treater_Pump.Cal.Cal_Points.Cal_Point[4].Rate)XIO(Treater_Pump.Cal.Calibrating)MOV(0,Treater_Pump.Rate);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[*******************Pump Calibration *************************

 

If The Cal Speeds are zero then set to default ]]>
</Comment>
<Text>
<![CDATA[MOV(0,Treater_Pump.Cal.Cal_Points.Cal_Point[0].Speed);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[MOV(2250,Treater_Pump.Cal.Cal_Points.Cal_Point[1].Speed);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[MOV(4500,Treater_Pump.Cal.Cal_Points.Cal_Point[2].Speed);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
