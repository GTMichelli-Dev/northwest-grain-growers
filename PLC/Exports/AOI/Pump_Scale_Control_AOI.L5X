<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Start_Pump)XIO(Treater_Pump.Faulted)XIO(Treater_Pump.Purge_Forward)XIO(Treater_Pump.Purge_Reverse)OTE(PumpTreatingOn);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[SAI_Scale_Rate(SAIScaleRate,Treater_Pump.TreaterScale.Lbs_Rate,Treater_Pump.TreaterScale.RawWeight,Treater_Pump.TreaterScale.Current_Oz_Rate,Treater_Pump.TreaterScale.Lbs_Gal,1000,1,0.3,Treater_Pump.TreaterScale.Adding_Weight,PumpTreatingOn);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Default The PID Loop
]]>
</Comment>
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.KP,0)MOV(0.65,Treater_Pump.TreaterScale.PID.KP);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[MUL(Rate_Oz_Mult,Treater_Pump.TreaterScale.Current_Oz_Rate,Treater_Pump.Current_Rate);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.KI,0)MOV(0.1,Treater_Pump.TreaterScale.PID.KI);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.MAXS,0)MOV(500,Treater_Pump.TreaterScale.PID.MAXS);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.MAXO,0)MOV(100,Treater_Pump.TreaterScale.PID.MAXO);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.UPD,0)MOV(0.001,Treater_Pump.TreaterScale.PID.UPD);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.MAXI,0)MOV(500,Treater_Pump.TreaterScale.PID.MAXI);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.MAXTIE,0)MOV(9000,Treater_Pump.TreaterScale.PID.MAXTIE);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.MAXCV,0)MOV(9000,Treater_Pump.TreaterScale.PID.MAXCV);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.PID.DB,0)MOV(2,Treater_Pump.TreaterScale.PID.DB);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[EQU(PIDStartDelay,0)MOV(5000,PIDStartDelay);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[MOV(PIDStartDelay,tmrPIDDelay.PRE);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[EQU(Treater_Pump.TreaterScale.Tank_Capacity,0)MOV(35,Treater_Pump.TreaterScale.Tank_Capacity);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[CPT(Treater_Pump.Speed_Percent,(Treater_Pump.Speed/Treater_Pump.TreaterScale.PID.MAXCV)*100);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[LEQ(Treater_Pump.PID_Activate_Delay,0)MOV(500,Treater_Pump.PID_Activate_Delay);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[MOV(Treater_Pump.PID_Activate_Delay,tmrPIDDelay.PRE);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[XIC(Treater_Pump.Start_Pump)XIO(Treater_Pump.TreaterScale.Adding_Weight)XIO(Treater_Pump.Faulted)XIO(Treater_Pump.Purge_Forward)XIO(Treater_Pump.Purge_Reverse)GRT(Treater_Pump.TreaterScale.PID.SP,0)TON(tmrPIDDelay,?,?);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[EQU(Rate_Oz_Mult,0)MOV(1,Rate_Oz_Mult);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Text>
<![CDATA[DIV(Treater_Pump.Rate,Rate_Oz_Mult,Treater_Pump.TreaterScale.Target_Oz_Rate);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Text>
<![CDATA[MOV(Treater_Pump.TreaterScale.Target_Oz_Rate,Treater_Pump.TreaterScale.PID.SP);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Text>
<![CDATA[XIC(tmrPIDDelay.DN)PID(Treater_Pump.TreaterScale.PID,Treater_Pump.TreaterScale.Current_Oz_Rate,0,Treater_Pump.Speed,0,0,0);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Text>
<![CDATA[MUL(Treater_Pump.TreaterScale.Current_Oz_Rate,Rate_Oz_Mult,Treater_Pump.Current_Rate);]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Text>
<![CDATA[LEQ(Treater_Pump.TreaterScale.Lbs_Gal,0)MOV(8.35,Treater_Pump.TreaterScale.Lbs_Gal);]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Text>
<![CDATA[GEQ(Treater_Pump.TreaterScale.Lbs_Gal,0)CPT(Treater_Pump.TreaterScale.Current_Gals,Treater_Pump.TreaterScale.RawWeight/Treater_Pump.TreaterScale.Lbs_Gal);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Text>
<![CDATA[LEQ(Treater_Pump.TreaterScale.Lbs_Gal,0)MOV(0,Treater_Pump.TreaterScale.Current_Gals);]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Text>
<![CDATA[GRT(Treater_Pump.TreaterScale.Tank_Capacity,0)CPT(Treater_Pump.TreaterScale.Percent_Tank_Full,Treater_Pump.TreaterScale.Current_Gals/Treater_Pump.TreaterScale.Tank_Capacity);]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Text>
<![CDATA[LEQ(Treater_Pump.TreaterScale.Tank_Capacity,0)MOV(0,Treater_Pump.TreaterScale.Percent_Tank_Full);]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Text>
<![CDATA[LES(Treater_Pump.TreaterScale.Current_Gals,Treater_Pump.TreaterScale.Warning_Gal)OTL(Treater_Pump.Below_Warning_Gals);]]>
</Text>
</Rung>
<Rung Number="30" Type="N">
<Text>
<![CDATA[LES(Treater_Pump.TreaterScale.Current_Gals,Treater_Pump.TreaterScale.Min_Gals)OTE(Treater_Pump.Below_Min_Gals);]]>
</Text>
</Rung>
<Rung Number="31" Type="N">
<Text>
<![CDATA[LES(Treater_Pump.TreaterScale.Current_Gals,Treater_Pump.TreaterScale.Min_Start_Gals)XIO(Treater_Pump.Start_Pump)OTL(Treater_Pump.Below_Min_Start_Gals);]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Text>
<![CDATA[GEQ(Treater_Pump.TreaterScale.Current_Gals,Treater_Pump.TreaterScale.Min_Start_Gals)OTU(Treater_Pump.Below_Min_Start_Gals);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
