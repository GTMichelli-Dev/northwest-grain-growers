<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Speed_Delta" DataType="DINT" Radix="Decimal" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[-5000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="-5000"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Rate_Delta" DataType="REAL" Radix="Float" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[-1.00000000e+003]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="-1000.0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Zero_Offset" DataType="REAL" Radix="Float" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[7.40000000e+003]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="7400.0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Slope" DataType="REAL" Radix="Float" ExternalAccess="None">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</LocalTag>
</LocalTags>
<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Figure Out Whate Data Points Need To Be Used Based On The Rate Desired
]]>
</Comment>
<Text>
<![CDATA[CMP(Speed<0)MOV(0,Speed);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[NEQ(Cal_Factor,0)CPT(Speed,Speed/Cal_Factor);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[SUB(Next_Index,1,Next_Index);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[CMP(Next_Index<0)MOV(4,Next_Index);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[CMP(Speed >= Cal_Points.Cal_Point[Next_Index].Speed)[CMP(Next_Index=4) ,CMP(Next_Index<4) CMP(Speed < Cal_Points.Cal_Point[Next_Index+1].Speed) ]MOV(Next_Index,Index);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Get the Two Points for the Calculations
if at the top of the graph use the last 2 (index 9 and 8)]]>
</Comment>
<Text>
<![CDATA[CMP(Index=4)[MOV(4,CP_Index_1) ,MOV(3,CP_Index_2) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[CMP(Index<4)[MOV(Index,CP_Index_1) ,ADD(Index,1,CP_Index_2) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Do the Math
]]>
</Comment>
<Text>
<![CDATA[CPT(Speed_Delta,(Cal_Points.Cal_Point[CP_Index_1].Speed-Cal_Points.Cal_Point[CP_Index_2].Speed));]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[CPT(Rate_Delta,(Cal_Points.Cal_Point[CP_Index_1].Rate-Cal_Points.Cal_Point[CP_Index_2].Rate));]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[CMP(Rate_Delta<>0)CPT(Slope,(Rate_Delta)/(Speed_Delta));]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[CMP(Rate_Delta=0)MOV(0,Slope);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[CPT(Zero_Offset,(-(Slope)*Cal_Points.Cal_Point[CP_Index_1].Speed)+Cal_Points.Cal_Point[CP_Index_1].Rate);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[CPT(Rate,(Slope*Speed)+Zero_Offset);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[EQU(Speed,0)MOV(0,Rate);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
<Dependencies>
<Dependency Type="DataType" Name="Cal_Points"/>
</Dependencies>
</AddOnInstructionDefinition>
