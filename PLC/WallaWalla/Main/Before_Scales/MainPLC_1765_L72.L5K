			ROUTINE Cancel_Cal_Bin 
					N: OTU(Loadout_Bin[IDX].Cal_Bin);
			END_ROUTINE

			ROUTINE Check_Bin_Availability 
					N: XIO(Clean_Scale_Unavailable)XIO(Loadout_Bin[IDX].Use_For_Treat_Loadout)OTE(Loadout_Bin[IDX].Available_For_Clean_Load);
					N: XIO(Treat_Scale_Unavailable)XIO(Loadout_Bin[IDX].Use_For_Clean_Loadout)OTE(Loadout_Bin[IDX].Available_For_Treat_Load);
			END_ROUTINE

			ROUTINE Check_If_Air_Gate_Open 
					N: XIC(Loadout_Bin[IDX].Air_Gate_Opened)OTL(Air_Gates_Opened);
			END_ROUTINE

			ROUTINE Check_If_Belt_Running 
					N: XIC(Belt[IDX].Running)OTL(Belts_Running);
			END_ROUTINE

			ROUTINE Check_If_Treat_Gate_Open 
					N: XIO(Loadout_Bin[IDX].Air_Gate_Opened)XIC(Loadout_Bin[IDX].Use_For_Treat_Loadout)OTU(Treat_Bin_Gates_Opened);
			END_ROUTINE

			ROUTINE Check_Transfer 
					N: XIC(Loadout_Bin[ckIDX].Use_For_Transfer_From)ONS(Current_Transfer_Bin_From[ckIDX])MOV(ckIDX,Transfer_From_IDX)FOR(Set_Transfer,IDX,0,28,1);
					N: XIC(Loadout_Bin[ckIDX].Use_For_Transfer_From)GRT(ckIDX,15)OTL(Use_Steel_Transfer_Bins);
					N: XIC(Loadout_Bin[ckIDX].Use_For_Transfer_To)ONS(Current_Transfer_Bin_To[ckIDX])MOV(ckIDX,Transfer_To_IDX)FOR(Set_Transfer,IDX,0,28,1);
			END_ROUTINE

			ROUTINE Check_Treater_Belts_Off 
					N: XIC(Loadout_Bin[IDX].Use_For_Treat_Loadout)XIC(Loadout_Bin[IDX].Air_Gate_Opened)OTL(Treat_Bins_Open);
			END_ROUTINE

			ROUTINE Clean_Belt_Batch_Ready 
					N: XIO(Belt[Loop_Idx].Motor_Control.Motor_Batch_Ready_Clean)OTU(Belts_Ready);
			END_ROUTINE

			ROUTINE Clean_Belt_Start 
					N: GEQ(Clean_Batch_Status,2)LEQ(Clean_Batch_Status,8)XIO(Manual_Mode)OTE(Clean_Interlock);
					N: EQU(Clean_Batch_Status,8)OTE(Auto_Stop_Clean);
					N: EQU(Clean_Batch_Status,1)FOR(Selectable_Clean_Bins,IDX,0,28,1);
					N: XIC(Clean_Interlock)OTU(Reversing_Belt_Reversed);
					N: XIC(Clean_Interlock)XIC(Use_Concrete_Side_Clean)XIC(Loadout_K_Valve[0].Clean_Gate_Opened)XIC(Belt[4].Running)XIC(Concrete_Leg.Motor_Start.Required_For_Clean_Batch)XIO(Concrete_Leg.Running)EQU(Clean_Batch_Status,3)OTL(Concrete_Leg.Motor_Start.Start_Motor);
					N: OTU(Bins_Rqd)FOR(Clean_Bin_Rqd,Loop_Idx,0,13,1);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)OTE(Concrete_Leg.Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)EQU(Clean_Batch_Status,5)MOV(6,Clean_Batch_Status);
					N: OTU(Bins_Rqd)OTU(Use_Steel_Side_Clean)OTU(Use_Concrete_Side_Clean);
					N: XIC(Clean_Interlock)OTL(Clean_Bin_Gates_Opened);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Gate_Ready,Loop_Idx,0,28,1);
					N: FOR(Clean_Bin_Rqd,Loop_Idx,16,28,1);
					N: XIC(Bins_Rqd)OTL(Use_Steel_Side_Clean);
					N: OTU(Bins_Rqd);
					N: FOR(Clean_Bin_Rqd,Loop_Idx,0,15,1);
					N: XIC(Bins_Rqd)OTL(Use_Concrete_Side_Clean);
					N: XIC(Clean_Interlock)[XIC(Use_Concrete_Side_Clean) ,XIC(Use_Steel_Side_Clean) ]OTU(Loadout_K_Valve[0].Send_To_Treater);
					N: XIC(Clean_Interlock)XIC(Use_Steel_Side_Clean)OTU(Loadout_K_Valve[1].Send_To_Treater);
					N: XIC(Clean_Interlock)XIC(Loadout_K_Valve[0].Clean_Gate_Opened)XIO(Belt[4].Running)EQU(Clean_Batch_Status,3)OTU(Reversing_Belt_Reversed)OTL(Belt[4].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)OTE(Belt[4].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)OTL(Concrete_Clean_Belts_Ready)FOR(Clean_Belt_Batch_Ready,Loop_Idx,1,4,1);
					N: XIC(Clean_Interlock)XIC(Concrete_Leg.Motor_Control.Motor_Batch_Ready_Clean)XIC(Belt[4].Motor_Control.Motor_Batch_Ready_Clean)XIC(Belt[3].Motor_Control.Motor_Batch_Ready_Clean)XIC(Belt[2].Motor_Control.Motor_Batch_Ready_Clean)XIC(Belt[1].Motor_Control.Motor_Batch_Ready_Clean)OTE(Concrete_Clean_Belts_Ready);
					N: XIC(Clean_Interlock)XIC(Use_Steel_Side_Clean)XIC(Loadout_K_Valve[0].Clean_Gate_Opened)XIC(Belt[4].Running)XIC(Concrete_Clean_Belts_Ready)XIO(Belt[6].Running)EQU(Clean_Batch_Status,3)OTL(Belt[6].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)XIC(Use_Steel_Side_Clean)OTE(Belt[6].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Use_Steel_Side_Clean)XIC(Loadout_K_Valve[0].Clean_Gate_Opened)XIC(Loadout_K_Valve[1].Clean_Gate_Opened)XIC(Belt[6].Running)XIO(Belt[7].Running)EQU(Clean_Batch_Status,3)OTL(Belt[7].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)XIC(Use_Steel_Side_Clean)OTE(Belt[7].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Use_Steel_Side_Clean)XIC(Belt[4].Running)XIC(Belt[6].Running)XIC(Belt[7].Running)XIC(Loadout_K_Valve[0].Clean_Gate_Opened)XIC(Loadout_K_Valve[1].Clean_Gate_Opened)OTE(Steel_Rqd_Belts_Running);
					N: XIC(Clean_Interlock)OTU(Bins_Rqd);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Rqd,Loop_Idx,2,5,1);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Rqd,Loop_Idx,7,13,1);
					N: XIC(Loadout_Bin[6].Use_For_Clean_Loadout)OTE(Belt[3].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)[XIC(Bins_Rqd) ,XIC(Belt[3].Motor_Start.Required_For_Clean_Batch) ]XIC(Use_Concrete_Side_Clean)XIO(Belt[1].Running)EQU(Clean_Batch_Status,3)OTL(Belt[1].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)[[XIC(Use_Concrete_Side_Clean) ,XIC(Belt[3].Motor_Start.Required_For_Clean_Batch) ] XIC(Bins_Rqd) ,XIC(Loadout_Bin[6].Use_For_Clean_Loadout) ]OTE(Belt[1].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Concrete_Leg.Motor_Start.Required_For_Clean_Batch)OTU(Reversing_Belt_Bypass_Valve);
					N: XIC(Clean_Interlock)XIO(Concrete_Leg.Motor_Start.Required_For_Clean_Batch)OTL(Reversing_Belt_Bypass_Valve);
					N: XIC(Clean_Interlock)OTU(Bins_Rqd);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Rqd,Loop_Idx,7,13,1);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)OTE(Belt[3].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)XIC(Use_Concrete_Side_Clean)XIC(Belt[2].Motor_Control.Motor_Batch_Ready)XIO(Belt[3].Running)EQU(Clean_Batch_Status,3)OTL(Belt[3].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)XIC(Loadout_Bin[6].Use_For_Clean_Loadout)OTE(Belt[2].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Loadout_Bin[6].Use_For_Clean_Loadout)XIC(Use_Concrete_Side_Clean)XIO(Belt[2].Running)EQU(Clean_Batch_Status,3)OTL(Belt[2].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)OTU(Bins_Rqd);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Rqd,Loop_Idx,16,20,1);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)OTE(Belt[10].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)XIC(Steel_Rqd_Belts_Running)XIO(Belt[10].Running)EQU(Clean_Batch_Status,3)OTL(Belt[10].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)OTU(Bins_Rqd);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Rqd,Loop_Idx,23,28,1);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)OTE(Belt[11].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)XIC(Steel_Rqd_Belts_Running)XIC(Belt[10].Motor_Control.Motor_Batch_Ready)XIO(Belt[11].Running)EQU(Clean_Batch_Status,3)OTL(Belt[11].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)OTU(Bins_Rqd);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Rqd,Loop_Idx,23,25,1);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)OTE(Belt[8].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)XIC(Steel_Rqd_Belts_Running)XIC(Belt[11].Running)XIO(Belt[8].Running)EQU(Clean_Batch_Status,3)OTL(Belt[8].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)OTU(Bins_Rqd);
					N: XIC(Clean_Interlock)FOR(Clean_Bin_Rqd,Loop_Idx,26,28,1);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)OTE(Belt[9].Motor_Start.Required_For_Clean_Batch);
					N: XIC(Clean_Interlock)XIC(Bins_Rqd)XIC(Steel_Rqd_Belts_Running)XIC(Belt[11].Running)XIC(Belt[8].Motor_Control.Motor_Batch_Ready)XIO(Belt[9].Running)EQU(Clean_Batch_Status,3)OTL(Belt[9].Motor_Start.Start_Motor);
					N: XIC(Clean_Interlock)OTL(Belts_Ready)FOR(Clean_Belt_Batch_Ready,Loop_Idx,1,11,1);
					N: XIC(Clean_Interlock)[XIC(Use_Concrete_Side_Clean) XIO(Concrete_Leg.Running) XIO(Loadout_Bin[14].Use_For_Clean_Loadout) XIO(Loadout_Bin[15].Use_For_Clean_Loadout) ,XIC(Use_Steel_Side_Clean) XIO(Belt[7].Running) ]OTU(Belts_Ready);
					N: XIC(Clean_Interlock)XIC(Belts_Ready)EQU(Clean_Batch_Status,3)MOV(4,Clean_Batch_Status);
					N: OTU(Bins_Rqd)FOR(Clean_Bin_Rqd,Loop_Idx,0,13,1);
					N: [EQU(Current_Dist_List_IDX,15) XIC(Bins_Rqd) ,XIO(Bins_Rqd) ]EQU(Clean_Batch_Status,2)OTE(Start_Clean_Belts_Enabled);
					N: XIC(Pause_Load_By_Time[1])EQU(Clean_Batch_Status,6)MOV(Pause_Load_Pre[1],tmr_Pause_Load_Timer[1].PRE)TON(tmr_Pause_Load_Timer[1],?,?);
					N: XIC(Pause_Load_By_Time[1])XIC(tmr_Pause_Load_Timer[1].DN)EQU(Clean_Batch_Status,6)OTU(Pause_Load_By_Time[1])MOV(7,Clean_Batch_Status);
					N: CPT(Pause_Load_Expired[1],tmr_Pause_Load_Timer[1].PRE-tmr_Pause_Load_Timer[1].ACC);
					N: XIO(Pause_Load_By_Time[1])MOV(0,Pause_Load_Expired[1]);
					N: XIC(Pause_Load_By_Weight[1])GEQ(Truck_Scales[1].Gross,Target_Weight[1])MOV(7,Clean_Batch_Status)OTU(Pause_Load_By_Weight[1]);
					N: EQU(Clean_Batch_Status,6)XIO(tmrCleanTime.DN)TON(tmrCleanTime,?,?);
					N: XIC(tmrCleanTime.DN)CTU(cntCleanTime,?,?);
					N: EQU(Clean_Batch_Status,0)RES(cntCleanTime);
					N: CPT(CleanHours,cntCleanTime.ACC/3600)CPT(CleanMinuets,cntCleanTime.ACC/60-(CleanHours*60))MOD(cntCleanTime.ACC,60,CleanSeconds);
			END_ROUTINE

			ROUTINE Clean_Bin_Gate_Ready 
					N: XIC(Loadout_Bin[0].Use_For_Clean_Loadout)XIO(Loadout_Bin[0].Air_Gate_Opened)OTU(Clean_Bin_Gates_Opened);
			END_ROUTINE

			ROUTINE Clean_Bin_Rqd 
					N: XIC(Loadout_Bin[Loop_Idx].Use_For_Clean_Loadout)OTL(Bins_Rqd);
			END_ROUTINE

			ROUTINE Close_Air_Gate 
					N: OTU(Loadout_Bin[IDX].Manual_Open);
					N: OTU(Loadout_Bin[IDX].Use_For_Clean_Loadout);
					N: OTU(Loadout_Bin[IDX].Use_For_Treat_Loadout);
					N: OTU(Loadout_Bin[IDX].Use_For_Transfer_To);
					N: OTU(Loadout_Bin[IDX].Use_For_Transfer_From);
			END_ROUTINE

			ROUTINE Concrete_Leg 
					N: [EQU(Current_Dist_List_IDX,15) XIC(Belt[4].Running) ,NEQ(Current_Dist_List_IDX,15) ]OTE(Concrete_Leg_Interlock);
					N: Motor_Control(Concrete_Leg.Motor_Control,CP_Remote_Leg_Start.0,CP_Remote_Leg_In.Spd_20_Out,CP_Remote_Leg_In.Spd_10_Out,Concrete_Leg.Running,ALM_SLP20_CPLeg,ALM_SLP10_CPLeg,ALM_OVRAMP_CPLeg,Concrete_Leg.Motor_Start,CP_Remote_Leg_In.Plug_Sensor,ALM_PLUG_CPLeg,CP_Remote_Leg_In.Amps,Concrete_Leg.Motor_Config,Concrete_Leg.Starting,ALM_WONT_START_CPLeg,Treat_Batch_Status,Clean_Batch_Status,Transfer_Batch_Status,Manual_Mode,Concrete_Leg_Interlock);
					N: XIC(Concrete_Leg.Running)[OTE(CP_Remote_Leg_Start.1) ,TOF(TMR_Concrete_Fan,?,?) ];
			END_ROUTINE

			ROUTINE Display 
					N: COP(System_Status_Msgs[Current_System_Msg_idx],System_Status_Msg,1);
			END_ROUTINE

			ROUTINE Get_Longest_Gate_Times 
					N: GEQ(Loadout_Bin[IDX].Treat_Load_Delay_Stop,Longest_Treat_Stop_Time)XIC(Loadout_Bin[IDX].Use_For_Treat_Loadout)[MOV(Loadout_Bin[IDX].Treat_Load_Delay_Stop,Longest_Treat_Stop_Time) ,MOV(IDX,Longest_Treat_Stop_IDX) ];
					N: GEQ(Loadout_Bin[IDX].Treat_Load_Delay_Start,Longest_Treat_Start_Time)XIC(Loadout_Bin[IDX].Use_For_Treat_Loadout)[MOV(Loadout_Bin[IDX].Treat_Load_Delay_Start,Longest_Treat_Start_Time) ,MOV(IDX,Longest_Treat_Start_IDX) ];
					N: GEQ(Loadout_Bin[IDX].Clean_Load_Delay_Stop,Longest_Clean_Stop_Time)XIC(Loadout_Bin[IDX].Use_For_Clean_Loadout)[MOV(Loadout_Bin[IDX].Clean_Load_Delay_Stop,Longest_Clean_Stop_Time) ,MOV(IDX,Longest_Clean_Stop_IDX) ];
					N: GEQ(Loadout_Bin[IDX].Clean_Load_Delay_Start,Longest_Clean_Start_Time)XIC(Loadout_Bin[IDX].Use_For_Clean_Loadout)[MOV(Loadout_Bin[IDX].Clean_Load_Delay_Start,Longest_Clean_Start_Time) ,MOV(IDX,Longest_Clean_Start_IDX) ];
			END_ROUTINE

			ROUTINE Get_System_Status 
					N: OTU(Belts_Running)FOR(Check_If_Belt_Running,IDX,1,11,1);
					N: OTU(Air_Gates_Opened)FOR(Check_If_Air_Gate_Open,IDX,0,28,1);
					N: [XIC(Belts_Running) ,XIC(Air_Gates_Opened) ,XIC(Concrete_Leg.Running) ,XIC(Treater_Loadout.Manual_Start) ,XIC(Treater_Loadout.Auto_Start) ]OTE(Belt_Gate_Leg_ON);
			END_ROUTINE

			ROUTINE K_Valves 
					N: Loadout_K_Valve_Control(Loadout_K_Valve_Control[0],Loadout_K_Valve[0],ALM_KValve0_Clean_Failed,ALM_KValve0_Treat_Failed,_701_K_BYPA,_701_K_TREA,Clean_K_Relay_Not_Used,_701K_VALVE);
					N: Loadout_K_Valve_Control(Loadout_K_Valve_Control[1],Loadout_K_Valve[1],ALM_KValve1_Clean_Failed,ALM_K_Valve1_Treat_Failed,R3M1_AENTR:2:I.0,R3M1_AENTR:2:I.1,R3M1_AENTR:3:O.1,R3M1_AENTR:3:O.0);
			END_ROUTINE

			ROUTINE Loadout_Time_Delays 
					N: MOV(0,Longest_Clean_Stop_Time)MOV(0,Longest_Clean_Stop_IDX)MOV(0,Longest_Clean_Start_Time)MOV(0,Longest_Clean_Start_IDX);
					N: MOV(0,Longest_Treat_Stop_Time)MOV(0,Longest_Treat_Stop_IDX)MOV(0,Longest_Treat_Start_Time)MOV(0,Longest_Treat_Start_IDX);
					N: FOR(Get_Longest_Gate_Times,IDX,0,28,1);
					N: FOR(Set_Gate_Delay,IDX,0,28,1);
			END_ROUTINE

			ROUTINE MainRoutine 
					N: GRT(ConfigureIndex,-1)JSR(BinConfigure,0);
					N: ONS(TestOneshot)TOF(testTmrOffDelay,?,?);
					N: XIC(testTmrOffDelay.DN)OSF(testStorageBit,TestOutputBit);
					N: XIC(TestOutputBit)CTU(textctr,?,?);
					N: XIC(testTmrOffDelay.TT)OTE(testOutput);
					N: AFI()FOR(Cancel_Cal_Bin,IDX,0,28,1);
					N: JSR(tmrTest,0);
					N: EQU(Clean_Batch_Status,0)EQU(Treat_Batch_Status,0)EQU(Transfer_Batch_Status,0)FOR(Reset_Bin,IDX,0,28,1);
					N: XIO(Manual_Mode)OTE(Auto_Mode);
					N: [EQU(Clean_Batch_Status,0) EQU(Treat_Batch_Status,0) EQU(Transfer_Batch_Status,0) ,XIC(Manual_Mode) ]XIC(ConfirmStop)OTE(All_Stop);
					N: AFI()XIC(Auto_Mode)ONS(Auto_Mode_ONS)OTL(All_Stop);
					N: XIC(All_Stop)JSR(Stop_All,0);
					N: JSR(Get_System_Status,0);
					N: JSR(Andco_Rate,0);
					N: JSR(Loadout_Time_Delays,0);
					N: JSR(Batch_Status,0);
					N: JSR(Amp_Gages,0);
					N: JSR(Display,0);
					N: JSR(Treaters,0);
					N: JSR(Reversing_Belt_Fans,0);
					N: JSR(Belts,0);
					N: JSR(Bins,0);
					N: JSR(K_Valves,0);
					N: JSR(Concrete_Leg,0);
					N: JSR(Amp_Gages,0);
					N: JSR(Request_Availability,0);
					N: XIC(Manual_Mode)MOV(1,Current_System_Msg_idx);
					N: XIO(Manual_Mode)MOV(0,Current_System_Msg_idx);
					N: JSR(PC_Tags,0);
			END_ROUTINE

