	ADD_ON_INSTRUCTION_DEFINITION Truck_Scale_Control (Revision := "1.0",
	                                                   ExecutePrescan := No,
	                                                   ExecutePostscan := No,
	                                                   ExecuteEnableInFalse := No,
	                                                   CreatedDate := "2017-03-28T16:02:08.365Z",
	                                                   CreatedBy := "MIDWAY-NUC\Administrator",
	                                                   EditedDate := "2017-08-12T16:05:20.258Z",
	                                                   EditedBy := "MIDWAY-NUC\Tech",
	                                                   SoftwareRevision := "v20.04")
		
		PARAMETERS
			EnableIn : BOOL (Usage := Input,
			                    RADIX := Decimal,
			                    Required := No,
			                    Visible := No,
			                    ExternalAccess := Read Only);
			EnableOut : BOOL (Usage := Output,
			                     RADIX := Decimal,
			                     Required := No,
			                     Visible := No,
			                     ExternalAccess := Read Only);
			Scale : udt_Truck_Scale (Usage := InOut,
			                 Required := Yes,
			                 Visible := Yes);
			Scale_Output : AB:ETHERNET_MODULE_DINT_4Bytes:O:0 (Usage := InOut,
			                        Required := Yes,
			                        Visible := Yes);
			Scale_Input : AB:ETHERNET_MODULE_DINT_4Bytes:I:0 (Usage := InOut,
			                       Required := Yes,
			                       Visible := Yes);
		END_PARAMETERS

		LOCAL_TAGS
			Rate_Tmr : TIMER (ExternalAccess := None,
			                   DefaultData := "[0,1000,713]");
			Accum_Rate_Index1 : COUNTER (ExternalAccess := None,
			                            DefaultData := "[0,11,0]");
			Old_Accum_Rate : REAL (RADIX := Float,
			                         ExternalAccess := None,
			                         DefaultData := 0.00000000e+000);
			Rate_Tare : REAL (RADIX := Float,
			                    ExternalAccess := None,
			                    DefaultData := 0.00000000e+000);
			Lock_Stable_Rate : DINT (RADIX := Decimal,
			                           ExternalAccess := None,
			                           DefaultData := 0);
			Scale_Avg1 : REAL[15] (RADIX := Float,
			                     ExternalAccess := None,
			                     DefaultData := "[0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000]");
			tmr_Stable : TIMER (ExternalAccess := None,
			                     DefaultData := "[0,2000,0]");
			tmr_Old_Rate : TIMER (ExternalAccess := None,
			                       DefaultData := "[0,1000,0]");
			Scale_Avg2 : REAL[15] (RADIX := Float,
			                     ExternalAccess := None,
			                     DefaultData := "[0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000]");
			Scale_Avg3 : REAL[15] (RADIX := Float,
			                     ExternalAccess := None,
			                     DefaultData := "[0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000,0.00000000e+000]");
			Avg_Rate1 : REAL (RADIX := Float,
			                    ExternalAccess := None,
			                    DefaultData := 0.00000000e+000);
			Avg_Rate2 : REAL (RADIX := Float,
			                    ExternalAccess := None,
			                    DefaultData := 0.00000000e+000);
			Accum_Rate_Index2 : COUNTER (ExternalAccess := None,
			                            DefaultData := "[0,5,0]");
			Accum_Rate_Index3 : COUNTER (ExternalAccess := None,
			                            DefaultData := "[0,5,0]");
			Avg_Rate3 : DINT (RADIX := Decimal,
			                    ExternalAccess := None,
			                    DefaultData := 0);
