					N: XIC(Config_Save_Bin)[COP(Config_Item_Number,Loadout_Bin[ConfigureIndex].Bin_Variety.Item_Number,1) ,COP(Config_Name,Loadout_Bin[ConfigureIndex].Bin_Variety.Name,1) ,COP(Config_Class,Loadout_Bin[ConfigureIndex].Bin_Variety.Class,1) ,MOV(Config_Pounds_Per_Inch,Loadout_Bin[ConfigureIndex].Andco_Values.Pounds_Per_Inch) ,CPT(Loadout_Bin[ConfigureIndex].Clean_Load_Delay_Start,Config_Clean_Delay_Start*1000) ,CPT(Loadout_Bin[ConfigureIndex].Treat_Load_Delay_Start,Config_Treat_Delay_Start*1000) ,CPT(Loadout_Bin[ConfigureIndex].Clean_Load_Delay_Stop,Config_Clean_Delay_Stop*1000) ,CPT(Loadout_Bin[ConfigureIndex].Treat_Load_Delay_Stop,Config_Treat_Delay_Stop*1000) ];
					N: XIC(Config_Save_Bin)EQU(ConfigureIndex,12)[COP(Config_Item_Number,Loadout_Bin[15].Bin_Variety.Item_Number,1) ,[COP(Config_Name,Loadout_Bin[15].Bin_Variety.Name,1) ,COP(Config_Class,Loadout_Bin[15].Bin_Variety.Class,1) ] ];
					N: XIC(Config_Save_Bin)EQU(ConfigureIndex,13)[COP(Config_Item_Number,Loadout_Bin[14].Bin_Variety.Item_Number,1) ,[COP(Config_Name,Loadout_Bin[14].Bin_Variety.Name,1) ,COP(Config_Class,Loadout_Bin[14].Bin_Variety.Class,1) ] ];
