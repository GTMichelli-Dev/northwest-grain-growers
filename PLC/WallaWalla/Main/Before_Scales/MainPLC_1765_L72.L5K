			ROUTINE AddWeights 
					N: CPT(Weight_Sum[ScaleIDX],Weight_Array[ScaleIDX,ShiftIDX+1]-Weight_Array[ScaleIDX,ShiftIDX]+Weight_Sum[ScaleIDX]);
			END_ROUTINE

			ROUTINE MainRoutine 
					N: FOR(Scale_Data,ScaleIDX,0,1,1);
			END_ROUTINE

			ROUTINE Scale_Data 
					N: XIC(ctrWtArray[ScaleIDX].DN)RES(ctrWtArray[ScaleIDX]);
					N: XIO(tmrRate[ScaleIDX].DN)TON(tmrRate[ScaleIDX],?,?);
					N: XIC(tmrRate[ScaleIDX].DN)CPT(Weight_Array_Idx[ScaleIDX],Weight_Array_Idx[ScaleIDX]+1)CTU(ctrWtArray[ScaleIDX],?,?);
					N: GEQ(Weight_Array_Idx[ScaleIDX],20)MOV(0,Weight_Array_Idx[ScaleIDX]);
					N: MOV(Weight_Array_Idx[ScaleIDX],Cur_Weight_Array_Idx);
					N: XIO(tmrTestRate[ScaleIDX].DN)TON(tmrTestRate[ScaleIDX],?,?);
					N: MOV(Truck_Scales[ScaleIDX].Gross,Current_Gross[ScaleIDX]);
					N: XIC(tmrTestRate[ScaleIDX].DN)AFI()CPT(Current_Gross[ScaleIDX],Current_Gross[ScaleIDX]+Scale_Test_Rate_Mlt);
					N: XIC(tmrRate[ScaleIDX].DN)[FOR(ShiftWeight,ShiftIDX,0,19,1) ,MOV(Current_Gross[ScaleIDX],Weight_Array[ScaleIDX,20]) ,AFI() MOV(tmrRate[ScaleIDX].ACC,Time_Array[ScaleIDX,Cur_Weight_Array_Idx]) ];
					N: MOV(0,Weight_Sum[ScaleIDX])MOV(0,Prev_Weight[ScaleIDX])FOR(AddWeights,ShiftIDX,0,4,1);
					N: MOV(Weight_Sum[ScaleIDX],Prev_Weight[ScaleIDX])MOV(0,Weight_Sum[ScaleIDX])MOV(0,Cur_Weight[ScaleIDX])FOR(AddWeights,ShiftIDX,10,19,1);
					N: MOV(Weight_Sum[ScaleIDX],Cur_Weight[ScaleIDX]);
					N: [CPT(Truck_Scales[ScaleIDX].Rate,Cur_Weight[ScaleIDX]/10*60) ,ABS(Truck_Scales[ScaleIDX].Rate,Truck_Scales[ScaleIDX].Rate) ];
					N: CPT(Truck_Scales[ScaleIDX].Avg_Rate,Truck_Scales[ScaleIDX].Rate);
					N: CPT(TestRate[ScaleIDX],Weight_Array[ScaleIDX,20]-Weight_Array[ScaleIDX,19]);
			END_ROUTINE

			ROUTINE ShiftWeight 
					N: MOV(Weight_Array[ScaleIDX,ShiftIDX+1],Weight_Array[ScaleIDX,ShiftIDX]);
			END_ROUTINE

