		ROUTINE Logic 
				N: CMP(Scale.Rate_Tol<=0)MOV(1,Scale.Rate_Tol);
				N: MOV(Scale_Input.Data[0],Scale.Gross);
				N: XIO(Rate_Tmr.DN)[CMP(ABS(Scale.Avg_Rate-Old_Accum_Rate)-Scale.Rate_Tol<=0) MOV(1,Lock_Stable_Rate) ,CMP(ABS(Scale.Avg_Rate-Old_Accum_Rate)-Scale.Rate_Tol>0) MOV(0,Lock_Stable_Rate) ];
				N: XIO(tmr_Old_Rate.DN)TON(tmr_Old_Rate,?,?);
				N: XIC(tmr_Old_Rate.DN)MOV(Scale.Avg_Rate,Old_Accum_Rate);
				N: CMP(Lock_Stable_Rate>0)TON(tmr_Stable,?,?);
				N: XIC(tmr_Stable.DN)OTE(Scale.Rate_Stable);
		END_ROUTINE

	END_ADD_ON_INSTRUCTION_DEFINITION

