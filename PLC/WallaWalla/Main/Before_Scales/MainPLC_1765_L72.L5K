			FBD_ROUTINE Totals (SheetSize := "Letter - 8.5 x 11 in",
			                    SheetOrientation := Landscape)
				SHEET  (Name := "")
					IREF  (ID := 0,
					       X := 260,
					       Y := 120,
					       Operand := "Calibration_Max",
					       HideDescription := No)
					END_IREF

					IREF  (ID := 1,
					       X := 80,
					       Y := 100,
					       Operand := "TestTag",
					       HideDescription := No)
					END_IREF

					SCL_BLOCK  (ID := 2,
					            X := 340,
					            Y := 40,
					            Operand := "SCL_01",
					            VisiblePins := "In, InEUMax, Out",
					            HideDescription := No)
					END_SCL_BLOCK

					TOT_BLOCK  (ID := 3,
					            X := 680,
					            Y := 40,
					            Operand := "TOT_01",
					            VisiblePins := "In, ProgStartReq, ProgStopReq, ProgResetReq, Total, OldTotal, ProgOper, RunStop, ProgResetDone, TargetFlag, TargetDev1Flag, TargetDev2Flag",
					            HideDescription := No)
					END_TOT_BLOCK

					WIRE  (FromElementID := 0,
					       FromParameter := "",
					       ToElementID := 2,
					       ToParameter := "InEUMax")
					END_WIRE

					WIRE  (FromElementID := 1,
					       FromParameter := "",
					       ToElementID := 2,
					       ToParameter := "In")
					END_WIRE

					WIRE  (FromElementID := 2,
					       FromParameter := "Out",
					       ToElementID := 3,
					       ToParameter := "In")
					END_WIRE

				END_SHEET

