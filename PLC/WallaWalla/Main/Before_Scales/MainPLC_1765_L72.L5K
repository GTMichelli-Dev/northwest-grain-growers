			ROUTINE Reversing_Belt 
					N: GRT(Belt[4].Motor_Control.Motor_Amps,1)TOF(TMR_Reverse_Delay,?,?);
					N: XIO(Belt[4].Motor_Start.Start_Motor)GRT(Belt[4].Motor_Control.Motor_Amps,1)OTL(Reverse_Belt_Stopping);
					N: LES(Belt[4].Motor_Control.Motor_Amps,1)OTU(Reverse_Belt_Stopping);
					N: XIC(R4M3_AENTR:1:O.7)OTU(R4M3_AENTR:2:O.11)OTL(Reversing_Belt_Reversed);
					N: XIC(R4M3_AENTR:2:O.11)OTU(R4M3_AENTR:1:O.7)OTU(Reversing_Belt_Reversed);
					N: [XIC(TMR_Reverse_Delay.TT) ,XIC(Reverse_Belt_Stopping) ]OTE(Belt[4].Motor_Start.Delay_Start);
					N: XIC(Reversing_Belt_Reversed)XIO(Treat_Interlock)XIO(Clean_Interlock)XIO(Transfer_Interlock)OTL(Loadout_K_Valve[0].Send_To_Treater);
					N: [XIC(Loadout_K_Valve[0].Send_To_Treater) XIC(Belt[5].Running) ,XIO(Loadout_K_Valve[0].Send_To_Treater) ]OTE(Reverse_Belt_Forward_Interlock);
					N: XIC(Reversing_Belt_Reversed)Motor_Control(Belt[4].Motor_Control,R4M3_AENTR:1:O.7,I8_000_Bit07,Belt[4].Motor_Control.Spd_10_Pct,Belt[4].Running,ALM_SLP20_Belt4,ALM_SLP10_Belt4,ALM_OVRAMP_Belt4,Belt[4].Motor_Start,Belt[4].Motor_Control.Plugged_Sensor,ALM_PLUG_Belt4,Belt[4].Motor_Control.Motor_Amps,Belt[4].Motor_Config,Belt[4].Starting,ALM_WONT_START_Belt4,Treat_Batch_Status,Clean_Batch_Status,Transfer_Batch_Status,Manual_Mode,Belt[3].Running);
					N: XIO(Reversing_Belt_Reversed)Motor_Control(Belt[4].Motor_Control,R4M3_AENTR:2:O.11,I8_000_Bit07,Belt[4].Motor_Control.Spd_10_Pct,Belt[4].Running,ALM_SLP20_Belt4,ALM_SLP10_Belt4,ALM_OVRAMP_Belt4,Belt[4].Motor_Start,Belt[4].Motor_Control.Plugged_Sensor,ALM_PLUG_Belt4,Belt[4].Motor_Control.Motor_Amps,Belt[4].Motor_Config,Belt[4].Starting,ALM_WONT_START_Belt4,Treat_Batch_Status,Clean_Batch_Status,Transfer_Batch_Status,Manual_Mode,Reverse_Belt_Forward_Interlock);
					N: [XIC(Reversing_Belt_Reversed) ,XIC(Concrete_Leg.Running) EQU(Current_Dist_List_IDX,15) ]OTU(Reversing_Belt_Bypass_Valve);
					N: XIC(Reversing_Belt_Bypass_Valve)OTE(ConcretePlantOut.0);
			END_ROUTINE

			ROUTINE Reversing_Belt_Fans 
					N: XIC(Belt[4].Motor_Start.Start_Motor)OTE(Auto_Start_Reversing_Belt_Fans);
					N: [XIC(Start_Blower_707) XIC(Manual_Mode) ,XIC(Auto_Start_Reversing_Belt_Fans) ,XIC(Reversing_Belt_Fans.Start_Both_Fans) XIC(Manual_Mode) ]OTE(R4M3_AENTR:3:O.0);
					N: [XIC(Reversing_Belt_Fans.Start_Both_Fans) XIC(Manual_Mode) ,XIC(Reversing_Belt_Fans.Start_Cyclone) XIC(Manual_Mode) ,XIC(Auto_Start_Reversing_Belt_Fans) ]OTE(R4M3_AENTR:0:O.13);
					N: [XIC(Reversing_Belt_Fans.Start_Aspirator) XIC(Manual_Mode) ,XIC(Reversing_Belt_Fans.Start_Both_Fans) XIC(Manual_Mode) ,XIC(Auto_Start_Reversing_Belt_Fans) ]OTE(R4M3_AENTR:1:O.11);
					N: XIC(Reversing_Belt_Fans.Cyclone_Running)XIC(Reversing_Belt_Fans.Aspirator_Running)OTE(Reversing_Belt_Fans.Both_Fans_Running);
					N: XIC(R4M2_AENTR:1:I.11)OTE(Reversing_Belt_Fans.Aspirator_Running);
					N: XIC(R4M2_AENTR:0:I.13)OTE(Reversing_Belt_Fans.Cyclone_Running);
					N: XIC(R4M2_AENTR:3:I.0)OTE(Blower_707_Running);
			END_ROUTINE

			ROUTINE Selectable_Clean_Bins 
					N: EQU(Treat_Batch_Status,0)OTL(Loadout_Bin[IDX].Selectable);
					N: GEQ(Treat_Batch_Status,1)GEQ(IDX,15)XIC(Use_Steel_Side_Treat)OTU(Loadout_Bin[IDX].Selectable);
					N: GEQ(Treat_Batch_Status,1)LEQ(IDX,15)XIC(Use_Steel_Side_Treat)OTL(Loadout_Bin[IDX].Selectable);
			END_ROUTINE

			ROUTINE Selectable_Transfer_Bins 
					N: EQU(Transfer_Batch_Status,1)GEQ(IDX,0)NEQ(Empty_Variety_ID,Loadout_Bin[IDX].Bin_Variety.Item_Number)NEQ(Empty_String,Loadout_Bin[IDX].Bin_Variety.Item_Number)OTL(Loadout_Bin[IDX].Selectable);
					N: EQU(Transfer_Batch_Status,1)[EQU(Empty_Variety_ID,Loadout_Bin[IDX].Bin_Variety.Item_Number) ,EQU(Empty_String,Loadout_Bin[IDX].Bin_Variety.Item_Number) ,LEQ(IDX,-1) ]OTU(Loadout_Bin[IDX].Selectable);
					N: EQU(Transfer_Batch_Status,2)[EQU(Empty_Variety_ID,Loadout_Bin[IDX].Bin_Variety.Item_Number) ,EQU(Empty_String,Loadout_Bin[IDX].Bin_Variety.Item_Number) ,GEQ(Transfer_From_IDX,0) EQU(Loadout_Bin[Transfer_From_IDX].Bin_Variety.Item_Number,Loadout_Bin[IDX].Bin_Variety.Item_Number) ]OTL(Loadout_Bin[IDX].Selectable);
					N: EQU(Transfer_Batch_Status,2)[LES(Transfer_From_IDX,0) ,NEQ(Empty_String,Loadout_Bin[IDX].Bin_Variety.Item_Number) NEQ(Empty_Variety_ID,Loadout_Bin[IDX].Bin_Variety.Item_Number) GEQ(Transfer_From_IDX,0) NEQ(Loadout_Bin[Transfer_From_IDX].Bin_Variety.Item_Number,Loadout_Bin[IDX].Bin_Variety.Item_Number) ]OTU(Loadout_Bin[IDX].Selectable);
			END_ROUTINE

			ROUTINE Selectable_Treat_Bins 
					N: EQU(Clean_Batch_Status,0)OTL(Loadout_Bin[IDX].Selectable);
					N: GEQ(Clean_Batch_Status,1)LEQ(IDX,15)XIC(Use_Concrete_Side_Clean)OTU(Loadout_Bin[IDX].Selectable);
					N: GEQ(Clean_Batch_Status,1)LEQ(IDX,15)XIO(Use_Concrete_Side_Clean)OTL(Loadout_Bin[IDX].Selectable);
					N: GEQ(Clean_Batch_Status,1)GRT(IDX,15)XIO(Use_Steel_Side_Clean)OTL(Loadout_Bin[IDX].Selectable);
			END_ROUTINE

			ROUTINE Set_Gate_Delay 
					N: XIC(Loadout_Bin[IDX].Use_For_Treat_Loadout)CPT(Loadout_Bin[IDX].StartDelayPre,Longest_Treat_Start_Time-Loadout_Bin[IDX].Treat_Load_Delay_Start);
					N: XIC(Loadout_Bin[IDX].Use_For_Treat_Loadout)CPT(Loadout_Bin[IDX].StopDelayPre,Longest_Treat_Stop_Time-Loadout_Bin[IDX].Treat_Load_Delay_Stop);
			END_ROUTINE

			ROUTINE Set_Transfer 
					N: EQU(IDX,Transfer_From_IDX)OTL(Loadout_Bin[IDX].Use_For_Transfer_From);
					N: NEQ(IDX,Transfer_From_IDX)OTU(Loadout_Bin[IDX].Use_For_Transfer_From);
					N: EQU(IDX,Transfer_To_IDX)OTL(Loadout_Bin[IDX].Use_For_Transfer_To);
					N: NEQ(IDX,Transfer_To_IDX)OTU(Loadout_Bin[IDX].Use_For_Transfer_To);
			END_ROUTINE

			ROUTINE Stop_All 
					N: MOV(0,Clean_Batch_Status);
					N: MOV(0,Treat_Batch_Status);
					N: MOV(0,Transfer_Batch_Status);
					N: FOR(Stop_Belt,IDX,1,11,1);
					N: OTU(Concrete_Leg.Motor_Start.Start_Motor);
					N: FOR(Close_Air_Gate,IDX,0,28,1);
					N: [OTU(Treater_Loadout.Auto_Start) ,OTU(Treater_Loadout.Manual_Start) ];
					N: OTU(Manually_Start_Treater);
					N: OTU(All_Stop);
					N: OTU(ConfirmStop);
			END_ROUTINE

			ROUTINE Stop_Belt 
					N: OTU(Belt[IDX].Motor_Start.Start_Motor);
			END_ROUTINE

			ROUTINE tmrTest 
					N: XIC(Bin_Open_test)TON(tmrBin_Delay_Start[0],?,?);
					N: XIO(Bin_Open_test)TON(tmrBin_Delay_Start[1],?,?);
					N: [XIC(tmrBin_Delay_Start[0].DN) ,XIC(tmrBin_Delay_Start[1].TT) ]OTE(Bin_Gate_Test);
			END_ROUTINE

			ROUTINE Transfer_Belt_Batch_Ready 
					N: XIO(Belt[Loop_Idx].Motor_Control.Motor_Batch_Ready_Transfer)OTU(Belts_Ready);
			END_ROUTINE

			ROUTINE Transfer_Belt_Start 
					N: EQU(Transfer_Batch_Status,0)MOV(-1,Transfer_To_IDX)MOV(-1,Transfer_From_IDX);
					N: EQU(Transfer_Batch_Status,1)XIC(Treater_Loadout.Auto_Start)OTU(Treater_Loadout.Auto_Start);
					N: EQU(Transfer_Batch_Status,3)EQU(Transfer_To_IDX,Current_Dist_List_IDX)MOV(5,Transfer_Batch_Status);
					N: EQU(Transfer_Batch_Status,3)NEQ(Transfer_To_IDX,Current_Dist_List_IDX)MOV(4,Transfer_Batch_Status);
					N: GEQ(Transfer_Batch_Status,1)LEQ(Transfer_Batch_Status,2)FOR(Selectable_Transfer_Bins,IDX,0,28,1);
					N: OTU(Use_Steel_Transfer_Bins);
					N: FOR(Check_Transfer,ckIDX,0,28,1);
					N: GEQ(Transfer_Batch_Status,5)LEQ(Transfer_Batch_Status,8)XIO(Manual_Mode)OTE(Transfer_Interlock);
					N: XIC(Transfer_Interlock)EQU(Transfer_Batch_Status,5)OTE(Transfer_Belts_Starting);
					N: XIC(Transfer_Interlock)XIO(Concrete_Leg.Running)[OTL(Concrete_Leg.Motor_Start.Start_Motor) ,OTL(Reversing_Belt_Reversed) ];
					N: XIC(Transfer_Interlock)OTL(Loadout_K_Valve[0].Send_To_Treater)OTU(Loadout_K_Valve[1].Send_To_Treater);
					N: XIC(Transfer_Interlock)XIC(Transfer_Belts_Starting)XIC(Concrete_Leg.Running)XIO(Belt[1].Running)OTL(Belt[1].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Transfer_Belts_Starting)XIC(Belt[1].Running)XIO(Belt[3].Running)OTL(Belt[3].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Transfer_Belts_Starting)XIC(Belt[3].Running)XIO(Belt[4].Running)XIC(Use_Steel_Transfer_Bins)OTL(Belt[4].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Transfer_Belts_Starting)XIC(Belt[4].Running)XIO(Belt[6].Running)XIC(Use_Steel_Transfer_Bins)OTL(Belt[6].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Transfer_Belts_Starting)XIC(Belt[6].Running)XIO(Belt[5].Running)XIC(Use_Steel_Transfer_Bins)OTL(Belt[5].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Transfer_Belts_Starting)XIC(Belt[5].Running)XIO(Belt[7].Running)XIC(Use_Steel_Transfer_Bins)OTL(Belt[7].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)[OTE(Belt[1].Motor_Start.Required_For_Transfer_Batch) ,OTE(Belt[3].Motor_Start.Required_For_Transfer_Batch) ,XIC(Use_Steel_Transfer_Bins) OTE(Belt[4].Motor_Start.Required_For_Transfer_Batch) ,XIC(Use_Steel_Transfer_Bins) OTE(Belt[6].Motor_Start.Required_For_Transfer_Batch) ,XIC(Use_Steel_Transfer_Bins) OTE(Belt[7].Motor_Start.Required_For_Transfer_Batch) ,OTE(Concrete_Leg.Motor_Start.Required_For_Transfer_Batch) ];
					N: XIC(Transfer_Interlock)OTU(Bins_Rqd);
					N: XIC(Transfer_Interlock)FOR(Transfer_Bin_Rqd,Loop_Idx,16,20,1);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)OTE(Belt[10].Motor_Start.Required_For_Transfer_Batch);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)XIC(Transfer_Belts_Starting)XIC(Belt[7].Running)XIO(Belt[10].Running)OTL(Belt[10].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)OTU(Bins_Rqd);
					N: XIC(Transfer_Interlock)FOR(Transfer_Bin_Rqd,Loop_Idx,23,28,1);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)XIC(Transfer_Belts_Starting)XIC(Belt[7].Running)XIO(Belt[11].Running)OTL(Belt[11].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)OTE(Belt[11].Motor_Start.Required_For_Transfer_Batch);
					N: XIC(Transfer_Interlock)OTU(Bins_Rqd);
					N: XIC(Transfer_Interlock)FOR(Transfer_Bin_Rqd,Loop_Idx,23,25,1);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)XIC(Transfer_Belts_Starting)XIC(Belt[11].Running)XIO(Belt[8].Running)OTL(Belt[8].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)OTE(Belt[8].Motor_Start.Required_For_Transfer_Batch);
					N: XIC(Transfer_Interlock)OTU(Bins_Rqd);
					N: XIC(Transfer_Interlock)FOR(Transfer_Bin_Rqd,Loop_Idx,26,28,1);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)XIC(Transfer_Belts_Starting)XIC(Belt[11].Running)XIO(Belt[9].Running)OTL(Belt[9].Motor_Start.Start_Motor);
					N: XIC(Transfer_Interlock)XIC(Bins_Rqd)OTE(Belt[9].Motor_Start.Required_For_Transfer_Batch);
					N: XIC(Transfer_Interlock)XIC(Transfer_Belts_Starting)OTL(Belts_Ready)FOR(Transfer_Belt_Batch_Ready,Loop_Idx,1,11,1);
					N: XIC(Transfer_Interlock)XIO(Concrete_Leg.Running)OTU(Belts_Ready);
					N: XIC(Transfer_Interlock)XIC(Belts_Ready)XIC(Transfer_Belts_Starting)MOV(6,Transfer_Batch_Status);
					N: EQU(Transfer_Batch_Status,7)XIO(tmrTransferTime.DN)TON(tmrTransferTime,?,?);
					N: XIC(tmrTransferTime.DN)CTU(cntTransferTime,?,?);
					N: EQU(Transfer_Batch_Status,0)RES(cntTransferTime);
					N: CPT(TransferHours,cntTransferTime.ACC/3600)CPT(TransferMinuets,cntTransferTime.ACC/60-(TransferHours*60))MOD(cntTransferTime.ACC,60,TransferSeconds);
					N: XIC(Pause_Transfer_By_Time)EQU(Transfer_Batch_Status,7)CPT(Pause_Transfer_Msc,60*Pause_Transfer_Pre*1000)MOV(Pause_Transfer_Msc,tmr_Pause_Transfer_Timer.PRE)TON(tmr_Pause_Transfer_Timer,?,?);
					N: XIC(Pause_Transfer_By_Time)XIC(tmr_Pause_Transfer_Timer.DN)EQU(Transfer_Batch_Status,7)OTU(Pause_Transfer_By_Time)MOV(6,Transfer_Batch_Status);
					N: CPT(Pause_Transfer_Load_Expired,tmr_Pause_Transfer_Timer.PRE-tmr_Pause_Transfer_Timer.ACC);
					N: XIO(Pause_Transfer_By_Time)MOV(0,Pause_Transfer_Load_Expired);
			END_ROUTINE

			ROUTINE Transfer_Bin_Rqd 
					N: XIC(Loadout_Bin[Loop_Idx].Use_For_Transfer_From)OTL(Bins_Rqd);
			END_ROUTINE

			ROUTINE Treaters 
					N: GRT(Treat_Batch_Status,0)OTU(Treater_Calibration);
					N: [XIC(Manually_Start_Treater) ,XIC(Auto_Start_Treatment) XIO(Pause_Treatment) ]OTE(Treatment_Running)OTE(Treater_Remote_Out.0);
					N: [XIC(Auto_Start_Treatment) ,XIC(Test1) ]TOF(tmr_Auto_Start,?,?);
					N: XIC(tmr_Auto_Start.TT)OTE(Treater_Remote_Out.5);
					N: XIO(Auto_Start_Treatment)XIO(Manually_Start_Treater)OTU(Pause_Treatment);
					N: XIO(Treater_Remote_In.3)XIO(Manually_Start_Treater)XIO(Manual_Blow_Out)MOV(Blow_Out_Time,tmr_Blow_Out.PRE)TON(tmr_Blow_Out,?,?);
					N: CPT(Blow_Out_Time_Remaining,(Blow_Out_Time-tmr_Blow_Out.ACC)*0.001);
					N: XIC(tmr_Blow_Out.TT)OTE(R3M1_AENTR:3:O.6);
					N: GRT(Treat_Batch_Status,0)OTU(Manual_Open_Calibration_Valves);
					N: [XIC(Treater_Remote_In.0) ,XIC(Manual_Open_Calibration_Valves) ]OTE(Treater_Calibration);
					N: XIC(Treater_Calibration)OTE(R3M1_AENTR:3:O.2)OTE(R3M1_AENTR:3:O.3);
					N: XIO(Treater_Calibration)XIC(Treater_Loadout.Auto_Start)OTE(R3M1_AENTR:3:O.4)OTE(R3M1_AENTR:3:O.5);
					N: XIC(Treater_Loadout.Auto_Start)OTU(Treater_Loadout.Close_Drip_Gate_Manual);
					N: XIO(Treater_Loadout.Auto_Start)XIO(Treater_Loadout.Manual_Start)XIO(Treater_Loadout.Close_Drip_Gate_Manual)[OTE(R3M1_AENTR:3:O.7) ,OTE(Treater_Loadout.Drip_Gate_Closed) ];
					N: XIO(Treater_Loadout.Use_A_Treater)XIO(Treater_Loadout.Use_B_Treater)OTL(Treater_Loadout.Use_B_Treater)OTL(Treater_Loadout.Use_A_Treater);
					N: [XIC(Treater_Loadout.Manual_Start) ,XIC(Treater_Loadout.Auto_Start) ]XIC(Treater_Loadout.Use_A_Treater)OTE(R4M3_AENTR:2:O.7);
					N: [XIC(Treater_Loadout.Manual_Start) ,XIC(Treater_Loadout.Auto_Start) ]XIC(Treater_Loadout.Use_B_Treater)OTE(R4M3_AENTR:2:O.4);
					N: [XIC(R4M3_AENTR:2:O.7) ,XIC(R4M3_AENTR:2:O.4) ]OTL(Loadout_K_Valve[1].Send_To_Treater);
					N: XIC(_700_TREAT)OTE(Probe_Above_K_Valve);
			END_ROUTINE

			ROUTINE Treat_Belt_Batch_Ready 
					N: XIO(Belt[Loop_Idx].Motor_Control.Motor_Batch_Ready_Treat)OTU(Belts_Ready);
			END_ROUTINE

			ROUTINE Treat_Belt_Start 
					N: OTU(Bins_Rqd)OTU(Use_Steel_Side_Treat)OTU(Use_Concrete_Side_Treat);
					N: GEQ(Treat_Batch_Status,2)LEQ(Treat_Batch_Status,8)XIO(Manual_Mode)OTE(Treat_Interlock);
					N: GRT(Treat_Batch_Status,0)TON(tmrSetWaterOil,?,?);
					N: XIC(tmrSetWaterOil.TT)OTE(Treater_Remote_Out.4);
					N: XIC(Treat_Interlock)OTU(Reversing_Belt_Reversed);
					N: OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,14,15,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[4].Motor_Start.Required_For_Treat_Batch);
					N: OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,0,13,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Concrete_Leg.Motor_Start.Required_For_Treat_Batch);
					N: EQU(Treat_Batch_Status,1)FOR(Selectable_Treat_Bins,IDX,0,28,1);
					N: XIC(Treat_Interlock)OTL(Belts_Ready)FOR(Treat_Belt_Batch_Ready,Loop_Idx,1,5,1);
					N: XIC(Treat_Interlock)XIC(Belts_Ready)XIC(Concrete_Leg.Motor_Control.Motor_Batch_Ready_Treat)OTE(Concrete_Belts_Ready);
					N: XIC(Treat_Interlock)OTL(Belts_Ready)FOR(Treat_Belt_Batch_Ready,Loop_Idx,1,11,1);
					N: XIC(Treat_Interlock)XIO(Concrete_Leg.Motor_Control.Motor_Batch_Ready_Treat)OTU(Belts_Ready);
					N: XIC(Treat_Interlock)OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,7,13,1);
					N: XIC(Treat_Interlock)XIC(Use_Steel_Side_Treat)XIC(Belt[7].Running)XIC(Loadout_K_Valve[1].Treater_Gate_Opened)OTE(Steel_Rqd_Belts_Running);
					N: XIC(Treat_Interlock)XIC(Belts_Ready)EQU(Treat_Batch_Status,3)MOV(4,Treat_Batch_Status);
					N: XIC(Treat_Interlock)EQU(Treat_Batch_Status,5)MOV(6,Treat_Batch_Status);
					N: OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,16,28,1);
					N: XIC(Bins_Rqd)OTL(Use_Steel_Side_Treat);
					N: OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,0,15,1);
					N: XIC(Bins_Rqd)OTL(Use_Concrete_Side_Treat);
					N: XIC(Treat_Interlock)XIC(Use_Concrete_Side_Treat)OTL(Loadout_K_Valve[0].Send_To_Treater);
					N: XIC(Treat_Interlock)OTL(Loadout_K_Valve[1].Send_To_Treater);
					N: XIC(Treat_Interlock)XIO(Treater_Loadout.Auto_Start)EQU(Treat_Batch_Status,3)OTL(Treater_Loadout.Auto_Start);
					N: XIC(Treat_Interlock)XIC(Use_Concrete_Side_Treat)XIC(Loadout_K_Valve[0].Treater_Gate_Opened)XIO(Belt[5].Running)EQU(Treat_Batch_Status,3)OTL(Belt[5].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)XIC(Use_Concrete_Side_Treat)OTE(Belt[5].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Loadout_K_Valve[0].Treater_Gate_Opened)XIC(Use_Concrete_Side_Treat)XIC(Belt[5].Running)XIO(Belt[4].Running)EQU(Treat_Batch_Status,3)OTU(Reversing_Belt_Reversed)OTL(Belt[4].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)XIC(Use_Concrete_Side_Treat)OTE(Belt[4].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Use_Concrete_Side_Treat)XIC(Loadout_K_Valve[0].Treater_Gate_Opened)XIC(Belt[4].Running)XIC(Concrete_Leg.Motor_Start.Required_For_Treat_Batch)XIO(Concrete_Leg.Running)EQU(Treat_Batch_Status,3)OTL(Concrete_Leg.Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)XIC(Use_Concrete_Side_Treat)XIC(Concrete_Leg.Motor_Start.Required_For_Treat_Batch)OTE(Concrete_Leg.Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Concrete_Leg.Motor_Start.Required_For_Treat_Batch)OTU(Reversing_Belt_Bypass_Valve);
					N: XIC(Treat_Interlock)XIO(Concrete_Leg.Motor_Start.Required_For_Treat_Batch)OTL(Reversing_Belt_Bypass_Valve);
					N: OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,2,13,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[1].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[1].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)XIO(Belt[1].Running)EQU(Treat_Batch_Status,3)OTL(Belt[1].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)XIC(Loadout_Bin[6].Use_For_Treat_Loadout)OTE(Belt[2].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Loadout_Bin[6].Use_For_Treat_Loadout)XIC(Belt[1].Running)XIO(Belt[2].Running)EQU(Treat_Batch_Status,3)OTL(Belt[2].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,7,13,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[3].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)XIC(Belt[1].Running)XIO(Belt[3].Running)EQU(Treat_Batch_Status,3)OTL(Belt[3].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)XIC(Use_Steel_Side_Treat)XIC(Loadout_K_Valve[1].Treater_Gate_Opened)XIC(Concrete_Belts_Ready)XIO(Belt[7].Running)EQU(Treat_Batch_Status,3)OTL(Belt[7].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)XIC(Use_Steel_Side_Treat)OTE(Belt[7].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,16,20,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[10].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)XIC(Belt[7].Running)XIO(Belt[10].Running)EQU(Treat_Batch_Status,3)OTL(Belt[10].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,23,28,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[11].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)XIO(Belt[11].Running)[XIO(Belt[10].Motor_Start.Required_For_Treat_Batch) ,XIC(Belt[10].Motor_Start.Required_For_Treat_Batch) XIC(Belt[10].Running) ]EQU(Treat_Batch_Status,3)OTL(Belt[11].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,23,25,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[8].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)XIC(Belt[11].Running)XIO(Belt[8].Running)EQU(Treat_Batch_Status,3)OTL(Belt[8].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,26,28,1);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)OTE(Belt[9].Motor_Start.Required_For_Treat_Batch);
					N: XIC(Treat_Interlock)XIC(Bins_Rqd)XIO(Belt[9].Running)[XIO(Belt[8].Motor_Start.Required_For_Treat_Batch) ,XIC(Belt[8].Motor_Start.Required_For_Treat_Batch) XIC(Belt[8].Running) ]EQU(Treat_Batch_Status,3)OTL(Belt[9].Motor_Start.Start_Motor);
					N: XIC(Treat_Interlock)OTL(Treat_Bin_Gates_Opened)FOR(Treat_Bin_Gate_Ready,Loop_Idx,0,28,1);
					N: XIC(Treat_Interlock)OTU(Bins_Rqd)FOR(Treat_Bin_Rqd,Loop_Idx,0,13,1);
					N: [EQU(Current_Dist_List_IDX,15) XIC(Bins_Rqd) ,XIO(Bins_Rqd) ]EQU(Treat_Batch_Status,2)OTE(Start_Treat_Belts_Enabled);
					N: XIC(Stop_Treater)OTU(Stop_Treater)OTU(Treater_Loadout.Auto_Start)OTU(Belt[5].Motor_Start.Start_Motor)OTU(Belt[7].Motor_Start.Start_Motor);
					N: XIC(R3M1_AENTR:2:I.8)OTE(Remote_Pause_Treat)[EQU(Treat_Batch_Status,6) ,EQU(Treat_Batch_Status,7) ]MOV(7,Treat_Batch_Status);
					N: XIO(R3M1_AENTR:2:I.8)[EQU(Treat_Batch_Status,6) ,EQU(Treat_Batch_Status,7) ]ONS(Reset_Remote_Pause)MOV(6,Treat_Batch_Status);
					N: [GEQ(Treat_Batch_Status,6) XIC(Loadout_Bin[Longest_Treat_Stop_IDX].Use_For_Treat_Loadout) XIC(Loadout_Bin[Longest_Treat_Stop_IDX].Air_Gate_Opened) ,XIC(tmrDelayTreatStart.TT) ]MOV(Loadout_Bin[Longest_Treat_Stop_IDX].Treat_Load_Delay_Start,tmrDelayTreatStart.PRE)TON(tmrDelayTreatStart,?,?);
					N: [EQU(Treat_Batch_Status,7) XIC(Loadout_Bin[Longest_Treat_Stop_IDX].Use_For_Treat_Loadout) XIO(Loadout_Bin[Longest_Treat_Stop_IDX].Air_Gate_Opened) ,XIC(tmrDelayTreatStop.TT) ]MOV(Loadout_Bin[Longest_Treat_Stop_IDX].Treat_Load_Delay_Stop,tmrDelayTreatStop.PRE)TON(tmrDelayTreatStop,?,?);
					N: GEQ(Treat_Batch_Status,6)[XIC(tmrDelayTreatStart.DN) ,XIC(tmrDelayTreatStop.TT) XIC(Treatment_Started) ]OTL(Treatment_Started)OTE(Auto_Start_Treatment);
					N: [XIO(Treatment_Started) ,LEQ(Treat_Batch_Status,5) ]OTU(Treatment_Started);
					N: XIC(Reset_Treat_Chemicals)TON(tmrResetChemicals,?,?)OTE(Treater_Remote_Out.2);
					N: XIC(tmrResetChemicals.DN)OTU(Reset_Treat_Chemicals);
					N: OTU(Treat_Bins_Open)FOR(Check_Treater_Belts_Off,IDX,0,28,1);
					N: GRT(Treat_Batch_Status,0)XIC(Treat_Interlock)XIO(Treatment_Running)XIO(Treat_Bins_Open)OTE(Finish_Treat_Ok);
					N: XIC(Pause_Load_By_Time[0])EQU(Treat_Batch_Status,6)MOV(Pause_Load_Pre[0],tmr_Pause_Load_Timer[0].PRE)TON(tmr_Pause_Load_Timer[0],?,?);
					N: XIC(Pause_Load_By_Time[0])XIC(tmr_Pause_Load_Timer[0].DN)EQU(Treat_Batch_Status,6)OTU(Pause_Load_By_Time[0])MOV(7,Treat_Batch_Status);
					N: CPT(Pause_Load_Expired[0],tmr_Pause_Load_Timer[0].PRE-tmr_Pause_Load_Timer[0].ACC);
					N: XIO(Pause_Load_By_Time[0])MOV(0,Pause_Load_Expired[0]);
					N: XIC(Pause_Load_By_Weight[0])GEQ(Truck_Scales[0].Gross,Target_Weight[0])MOV(7,Treat_Batch_Status)OTU(Pause_Load_By_Weight[0]);
					N: EQU(Treat_Batch_Status,6)XIO(tmrTreatTime.DN)TON(tmrTreatTime,?,?);
					N: XIC(tmrTreatTime.DN)CTU(cntTreatTime,?,?);
					N: EQU(Treat_Batch_Status,0)RES(cntTreatTime);
					N: CPT(TreatHours,cntTreatTime.ACC/3600)CPT(TreatMinuets,cntTreatTime.ACC/60-(TreatHours*60))MOD(cntTreatTime.ACC,60,TreatSeconds);
			END_ROUTINE

			ROUTINE Treat_Bin_Gate_Ready 
					N: XIC(Loadout_Bin[0].Use_For_Treat_Loadout)XIO(Loadout_Bin[0].Air_Gate_Opened)OTU(Clean_Bin_Gates_Opened);
