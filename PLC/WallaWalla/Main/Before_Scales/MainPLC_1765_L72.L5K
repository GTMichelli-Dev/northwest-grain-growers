			ROUTINE Update_Andco_Cal_Points 
					N: MOV(0,Loadout_Bin[IDX].Rate_Cal_Points[0].Rate);
					N: MOV(1000,Loadout_Bin[IDX].Rate_Cal_Points[1].Rate);
					N: MOV(2000,Loadout_Bin[IDX].Rate_Cal_Points[2].Rate);
					N: MOV(3000,Loadout_Bin[IDX].Rate_Cal_Points[3].Rate);
					N: MOV(4000,Loadout_Bin[IDX].Rate_Cal_Points[4].Rate);
					N: MOV(0,Loadout_Bin[IDX].Rate_Cal_Points[0].Andco_Position);
					N: LEQ(Loadout_Bin[IDX].Rate_Cal_Points[1].Andco_Position,0)MOV(1,Loadout_Bin[IDX].Rate_Cal_Points[1].Andco_Position);
					N: LEQ(Loadout_Bin[IDX].Rate_Cal_Points[2].Andco_Position,Loadout_Bin[IDX].Rate_Cal_Points[1].Andco_Position)CPT(Loadout_Bin[IDX].Rate_Cal_Points[2].Andco_Position,Loadout_Bin[IDX].Rate_Cal_Points[1].Andco_Position+1);
					N: LEQ(Loadout_Bin[IDX].Rate_Cal_Points[3].Andco_Position,Loadout_Bin[IDX].Rate_Cal_Points[2].Andco_Position)CPT(Loadout_Bin[IDX].Rate_Cal_Points[3].Andco_Position,Loadout_Bin[IDX].Rate_Cal_Points[2].Andco_Position+1);
					N: LEQ(Loadout_Bin[IDX].Rate_Cal_Points[4].Andco_Position,Loadout_Bin[IDX].Rate_Cal_Points[3].Andco_Position)CPT(Loadout_Bin[IDX].Rate_Cal_Points[4].Andco_Position,Loadout_Bin[IDX].Rate_Cal_Points[3].Andco_Position+1);
					N: LEQ(Loadout_Bin[IDX].Andco_Values.Raw_Position,Loadout_Bin[IDX].Rate_Cal_Points[1].Andco_Position)MOV(0,Point1)MOV(1,Point2);
					N: GRT(Loadout_Bin[IDX].Andco_Values.Raw_Position,Loadout_Bin[IDX].Rate_Cal_Points[1].Andco_Position)LEQ(Loadout_Bin[IDX].Andco_Values.Raw_Position,Loadout_Bin[IDX].Rate_Cal_Points[2].Andco_Position)MOV(1,Point1)MOV(2,Point2);
					N: GRT(Loadout_Bin[IDX].Andco_Values.Raw_Position,Loadout_Bin[IDX].Rate_Cal_Points[2].Andco_Position)LEQ(Loadout_Bin[IDX].Andco_Values.Raw_Position,Loadout_Bin[IDX].Rate_Cal_Points[3].Andco_Position)MOV(2,Point1)MOV(3,Point2);
					N: GRT(Loadout_Bin[IDX].Andco_Values.Raw_Position,Loadout_Bin[IDX].Rate_Cal_Points[3].Andco_Position)MOV(3,Point1)MOV(4,Point2);
					N: CPT(DeltaY,Loadout_Bin[IDX].Rate_Cal_Points[Point1].Rate-Loadout_Bin[IDX].Rate_Cal_Points[Point2].Rate);
					N: CPT(DeltaX,Loadout_Bin[IDX].Rate_Cal_Points[Point1].Andco_Position-Loadout_Bin[IDX].Rate_Cal_Points[Point2].Andco_Position);
					N: CPT(Rate_Mult,DeltaY/DeltaX);
					N: XIO(Loadout_Bin[IDX].Andco_Values.Closed)CPT(Loadout_Bin[IDX].Andco_Values.Rate,(Loadout_Bin[IDX].Andco_Values.Raw_Position-Loadout_Bin[IDX].Rate_Cal_Points[Point1].Andco_Position)*Rate_Mult+Loadout_Bin[IDX].Rate_Cal_Points[Point1].Rate);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Closed)MOV(0,Loadout_Bin[IDX].Andco_Values.Rate);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)LES(Loadout_Bin[IDX].Andco_Values.New_Rate,Loadout_Bin[IDX].Rate_Cal_Points[1].Andco_Position)MOV(0,Point1)MOV(1,Point2);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)GEQ(Loadout_Bin[IDX].Andco_Values.New_Rate,Loadout_Bin[IDX].Rate_Cal_Points[1].Rate)LES(Loadout_Bin[IDX].Andco_Values.New_Rate,Loadout_Bin[IDX].Rate_Cal_Points[2].Rate)MOV(1,Point1)MOV(2,Point2);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)GEQ(Loadout_Bin[IDX].Andco_Values.New_Rate,Loadout_Bin[IDX].Rate_Cal_Points[2].Rate)LES(Loadout_Bin[IDX].Andco_Values.New_Rate,Loadout_Bin[IDX].Rate_Cal_Points[3].Rate)MOV(2,Point1)MOV(3,Point2);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)GEQ(Loadout_Bin[IDX].Andco_Values.New_Rate,Loadout_Bin[IDX].Rate_Cal_Points[3].Rate)MOV(3,Point1)MOV(4,Point2);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)[MOV(Loadout_Bin[IDX].Rate_Cal_Points[Point1].Rate,X1) ,MOV(Loadout_Bin[IDX].Rate_Cal_Points[Point2].Rate,X2) ,MOV(Loadout_Bin[IDX].Rate_Cal_Points[Point1].Andco_Position,Y1) ,MOV(Loadout_Bin[IDX].Rate_Cal_Points[Point2].Andco_Position,Y2) ];
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)CPT(DeltaY,Y2-Y1);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)CPT(DeltaX,X2-X1);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)CPT(Slope,DeltaY/DeltaX);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)CPT(B_Offset,Y1-(Slope*X1));
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)CPT(Loadout_Bin[IDX].Andco_Values.New_Pos,Slope*Loadout_Bin[IDX].Andco_Values.New_Rate+B_Offset);
					N: XIC(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)OTU(Loadout_Bin[IDX].Andco_Values.Set_New_Rate)OTL(Loadout_Bin[IDX].Andco_Values.Move_Gate);
			END_ROUTINE

	END_PROGRAM

